{# templates/security/login.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}{{ 'login.meta.title'|trans }}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
    <style>
        body {
            background-color: #0f1b28 !important;
            color: white;
        }
        .login-container {
            max-width: 900px;
            width: 100%;
            background: white;
            color: black;
            border-radius: 10px;
            overflow: hidden;
        }
        .left-panel, .right-panel {
            padding: 30px;
        }
        .right-panel {
            background: #f8f9fa;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }
    </style>
{% endblock %}

{% block body %}
<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="login-container shadow-lg row">
        <!-- Partie gauche : Connexion -->
        <div class="col-md-6 col-12 left-panel">
            <div class="text-center">
                <img class="mb-3 rounded" src="{{ asset('uploads/photos/entite/logo/logo-wikiformation.png') }}" alt="Logo" style="width: 100px;">
            </div>
            
            {% if error %}
                <div class="alert alert-danger text-center">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ type }}">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}
            
            {% if app.user %}
                <div class="alert alert-info text-center">
                    {{ 'login.already_connected'|trans({'%user%': app.user.userIdentifier})|raw }}
                    <a href="{{ path('app_logout') }}" class="text-danger">{{ 'login.logout'|trans }}</a>
                    <a href="{{ path('app_workspace') }}" class="text-primary"><br>
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="currentColor" class="bi bi-speedometer2" viewBox="0 0 16 16">
                    <path d="M8 4a.5.5 0 0 1 .5.5V6a.5.5 0 0 1-1 0V4.5A.5.5 0 0 1 8 4M3.732 5.732a.5.5 0 0 1 .707 0l.915.914a.5.5 0 1 1-.708.708l-.914-.915a.5.5 0 0 1 0-.707M2 10a.5.5 0 0 1 .5-.5h1.586a.5.5 0 0 1 0 1H2.5A.5.5 0 0 1 2 10m9.5 0a.5.5 0 0 1 .5-.5h1.5a.5.5 0 0 1 0 1H12a.5.5 0 0 1-.5-.5m.754-4.246a.39.39 0 0 0-.527-.02L7.547 9.31a.91.91 0 1 0 1.302 1.258l3.434-4.297a.39.39 0 0 0-.029-.518z"/>
                    <path fill-rule="evenodd" d="M0 10a8 8 0 1 1 15.547 2.661c-.442 1.253-1.845 1.602-2.932 1.25C11.309 13.488 9.475 13 8 13c-1.474 0-3.31.488-4.615.911-1.087.352-2.49.003-2.932-1.25A8 8 0 0 1 0 10m8-7a7 7 0 0 0-6.603 9.329c.203.575.923.876 1.68.63C4.397 12.533 6.358 12 8 12s3.604.532 4.923.96c.757.245 1.477-.056 1.68-.631A7 7 0 0 0 8 3"/>
                    </svg></a>
                </div>
            {% endif %}
            
            <form method="post">
                <h5 class="text-center mb-3">{{ 'login.form.title'|trans }}</h5>

                <div class="mb-3">
                    <label for="username" class="form-label">{{ 'login.form.email'|trans }}</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control" required autofocus>
                    </div>
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label">{{ 'login.form.password'|trans }}</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input type="password" name="_password" id="password" class="form-control password-login-field" required>
                        <button type="button" class="btn btn-outline-secondary toggle-password" data-target=".password-login-field">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" name="_remember_me" id="_remember_me">
                    <label class="form-check-label" for="_remember_me">{{ 'login.form.remember'|trans }}</label>
                </div>

                <button class="btn btn-primary w-100" type="submit">{{ 'login.form.submit'|trans }}</button>

                <div class="text-center mt-3">
                    <small><a href="{{ path('app_forgot_password_request') }}" class="text-muted">{{ 'login.form.forgot'|trans }}</a></small>
                </div>
            </form>
        </div>

        <!-- Partie droite : Inscription -->
        <div class="col-md-6 col-12 right-panel text-center">
            <h4>{{ 'login.signup.title'|trans }}</h4>
            <p>{{ 'login.signup.text'|trans }}</p>
            <div class="row">
                <div class="col-12 d-flex gap-2">
                    <a href="{{ path('app_register') }}" class="btn btn-success">{{ 'login.signup.create'|trans }}</a>
                    <a href="{{ path('app_public') }}" class="btn btn-primary">{{ 'login.signup.home'|trans }}</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.querySelectorAll('.toggle-password').forEach(button => {
        button.addEventListener('click', function () {
            const input = document.querySelector(this.dataset.target);
            const icon = this.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        });
    });
</script>

{% endblock %}
