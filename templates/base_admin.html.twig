        </div>

        <footer class="footer">
            &copy; 2025 - Wiki Formation - <a href="#" id="manage-cookies" class="text-body text-decoration-none">Gérer les cookies</a>
        </footer>

        <button id="scrollToTopBtn" class="btn btn-warning rounded-circle shadow" title="Remonter">
            ↑
        </button>
        <script>
            const scrollBtn = document.getElementById("scrollToTopBtn");

            window.addEventListener("scroll", () => {
                if (window.scrollY > 200) {
                    scrollBtn.style.display = "block";
                } else {
                    scrollBtn.style.display = "none";
                }
            });

            scrollBtn.addEventListener("click", () => {
                window.scrollTo({
                    top: 0,
                    behavior: "smooth"
                });
            });
            
            document.addEventListener("DOMContentLoaded", function() {
                const sidebar  = document.querySelector('.sidebar');
                const content  = document.querySelector('.content');
                const toggleBtn= document.querySelector('.toggle-btn');
                const closeBtn = document.querySelector('.close-btn');
                const footer   = document.querySelector('.footer');
                const navbar   = document.querySelector('.navbar');

                if(!sidebar || !content) return;

                function applyState(isOpen){
                    // Sidebar
                    sidebar.classList.toggle('active', isOpen);

                    // Content
                    content.classList.toggle('full-width', !isOpen);

                    // Navbar / Footer (si présents)
                    if (navbar) navbar.classList.toggle('full-width', !isOpen);
                    if (footer) footer.classList.toggle('full-width', !isOpen);

                    // Bouton toggle (si présent)
                    if (toggleBtn) toggleBtn.classList.toggle('hidden', isOpen);

                    localStorage.setItem('menuOpen', isOpen ? 'true' : 'false');
                }

                // Etat initial
                const isMenuOpen = localStorage.getItem('menuOpen') === 'true';
                applyState(isMenuOpen);

                // Events
                toggleBtn?.addEventListener('click', () => applyState(true));
                closeBtn?.addEventListener('click', () => applyState(false));



                document.querySelectorAll('.dropdown-submenu > a').forEach(function (element) {
                    element.addEventListener("click", function (e) {
                        if (window.innerWidth < 992) { // Seulement pour mobile
                            e.preventDefault();
                            e.stopPropagation();

                            let submenu = this.parentElement;
                            submenu.classList.toggle("show");

                            // Fermer les autres sous-menus ouverts
                            submenu.parentElement.querySelectorAll('.dropdown-submenu.show').forEach(function (openSubmenu) {
                                if (openSubmenu !== submenu) {
                                    openSubmenu.classList.remove("show");
                                }
                            });
                        }
                    });
                });

                // Fermer les menus ouverts si on clique ailleurs
                document.addEventListener("click", function () {
                    if (window.innerWidth < 992) { // Seulement sur mobile
                        document.querySelectorAll('.dropdown-submenu.show').forEach(function (submenu) {
                            submenu.classList.remove("show");
                        });
                    }
                });
            });
            
