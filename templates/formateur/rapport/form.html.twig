{# templates/administrateur/formateur/rapport/form.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}{{ title }}{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css')}}">
  <link rel="stylesheet" href="{{ asset('dist/css/formulaire.css')}}">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css">

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};

      --bg: #f5f7fb;
      --panel: #ffffff;
      --ink: #0f172a;
      --muted:#64748b;
      --stroke: rgba(15, 23, 42, .10);
      --shadow: 0 18px 55px rgba(15, 23, 42, .10);
      --radius: 18px;

      --theme-glow: color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      --theme-soft: color-mix(in srgb, var(--theme-color-principal) 10%, #ffffff);
      --secondary-soft: color-mix(in srgb, var(--theme-color-secondaire) 16%, #ffffff);
    }

    body{ background: var(--bg); }

    /* ===== HERO (identique Sessions / Réservation) ===== */
    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;
      box-shadow: 0 18px 50px rgba(0,0,0,.14);
      background:
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }
    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }
    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }
    .hero .chip{
      display:inline-flex;
      align-items:center;
      gap:.5rem;
      padding:.32rem .7rem;
      border-radius: 999px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(255,255,255,.14);
      font-size:.82rem;
      color: rgba(255,255,255,.92);
      backdrop-filter: blur(6px);
      white-space: nowrap;
    }
    .hero .chip i{ color: var(--theme-color-secondaire); }
    .hero .chip--pill{
      background: color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
      border-color: color-mix(in srgb, var(--theme-color-secondaire) 28%, rgba(255,255,255,.14));
      color:#fff;
    }
    .hero .btn{ border-radius: 14px; font-weight: 800; }
    .hero .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .hero .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }

    @media (max-width:768px){
      .hero{ border-radius:16px; }
    }

    /* ===== Cards premium ===== */
    .cardx{
      background: var(--panel);
      border: 1px solid var(--stroke);
      border-radius: var(--radius);
      box-shadow: 0 10px 28px rgba(15,23,42,.08);
      overflow:hidden;
    }
    .cardx-h{
      padding: .95rem 1.05rem;
      display:flex; align-items:center; justify-content:space-between; gap:1rem;
      border-bottom: 1px solid var(--stroke);
    }
    .cardx-title{
      margin:0; font-weight:800; letter-spacing:-.01em; color: var(--ink);
      display:flex; align-items:center; gap:.6rem;
    }
    .chip{
      font-size:.78rem; padding:.25rem .55rem; border-radius:999px;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, var(--stroke));
      color: var(--muted);
      white-space:nowrap;
    }

    /* ===== Form ===== */
    label.form-label{ font-weight: 700; color: var(--ink); }
    .form-text, .text-muted, .small{ color: var(--muted) !important; }
    .form-control, .form-select, textarea{
      border-radius: 14px;
      border: 1px solid var(--stroke);
      padding: .65rem .85rem;
    }
    .form-control:focus, .form-select:focus, textarea:focus{
      border-color: color-mix(in srgb, var(--theme-color-principal) 55%, var(--stroke));
      box-shadow: 0 0 0 .2rem color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
    }

    /* ===== TomSelect ===== */
    .cardx.allow-overflow{ overflow: visible !important; position: relative; z-index: 1; }
    .ts-wrapper .ts-control{
      border-radius: 14px !important;
      padding: .55rem .75rem !important;
      border-color: var(--stroke) !important;
    }
    .ts-wrapper.focus .ts-control{
      box-shadow: 0 0 0 .2rem color-mix(in srgb, var(--theme-color-principal) 18%, transparent) !important;
      border-color: color-mix(in srgb, var(--theme-color-principal) 55%, var(--stroke)) !important;
    }
    .ts-dropdown{ z-index: 2000 !important; }
    .ts-dropdown, .ts-dropdown .ts-dropdown-content{
      border-radius: 14px !important;
      border: 1px solid var(--stroke) !important;
      box-shadow: 0 18px 55px rgba(15, 23, 42, .18) !important;
    }
    .ts-dropdown .option{ padding: .55rem .75rem !important; }

    /* ===== Actions sticky (desktop) ===== */
    .sticky-actions{
      position: sticky; bottom: 14px; z-index: 5;
      background: color-mix(in srgb, var(--panel) 82%, transparent);
      backdrop-filter: blur(10px);
      border: 1px solid var(--stroke);
      border-radius: var(--radius);
      padding: .75rem;
      box-shadow: var(--shadow);
    }

    .btn-outline-theme{
      border-color: color-mix(in srgb, var(--theme-color-principal) 35%, var(--stroke));
      color: var(--theme-color-principal);
    }
    .btn-outline-theme:hover{
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border-color: color-mix(in srgb, var(--theme-color-principal) 55%, var(--stroke));
      color: var(--theme-color-principal);
    }
  </style>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
{% endblock %}

{% block body %}

  {# ===== HERO premium ===== #}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>

    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-file-earmark-text me-2" style="color:var(--theme-color-secondaire)"></i>
            {{ title }}
          </h2>
          <div class="opacity-75 mt-1">
            Veuillez signaler un problème lié à une formation.
          </div>

          <div class="d-flex flex-wrap gap-2 mt-3">
            <span class="chip"><i class="bi bi-file-earmark-text"></i> Rapport</span>
            <span class="chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
            <span class="chip"><i class="bi bi-pencil-square"></i> {{ modeEdition|default(false) ? 'Modification' : 'Création' }}</span>
            <span class="chip chip--pill"><i class="bi bi-clock-history"></i> <span id="hero-last-refresh">—</span></span>
          </div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
          <a class="btn btn-outline-theme btn-sm fw-semibold"
             href="{{ path('app_formateur_rapport_index', { entite: entite.id }) }}">
            <i class="bi bi-arrow-left me-1"></i> Retour
          </a>

          <button form="{{ form.vars.id }}" type="submit" class="btn btn-light btn-sm fw-semibold" id="btnHeroSubmit">
            <i class="bi bi-check2 me-1"></i> Enregistrer
          </button>
        </div>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  {{ form_start(form, {
    attr: {
      id: form.vars.id,
      novalidate:'novalidate',
      name:'rapport_formateur_form'
    }
  }) }}
  {{ form_errors(form) }}

  <div class="row g-4">
    {# ===== COL LEFT ===== #}
    <div class="col-lg-7">

      <div class="cardx mb-4 allow-overflow">
        <div class="cardx-h">
          <h5 class="cardx-title">
            <i class="fa fa-link text-warning"></i>
            Références
          </h5>
          <span class="chip">Étape 1</span>
        </div>
        <div class="p-3 p-md-4">
          <div class="row g-3">
            <div class="col-md-12">{{ form_row(form.session) }}</div>
          </div>
          <div class="form-text mt-2">
            Choisis la session concernée.
          </div>
        </div>
      </div>

      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title">
            <i class="fa fa-comment-dots text-warning"></i>
            Commentaires
          </h5>
          <span class="chip">Étape 2</span>
        </div>
        <div class="p-3 p-md-4">
          {{ form_row(form.commentaires) }}
          <div class="form-text mt-2">Sois factuel : déroulé, points clés, actions, suivi.</div>
        </div>
      </div>

    </div>

    {# ===== COL RIGHT (Résumé + validation live) ===== #}
    <div class="col-lg-5">

      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title">
            <i class="fa fa-circle-info text-warning"></i>
            Résumé
          </h5>
          <span class="chip">Contrôle</span>
        </div>

        <div class="p-3 p-md-4">
          <div class="small text-muted mb-3">Vérifie rapidement avant d’enregistrer.</div>

          <div class="p-3 rounded-4 border mb-3"
               style="border-color: var(--stroke); background: linear-gradient(180deg, var(--theme-soft), transparent);">
            <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
              <div class="fw-bold">Choix actuels</div>
              <span id="resume-valid-pill"
                    class="badge rounded-pill px-3 py-2"
                    style="border:1px solid var(--stroke); background: rgba(255,193,7,.15); color: var(--ink);">
                ⚠️ Incomplet
              </span>
            </div>

            <div class="mt-2 small">
              <div class="d-flex justify-content-between gap-3 py-1">
                <span class="text-muted">Session</span>
                <span class="fw-semibold text-end" id="resume-session">—</span>
              </div>

              <hr class="my-2" style="border-color: var(--stroke);">

              <div class="d-flex justify-content-between gap-3 py-1">
                <span class="text-muted">Commentaire</span>
                <span class="fw-semibold text-end" id="resume-commentaires">—</span>
              </div>
            </div>
          </div>

          <div class="d-flex gap-2">
            <a href="javascript:history.back()" class="btn btn-outline-theme w-50">
              <i class="fa fa-arrow-left me-1"></i> Retour
            </a>
            <button type="submit" class="btn btn-gradient w-50">
              <i class="fa fa-check me-1"></i> Enregistrer
            </button>
          </div>
        </div>
      </div>

      <div class="sticky-actions d-none d-lg-block">
        <div class="d-flex align-items-center justify-content-between">
          <div class="small text-muted">
            <strong class="text-dark">Astuce :</strong> complète session.
          </div>
          <span class="badge rounded-pill"
                style="border:1px solid var(--stroke); background: var(--secondary-soft); color: var(--ink);">
            Rapport
          </span>
        </div>
      </div>

    </div>
  </div>

  {{ form_end(form) }}

  <script>
  document.addEventListener('DOMContentLoaded', function () {

    // ---- IDs fiables Symfony ----
    const idSession   = '#{{ form.session.vars.id }}';
    const idCom       = '#{{ form.commentaires.vars.id }}';

    const form = document.querySelector('form[name="rapport_formateur_form"]');
    const submitButtons = form ? [...form.querySelectorAll('button[type="submit"]')] : [];

    // ===== HERO last refresh =====
    const heroRefreshEl = document.getElementById('hero-last-refresh');

    function nowLabel(){
      const d = new Date();
      return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR', { hour:'2-digit', minute:'2-digit' });
    }
    function setHeroLastRefresh(prefix = 'Maj : '){
      if (!heroRefreshEl) return;
      heroRefreshEl.textContent = prefix + nowLabel();
    }
    setHeroLastRefresh();

    // ---------- TomSelect ----------
    const tsOptions = {
      create: false,
      allowEmptyOption: true,
      plugins: ['remove_button'],
      sortField: { field: 'text', direction: 'asc' },
      dropdownParent: 'body',
      render: { no_results: () => '<div class="text-muted px-2 py-1">Aucun résultat</div>' }
    };

    [idSession].forEach(sel => {
      const el = document.querySelector(sel);
      if (el && !el.tomselect) new TomSelect(el, tsOptions);
    });

    function getSelectedText(selectEl){
      if (!selectEl || !selectEl.value) return '';
      const opt = selectEl.selectedOptions && selectEl.selectedOptions[0];
      return (opt ? opt.textContent : '').trim();
    }

    // ---------- Résumé live ----------
    const $resume = {
      session: document.getElementById('resume-session'),
      commentaires: document.getElementById('resume-commentaires'),
      pill: document.getElementById('resume-valid-pill')
    };

    function isFormComplete(){
      const s = document.querySelector(idSession);
      const okBusiness = !!(s?.value && f?.value);
      const okHtml = form ? form.checkValidity() : true;
      return okBusiness && okHtml;
    }

    function refreshResume(){
      const selSession = document.querySelector(idSession);
      const comVal     = (document.querySelector(idCom)?.value || '').trim();

      if ($resume.session)     $resume.session.textContent = getSelectedText(selSession) || '—';
      if ($resume.commentaires) {
        $resume.commentaires.textContent = comVal ? (comVal.length > 42 ? (comVal.slice(0,42) + '…') : comVal) : '—';
      }

      const ok = isFormComplete();
      submitButtons.forEach(b => b.disabled = !ok);

      if ($resume.pill) {
        if (ok) {
          $resume.pill.textContent = '✅ Complet';
          $resume.pill.style.background = 'rgba(25,135,84,.15)';
          $resume.pill.style.borderColor = 'rgba(25,135,84,.35)';
          $resume.pill.style.color = 'var(--ink)';
        } else {
          $resume.pill.textContent = '⚠️ Incomplet';
          $resume.pill.style.background = 'rgba(255,193,7,.15)';
          $resume.pill.style.borderColor = 'rgba(255,193,7,.35)';
          $resume.pill.style.color = 'var(--ink)';
        }
      }
    }

    if (form) {
      form.addEventListener('input', () => { refreshResume(); setHeroLastRefresh(); });
      form.addEventListener('change', () => { refreshResume(); setHeroLastRefresh(); });
      form.addEventListener('submit', () => setHeroLastRefresh('Envoi : '));
    }

    refreshResume();

    // ---------- Validation (submit) : comme ta réservation ----------
    initFormValidation({
      formName: 'rapport_formateur_form',
      tomSelectFields: [
        { id: '{{ form.session.vars.id }}',   label: '*Session' },
      ]
    });

  });

  function initFormValidation({ formName, tomSelectFields = [] }){
    const form = document.querySelector(`form[name="${formName}"]`); if (!form) return;
    const submit = form.querySelector('button[type="submit"]'); if(!submit) return;

    let alertBox = document.getElementById('form-error-alert');
    if(!alertBox){
      alertBox = document.createElement('div');
      alertBox.id = 'form-error-alert';
      alertBox.className = 'alert alert-danger d-none';
      submit.parentElement.prepend(alertBox);
    }

    form.addEventListener('submit', (e) => {
      const invalid = form.querySelectorAll(':invalid');
      const msgs = new Set(); let first = null;

      tomSelectFields.forEach(({id,label})=>{
        const f = document.getElementById(id);
        if (f && f.hasAttribute('required') && (!f.value || !String(f.value).trim())) {
          f.classList.add('is-invalid'); if (!first) first = f; msgs.add(`- ${label}`);
        }
      });

      if (invalid.length || msgs.size){
        e.preventDefault();
        invalid.forEach(f=>{
          f.classList.add('is-invalid');
          if (!first) first = f;
          const l = form.querySelector(`label[for="${f.id}"]`);
          if (l) msgs.add(`- ${l.textContent.trim()}`);
        });
        alertBox.innerHTML = `<strong>Champs requis manquants :</strong><br>${[...msgs].join('<br>')}`;
        alertBox.classList.remove('d-none');
        if (first) first.scrollIntoView({behavior:'smooth', block:'center'});
      }
    });
  }
  </script>

{% endblock %}