{% extends 'base_admin.html.twig' %}
{% block title %}Rapports formateur{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/style-table.css') }}">
  <link rel="stylesheet" href="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/datatables.min.css"/>
  <link rel="stylesheet" href="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.css"/>

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }

    .hero{
      border-radius:22px; position:relative; overflow:hidden; color:#fff;
      box-shadow:0 18px 50px rgba(0,0,0,.14);
      background:
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }
    .hero::after{
      content:""; position:absolute; inset:0; pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }
    .hero .accent{
      width:12px; border-radius:999px; background:var(--theme-color-secondaire);
      box-shadow:0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }
    .hero .subtitle{ opacity:.86 }
    .hero .meta-chip{
      display:inline-flex; align-items:center; gap:.5rem;
      padding:.35rem .65rem; border-radius:999px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(255,255,255,.14);
      backdrop-filter: blur(6px);
      font-size:.825rem;
    }

    .kpi-card{
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 10px 26px rgba(0,0,0,.06);
      border-radius:18px;
      overflow:hidden;
      background:#fff;
      position:relative;
    }
    .kpi-card:before{
      content:""; position:absolute; inset:0;
      background: radial-gradient(700px 120px at 20% 0%, rgba(255,193,7,.12), transparent 55%);
      pointer-events:none;
    }
    .kpi-ico{
      width:44px; height:44px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }

    .filter-icon{
      width:38px; height:38px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }
    .kpi-label{ color: rgba(0,0,0,.55); font-size:.85rem }
    .kpi-value{ font-weight:800; font-size:1.6rem; letter-spacing:-.02em }
    .kpi-sub{ color: rgba(0,0,0,.50); font-size:.82rem }
    .kpi-bar{ height:6px; border-radius:999px; background: rgba(0,0,0,.06); overflow:hidden; }
    .kpi-bar>span{ display:block; height:100%; width:0%; background:var(--theme-color-secondaire); border-radius:999px; transition:width .35s ease; }

    .toolbar{
      border-radius:16px; background:#fff;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 10px 24px rgba(0,0,0,.05);
      padding:.85rem;
    }
    .chip{
      display:inline-flex; align-items:center; gap:.5rem;
      padding:.35rem .7rem; border-radius:999px;
      background: rgba(0,0,0,.03);
      border: 1px solid rgba(0,0,0,.06);
      font-size:.85rem; color: rgba(0,0,0,.65);
    }

    .table-card{
      border-radius:18px; background:#fff;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 12px 30px rgba(0,0,0,.06);
      overflow:hidden;
    }
    table.dataTable{ margin:0 !important; }
    table.dataTable thead th{
      position: sticky; top: 0; z-index: 2;
      background:#f7f8fa !important;
      border-bottom: 1px solid rgba(0,0,0,.08) !important;
      text-transform: uppercase;
      font-size:.78rem;
      letter-spacing:.06em;
      color: rgba(0,0,0,.55);
    }
    .dt-top{ padding:.75rem .85rem; border-bottom:1px solid rgba(0,0,0,.06); background:#fff; }
    .dt-bottom-internal{ padding:1rem .85rem !important; border-top:1px solid rgba(0,0,0,.06); background:#fff; margin-top:.75rem !important; }
    .dt-actions .btn{ border-radius:999px; font-weight:700; padding:.40rem .75rem; }

    #tableauRapports tbody tr:nth-child(even) > *{ background-color: rgba(35,51,66,.035) !important; }
    #tableauRapports tbody tr:nth-child(odd)  > *{ background-color: #fff !important; }
    #tableauRapports tbody tr:hover > *{ background-color: rgba(255,193,7,.08) !important; }
    #tableauRapports tbody td{ padding-top:.75rem !important; padding-bottom:.75rem !important; }

    @media (max-width:768px){
      table.dataTable td.action-column{
        position: sticky; right:0; background:#fff; z-index:5;
        box-shadow: -12px 0 18px -14px rgba(0,0,0,.22);
      }
      .hero{ border-radius:16px; }
    }
  </style>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
  <script src="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.js"></script>
{% endblock %}

{% block body %}


  {# ===== HERO ===== #}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>
    <div class="flex-grow-1">
      <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
        <span class="meta-chip"><i class="bi bi-clipboard-check"></i> Rapports</span>
        <span class="meta-chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
        <span class="meta-chip"><i class="bi bi-clock-history"></i> <span id="hero-last-refresh">-</span></span>
      </div>

      <div class="d-flex flex-wrap align-items-end gap-3">
        <div class="me-auto">
          <h2 class="fw-bold mb-1">Rapports formateur</h2>
          <div class="subtitle">Liste, recherche, filtres, export & détails.</div>
        </div>

        <div class="d-flex flex-wrap gap-2">
          <a class="btn btn-outline-light btn-sm fw-semibold"
             href="{{ path('app_formateur_dashboard', { entite: entite.id }) }}">
            <i class="bi bi-arrow-left"></i> Tableau de bord
          </a>

          <a class="btn btn-warning btn-sm fw-semibold"
             href="{{ path('app_formateur_rapport_new', { entite: entite.id }) }}">
            <i class="bi bi-plus-circle"></i> Nouveau
          </a>
        </div>
      </div>
    </div>
  </div>

  {# ===== KPI ===== #}
  <div class="row g-3 mb-3">
    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-files fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Rapports</div>
              <div class="kpi-value" id="kpi-count">-</div>
              <div class="kpi-sub">Total</div>
            </div>
          </div>
          <div class="mt-3 kpi-bar"><span id="kpi-bar-count"></span></div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-chat-left-text fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Commentaires</div>
              <div class="kpi-value" id="kpi-com">-</div>
              <div class="kpi-sub">Renseignés</div>
            </div>
          </div>
          <div class="mt-3 kpi-bar"><span id="kpi-bar-com"></span></div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-ui-checks-grid fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Critères</div>
              <div class="kpi-value" id="kpi-crit">-</div>
              <div class="kpi-sub">Présents</div>
            </div>
          </div>
          <div class="mt-3 kpi-bar"><span id="kpi-bar-crit"></span></div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-calendar2-week fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Derniers 30j</div>
              <div class="kpi-value" id="kpi-last30">-</div>
              <div class="kpi-sub">Soumissions</div>
            </div>
          </div>
          <div class="mt-3 kpi-bar"><span id="kpi-bar-last30"></span></div>
        </div>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  {# ===== TOOLBAR ===== #}
  <div class="toolbar mb-3">
    <div class="d-flex flex-wrap gap-2 align-items-center">
      <div class="me-auto d-flex flex-wrap gap-2 align-items-center">
        <span class="chip">
          <i class="bi bi-calendar3"></i>
          Du
          <input id="dateFrom" type="date" class="form-control form-control-sm ms-2" style="width:auto">
          au
          <input id="dateTo" type="date" class="form-control form-control-sm ms-2" style="width:auto">
        </span>

        <span class="chip">
          <i class="bi bi-chat-left-text"></i>
          Commentaires
          <select id="hasCommentaires" class="form-select form-select-sm ms-2" style="width:auto">
            <option value="all">Tous</option>
            <option value="yes">Avec</option>
            <option value="no">Sans</option>
          </select>
        </span>

        <span class="chip">
          <i class="bi bi-ui-checks-grid"></i>
          Critères
          <select id="hasCriteres" class="form-select form-select-sm ms-2" style="width:auto">
            <option value="all">Tous</option>
            <option value="yes">Avec</option>
            <option value="no">Sans</option>
          </select>
        </span>
      </div>

      <div class="d-flex gap-2 align-items-center">
        <button id="btnReset" class="btn btn-outline-secondary btn-sm fw-semibold" type="button">
          <i class="bi bi-arrow-counterclockwise"></i> Reset
        </button>

        <div class="dropdown">
          <button class="btn btn-warning btn-sm fw-semibold dropdown-toggle" type="button"
                  data-bs-toggle="dropdown" aria-expanded="false">
            <i class="bi bi-download"></i> Export
          </button>
          <ul class="dropdown-menu dropdown-menu-end" id="exportMenu"></ul>
        </div>
      </div>
    </div>
  </div>

  {# ===== TABLE ===== #}
  <div class="table-card mb-4 p-3">
    <table id="tableauRapports" class="table table-hover align-middle mb-0" style="width:100%">
      <thead>
        <tr>
          <th style="width:90px">#</th>
          <th>Session</th>
          <th>Formateur</th>
          <th>Soumis le</th>
          <th>Commentaire</th>
          <th class="text-end" style="width:180px">Actions</th>
        </tr>
      </thead>
      <tbody><tr><td colspan="6"></td></tr></tbody>
    </table>
  </div>


{# ===== MODAL DETAILS ===== #}
<div class="modal fade" id="rapportModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content rounded-3">
      <div class="modal-header">
        <h5 class="modal-title" id="rapportModalTitle">Détails</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
      </div>
      <div class="modal-body" id="rapportModalBody">…</div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fermer</button>
      </div>
    </div>
  </div>
</div>

<script>
$(function () {
  const $dateFrom = $('#dateFrom');
  const $dateTo   = $('#dateTo');
  const $hasCom   = $('#hasCommentaires');
  const $hasCrit  = $('#hasCriteres');

  function nowLabel(){
    const d = new Date();
    return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
  }

  function getFilters(){
    return {
      dateFrom: $dateFrom.val() || '',
      dateTo: $dateTo.val() || '',
      hasCommentaires: $hasCom.val() || 'all',
      hasCriteres: $hasCrit.val() || 'all',
    };
  }

  function openDetails(row){
    const title = `Rapport #${row.id} — ${row.session}`;
    const crit = row.criteres ? JSON.stringify(row.criteres, null, 2) : '';
    const html = `
      <div class="d-flex flex-wrap gap-2 mb-3">
        <span class="badge text-bg-light border"><i class="bi bi-easel2 me-1"></i>${row.session}</span>
        <span class="badge text-bg-light border"><i class="bi bi-person-badge me-1"></i>${row.formateur}</span>
        <span class="badge text-bg-light border"><i class="bi bi-clock-history me-1"></i>${row.submittedAt}</span>
        <span class="badge text-bg-light border"><i class="bi bi-ui-checks-grid me-1"></i>${row.critCount} critère(s)</span>
      </div>

      <h6 class="fw-bold mb-2"><i class="bi bi-chat-left-text me-1"></i> Commentaires</h6>
      <div class="border rounded p-3 bg-light mb-3" style="white-space:pre-wrap">${(row.commentFull && row.commentFull.trim()) ? $('<div>').text(row.commentFull).html() : '<span class="text-muted">—</span>'}</div>

      <h6 class="fw-bold mb-2"><i class="bi bi-ui-checks-grid me-1"></i> Critères</h6>
      <pre class="border rounded p-3 bg-light mb-0" style="max-height:260px; overflow:auto">${crit ? $('<div>').text(crit).html() : '—'}</pre>
    `;

    $('#rapportModalTitle').text(title);
    $('#rapportModalBody').html(html);
    bootstrap.Modal.getOrCreateInstance(document.getElementById('rapportModal')).show();
  }

  const table = $('#tableauRapports').DataTable({
    processing: true,
    serverSide: true,
    ajax: {
      url: "{{ path('app_formateur_rapport_ajax', { entite: entite.id }) }}",
      type: "POST",
      data: function(d){
        Object.assign(d, getFilters());
      }
    },

    dom:
      '<"dt-top d-flex flex-wrap gap-2 align-items-center justify-content-between"'
        + '<"dt-actions d-flex gap-2 align-items-center"B>'
        + '<"dt-search"f>'
      + '>'
      + 'rt'
      + '<"dt-bottom-internal d-flex flex-wrap gap-2 align-items-center justify-content-between"lip>',

    buttons: [
      { extend: 'copy',  title: 'Rapports formateur', text: 'Copier' },
      { extend: 'csv',   title: 'Rapports formateur', text: 'CSV' },
      { extend: 'excel', title: 'Rapports formateur', text: 'Excel' },
      { extend: 'pdf',   title: 'Rapports formateur', text: 'PDF' },
      { extend: 'print', title: 'Rapports formateur', text: 'Imprimer' },
    ],

    lengthMenu: [[10,25,50,100,500],[10,25,50,100,500]],

    columns: [
      { data:'id' },
      { data:'session' },
      { data:'formateur' },
      { data:'submittedAt' },
      { data:'comment' },
      { data:'actions' }
    ],

    columnDefs: [
      {
        targets: 5,
        className: 'action-column text-end',
        orderable: false,
        searchable: false,
        render: function(data, type, row){
          return `
            <button type="button" class="btn btn-sm btn-outline-secondary fw-semibold" data-action="details">
              <i class="bi bi-eye"></i> Détails
            </button>
          `;
        }
      },
      { targets:[4,5], searchable:false }
    ],

    order: [[3,'desc']],
    language: { url:'https://cdn.datatables.net/plug-ins/2.2.2/i18n/fr-FR.json' },
    deferRender: true,

    initComplete: function(){
      // buttons -> dropdown export
      const api = this.api();
      const container = api.buttons().container();
      const $btns = $(container).find('button');

      $('#exportMenu').empty();
      $btns.each(function(){
        const $b = $(this);
        const label = $b.text().trim();

        const icon = label === 'Excel' ? 'bi-file-earmark-excel' :
                     label === 'PDF' ? 'bi-file-earmark-pdf' :
                     label === 'CSV' ? 'bi-filetype-csv' :
                     label === 'Imprimer' ? 'bi-printer' :
                     label === 'Copier' ? 'bi-clipboard' : 'bi-download';

        const $item = $(`
          <li>
            <a class="dropdown-item d-flex align-items-center gap-2" href="#">
              <i class="bi ${icon}"></i> <span>${label}</span>
            </a>
          </li>
        `);

        $item.on('click', function(e){
          e.preventDefault();
          $b.trigger('click');
        });

        $('#exportMenu').append($item);
      });

      $(container).hide();
    }
  });

  // click détails
  $('#tableauRapports tbody').on('click', '[data-action="details"]', function(){
    const row = table.row($(this).closest('tr')).data();
    if(row) openDetails(row);
  });

  table.on('draw.dt', function(){
    $('#hero-last-refresh').text('Maj : ' + nowLabel());
  });

  async function loadKpis(){
    const f = getFilters();
    const url = new URL("{{ path('app_formateur_rapport_kpis', { entite: entite.id }) }}", window.location.origin);
    Object.entries(f).forEach(([k,v]) => url.searchParams.set(k, v));

    const res = await fetch(url, { headers: { 'Accept':'application/json' }});
    if(!res.ok) return;
    const k = await res.json();

    const count = k.count || 0;
    const com   = k.withCommentaires || 0;
    const crit  = k.withCriteres || 0;
    const last30= k.last30 || 0;

    $('#kpi-count').text(count);
    $('#kpi-com').text(com);
    $('#kpi-crit').text(crit);
    $('#kpi-last30').text(last30);

    const pct = (n) => count > 0 ? Math.min(100, Math.round((n / count) * 100)) : 0;
    $('#kpi-bar-count').css('width', count ? '100%' : '0%');
    $('#kpi-bar-com').css('width', pct(com) + '%');
    $('#kpi-bar-crit').css('width', pct(crit) + '%');
    $('#kpi-bar-last30').css('width', pct(last30) + '%');

    $('#hero-last-refresh').text('Maj : ' + nowLabel());
  }

  loadKpis();

  // Rechargement sur filtres
  $('#dateFrom, #dateTo, #hasCommentaires, #hasCriteres').on('change', function(){
    table.ajax.reload(null, true);
    loadKpis();
  });

  $('#btnReset').on('click', function(){
    $dateFrom.val('');
    $dateTo.val('');
    $hasCom.val('all');
    $hasCrit.val('all');
    table.search('').draw();
    table.ajax.reload(null, true);
    loadKpis();
  });
});
</script>
{% endblock %}