{% block javascripts %}
{{ parent() }}
{# 1. jQuery (tu l'as déjà) #}
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>


{# 3. DataTables (core + intégration Bootstrap 5 en un seul fichier pratique) #}
<script src="https://cdn.datatables.net/v/bs5/dt-2.1.6/datatables.min.js"></script>

<script type="text/javascript" src="https://cdn.datatables.net/v/bs5/jszip-2.5.0/dt-1.10.25/b-1.7.1/b-html5-1.7.1/b-print-1.7.1/date-1.1.1/fh-3.1.9/r-2.2.9/rg-1.1.3/sc-2.0.4/sp-1.3.0/datatables.min.js"></script>

<script>
/* ===== Modales utilitaires (showModal / confirmDialog) ===== */
(function(){
  function getBS(){ const c=(window.bootstrap||globalThis.bootstrap||bootstrap||null); return (c && c.Modal)?c:null; }
  window.showModal = function(title, html, variant='info'){
    const m=document.getElementById('appModal'), bs=getBS(); if(!m||!bs){ alert((title||'Info')+'\n\n'+(html||'')); return; }
    m.querySelector('#appModalTitle').textContent = title||'Information';
    m.querySelector('#appModalBody').innerHTML    = html||'';
    const ok=m.querySelector('.modal-footer .btn'); ok.className='btn';
    ok.classList.add({info:'btn-primary',success:'btn-success',warning:'btn-warning',danger:'btn-danger'}[variant]||'btn-primary');
    bs.Modal.getOrCreateInstance(m, {backdrop:true, focus:true}).show();
  };
})();
</script>

<script>
(function(){
  function getBS(){ const c=(window.bootstrap||globalThis.bootstrap||bootstrap||null); return (c && c.Modal)?c:null; }

  window.confirmDialog = function(message, {title='Confirmer', confirmText='Confirmer', variant='danger'} = {}){
    return new Promise(resolve=>{
      const bs = getBS();
      const modal = document.getElementById('confirmModal');

      // Si la modale n'est pas dispo → fallback natif
      if (!bs || !modal) { resolve(!!confirm((title?title+'\n\n':'')+(message||'Êtes-vous sûr ?'))); return; }

      // Récupère les éléments en vérifiant qu'ils existent
      const elTitle = modal.querySelector('.modal-title');
      const elBody  = modal.querySelector('#confirmModalBody');
      const btnOk   = modal.querySelector('#confirmModalOk');

      // Si un des éléments manque → fallback natif
      if (!elTitle || !elBody || !btnOk) {
        resolve(!!confirm((title?title+'\n\n':'')+(message||'Êtes-vous sûr ?')));
        return;
      }

      // Remplissage sécurisé
      elTitle.textContent = title || 'Confirmer';
      elBody.innerHTML    = message || 'Êtes-vous sûr ?';
      btnOk.textContent   = confirmText || 'Confirmer';
      btnOk.className     = 'btn ' + (variant==='danger' ? 'btn-danger'
                                   : variant==='warning' ? 'btn-warning'
                                   : variant==='success' ? 'btn-success' : 'btn-primary');

      const inst = bs.Modal.getOrCreateInstance(modal, {backdrop:true, focus:true});
      const onOk  = ()=>{ cleanup(); inst.hide(); resolve(true);  };
      const onHide= ()=>{ cleanup();              resolve(false); };

      function cleanup(){
        btnOk.removeEventListener('click', onOk);
        modal.removeEventListener('hidden.bs.modal', onHide);
      }

      btnOk.addEventListener('click', onOk,   {once:true});
      modal.addEventListener('hidden.bs.modal', onHide, {once:true});
      inst.show();
    });
  };
})();
</script>

<script>
document.addEventListener('DOMContentLoaded', function () {
  // Sécurité : jQuery + DataTables requis
  if (!window.jQuery) {
    console.error('jQuery non chargé : ajoute');
    return;
  }
  if (!jQuery.fn || !jQuery.fn.DataTable) {
    console.error('DataTables non chargé : ajoute le JS DataTables AVANT ce script.');
    return;
  }

  (function ($) {

    const fmtBytes = b => (b==null)?'-':(b<1024? b+' o' : b<1048576? (b/1024).toFixed(1)+' Ko' : b<1073741824? (b/1048576).toFixed(1)+' Mo' : (b/1073741824).toFixed(1)+' Go');
    const escapeHtml = s => String(s||'').replace(/[&<>"']/g, m => ({
  '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
}[m]));

    const iconFor = nameLower =>{
      if(nameLower.includes('pdf')) return 'bi-file-earmark-pdf-fill';
      if(nameLower.includes('ppt')) return 'bi-file-earmark-slides-fill';
      if(nameLower.includes('xls')||nameLower.includes('csv')) return 'bi-file-earmark-spreadsheet-fill';
      if(nameLower.includes('doc')) return 'bi-file-earmark-word-fill';
      if(/\.(png|jpg|jpeg|webp|gif)$/i.test(nameLower)) return 'bi-file-earmark-image-fill';
      return 'bi-file-earmark-text-fill';
    };

    let CURRENT_ASSET_ID = null;
    const setCurrentAsset = (id, name) => {
      CURRENT_ASSET_ID = id || null;
      const el = document.getElementById('currentAssetName');
      if (el) el.textContent = name || '-';
      loadAssignments();
    };

    // ===== DataTable : Assets =====
    const dtAssets = $('#dtAssets').DataTable({
      ajax: {
        url: "{{ path('app_formateur_supports_assets_feed', {entite: entite.id}) }}",
        dataSrc: 'data'
      },
      columns: [
        { data:null, render: (r)=>{
            const title = r.titre || r.originalName || 'Document';
            const ico = iconFor((title||'').toLowerCase());
            const typeBadge = /\bpdf\b/i.test(r.mimeType||'')?'PDF': /\bppt/i.test(r.mimeType||'')?'PPT' : /\bexcel|sheet|csv/i.test(r.mimeType||'')?'Excel' : /\.(png|jpg|jpeg|webp|gif)$/i.test(r.originalName||'')?'Image':'Fichier';
            return `
              <div class="d-flex align-items-center gap-2">
                <span class="badge rounded-2 bg-secondary border"><i class="bi ${ico}"></i></span>
                <div class="flex-grow-1">
                  <div class="fw-bold">${escapeHtml(title)}</div>
                  <div class="text-muted small">${fmtBytes(r.size)} · <span class="badge-type">${typeBadge}</span></div>
                </div>
              </div>`;
          }
        },
        { data:'uploadedAt' },
        { data:null, orderable:false, className:'text-end action-col', render:(r)=>{
            const t = r.titre || r.originalName || 'Document';
            return `
              <div class="btn-group">
                <a class="btn btn-sm btn-outline-secondary" href="${r.url}" target="_blank" title="Télécharger"><i class="bi bi-download"></i></a>
                <button class="btn btn-sm btn-primary" data-choose data-id="${r.id}" data-name="${escapeHtml(t)}"><i class="bi bi-check2-circle"></i></button>
              </div>`;
          }
        }
      ],
      order: [[1,'desc']],
      deferRender:true, pageLength:10, lengthMenu:[10,25,50,100],
      dom: '<"row"<"col-md-6"f><"col-md-6 text-end"l>>rt<"row mt-2"<"col-md-6"i><"col-md-6 text-end"p>>',
      language: { url:'https://cdn.datatables.net/plug-ins/2.2.2/i18n/fr-FR.json' },
    });

    // Sélection d’un asset (bouton)
    $('#dtAssets').on('click','[data-choose]', function(){
      setCurrentAsset(this.dataset.id, this.dataset.name);
    });

    // Click ligne (hors actions) => sélection
    $('#dtAssets tbody').on('click', 'tr', function(e){
      if (e.target.closest('.btn-group')) return;
      const row = dtAssets.row(this).data(); if(!row) return;
      const title = row.titre || row.originalName || 'Document';
      setCurrentAsset(row.id, title);
    });

    // Upload
    document.getElementById('libUploadForm')?.addEventListener('submit', async (e)=>{
      e.preventDefault();
      const btn=e.currentTarget.querySelector('button[type=submit]'); const old=btn?.innerHTML;
      if(btn){ btn.disabled=true; btn.innerHTML='<span class="spinner-border spinner-border-sm me-1"></span> Import…'; }
      try{
        const r = await fetch("{{ path('app_formateur_supports_library_upload', {entite: entite.id}) }}", { method:'POST', body:new FormData(e.currentTarget), headers:{'X-Requested-With':'XMLHttpRequest'} });
        if(!r.ok) throw new Error('HTTP '+r.status);
        await r.json();
        $('#dtAssets').DataTable().ajax.reload(null,false);
        const f=document.getElementById('libFiles'); if(f) f.value='';
        showModal('Import terminé', 'Fichier(s) importé(s) dans la bibliothèque.', 'success');
      }catch(err){ showModal('Upload refusé', String(err.message||err), 'danger'); }
      finally{ if(btn){ btn.disabled=false; btn.innerHTML=old; } }
    });
    document.getElementById('btnClear')?.addEventListener('click', ()=>{ const f=document.getElementById('libFiles'); if(f) f.value=''; });

    // ===== DataTable : Sessions (sélection) =====
    const dtSess = $('#dtSessionsSelect').DataTable({
      ajax:{ url:"{{ path('app_formateur_supports_sessions_feed', {entite: entite.id}) }}", dataSrc:'data' },
      columns:[
        { data:null, orderable:false, render:(r)=>`<input type="checkbox" class="form-check-input" value="${r.id}">` },
        { data:'code' },
        { data:'formation' },
        { data:'dates' }
      ],
      order:[[1,'desc']], pageLength:10, lengthMenu:[10,25,50],
      dom:'t<"d-flex justify-content-between align-items-center mt-2"ip>',
      language: { url:'https://cdn.datatables.net/plug-ins/2.2.2/i18n/fr-FR.json' },
    });

    // Toggle checkbox au clic de ligne
    $('#dtSessionsSelect tbody').on('click', 'tr', function(e){
      const cb = this.querySelector('input[type=checkbox]'); if(!cb) return;
      if(e.target !== cb) cb.checked = !cb.checked;
      updateCounts();

      // ✅ Recharge la liste stagiaires pour la session sélectionnée
      dtUsers.ajax.reload(null, true);
    });


    // ===== DataTable : Utilisateurs (sélection) =====
    // Helper : 1ère session cochée
    function getSelectedSessionId(){
      const cb = document.querySelector('#dtSessionsSelect input[type=checkbox]:checked');
      return cb ? cb.value : null;
    }

    // ===== DataTable : Utilisateurs (sélection) =====
    const dtUsers = $('#dtUsersSelect').DataTable({
      ajax: {
        url: "{{ path('app_formateur_supports_trainees_feed', {entite: entite.id}) }}",
        dataSrc: 'data',
        data: function (d) {
          d.sessionId = getSelectedSessionId() || 0; // IMPORTANT
        }
      },
      columns:[
        { data:null, orderable:false, render:(r)=>`<input type="checkbox" class="form-check-input" value="${r.id}">` },
        { data:'nom' },
        { data:'email' }
      ],
      order:[[1,'asc']], pageLength:10, lengthMenu:[10,25,50],
      dom:'t<"d-flex justify-content-between align-items-center mt-2"ip>',
      language: { url:'https://cdn.datatables.net/plug-ins/2.2.2/i18n/fr-FR.json' },
    });


    $('#dtUsersSelect tbody').on('click', 'tr', function(e){
      const cb = this.querySelector('input[type=checkbox]'); if(!cb) return;
      if(e.target !== cb) cb.checked = !cb.checked;
      updateCounts();
    });

    // Compteurs
    function updateCounts(){
      const s = $('#dtSessionsSelect input[type=checkbox]:checked').length;
      const u = $('#dtUsersSelect input[type=checkbox]:checked').length;
      document.getElementById('countSessions').textContent = (s||0)+' sélection'+(s>1?'s':'');
      document.getElementById('countUsers').textContent    = (u||0)+' sélection'+(u>1?'s':'');
    }
    $('#dtSessionsSelect, #dtUsersSelect').on('change','input[type=checkbox]', updateCounts);

    // Affectations existantes
    async function loadAssignments(){
      const as = document.getElementById('assignSessions');
      const au = document.getElementById('assignUsers');
      if(!as || !au) return;
      if(!CURRENT_ASSET_ID){ as.innerHTML='-'; au.innerHTML='-'; return; }

      try{
        const url = new URL("{{ path('app_formateur_supports_assignments_feed',{entite:entite.id}) }}", window.location.origin);
        url.searchParams.set('assetId', CURRENT_ASSET_ID);
        const r = await fetch(url, {headers:{'X-Requested-With':'XMLHttpRequest'}}).then(x=>x.json());

        as.innerHTML=''; (r.sessions||[]).forEach(s=>{
          as.insertAdjacentHTML('beforeend', `
            <div class="d-flex align-items-center justify-content-between border rounded p-2">
              <div><strong>${escapeHtml(s.code)}</strong> - ${escapeHtml(s.formation)}
                <span class="text-muted small ms-1">${escapeHtml(s.dates)}</span></div>
              <button type="button" class="btn btn-sm btn-outline-danger" data-unassign="session" data-link-id="${s.linkId}" data-asset-id="${CURRENT_ASSET_ID}">
                <i class="bi bi-x-circle"></i>
              </button>
            </div>`);
        });

        au.innerHTML=''; (r.users||[]).forEach(u=>{
          au.insertAdjacentHTML('beforeend', `
            <div class="d-flex align-items-center justify-content-between border rounded p-2">
              <div>${escapeHtml(u.nom)} <span class="text-muted small ms-1">${escapeHtml(u.email)}</span></div>
              <button type="button" class="btn btn-sm btn-outline-danger" data-unassign="user" data-link-id="${u.linkId}" data-asset-id="${CURRENT_ASSET_ID}">
                <i class="bi bi-x-circle"></i>
              </button>
            </div>`);
        });

      }catch(err){
        as.innerHTML = '<div class="text-danger">Erreur de chargement.</div>';
        au.innerHTML = '<div class="text-danger">Erreur de chargement.</div>';
      }
    }
    window.loadAssignments = loadAssignments;

    // Assigner
    async function assign(type){
      if(!CURRENT_ASSET_ID){ showModal('Sélection requise', 'Sélectionne d’abord un document.', 'warning'); return; }
      const ids = Array.from(document.querySelectorAll(type==='sessions' ? '#dtSessionsSelect input:checked' : '#dtUsersSelect input:checked')).map(i=>i.value);
      if(!ids.length){ showModal('Sélection requise', type==='sessions'?'Choisis au moins une session.':'Choisis au moins un stagiaire.', 'warning'); return; }

      const btn = document.getElementById(type==='sessions'?'btnAssignSessions':'btnAssignUsers');
      const old = btn.innerHTML; btn.disabled=true; btn.innerHTML='<span class="spinner-border spinner-border-sm me-1"></span> Lien…';

      try{
        const f = new FormData();
        f.append('assetId', CURRENT_ASSET_ID);
        ids.forEach(id => f.append(type==='sessions' ? 'sessionIds[]' : 'userIds[]', id));
        f.append('visible', document.getElementById(type==='sessions'?'visibleSess':'visibleUsers').checked ? '1' : '0');

        await fetch(type==='sessions'
            ? "{{ path('app_formateur_supports_assign_sessions',{entite:entite.id}) }}"
            : "{{ path('app_formateur_supports_assign_users',{entite:entite.id}) }}",
          { method:'POST', body:f, headers:{'X-Requested-With':'XMLHttpRequest'} });

        await loadAssignments();
        showModal('Affectation effectuée', type==='sessions'?'Lié aux sessions sélectionnées.':'Lié aux stagiaires sélectionnés.', 'success');
      }catch(err){
        showModal('Affectation refusée', String(err.message||err), 'danger');
      }finally{
        btn.disabled=false; btn.innerHTML=old;
      }
    }
    document.getElementById('btnAssignSessions')?.addEventListener('click', ()=>assign('sessions'));
    document.getElementById('btnAssignUsers')?.addEventListener('click',   ()=>assign('users'));

    // Désaffecter (délégation globale)
    document.addEventListener('click', async (e)=>{
      const btn = e.target.closest('[data-unassign]'); if(!btn) return;
      e.preventDefault();
      const type=btn.getAttribute('data-unassign'), linkId=btn.getAttribute('data-link-id'), assetId=btn.getAttribute('data-asset-id')||CURRENT_ASSET_ID||'';
      if(!linkId) return;
      const ok = await window.confirmDialog(type==='session'?'Retirer ce lien de session ?':'Retirer ce lien stagiaire ?', { title:'Supprimer le lien', confirmText:'Retirer', variant:'danger' });
      if(!ok) return;
      const old = btn.innerHTML; btn.disabled=true; btn.innerHTML='<span class="spinner-border spinner-border-sm"></span>';
      try{
        const f=new FormData(); f.append('id', linkId); if(assetId) f.append('assetId', assetId);
        const url = type==='session'
          ? "{{ path('app_formateur_supports_unassign_session',{entite:entite.id}) }}"
          : "{{ path('app_formateur_supports_unassign_user',{entite:entite.id}) }}";
        await fetch(url, { method:'POST', body:f, headers:{'X-Requested-With':'XMLHttpRequest'} });
        await loadAssignments();
      }catch(err){ showModal('Action refusée', String(err.message||err), 'danger'); btn.disabled=false; btn.innerHTML=old; }
    });

    // Init affectations (aucune sélection au départ)
    loadAssignments();

  })(jQuery);
});
</script>

{% endblock %}
