{# templates/formateur/supports_library.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}Ma bibliothèque de supports{% endblock %}

{% block stylesheets %}
{{ parent() }}


<link rel="stylesheet" href="https://cdn.datatables.net/v/bs5/dt-2.1.6/datatables.min.css">
<link rel="stylesheet" href="{{ asset('dist/css/formulaire.css')}}">

<style>
:root{
  --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
  --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
  --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
  --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};

  /* aliases locaux (si tu les utilises ailleurs dans la page) */
  --brand: var(--theme-color-principal);
  --accent: var(--theme-color-secondaire);

  --ink:#0f2336; --muted:#6c8595;
  --card:#ffffff; --card-2:#fafcfe; --line:#e8eef5;
  --r:.9rem; --r-lg:1rem; --shadow:0 10px 30px rgba(15,35,54,.10);
}
/* ===== HERO (style QCM, piloté par couleurs entité) ===== */
.hero{
  border-radius: 22px;
  position: relative;
  overflow: hidden;
  color: #fff;
  box-shadow: 0 18px 50px rgba(0,0,0,.14);
  background:
    radial-gradient(1200px 420px at 12% -10%,
      color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
      transparent 58%
    ),
    radial-gradient(900px 380px at 92% 0%,
      color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
      transparent 60%
    ),
    radial-gradient(700px 260px at 55% 115%,
      color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
      transparent 62%
    ),
    linear-gradient(135deg,
      color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
      color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
    );
}
.hero::after{
  content:"";
  position:absolute;
  inset:0;
  pointer-events:none;
  background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
  opacity:.85;
}
.hero .accent{
  width: 12px;
  border-radius: 999px;
  background: var(--theme-color-secondaire);
  box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
}
.hero .subtitle{ opacity:.86 }

/* ✅ chips HERO (style QCM) */
.hero .meta-chip{
  display:inline-flex;
  align-items:center;
  gap:.45rem;
  padding:.28rem .65rem;
  border-radius:999px;
  font-size:.82rem;
  background: rgba(255,255,255,.10);
  border: 1px solid rgba(255,255,255,.14);
  color: rgba(255,255,255,.92);
  white-space: nowrap;
}
.hero .meta-chip i{ color: var(--theme-color-secondaire); }

/* ✅ boutons hero */
.hero .btn{
  border-radius: 14px;
  font-weight: 800;
}

/* ✅ outline spécifique hero (à la place du btn-chip) */
.hero .btn-outline-hero{
  border-color: rgba(255,255,255,.35);
  color:#fff;
}
.hero .btn-outline-hero:hover{
  background: rgba(255,255,255,.10);
  border-color: rgba(255,255,255,.55);
  color:#fff;
}

@media (max-width:768px){
  .hero{ border-radius: 16px; }
}
.btn-chip{ border-radius:999px; font-weight:700; border:1px solid color-mix(in oklab, var(--brand) 25%, var(--line)); color:white !important; }

/* Cartes/panneaux */
.panel{ background:var(--card); border:1px solid var(--line); border-radius:var(--r-lg); box-shadow:var(--shadow); overflow:hidden; }
.panel-h{ padding:.8rem 1rem; border-bottom:1px solid var(--line); background:var(--card); }
.panel-h h5{ margin:0; font-size:1rem; font-weight:800; color:var(--ink); }
.panel-b{ padding:1rem; }

/* Datatables : en-tête et cellules compactes, actions collées à droite sur mobile */
table.dataTable thead th{ font-weight:800; color:var(--ink); border-bottom:1px solid var(--line) !important; }
table.dataTable tbody td{ vertical-align:middle; }
.badge-type{ font-size:.72rem; font-weight:800; padding:.15rem .42rem; border-radius:.5rem;
  border:1px solid color-mix(in oklab, var(--accent) 40%, white 60%);
  background:color-mix(in oklab, var(--accent) 12%, white 88%);
  color:color-mix(in oklab, var(--accent) 70%, black 30%);
}

@media (min-width:1200px){ .sticky-panel{ position:sticky; top:1rem; } }

/* Panneau d’affectation */
.assign-card{
  border:1px solid var(--line); border-radius:1rem; overflow:hidden;
  background:linear-gradient(180deg, var(--card), var(--card-2)); box-shadow:var(--shadow);
  margin-bottom:1rem;
}
.assign-card .ac-head{
  display:flex; align-items:center; justify-content:space-between;
  padding:.65rem .85rem; background: color-mix(in oklab, var(--brand) 6%, var(--card));
  border-bottom:1px solid var(--line);
}
.assign-card .ac-title{ font-weight:900; color:var(--ink); }
.count-badge{
  font-size:.72rem; font-weight:800; border-radius:999px; padding:.2rem .6rem;
  border:1px solid color-mix(in oklab, var(--brand) 30%, var(--line));
  background: color-mix(in oklab, var(--brand) 8%, white 92%); color: color-mix(in oklab, var(--brand) 75%, black 25%);
}

.current-asset{
  display:flex; align-items:center; gap:.75rem;
  border:1px solid var(--line); border-radius: .9rem;
  padding:.7rem .8rem; background:linear-gradient(180deg, var(--card), var(--card-2));
}
.current-asset .ca-ico{
  width:38px; height:38px; border-radius:.55rem; display:grid; place-items:center;
  background: color-mix(in oklab, var(--brand) 12%, white 88%); color: color-mix(in oklab, var(--brand) 80%, black 20%);
}
.current-asset .ca-label{ font-size:.78rem; text-transform:uppercase; letter-spacing:.02em; color:var(--muted); font-weight:700; }
.current-asset .ca-name{ font-weight:800; line-height:1.2; color:var(--ink); }

#dtAssets td.action-col{ width:1%; white-space:nowrap; }
#dtSessionsSelect td, #dtUsersSelect td{ white-space:nowrap; }

/* Mobile : action sticky à droite si table déborde */
@media (max-width:768px){
  table.dataTable td.action-col{ position:sticky; right:0; background:var(--card); z-index:5; box-shadow:-8px 0 12px -8px rgba(0,0,0,.08); }
}


:root{
  --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
  --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
  --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
  --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
}
</style>

<link rel="stylesheet" href="{{ asset('dist/css/style.css')}}">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css">

