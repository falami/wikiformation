{% extends 'base_admin.html.twig' %}
{% block title %}Session {{ session.code }} - Formateur{% endblock %}


{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="https://cdn.datatables.net/2.2.2/css/dataTables.dataTables.css" />
<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css" rel="stylesheet"/>
<style>
  .fc { --fc-border-color:#e9ecef; --fc-page-bg-color:transparent; }
  .session-card { border-radius:1rem; border:1px solid #e9ecef; padding:1rem; background:#fff; }
</style>
<style>
:root{ --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
       --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
       --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
       --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};}
@media (max-width:768px){
  table.dataTable td.action-column{ position:sticky; right:0; background:#fff; z-index:5; box-shadow:-8px 0 12px -8px rgba(0,0,0,.08); }
}
</style>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fancyapps/ui/dist/fancybox.css"/>
<style>.sign-pad{border:1px dashed var(--stroke,#ddd); border-radius:12px; background:#fff;}</style>
<link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
<link rel="stylesheet" href="https://cdn.datatables.net/2.2.2/css/dataTables.dataTables.css"/>
<link rel="stylesheet" href="{{ asset('dist/css/style-table.css') }}">
{% endblock %}

{% block body %}
<div class="row g-3">
  <div class="col-12 col-xl-8">
    <div class="card shadow-sm">
      <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-center">
          <h4 class="mb-2">{{ session.formation.titre }}</h4>
          <span class="badge bg-info-subtle text-info">Code {{ session.code }}</span>
        </div>
        <div class="text-muted mb-3">
          {% for j in session.jours %}
              {{ j.dateDebut|date('d/m/Y : H:i') }} → {{ j.dateFin|date('H:i') }} - {{ session.site.nom }}<br>
          {% endfor %} 
        </div>

        <h6 class="mt-3">Participants</h6>
        <ul class="list-group mb-3">
          {% for r in session.reservations %}
            <li class="list-group-item d-flex justify-content-between align-items-center">
              <span>{{ r.utilisateur.prenom }} {{ r.utilisateur.nom }}</span>
              <span class="text-muted small">{{ r.status.name }}</span>
            </li>
          {% else %}
            <li class="list-group-item text-muted">Aucun stagiaire inscrit.</li>
          {% endfor %}
        </ul>

        <h6 class="mt-4">Supports (Formation & Session)</h6>
        <div class="row g-2">
          {% for d in session.formation.supportDocuments ?? [] %}{% endfor %} {# si tu ajoutes relation inverse #}
          {# simple liste via assets #}
          {% set folder = asset('uploads/supports') %}
          <div id="supports-list"></div>
          <template id="tpl-item">
            <div class="col-12">
              <div class="d-flex justify-content-between align-items-center border rounded p-2">
                <div><i class="bi bi-file-earmark-text"></i> <span data-title></span></div>
                <a class="btn btn-sm btn-outline-secondary" data-href target="_blank">Ouvrir</a>
              </div>
            </div>
          </template>
        </div>

        <form id="upload-form" class="mt-3" enctype="multipart/form-data">
          <div class="row g-2 align-items-end">
            <div class="col-lg-6">
              <label class="form-label">Titre du document</label>
              <input name="titre" class="form-control" placeholder="Support de cours (PDF, PPTX, ZIP…)" />
            </div>
            <div class="col-lg-6">
              <input type="file" name="file" class="form-control" required>
            </div>
            <div class="col-12">
              <button class="btn btn-primary btn-sm"><i class="bi bi-cloud-upload"></i> Déposer</button>
              <small class="text-muted ms-2">Formats libres - taille max selon php.ini</small>
            </div>
          </div>
        </form>
        <div id="upload-status" class="small text-muted mt-2"></div>
      </div>
    </div>
  </div>


  

  <div class="col-12 col-xl-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <h5 class="mb-2">Émargement formateur</h5>
        <label class="form-label">Jour</label>



        {% for j in session.jours %}
          <input type="date" id="sign-date" class="form-control mb-2" value="{{ j.dateDebut|date('Y-m-d') }}" min="{{ j.dateDebut|date('Y-m-d') }}" max="{{ j.dateFin|date('Y-m-d') }}"/>

          <canvas id="pad" width="520" height="180" class="sign-pad w-100"></canvas>
          <div class="d-flex gap-2 mt-2">
            <button id="pad-clear" class="btn btn-sm btn-outline-secondary">Effacer</button>
            <button id="pad-save"  class="btn btn-sm btn-primary ms-auto"><i class="bi bi-pen"></i> Signer</button>
          </div>
          <div class="small text-muted mt-2" id="sign-status"></div>
        {% endfor %} 


        

        <hr class="my-3"/>
        <a class="btn btn-outline-success btn-sm" href="{{ path('app_formateur_emargement_export', {entite: entite.id, id: session.id}) }}"><i class="bi bi-filetype-csv"></i> Export CSV émargement</a>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/@fancyapps/ui/dist/fancybox.umd.js"></script>
<script src="https://cdn.jsdelivr.net/npm/signature_pad@5.0.4/dist/signature_pad.umd.min.js"></script>
<script>
  // Upload
  const form = document.getElementById('upload-form');
  const status = document.getElementById('upload-status');
  form.addEventListener('submit', async (e)=>{
    e.preventDefault();
    status.textContent = 'Envoi en cours…';
    const fd = new FormData(form);
    const res = await fetch('{{ path("app_formateur_supports_upload",{entite: entite.id, id: session.id}) }}', { method:'POST', body: fd });
    const json = await res.json();
    status.textContent = json.ok ? 'Document déposé.' : 'Erreur lors du dépôt.';
    if (json.ok) location.reload();
  });

  // Signature
  const canvas = document.getElementById('pad');
  const pad = new SignaturePad(canvas, { backgroundColor:'#fff', penColor:'#111' });
  document.getElementById('pad-clear').onclick = ()=> pad.clear();
  document.getElementById('pad-save').onclick = async ()=>{
    if (pad.isEmpty()) { alert('Merci de signer.'); return; }
    const fd = new FormData();
    fd.append('dataUrl', pad.toDataURL('image/png'));
    fd.append('date', document.getElementById('sign-date').value);
    const res = await fetch('{{ path("app_formateur_session_sign",{entite: entite.id, id: session.id}) }}', { method:'POST', body: fd });
    const json = await res.json();
    document.getElementById('sign-status').textContent = json.ok ? (json.already?'Déjà signé.':'Signature enregistrée.') : 'Erreur.';
  };

  function fixDpi(){
    const ratio = window.devicePixelRatio||1;
    const w=canvas.clientWidth, h=canvas.clientHeight;
    canvas.width=w*ratio; canvas.height=h*ratio; canvas.getContext('2d').scale(ratio,ratio); pad.clear();
  }
  window.addEventListener('resize', fixDpi); fixDpi();
</script>
{% endblock %}
