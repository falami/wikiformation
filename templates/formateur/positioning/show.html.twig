{# templates/formateur/positioning/show.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}Positionnement — {{ attempt.questionnaire.title }}{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }

    .p-hero{
      border-radius: 18px;
      background:
        radial-gradient(900px 280px at 10% 0%, rgba(255,255,255,.10), transparent 55%),
        radial-gradient(700px 240px at 90% 10%, rgba(255,193,7,.18), transparent 55%),
        linear-gradient(135deg, rgba(35,51,66,.98), rgba(35,51,66,.78));
      color:#fff;
      box-shadow: 0 18px 50px rgba(0,0,0,.14);
      overflow:hidden;
    }
    .meta-chip{
      display:inline-flex; align-items:center; gap:.45rem;
      padding:.35rem .65rem; border-radius:999px;
      background:rgba(255,255,255,.12);
      border:1px solid rgba(255,255,255,.14);
      font-size:.82rem;
      white-space:nowrap;
    }

    .grid-card{
      background:#fff;
      border-radius:18px;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 12px 30px rgba(0,0,0,.06);
      overflow:hidden;
    }
    .info-card{
      background:#fff;
      border-radius:18px;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 10px 26px rgba(0,0,0,.06);
      padding: 1rem;
    }

    .grid-wrap{ overflow:auto; }
    .grid-table{
      width:100%;
      border-collapse: separate;
      border-spacing: 0;
      min-width: 1050px;
    }

    .grid-table thead th{
      position: sticky;
      top: 0;
      z-index: 5;
      background: #f7f8fa;
      border-bottom: 1px solid rgba(0,0,0,.10);
      font-size:.78rem;
      text-transform: uppercase;
      letter-spacing: .06em;
      color: rgba(0,0,0,.60);
      padding: .65rem .75rem;
      text-align:center;
      vertical-align: middle;
      white-space: nowrap;
    }
    .grid-table thead th:first-child{
      text-align:left;
      min-width: 520px;
    }
    .grid-table tbody td{
      border-bottom: 1px solid rgba(0,0,0,.06);
      padding: .65rem .75rem;
      vertical-align: middle;
      background:#fff;
    }
    .grid-table tbody tr.row-item:nth-child(even) td{ background: rgba(35,51,66,.025); }
    .grid-table tbody tr.row-item:hover td{ background: rgba(255,193,7,.08); }

    .row-chapter td{
      background: #eef0f3 !important;
      border-bottom: 1px solid rgba(0,0,0,.10) !important;
      padding: .55rem .75rem !important;
    }
    .chapter-title{
      font-weight: 900;
      letter-spacing: -.01em;
      color: rgba(0,0,0,.78);
      font-size: 1rem;
      display:flex;
      align-items:center;
      gap:.55rem;
    }
    .chapter-badge{
      font-size:.75rem;
      padding:.25rem .55rem;
      border-radius:999px;
      border:1px solid rgba(0,0,0,.12);
      background: rgba(255,255,255,.65);
      color: rgba(0,0,0,.65);
      font-weight: 800;
    }
    .item-label{ font-weight: 700; color: rgba(0,0,0,.78); line-height: 1.15; white-space: normal; }
    .item-sub{ font-size: .85rem; color: rgba(0,0,0,.55); margin-top: .15rem; }
    .cell{ width: 44px; min-width: 44px; text-align:center; }

    .box{
      width: 28px; height: 28px;
      border-radius: 7px;
      border: 1px solid rgba(0,0,0,.22);
      background: rgba(0,0,0,.04);
      display:inline-flex; align-items:center; justify-content:center;
      box-shadow: inset 0 1px 0 rgba(255,255,255,.75);
      color: transparent;
      font-size: 1.05rem; line-height: 1;
    }
    .box.is-on{
      background: rgba(255,193,7,.22);
      border-color: rgba(255,193,7,.70);
      color: rgba(0,0,0,.82);
    }
    .h-ico{
      display:inline-flex; align-items:center; justify-content:center;
      width: 28px; height: 28px; border-radius: 10px;
      border:1px solid rgba(0,0,0,.10); background:#fff;
      font-size: 1.05rem;
    }
    .h-lbl{ font-size:.75rem; color: rgba(0,0,0,.60); margin-top:.25rem; }
  </style>
{% endblock %}

{% block body %}
<div class="container-fluid px-3">

  <div class="p-hero p-4 mb-3">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
      <div class="flex-grow-1">
        <div class="d-flex flex-wrap gap-2 mb-2">
          <span class="meta-chip"><i class="bi bi-person-badge"></i> Formateur</span>
          <span class="meta-chip"><i class="bi bi-clipboard-check"></i> Positionnement</span>
          <span class="meta-chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
          <span class="meta-chip"><i class="bi bi-person"></i>
            {{ attempt.stagiaire ? (attempt.stagiaire.nomComplet|default(attempt.stagiaire.email|default('—'))) : '—' }}
          </span>

          <span class="meta-chip">
            <i class="bi bi-collection"></i>
            Session :
            {% if attempt.session %}
              #{{ attempt.session.id }}
            {% elseif attempt.inscription and attempt.inscription.session %}
              #{{ attempt.inscription.session.id }}
            {% else %}
              Hors session
            {% endif %}
          </span>

          <span class="meta-chip">
            <i class="bi bi-send-check"></i>
            Soumis : {{ attempt.submittedAt ? attempt.submittedAt|date('d/m/Y H:i') : 'Non' }}
          </span>
        </div>

        <h2 class="fw-bold mb-1">{{ attempt.questionnaire ? attempt.questionnaire.title : '—' }}</h2>
        <div class="opacity-75">Réponses du stagiaire + saisie de ta conclusion</div>
      </div>

      <a class="btn btn-light btn-sm fw-semibold"
         href="{{ path('app_formateur_positioning_index', { entite: entite.id }) }}">
        <i class="bi bi-arrow-left"></i> Retour
      </a>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  {# ✅ Mapping (comme admin) #}
  {% set kMap = {
    'NONE':0, 'AUCUN':0, 'FAIBLE':0, 'DEBUTANT':0, 'LOW':0, '1':0, '0':0,
    'BASIC':1, 'BASE':1, 'MOYEN':1, 'INTERMEDIAIRE':1, 'MEDIUM':1, '2':1,
    'GOOD':2, 'BON':2, 'BIEN':2, 'ELEVEE':2, 'HIGH':2, '3':2,
    'ADVANCED':3, 'AVANCE':3, 'EXPERT':3, 'TRES_BON':3, '4':3
  } %}

  {% set iMap = {
    'YES':0, 'OUI':0, '1':0,
    'NO':1, 'NON':1, '0':1,
    'UNKNOWN':2, 'NE_SAIS_PAS':2, 'NSP':2, '2':2
  } %}

  {# ✅ regroupe en gardant l'ordre (answers déjà triés) #}
  {% set groups = [] %}
  {% set currentChapterId = null %}
  {% set current = null %}

  {% for ans in answers %}
    {% set ch = ans.item.chapter %}
    {% set chId = ch ? ch.id : 0 %}

    {% if currentChapterId != chId %}
      {% if current is not null %}
        {% set groups = groups|merge([current]) %}
      {% endif %}

      {% set currentChapterId = chId %}
      {% set current = { chapter: ch, answers: [], kSum:0, kCount:0, iYes:0, iNo:0, iUnk:0 } %}
    {% endif %}

    {% set current = current|merge({ answers: current.answers|merge([ans]) }) %}

    {% if ans.knowledge %}
      {% set kKey = (ans.knowledge.value ?? ans.knowledge)|upper %}
      {% if kMap[kKey] is defined %}
        {% set current = current|merge({ kSum: current.kSum + kMap[kKey], kCount: current.kCount + 1 }) %}
      {% endif %}
    {% endif %}

    {% if ans.interest %}
      {% set iKey = (ans.interest.value ?? ans.interest)|upper %}
      {% if iKey == 'YES' %}
        {% set current = current|merge({ iYes: current.iYes + 1 }) %}
      {% elseif iKey == 'NO' %}
        {% set current = current|merge({ iNo: current.iNo + 1 }) %}
      {% elseif iKey == 'UNKNOWN' %}
        {% set current = current|merge({ iUnk: current.iUnk + 1 }) %}
      {% endif %}
    {% endif %}
  {% endfor %}

  {% if current is not null %}
    {% set groups = groups|merge([current]) %}
  {% endif %}

  {# ✅ Réponses stagiaire #}
  <div class="grid-card mb-3">
    <div class="p-3 border-bottom" style="background: linear-gradient(180deg, rgba(0,0,0,.015), transparent);">
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <div class="fw-bold"><i class="bi bi-ui-checks"></i> Réponses du stagiaire</div>
        <div class="text-muted small">Chapitres + items (cases cochées)</div>
      </div>
    </div>

    <div class="grid-wrap">
      <table class="grid-table">
        <thead>
          <tr>
            <th>Compétence / item</th>

            <th colspan="4">
              <div class="fw-bold" style="text-transform:none; letter-spacing:0; font-size:.9rem;">Connaissance</div>
              <div class="d-flex justify-content-center gap-3 mt-2">
                <div class="text-center"><div class="h-ico">😶</div><div class="h-lbl">Aucun</div></div>
                <div class="text-center"><div class="h-ico">🙂</div><div class="h-lbl">Base</div></div>
                <div class="text-center"><div class="h-ico">😃</div><div class="h-lbl">Bon</div></div>
                <div class="text-center"><div class="h-ico">🤩</div><div class="h-lbl">Avancé</div></div>
              </div>
            </th>

            <th colspan="3">
              <div class="fw-bold" style="text-transform:none; letter-spacing:0; font-size:.9rem;">Intérêt à l’étudier</div>
              <div class="d-flex justify-content-center gap-3 mt-2">
                <div class="text-center"><div class="h-ico">✅</div><div class="h-lbl">Oui</div></div>
                <div class="text-center"><div class="h-ico">🚫</div><div class="h-lbl">Non</div></div>
                <div class="text-center"><div class="h-ico">❓</div><div class="h-lbl">NSP</div></div>
              </div>
            </th>
          </tr>
        </thead>

        <tbody>
        {% if answers|length == 0 %}
          <tr><td colspan="8" class="text-center text-muted py-4">Aucune réponse.</td></tr>
        {% else %}
          {% for g in groups %}
            {% set ch = g.chapter %}
            {% set chTitle = ch ? (ch.title|default(ch.label|default('Chapitre'))) : 'Sans chapitre' %}

            {% set total = g.answers|length %}
            {% set kAvg = (g.kCount > 0) ? (g.kSum / g.kCount) : null %}
            {% set yesPct = (total > 0) ? (g.iYes * 100 / total) : 0 %}
            {% set noPct  = (total > 0) ? (g.iNo  * 100 / total) : 0 %}
            {% set unkPct = (total > 0) ? (g.iUnk * 100 / total) : 0 %}

            <tr class="row-chapter">
              <td colspan="8">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                  <div class="chapter-title">
                    <i class="bi bi-folder2-open"></i>
                    {{ chTitle }}
                    <span class="chapter-badge">{{ total }} item(s)</span>
                  </div>

                  <div class="d-flex flex-wrap gap-2">
                    <span class="badge text-bg-light border">
                      <i class="bi bi-bar-chart-line"></i>
                      Connaissance moy :
                      <strong>
                        {% if kAvg is null %}—{% else %}{{ kAvg|number_format(2, ',', ' ') }} / 3{% endif %}
                      </strong>
                    </span>

                    <span class="badge text-bg-light border">✅ Oui <strong>{{ yesPct|number_format(0) }}%</strong></span>
                    <span class="badge text-bg-light border">🚫 Non <strong>{{ noPct|number_format(0) }}%</strong></span>
                    <span class="badge text-bg-light border">❓ NSP <strong>{{ unkPct|number_format(0) }}%</strong></span>
                  </div>
                </div>
              </td>
            </tr>

            {% for ans in g.answers %}
              {% set kRaw = ans.knowledge is not null ? (ans.knowledge.value ?? ans.knowledge) : '' %}
              {% set iRaw = ans.interest is not null ? (ans.interest.value ?? ans.interest) : '' %}
              {% set kKey = kRaw|upper %}
              {% set iKey = iRaw|upper %}

              {% set kIdx = (kKey and kMap[kKey] is defined) ? kMap[kKey] : null %}
              {% set iIdx = (iKey and iMap[iKey] is defined) ? iMap[iKey] : null %}

              <tr class="row-item">
                <td>
                  <div class="item-label">{{ ans.item.label }}</div>
                  <div class="item-sub">
                    Niveau : <strong>{{ ans.item.level }}</strong>
                    <span class="text-muted">— Position : {{ ans.item.position }}</span>
                  </div>
                </td>

                {% for idx in 0..3 %}
                  <td class="cell">
                    <span class="box {{ kIdx is not null and kIdx == idx ? 'is-on' : '' }}">
                      {% if kIdx is not null and kIdx == idx %}<i class="bi bi-check-lg"></i>{% endif %}
                    </span>
                  </td>
                {% endfor %}

                {% for idx in 0..2 %}
                  <td class="cell">
                    <span class="box {{ iIdx is not null and iIdx == idx ? 'is-on' : '' }}">
                      {% if iIdx is not null and iIdx == idx %}<i class="bi bi-check-lg"></i>{% endif %}
                    </span>
                  </td>
                {% endfor %}
              </tr>
            {% endfor %}
          {% endfor %}
        {% endif %}
        </tbody>
      </table>
    </div>
  </div>

  <div class="row g-3 mb-3">
    <div class="col-12 col-lg-6">
      <div class="info-card h-100">
        <div class="fw-bold mb-2"><i class="bi bi-chat-left-text"></i> Commentaire stagiaire</div>
        <div class="text-muted" style="white-space: pre-wrap;">{{ attempt.stagiaireComment ?: '—' }}</div>
      </div>
    </div>

    <div class="col-12 col-lg-6">
      <div class="info-card h-100">
        <div class="fw-bold mb-2"><i class="bi bi-mortarboard"></i> Conclusion formateur</div>

        {{ form_start(form) }}

          <div class="mb-3">
            {{ form_label(form.suggestedLevel, null, { label_attr: { class: 'form-label fw-bold' } }) }}
            {{ form_widget(form.suggestedLevel, { attr: { class: 'form-select' } }) }}
            {{ form_errors(form.suggestedLevel) }}
          </div>

          <div class="mb-3">
            {{ form_label(form.formateurConclusion, null, { label_attr: { class: 'form-label fw-bold' } }) }}
            {{ form_widget(form.formateurConclusion, { attr: { class: 'form-control', rows: 6 } }) }}
            {{ form_errors(form.formateurConclusion) }}
          </div>

          <button class="btn btn-warning fw-semibold">
            <i class="bi bi-save"></i> Enregistrer
          </button>

        {{ form_end(form) }}


      </div>
    </div>
  </div>

</div>
{% endblock %}
