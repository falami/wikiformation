{# templates/formateur/positioning/index.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}Positionnements — Formateur{% endblock %}

{% block stylesheets %}
  {{ parent() }}

  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/style-table.css') }}">
  <link rel="stylesheet" href="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.css"/>

  <style>
    :root {
        --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
        --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
        --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
        --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }

    /* ===== HERO ===== */
    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;

      /* Ombre douce premium */
      box-shadow: 0 18px 50px rgba(0,0,0,.14);

      /* Fond piloté par les couleurs de l'entité */
      background:
        /* halo clair (tertiaire) */
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        /* halo accent (secondaire) */
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        /* voile subtil (quaternaire) pour la profondeur */
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        /* dégradé principal (principal -> plus clair) */
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    /* léger glass highlight */
    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    /* barre accent = secondaire (et glow basé sur secondaire) */
    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }

    /* ===== Chips HERO (comme sessions) ===== */
    .hero .chip{
      display:inline-flex;
      align-items:center;
      gap:.5rem;
      padding:.32rem .7rem;
      border-radius: 999px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(255,255,255,.14);
      font-size:.82rem;
      color: rgba(255,255,255,.92);
      backdrop-filter: blur(6px);
      white-space: nowrap;
    }
    .hero .chip i{ color: var(--theme-color-secondaire); }

    .hero .chip--pill{
      background: color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
      border-color: color-mix(in srgb, var(--theme-color-secondaire) 28%, rgba(255,255,255,.14));
      color:#fff;
    }

    .hero .btn{
      border-radius: 14px;
      font-weight: 800;
    }
    .hero .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .hero .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }

    /* ===== KPI ===== */
    .kpi-card{
      border: 1px solid rgba(0,0,0,.06);
      box-shadow: 0 10px 26px rgba(0,0,0,.06);
      border-radius: 18px;
      overflow:hidden;
      background:#fff;
    }
    
    .kpi-label{ color: rgba(0,0,0,.55); font-size:.85rem }
    .kpi-value{ font-weight:800; font-size:1.6rem; letter-spacing:-.02em }
    .kpi-sub{ color: rgba(0,0,0,.50); font-size:.82rem }

    /* ===== Filterbar (same as sessions) ===== */
    .filterbar{
      background:#fff;
      border-radius:18px;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 10px 24px rgba(0,0,0,.05);
      overflow: visible;
    }
    .filterbar__top{
      padding: .9rem 1rem;
      border-bottom:1px solid rgba(0,0,0,.06);
      background: linear-gradient(180deg, rgba(0,0,0,.015), transparent);
      display:flex;
      align-items:center;
      gap:.75rem;
    }
    .filterbar__title{ font-weight:800; letter-spacing:-.01em; margin:0; font-size:1rem; }
    .filterbar__hint{ color: rgba(0,0,0,.55); font-size:.85rem; margin-left:.25rem; }
    .filterbar__body{ padding: 1rem; }

    .filtergrid{
      display:grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: .75rem;
      align-items:end;
    }
    .fcol-stagiaire{ grid-column: span 7; }
    .fcol-conclusion{ grid-column: span 4; }
    .fcol-actions{ grid-column: span 1; }

    @media (max-width: 1200px){
      .fcol-stagiaire{ grid-column: span 6; }
      .fcol-conclusion{ grid-column: span 6; }
      .fcol-actions{ grid-column: span 12; }
    }
    @media (max-width: 768px){
      .filterbar__body{ padding:.85rem; }
      .fcol-stagiaire,.fcol-conclusion,.fcol-actions{ grid-column: span 12; }
      .hero{ border-radius:16px; }
    }

    .filter-control .form-label{
      font-size:.78rem;
      font-weight:700;
      color: rgba(0,0,0,.55);
      text-transform:uppercase;
      letter-spacing:.06em;
      margin-bottom:.25rem;
    }
    .filterbox{
      border:1px solid rgba(0,0,0,.08);
      border-radius:14px;
      padding:.55rem .6rem;
      background:#fff;
      box-shadow: 0 8px 18px rgba(0,0,0,.04);
    }
    .filterbox:focus-within{
      border-color: rgba(255,193,7,.55);
      box-shadow: 0 0 0 .2rem rgba(255,193,7,.18), 0 10px 18px rgba(0,0,0,.06);
    }
    .filterrow{ display:flex; gap:.6rem; align-items:center; }
    .kpi-ico{
      width:44px; height:44px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }

    .filter-icon{
      width:38px; height:38px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }
    .filterbox .form-select,
    .filterbox .form-control{
      border:0 !important;
      box-shadow:none !important;
      padding-left:0 !important;
      padding-right:0 !important;
      background:transparent !important;
    }

    /* Reset (same as sessions) */
    .resetbox{
      border:1px solid rgba(0,0,0,.08);
      border-radius:14px;
      padding:.55rem .6rem;
      background:#fff;
      box-shadow:0 8px 18px rgba(0,0,0,.04);
      cursor:pointer;
      user-select:none;
      transition: all .16s ease;
      width: 100%;
      display:flex;
      align-items:center;
      justify-content:center;
    }
    .resetbox:hover{
      border-color: rgba(0,0,0,.14);
      box-shadow: 0 10px 20px rgba(0,0,0,.06);
      transform: translateY(-1px);
    }
    .resetbox:focus,
    .resetbox:focus-visible{
      outline: none;
      border-color: rgba(255,193,7,.55);
      box-shadow: 0 0 0 .2rem rgba(255,193,7,.18), 0 10px 18px rgba(0,0,0,.06);
    }
    .resetbox.is-active{
      border-color: rgba(255,193,7,.35);
      background: rgba(255,193,7,.06);
    }
    .resetbox:disabled{ cursor: default; opacity: .55; transform:none; }
    .resetbox__text{ font-size:.9rem; font-weight:800; color: rgba(0,0,0,.65); }
    .resetbox__badge{
      min-width: 28px;
      height: 22px;
      padding: 0 .5rem;
      border-radius: 999px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      font-size:.78rem;
      font-weight:800;
      background: rgba(0,0,0,.06);
      color: rgba(0,0,0,.65);
      border: 1px solid rgba(0,0,0,.08);
      margin-left:.5rem;
    }
    .resetbox.is-active .resetbox__badge{
      background: rgba(255,193,7,.22);
      border-color: rgba(255,193,7,.30);
      color: rgba(0,0,0,.75);
    }

    .active-filters{
      padding: .65rem 1rem;
      border-top:1px solid rgba(0,0,0,.06);
      background:#fff;
      display:flex;
      align-items:center;
      gap:.5rem;
      flex-wrap:wrap;
    }
    .active-filters .label{
      font-size:.8rem;
      color: rgba(0,0,0,.55);
      font-weight:800;
      margin-right:.25rem;
    }
    .af-badge{
      display:inline-flex;
      align-items:center;
      gap:.35rem;
      border-radius:999px;
      padding:.35rem .6rem;
      border:1px solid rgba(0,0,0,.08);
      background: rgba(0,0,0,.03);
      font-size:.82rem;
      cursor:pointer;
      user-select:none;
    }
    .af-badge:hover{ background: rgba(255,193,7,.12); border-color: rgba(255,193,7,.25); }
    .af-badge i{ opacity:.7; }

    /* ===== Table card + DT ===== */
    .table-card{
      background:#fff;
      border-radius:18px;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 12px 30px rgba(0,0,0,.06);
      overflow: visible;
    }
    table.dataTable thead th{
      background:#f7f8fa!important;
      border-bottom:1px solid rgba(0,0,0,.08)!important;
      font-size:.78rem;
      text-transform:uppercase;
      letter-spacing:.05em;
      color: rgba(0,0,0,.55);
      text-align:center !important;
      vertical-align: middle;
    }
    #tableauAttempts tbody td{
      padding-top:.65rem!important;
      padding-bottom:.65rem!important;
      vertical-align: middle;
      text-align:center !important;
    }
    #tableauAttempts tbody tr:nth-child(even) > *{ background:rgba(35,51,66,.035)!important; }
    #tableauAttempts tbody tr:hover > *{ background:rgba(255,193,7,.08)!important; }

    #tableauAttempts td.action-column{
      overflow: visible !important;
      position: relative;
      white-space: nowrap !important;
      min-width: 130px;
      text-align:right !important;
    }

    /* Hover actions (same spirit as sessions) */
    #tableauAttempts td.action-column .hover-actions{
      opacity:0;
      visibility:hidden;
      transform: translateY(2px);
      transition: opacity .15s ease, transform .15s ease, visibility .15s;
    }
    #tableauAttempts tbody tr:hover td.action-column .hover-actions,
    #tableauAttempts td.action-column:focus-within .hover-actions{
      opacity:1;
      visibility:visible;
      transform:none;
    }
    @media (hover: none){
      #tableauAttempts td.action-column .hover-actions{ opacity:1; visibility:visible; transform:none; }
    }

    @media (max-width:768px){
      #tableauAttempts td.action-column{
        position:sticky;
        right:0;
        background:#fff !important;
        box-shadow:-12px 0 18px -14px rgba(0,0,0,.22);
        z-index:5;
      }
    }


    /* Conclusion badges */
.badge-soft{
  border:1px solid rgba(0,0,0,.10);
  border-radius:999px;
  padding:.25rem .55rem;
  font-weight:800;
  font-size:.8rem;
  display:inline-flex;
  align-items:center;
  gap:.35rem;
}

.badge-soft.badge-done{
  background: rgba(25,135,84,.12);     /* success */
  border-color: rgba(25,135,84,.35);
  color: #146c43;
}
.badge-soft.badge-todo{
  background: rgba(220,53,69,.12);     /* danger */
  border-color: rgba(220,53,69,.35);
  color: #b02a37;
}

  </style>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
  <script src="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.js"></script>
{% endblock %}

{% block body %}

  {# ===== HERO (comme sessions) ===== #}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>

    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-ui-checks me-2" style="color:var(--theme-color-secondaire)"></i>
            Positionnements
          </h2>
          <div class="opacity-75 mt-1">Positionnements soumis qui te sont affectés.</div>

          <div class="d-flex flex-wrap gap-2 mt-3">
            <span class="chip"><i class="bi bi-person-badge"></i> Formateur</span>
            <span class="chip"><i class="bi bi-ui-checks"></i> Positionnements</span>
            <span class="chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
            <span class="chip chip--pill"><i class="bi bi-clock-history"></i> <span id="hero-last-refresh">—</span></span>
          </div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
          <a class="btn btn-outline-theme btn-sm fw-semibold"
            href="{{ path('app_formateur_dashboard', { entite: entite.id }) }}">
            <i class="bi bi-arrow-left me-1"></i> Tableau de bord
          </a>

          <div class="dropdown">
            <button class="btn btn-warning btn-sm fw-semibold dropdown-toggle" data-bs-toggle="dropdown">
              <i class="bi bi-download"></i> Export
            </button>
            <ul class="dropdown-menu dropdown-menu-end" id="exportMenu"></ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  {# KPI #}
  <div class="row g-3 mb-3">
    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100"><div class="p-3">
        <div class="d-flex align-items-center gap-3">
          <div class="kpi-ico"><i class="bi bi-inboxes fs-4"></i></div>
          <div class="flex-grow-1">
            <div class="kpi-label">Positionnements</div>
            <div class="kpi-value" id="kpi-count">—</div>
            <div class="kpi-sub">Dans la liste</div>
          </div>
        </div>
      </div></div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100"><div class="p-3">
        <div class="d-flex align-items-center gap-3">
          <div class="kpi-ico"><i class="bi bi-pencil-square fs-4"></i></div>
          <div class="flex-grow-1">
            <div class="kpi-label">Conclusion</div>
            <div class="kpi-value" id="kpi-todo">—</div>
            <div class="kpi-sub">À faire</div>
          </div>
        </div>
      </div></div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100"><div class="p-3">
        <div class="d-flex align-items-center gap-3">
          <div class="kpi-ico"><i class="bi bi-check2-circle fs-4"></i></div>
          <div class="flex-grow-1">
            <div class="kpi-label">Conclusion</div>
            <div class="kpi-value" id="kpi-done">—</div>
            <div class="kpi-sub">Rédigée</div>
          </div>
        </div>
      </div></div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100"><div class="p-3">
        <div class="d-flex align-items-center gap-3">
          <div class="kpi-ico"><i class="bi bi-funnel fs-4"></i></div>
          <div class="flex-grow-1">
            <div class="kpi-label">Filtres</div>
            <div class="kpi-value" id="kpi-filters">0</div>
            <div class="kpi-sub">Actifs</div>
          </div>
        </div>
      </div></div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  <div class="filterbar mb-3">
    <div class="filterbar__top">
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <div class="filter-icon"><i class="bi bi-funnel"></i></div>
        <div>
          <div class="filterbar__title">Filtres</div>
          <div class="filterbar__hint">Stagiaire, conclusion…</div>
        </div>
      </div>

      <div class="ms-auto d-flex gap-2 align-items-center">
        <button class="btn btn-outline-secondary btn-sm fw-semibold d-md-none"
                type="button" data-bs-toggle="collapse" data-bs-target="#filtersCollapse">
          <i class="bi bi-sliders"></i> Filtres
        </button>
      </div>
    </div>

    <div class="collapse d-md-block" id="filtersCollapse">
      <div class="filterbar__body">
        <div class="filtergrid">

          <div class="filter-control fcol-stagiaire">
            <div class="form-label">Stagiaire</div>
            <div class="filterbox">
              <div class="filterrow">
                <div class="filter-icon"><i class="bi bi-person"></i></div>
                <input id="stagiaireFilter" class="form-control form-control-sm" placeholder="Nom / prénom / email">
              </div>
            </div>
          </div>

          <div class="filter-control fcol-conclusion">
            <div class="form-label">Conclusion</div>
            <div class="filterbox">
              <div class="filterrow">
                <div class="filter-icon"><i class="bi bi-card-text"></i></div>
                <select id="conclusionFilter" class="form-select form-select-sm">
                  <option value="all">Toutes</option>
                  <option value="todo">À faire</option>
                  <option value="done">Rédigée</option>
                </select>
              </div>
            </div>
          </div>

          <div class="filter-control fcol-actions">
            <div class="form-label">&nbsp;</div>
            <button id="btnReset" type="button" class="resetbox" title="Réinitialiser les filtres">
              <i class="bi bi-arrow-counterclockwise me-2"></i>
              <span class="resetbox__text">Reset</span>
              <span class="resetbox__badge" id="resetCount" style="display:none;">0</span>
            </button>
          </div>

        </div>
      </div>

      <div class="active-filters" id="activeFilters">
        <span class="label"><i class="bi bi-lightning-charge"></i> Actifs :</span>
        <span class="text-muted small" id="activeFiltersEmpty">Aucun</span>
      </div>
    </div>
  </div>

  <div class="table-card mb-4 p-3">
    <table id="tableauAttempts" class="table table-hover align-middle mb-0 w-100">
      <thead>
        <tr>
          <th>Stagiaire</th>
          <th>Questionnaire</th>
          <th>Session</th>
          <th>Soumis</th>
          <th>Conclusion</th>
          <th class="text-end"></th>
        </tr>
      </thead>
      <tbody></tbody>
    </table>
  </div>


<script>
$(function(){
  const $stagiaire = $('#stagiaireFilter');
  const $conclu    = $('#conclusionFilter');

  function nowLabel(){
    const d = new Date();
    return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
  }

  function updateResetUi(count){
    const btn = document.getElementById('btnReset');
    const badge = document.getElementById('resetCount');
    if(!btn || !badge) return;

    $('#kpi-filters').text(String(count));

    if(count > 0){
      btn.disabled = false;
      btn.classList.add('is-active');
      badge.style.display = 'inline-flex';
      badge.textContent = String(count);
    } else {
      btn.disabled = true;
      btn.classList.remove('is-active');
      badge.style.display = 'none';
      badge.textContent = '0';
    }
  }

  function buildActiveFilters(){
    const items = [];

    const st = ($stagiaire.val() || '').trim();
    if(st) items.push({ key:'stagiaire', label:'Stagiaire', value: st });

    const c = $conclu.val();
    if(c && c !== 'all') items.push({ key:'conclusion', label:'Conclusion', value: $('#conclusionFilter option:selected').text() });

    const $wrap = $('#activeFilters');
    $wrap.find('.af-badge').remove();

    if(items.length === 0){
      $('#activeFiltersEmpty').show();
      updateResetUi(0);
      return;
    }

    $('#activeFiltersEmpty').hide();
    updateResetUi(items.length);

    items.forEach(it=>{
      const $b = $(`<span class="af-badge" data-key="${it.key}">
        <strong>${it.label} :</strong> ${it.value} <i class="bi bi-x-lg ms-1"></i>
      </span>`);

      $b.on('click', ()=>{
        switch(it.key){
          case 'stagiaire': $stagiaire.val(''); break;
          case 'conclusion': $conclu.val('all'); break;
        }
        refreshAll(true);
      });

      $wrap.append($b);
    });
  }

  const table = $('#tableauAttempts').DataTable({
    serverSide: true,
    processing: true,
    autoWidth: true,
    scrollX: true,
    scrollCollapse: true,
    responsive: false,

    ajax:{
      url:"{{ path('app_formateur_positioning_ajax', { entite: entite.id }) }}",
      type:"POST",
      data: d => {
        d.stagiaireFilter  = $stagiaire.val() || '';
        d.conclusionFilter = $conclu.val() || 'all';
      }
    },

    dom:
      '<"dt-top d-flex flex-wrap gap-2 align-items-center justify-content-between"'
        + '<"dt-actions d-flex gap-2 align-items-center"B>'
        + '<"dt-search"f>'
      + '>'
      + 'rt'
      + '<"dt-bottom-internal d-flex flex-wrap gap-2 align-items-center justify-content-between"lip>',

    buttons:['copy','csv','excel','pdf','print'],
    lengthMenu:[[10,25,50,500],[10,25,50,500]],

    columns:[
      {data:'stagiaire'},
      {data:'questionnaire'},
      {data:'session', orderable:false, searchable:false},
      {data:'submittedAt'},
      {data:'conclusion', orderable:false, searchable:false},
      {data:'actions', orderable:false, searchable:false}
    ],

    columnDefs:[
      {targets: 5, className:'action-column text-end', orderable:false, searchable:false},
      {targets: [2,3,4], className:'text-center'},
    ],

    order:[[3,'desc']],
    language:{ url:'https://cdn.datatables.net/plug-ins/2.2.2/i18n/fr-FR.json' },

    initComplete:function(){
      const api = this.api();
      const $btns = $(api.buttons().container()).find('button');

      $('#exportMenu').empty();
      $btns.each(function(){
        const $b=$(this);
        $('<li><a class="dropdown-item" href="#">'+$b.text()+'</a></li>')
          .on('click',e=>{e.preventDefault();$b.click();})
          .appendTo('#exportMenu');
      });
      $(api.buttons().container()).hide();
      api.columns.adjust();
    }
  });

  // KPI live from ajax payload (recordsFiltered + scan current page for todo/done)
  table.on('xhr.dt', function(e, settings, json){
    $('#kpi-count').text(json?.recordsFiltered ?? json?.recordsTotal ?? '—');
    $('#hero-last-refresh').text('Maj : ' + nowLabel());
  });

  table.on('draw.dt', function(){
    // calc todo/done from displayed rows (best-effort)
    let todo = 0, done = 0;
    $('#tableauAttempts tbody tr').each(function(){
      const html = $(this).find('td').eq(4).html() || '';
      if(html.includes('badge-todo')) todo++;
      if(html.includes('badge-done')) done++;
    });
    $('#kpi-todo').text(todo);
    $('#kpi-done').text(done);


    table.columns.adjust();
  });

  function refreshAll(resetPaging=false){
    table.ajax.reload(null, resetPaging ? true : false);
    buildActiveFilters();
  }

  let t=null;
  $stagiaire.on('input', ()=>{
    clearTimeout(t);
    t=setTimeout(()=>refreshAll(true), 250);
  });
  $conclu.on('change', ()=>refreshAll(true));

  $('#btnReset').on('click', function(){
    $stagiaire.val('');
    $conclu.val('all');
    table.search('');
    refreshAll(true);
  });

  buildActiveFilters();
  $('#hero-last-refresh').text('Maj : ' + nowLabel());
});
</script>
{% endblock %}
