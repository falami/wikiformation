        <div class="card-header d-flex align-items-center justify-content-between px-3 py-3">
          <h5 class="section-title mb-0">Ma bibliothèque (aperçu rapide)</h5>
          <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_formateur_supports_library', { entite: entite.id }) }}"><i class="bi bi-box-arrow-up-right"></i> Ouvrir</a>
        </div>
        <div class="card-body p-4">
          <div id="assets-list" class="row g-3"></div>
