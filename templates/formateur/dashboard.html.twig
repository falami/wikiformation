<script>
// Locale FR FullCalendar (fallback)
(function(){
  const FC=(window.FullCalendar=window.FullCalendar||{});
  FC.globalLocales=FC.globalLocales||[];
  if(!FC.globalLocales.some(l=>l.code==='fr')){
    FC.globalLocales.push({
      code:'fr',
      buttonText:{prev:'Préc.',next:'Suiv.',today:'Aujourd’hui',year:'Année',month:'Mois',week:'Semaine',day:'Jour',list:'Liste'},
      weekText:'Sem.',allDayText:'Toute la journée',moreLinkText:'en plus',noEventsText:'Aucun évènement à afficher',
      week:{dow:1,doy:4}
    });
  }
})();
</script>

<script>
$(function(){

  /* ===== helpers ===== */
  function escapeHtml(s){return String(s||'').replace(/[&<>"']/g, m=>({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[m]));}
  function stripHtml(html){ return String(html||'').replace(/<[^>]+>/g,'').trim(); }
  function pad(n){ return n<10?('0'+n):n; }

  const toFr = (ymd)=>{
    if(!ymd) return '';
    if(ymd.includes('/')) return ymd;
    const [Y,M,D]=ymd.split('-').map(n=>parseInt(n,10));
    return pad(D)+'/'+pad(M)+'/'+Y;
  };

  /* ===== Sélection session courante (pour bouton appréciation) ===== */
  let CURRENT_SESSION_ID = null;
  function syncSatisfactionBtn(){
    const btn = document.getElementById('btnOpenSatisfaction');
    if(!btn) return;
    if(!CURRENT_SESSION_ID){
      btn.disabled = true;
      btn.title = 'Sélectionnez une session pour laisser votre appréciation';
      return;
    }
    btn.disabled = false;
    btn.title = 'Laisser / modifier mon appréciation pour cette session';
  }

  

  /* ===== DataTables : mes sessions ===== */
  const dt = $('#table-formateur').DataTable({
    scrollX: true,
    autoWidth: false,
    responsive: false,
  
    ajax:{ url:"{{ path('app_formateur_dashboard_sessions_ajax', { entite: entite.id }) }}", type:'POST' },
    columns:[
      {data:'code'},
      {data:'formation'},
      {data:'dates'},
      {data:'inscrits', className:'text-center', render:d => '<span class="status-pill"><i class="bi bi-people-fill me-1"></i>'+ (d ?? 0) +'</span>'},
      {
        data: 'actions',
        className: 'text-center',
        render: function(d, type, row){
          const raw = (d || '').trim();
          if(!raw) return '';

          const key = String(row.code || row.sessionId || row.id || '')
            .replace(/\W+/g,'_') || Math.random().toString(16).slice(2);

          const menuId = 'act_' + key;

          return `
            <div class="actions-wrap">
              <div class="dropdown action-dd">
                <button class="btn btn-action btn-sm dropdown-toggle" type="button"
                  id="${menuId}"
                  data-bs-toggle="dropdown"
                  data-bs-boundary="viewport"
                  data-bs-display="static"
                  aria-expanded="false">
                  <i class="bi bi-three-dots-vertical"></i> Actions
                </button>

                <div class="dropdown-menu dropdown-menu-end" aria-labelledby="${menuId}">
                  <div class="dd-head">
                    <div class="t"><i class="bi bi-lightning-charge me-1"></i> Actions</div>
                  </div>
                  ${raw}
                </div>
              </div>
            </div>
          `;
        }
      },

      {data:'firstStartIso', visible:false, searchable:false},
      {data:'lastEndIso', visible:false, searchable:false},
    ],
    order:[[5,'desc']],
    pageLength:10,
    language: { url:'https://cdn.datatables.net/plug-ins/2.3.4/i18n/fr-FR.json' },
    drawCallback:function(){
      computeKpisFromTable(this.api());
      buildTimelineFromTable(this.api(), '#upcoming-timeline', 6);
    },
  });

  $('#searchAll').on('input', function(){ dt.search(this.value).draw(); });

  $('#btnExportTable').on('click', function(){
    const rows = dt.rows({search:'applied'}).data().toArray();
    const header = ['Code','Formation','Dates','Inscrits'];
    const lines = [header.join(';')].concat(
      rows.map(r => [r.code, stripHtml(r.formation), stripHtml(r.dates), r.inscrits]
        .map(v => '"'+String(v ?? '').replaceAll('"','""')+'"').join(';'))
    );
    const blob = new Blob([lines.join('\n')], {type:'text/csv;charset=utf-8;'});
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href=url; a.download='sessions_formateur.csv'; a.click();
    URL.revokeObjectURL(url);
  });

  /* ===== KPIs ===== */
  function computeKpisFromTable(api){
    const data = api.rows({search:'applied'}).data().toArray();
    const now = new Date();

    let upcoming=0, live=0, trainees=0;

    data.forEach(row=>{
      const startIso = row.firstStartIso;
      const endIso   = row.lastEndIso;

      if(startIso && endIso){
        const start = new Date(startIso);
        const end   = new Date(endIso);

        if(now < start) upcoming++;
        else if(now >= start && now <= end) live++;
      }

      const n = parseInt(row.inscrits || 0, 10);
      if(!isNaN(n)) trainees += n;
    });

    $('#kpi-upcoming').text(upcoming);
    $('#kpi-live').text(live);
    $('#kpi-trainees').text(trainees);
  }


  /* ===== Timeline ===== */
  function buildTimelineFromTable(api, selector, maxItems){
    const data = api.rows().data().toArray();
    const now = new Date();

    const items = data
      .filter(r => r.firstStartIso)
      .map(r => {
        const start = new Date(r.firstStartIso);
        return {
          whenDate: start,
          when: start.toLocaleString('fr-FR', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }),
          what: `${stripHtml(r.formation)} (${r.code||''})`,
        };
      })
      .filter(it => it.whenDate > now)
      .sort((a,b)=> a.whenDate - b.whenDate);

    const ul = document.querySelector(selector);
    ul.innerHTML = '';

    if(items.length === 0){
      ul.innerHTML = '<li><span class="dot"></span><span class="when">-</span><span class="what">Aucun évènement à venir.</span></li>';
      return;
    }

    items.slice(0, maxItems || 6).forEach(it=>{
      const li = document.createElement('li');
      li.innerHTML = `<span class="dot"></span><span class="when">${it.when}</span><span class="what">${escapeHtml(it.what)}</span>`;
      ul.appendChild(li);
    });
  }


  /* ===== FullCalendar ===== */
  const calendar = new FullCalendar.Calendar(document.getElementById('calendar'), {
    locale:'fr', height:'auto', initialView:'dayGridMonth',
    headerToolbar:{ left:'prev,next today', center:'title', right:'dayGridMonth,timeGridWeek,listWeek' },
    events: "{{ path('app_formateur_calendar_feed', { entite: entite.id }) }}",
    eventDidMount: (info)=>{ info.el.style.borderRadius = '.6rem'; info.el.style.boxShadow = '0 8px 20px rgba(0,0,0,.08)'; },
    eventClick: (info) => {
      info.jsEvent?.preventDefault();
      const sid = info.event.extendedProps?.sessionId || info.event.id;
      const ymd = (info.event.startStr || '').slice(0,10);
      window.__openEma?.({ sessionId: sid, sessionLabel: info.event.title || 'Session', date: ymd });
    }
  });
  calendar.render();

  /* ===== Supports (aperçu) ===== */
  fetch("{{ path('app_formateur_supports_assets_feed', { entite: entite.id }) }}")
    .then(r=>r.json()).then(payload=>{
      const all = (payload?.data||[]);
      $('#kpi-files').text(all.length || 0);

      const rows = all.slice(0,8);
      const wrap = document.getElementById('assets-list'); wrap.innerHTML='';
      if(rows.length===0){
        wrap.innerHTML = '<div class="text-muted">Aucun support dans votre bibliothèque pour le moment.</div>';
        return;
      }
      rows.forEach(a=>{
        const col = document.createElement('div'); col.className = 'col-12 col-md-6 col-xxl-3';
        col.innerHTML = `
          <div class="asset-item">
            <div class="asset-icon"><i class="bi bi-file-earmark-text-fill"></i></div>
            <div class="flex-grow-1 text-truncate">
              <div class="asset-name" title="${escapeHtml(a.originalName || a.titre || '')}">${escapeHtml(a.titre || a.originalName || 'Document')}</div>
              <div class="asset-meta">${escapeHtml(a.mimeType || '')} · ${escapeHtml(a.uploadedAt || '')}</div>
            </div>
            <a class="btn btn-sm btn-outline-secondary" href="${a.url}" target="_blank" title="Télécharger"><i class="bi bi-download"></i></a>
          </div>`;
        wrap.appendChild(col);
      });
    });

  /* ===== Backdrops z-index helper (propre, pas en double) ===== */
  function tagLastBackdrop(className){
    const bds = document.querySelectorAll('.modal-backdrop');
    const last = bds[bds.length - 1];
    if(last) last.classList.add(className);
  }
  document.getElementById('emargementModal')?.addEventListener('shown.bs.modal', () => tagLastBackdrop('emargement-backdrop'));
  document.getElementById('signatureModal')?.addEventListener('shown.bs.modal', () => tagLastBackdrop('signature-backdrop'));
  document.getElementById('sigPreviewModal')?.addEventListener('shown.bs.modal', () => tagLastBackdrop('preview-backdrop'));

  /* ===== Émargements (formateur) ===== */
  let STATE = {
    sessionId: null,
    sessionLabel: '-',
    date: (new Date()).toISOString().slice(0,10),
    rows: [],
    autoPeriode: null, // ✅
    outOfSession: false
  };


  function setHeader(){
    $('#ema-date').text(toFr(STATE.date));
    $('#ema-session').text(STATE.sessionLabel||'-');

    if (__fpEma) {
      __fpEma.setDate(STATE.date, false); // n’appelle pas onChange
    } else {
      $('#ema-date-input').val(STATE.date);
    }
  }


  function viewBtn(url, at){
    if(!url) return '';
    const safeAt = at ? escapeHtml(at) : '';
    return `
      <button type="button" class="btn btn-mini btn-outline-secondary js-view-sig"
              data-url="${escapeHtml(url)}" data-at="${safeAt}">
        <i class="bi bi-eye"></i>
      </button>`;
  }

  function cellTrainer(info, periode){
    if(!info?.signed){
      return `<div class="ema-actioncell">
        <button class="btn btn-mini btn-outline-success js-open-sign" data-periode="${periode}">
          <i class="bi bi-pencil"></i> Signer
        </button>
      </div>`;
    }
    return `<div class="ema-actioncell">
      <span class="pill-success"><i class="bi bi-check2-circle"></i> Signé</span>
      ${viewBtn(info.url, info.at)}
      <button class="btn btn-mini btn-outline-danger js-unsign" data-periode="${periode}">
        <i class="bi bi-trash"></i>
      </button>
    </div>`;
  }

  function cellReadonly(info){
    if(!info?.signed){
      return `<div class="ema-actioncell"><span class="badge bg-secondary-subtle text-secondary">Non signé</span></div>`;
    }
    return `<div class="ema-actioncell">
      <span class="pill-success"><i class="bi bi-check2-circle"></i> Signé</span>
      ${viewBtn(info.url, info.at)}
    </div>`;
  }

  function renderEma(){
    if (STATE.outOfSession) {
      $('#ema-tbody').html(`
        <tr>
          <td colspan="3" class="text-center text-muted py-4">
            <i class="bi bi-info-circle me-1"></i>
            Aucun émargement à faire pour cette date.
          </td>
        </tr>
      `);
      return;
    }

    const rows = STATE.rows || [];
    if(rows.length===0){
      $('#ema-tbody').html('<tr><td colspan="3" class="text-center text-muted py-4">Aucune ligne.</td></tr>');
      return;
    }

    const html = rows.map(r=>{
      const badge = r.isTrainer ? ' <span class="badge-trainer">Formateur</span>' : '';
      const am = r.am || {signed:false}, pm = r.pm || {signed:false};

      return `
        <tr>
          <td><strong>${escapeHtml(r.name||'-')}</strong>${badge}</td>
          <td class="text-center">${r.isTrainer ? cellTrainer(am,'AM') : cellReadonly(am)}</td>
          <td class="text-center">${r.isTrainer ? cellTrainer(pm,'PM') : cellReadonly(pm)}</td>
        </tr>
      `;
    }).join('');

    $('#ema-tbody').html(html);
  }


  function buildRows(payload){
    const out = [];

    if(payload?.trainer){
      out.push({
        isTrainer:true,
        name: payload.trainer.name || 'Moi',
        am: { signed: !!payload.trainer.signed_am, url: payload.trainer.signature_am_url || null, at: payload.trainer.signed_at_am || null },
        pm: { signed: !!payload.trainer.signed_pm, url: payload.trainer.signature_pm_url || null, at: payload.trainer.signed_at_pm || null }
      });
    }

    (payload?.trainees || []).forEach(t=>{
      out.push({
        isTrainer:false,
        name: t.name || 'Stagiaire',
        am: { signed: !!t.signed_am, url: t.signature_am_url || null, at: t.signed_at_am || null },
        pm: { signed: !!t.signed_pm, url: t.signature_pm_url || null, at: t.signed_at_pm || null }
      });
    });

    return out;
  }


  function loadEma(){
    $('#ema-tbody').html('<tr><td colspan="3" class="text-center text-muted py-4">⏳ Chargement…</td></tr>');

    const url = "{{ path('app_formateur_emargement_feed', { entite: entite.id }) }}"
              + "?session="+encodeURIComponent(STATE.sessionId)
              + "&date="+encodeURIComponent(STATE.date);

    return fetch(url, { headers:{'Accept':'application/json'} })
      .then(r => r.json())
      .then(j => {
        if(j?.error){
          $('#ema-tbody').html(`<tr><td colspan="3" class="text-center text-danger py-4">${escapeHtml(j.error)}</td></tr>`);
          return;
        }

        STATE.outOfSession = !!j.outOfSession;

        if (j?.allowedDays && __fpEma) {
          // ✅ n'autorise que les jours de formation
          __fpEma.set('enable', j.allowedDays);

          // si la date courante n'est pas autorisée, on ne force pas forcément,
          // mais tu peux choisir de la remettre sur le 1er jour :
          if (STATE.outOfSession && j.allowedDays.length) {
            // optionnel : auto-repositionner sur le 1er jour valide
            // STATE.date = j.allowedDays[0];
            // __fpEma.setDate(STATE.date, true);
          }
        }

        if (j?.sessionLabel) STATE.sessionLabel = j.sessionLabel;
        setHeader();

        STATE.rows = buildRows(j); // sera vide si outOfSession
        renderEma();
      })

      .catch(e=>{
        console.error(e);
        $('#ema-tbody').html('<tr><td colspan="3" class="text-center text-danger py-4">Erreur de chargement</td></tr>');
      });
  }

  /* ===== Flatpickr (ema date) ===== */
  let __fpEma = null;
  function initEmaDatepicker(){
    const input = document.getElementById('ema-date-input');
    if(!input || typeof flatpickr !== 'function') return;

    if(__fpEma){ try{ __fpEma.destroy(); }catch(e){} __fpEma=null; }

    __fpEma = flatpickr(input, {
      locale: 'fr',
      dateFormat: 'Y-m-d',
      altInput: true,
      altFormat: 'd/m/Y',
      defaultDate: STATE?.date || new Date(),
      allowInput: true,
      onChange: function(selectedDates, dateStr){
        if(dateStr){
          STATE.date = dateStr;
          setHeader();
          loadEma();
        }
      }
    });
  }

  /* ===== Open ema modal ===== */
  window.__openEma = ({ sessionId, sessionLabel, date, periode })=>{
    if(!sessionId){ alert('ID session manquant'); return; }

    STATE.sessionId = String(sessionId);
    STATE.sessionLabel = sessionLabel || STATE.sessionLabel;
    if(date) STATE.date = String(date);

    // ✅ si on appelle depuis “Matin/Après-midi”
    STATE.autoPeriode = periode || null;

    // sync "session sélectionnée" pour appréciation
    CURRENT_SESSION_ID = STATE.sessionId;
    syncSatisfactionBtn();

    setHeader();

    return loadEma().then(()=>{
      const modalEl = document.getElementById('emargementModal');
      modalEl.addEventListener('shown.bs.modal', () => initEmaDatepicker(), { once:true });
      bootstrap.Modal.getOrCreateInstance(modalEl).show();

      // ✅ auto-open signature AM/PM si demandé
      if (STATE.autoPeriode) {
        setTimeout(() => {
          const btn = document.querySelector(`#ema-tbody .js-open-sign[data-periode="${STATE.autoPeriode}"]`);
          if (btn) btn.click(); // pas signé -> ouvre le pad
          STATE.autoPeriode = null;
        }, 120);
      }
    });
  };


  $('#ema-refresh').on('click', ()=>{
    const v = $('#ema-date-input').val();
    if(v) STATE.date = v;
    setHeader();
    loadEma();
  });

  /* ===== Click DataTable: ouvrir émargement ===== */
  $(document).on('click', '.js-emargement', function(e){
    e.preventDefault();
    const sid = this.dataset.sessionId;
    const label = this.dataset.sessionLabel || 'Session';
    const today = (new Date()).toISOString().slice(0,10);
    window.__openEma?.({ sessionId: sid, sessionLabel: label, date: today });
  });

  /* ===== Appréciation formation (formateur) ===== */
  function goSatisfaction(sessionId){
    const tpl = document.getElementById('satisfaction-url-template')?.dataset?.url || '';
    if(!tpl){ alert('URL template manquante.'); return; }

    // tpl ressemble à : .../satisfaction/session/0/fill
    const url = String(tpl).replace(/\/session\/\d+\/fill\b/, `/session/${sessionId}/fill`);

    window.location.href = url;
  }




  $('#btnOpenSatisfaction').on('click', function(){
    if(!CURRENT_SESSION_ID) return;
    goSatisfaction(CURRENT_SESSION_ID);
  });

  $(document).on('click', '.js-satisfaction', function(e){
    e.preventDefault();
    const sid = this.dataset.sessionId;
    if(!sid) return;
    CURRENT_SESSION_ID = String(sid);
    syncSatisfactionBtn();
    goSatisfaction(CURRENT_SESSION_ID);
  });

  /* ===== Signature: open modal ===== */
  window.CURRENT_PERIODE = null;

  $(document).on('click', '.js-open-sign', function(e){
    e.preventDefault();
    window.CURRENT_PERIODE = this.dataset.periode || null;

    const el = document.getElementById('signatureModal');
    el.addEventListener('shown.bs.modal', () => {
      window.initSignaturePad?.();
      window.__signaturePad?.clear();
    }, { once:true });

    bootstrap.Modal.getOrCreateInstance(el, { backdrop:'static', focus:false }).show();
  });

  $('#btnClearSignature').on('click', ()=> window.__signaturePad?.clear());

  $('#btnSaveSignature').on('click', async function(){
    if (!window.__signaturePad || window.__signaturePad.isEmpty()) { alert('Veuillez signer.'); return; }
    if (!window.CURRENT_PERIODE) { alert('Période inconnue.'); return; }

    const dataUrl = window.__signaturePad.toDataURL('image/png');
    const tpl = document.getElementById('sign-url-template')?.dataset?.url || '';
    const url = String(tpl).replace('__ID__', String(STATE.sessionId || ''));

    const form = new FormData();
    form.append('signatureData', dataUrl);
    form.append('periode', window.CURRENT_PERIODE);
    form.append('date', toFr(STATE.date)); // endpoint attend FR

    const res = await fetch(url, {
      method:'POST',
      credentials:'same-origin',
      headers:{'X-Requested-With':'XMLHttpRequest'},
      body: form
    });

    const json = await res.json().catch(()=>null);
    if (!res.ok || !json || json.success !== true) {
      alert((json && (json.message||json.error)) || ('HTTP '+res.status));
      return;
    }

    bootstrap.Modal.getOrCreateInstance(document.getElementById('signatureModal')).hide();
    await loadEma();
  });

  /* ===== Preview signature ===== */
  $(document).on('click', '.js-view-sig', function(){
    const url = this.dataset.url;
    const at  = this.dataset.at || '';
    if(!url) return;

    $('#sigPreviewImg').attr('src', url);
    $('#sigPreviewMeta').text(at ? ('Signé le ' + at) : 'Signature');

    bootstrap.Modal.getOrCreateInstance(document.getElementById('sigPreviewModal')).show();
  });

  /* ===== Unsign ===== */
  $(document).on('click', '.js-unsign', async function(e){
    e.preventDefault();
    const periode = this.dataset.periode;
    if (!confirm('Supprimer votre signature '+periode+' ?')) return;

    const tpl = document.getElementById('unsign-url-template')?.dataset?.url || '';
    const url = String(tpl).replace('__ID__', String(STATE.sessionId || ''));

    const form = new FormData();
    form.append('periode', periode);
    form.append('date', toFr(STATE.date));

    const res = await fetch(url, {
      method:'POST',
      credentials:'same-origin',
      headers:{'X-Requested-With':'XMLHttpRequest'},
      body: form
    });

    const json = await res.json().catch(()=>null);
    if (!res.ok || !json || json.success !== true) {
      alert((json && (json.message||json.error)) || ('HTTP '+res.status));
      return;
    }

    await loadEma();
  });

  // init bouton appréciation au chargement
  syncSatisfactionBtn();

});
</script>

<script>
// SignaturePad init (robuste: canvas visible uniquement après "shown")
window.initSignaturePad = function(){
  const canvas = document.getElementById('signatureCanvas');
  if (!canvas) return;

  if (window.__signaturePad) { try{ window.__signaturePad.off(); }catch(_){ } window.__signaturePad=null; }

  const wrap = canvas.parentElement;
  const cssWidth  = wrap ? wrap.clientWidth : (canvas.clientWidth || 600);
  const cssHeight = 200;

  canvas.style.width  = cssWidth + 'px';
  canvas.style.height = cssHeight + 'px';

  const ratio = Math.max(window.devicePixelRatio || 1, 1);
  canvas.width  = Math.floor(cssWidth * ratio);
  canvas.height = Math.floor(cssHeight * ratio);

  const ctx = canvas.getContext('2d');
  ctx.setTransform(ratio, 0, 0, ratio, 0, 0);

  if (typeof window.SignaturePad !== 'function') { console.error('SignaturePad non chargé'); return; }
  window.__signaturePad = new SignaturePad(canvas, {
    throttle:16,
    minWidth:.5,
    maxWidth:2.5,
    backgroundColor:'rgb(255,255,255)'
  });
};
</script>
{% endblock %}
