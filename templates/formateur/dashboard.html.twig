    </div>

    <div class="col-12">
      <div class="section-card h-100">
        <div class="card-header d-flex align-items-center justify-content-between px-3 py-3">
          <h5 class="section-title mb-0">Calendrier & à venir</h5>
          <span class="text-muted small">Clique sur un évènement pour ouvrir les émargements</span>
        </div>
        <div class="card-body p-1">
          <div id="calendar" class="mb-4"></div>

          <h6 class="fw-bold mb-2">Prochaines sessions</h6>
          <ul class="timeline" id="upcoming-timeline">
            <li><span class="dot"></span><span class="when">-</span><span class="what">Chargement…</span></li>
          </ul>
        </div>
