{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
    <style>
        body{
            min-height:100vh;
            background:
                radial-gradient(circle at top left, rgba(255,193,7,.10), transparent 30%),
                radial-gradient(circle at bottom right, rgba(255,255,255,.05), transparent 25%),
                linear-gradient(135deg, #0f1b28 0%, #233342 100%);
            color:#fff;
        }

        .reset-shell{
            min-height:100vh;
            display:flex;
            align-items:center;
            justify-content:center;
            padding:32px 16px;
        }

        .reset-card{
            width:100%;
            max-width:460px;
            border:none;
            border-radius:22px;
            background:rgba(255,255,255,.98);
            box-shadow:0 25px 60px rgba(0,0,0,.18);
            overflow:hidden;
        }

        .reset-card-body{
            padding:32px 28px;
        }

        .brand-wrap{
            text-align:center;
            margin-bottom:22px;
        }

        .brand-logo{
            width:96px;
            height:auto;
            border-radius:14px;
            box-shadow:0 8px 20px rgba(0,0,0,.10);
            background:#fff;
            padding:8px;
        }

        .brand-name{
            margin-top:12px;
            margin-bottom:0;
            font-size:1.35rem;
            font-weight:700;
            color:#0f1b28;
        }

        .reset-title{
            text-align:center;
            font-size:1.5rem;
            font-weight:700;
            color:#0f1b28;
            margin-bottom:8px;
        }

        .reset-subtitle{
            text-align:center;
            color:#6c757d;
            margin-bottom:24px;
        }

        .form-label{
            font-weight:600;
            color:#233342;
            margin-bottom:8px;
        }

        .input-group-text{
            border-radius:14px 0 0 14px;
            background:#f8fbff;
            border-color:#dbe7f3;
            color:#0f1b28;
        }

        .form-control{
            border-radius:0 14px 14px 0;
            min-height:48px;
            border-color:#dbe7f3;
            box-shadow:none;
        }

        .form-control:focus{
            border-color:#0f1b28;
            box-shadow:0 0 0 .2rem rgba(15,27,40,.12);
        }

        .btn-reset{
            width:100%;
            border:none;
            border-radius:999px;
            padding:13px 18px;
            font-weight:700;
            background:linear-gradient(135deg, #0f1b28 0%, #1f3449 100%);
            color:#fff;
            box-shadow:0 12px 24px rgba(15,27,40,.18);
        }

        .btn-reset:hover{
            color:#fff;
            background:linear-gradient(135deg, #132537 0%, #294259 100%);
        }

        .back-link{
            text-align:center;
            margin-top:16px;
        }

        .back-link a{
            color:#6c757d;
            text-decoration:none;
        }

        .back-link a:hover{
            color:#0f1b28;
            text-decoration:underline;
        }

        .help-box{
            background:#f8fbff;
            border:1px solid #e4edf6;
            border-radius:16px;
            color:#52606d;
            font-size:.95rem;
            padding:14px 16px;
            margin-bottom:20px;
        }

        .invalid-feedback,
        .form-error-message{
            display:block;
            font-size:.875rem;
        }
    </style>
{% endblock %}

{% block body %}
<div class="reset-shell">
    <div class="reset-card">
        <div class="reset-card-body">
            <div class="brand-wrap">
                <img
                    class="brand-logo"
                    src="{{ asset('uploads/photos/entite/logo/logo-wikiformation.png') }}"
                    alt="Logo Wiki Formation"
                >
                <h1 class="brand-name">Wiki Formation</h1>
            </div>

            <div class="reset-title">Mot de passe oublié ?</div>
            <p class="reset-subtitle">
                Renseignez votre adresse e-mail pour recevoir un lien de réinitialisation.
            </p>

            {% include 'flagMessage.html.twig' ignore missing %}

            {{ form_start(requestForm, { attr: { novalidate: 'novalidate' } }) }}
                <div class="help-box">
                    Entrez l’adresse e-mail utilisée pour votre compte. Si elle existe, nous vous enverrons un lien sécurisé pour choisir un nouveau mot de passe.
                </div>

                <div class="mb-3">
                    {{ form_label(requestForm.email, 'Adresse e-mail', { label_attr: { class: 'form-label' } }) }}

                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-envelope"></i>
                        </span>
                        {{ form_widget(requestForm.email, {
                            attr: {
                                class: 'form-control',
                                placeholder: 'nom@exemple.com',
                                autocomplete: 'email'
                            }
                        }) }}
                    </div>

                    <div class="mt-2">
                        {{ form_errors(requestForm.email) }}
                    </div>
                </div>

                <button class="btn btn-reset" type="submit">
                    <i class="bi bi-send me-1"></i>
                    Envoyer le lien de réinitialisation
                </button>
            {{ form_end(requestForm) }}

            <div class="back-link">
                <small>
                    <a href="{{ path('app_login') }}">
                        <i class="bi bi-arrow-left me-1"></i>
                        Retour à la connexion
                    </a>
                </small>
            </div>
        </div>
    </div>
</div>
{% endblock %}