{% extends 'base.html.twig' %}

{% block title %}{{ 'forgot.meta.title'|trans }}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
    <style>
        body {
            background-color: #0f1b28;
            color: white;
        }
    </style>
{% endblock %}

{% block body %}
<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg p-4" style="max-width: 400px; width: 100%;">
        <div class="text-center">
            <img class="mb-3 rounded" src="{{ asset('uploads/photos/entite/logo/logo-wikiformation.png') }}" alt="Logo" style="width: 100px;">
            <h4 class="text-warning">Wiki Formation</h4>
        </div>

        <h5 class="text-center mb-3">{{ 'forgot.title'|trans }}</h5>
        <p class="text-center text-muted">{{ 'forgot.subtitle'|trans }}</p>

        {% include 'flagMessage.html.twig' %}

        {{ form_start(requestForm) }}
            <div class="mb-3">
                <label class="form-label">{{ 'forgot.email.label'|trans }}</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                    {{ form_widget(requestForm.email, {
                        attr: {
                            class: 'form-control',
                            placeholder: 'forgot.email.placeholder'|trans
                        }
                    }) }}
                </div>
            </div>

            <button class="btn btn-primary w-100" type="submit">{{ 'forgot.submit'|trans }}</button>

            <div class="text-center mt-3">
                <small><a href="{{ path('app_login') }}" class="text-muted">{{ 'forgot.back'|trans }}</a></small>
            </div>
        {{ form_end(requestForm) }}
    </div>
</div>
{% endblock %}
