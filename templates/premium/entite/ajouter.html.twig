            {# ====================== LOGO (horizontal) ====================== #}
            <div class="col-lg-6">
                <div class="upload-card">
                <div class="upload-head">
                    <div class="d-flex align-items-center gap-2">
                    <span class="upload-badge"><i class="fa-solid fa-panorama"></i></span>
                    <div>
                        <div class="upload-title">Logo menu (horizontal)</div>
                        <div class="upload-sub">Recommandé : 800×800 (recadré). Format horizontal.</div>
                    </div>
                    </div>
                    <span class="upload-hint">JPG/PNG/WebP</span>
                </div>

                {# input file caché + dropzone custom #}
                <div
                    class="dropzone-uploader"
                    data-input-id="{{ form.logo.vars.id }}"
                    data-preview-id="preview_logo"
                    data-remove-id="{{ form.removeLogo.vars.id }}"
                    data-existing="{{ nouvelleEntite.logo is defined and nouvelleEntite.logo ? 1 : (entite.logo is defined and entite.logo ? 1 : 0) }}"
                >
                    <div class="dz-inner">
                    <div class="dz-icon"><i class="fa-solid fa-cloud-arrow-up"></i></div>
                    <div class="dz-text">
                        <div class="dz-title">Glisse-dépose ton image ici</div>
                        <div class="dz-sub">ou <span class="dz-link">clique pour choisir</span></div>
                    </div>
                    <div class="dz-meta">
                        <span class="dz-chip"><i class="fa-regular fa-image me-1"></i> Aperçu en temps réel</span>
                        <span class="dz-chip"><i class="fa-solid fa-shield-halved me-1"></i> Champs sécurisé</span>
                    </div>
