            </div>

            {# ✅ Optionnel : si tu veux afficher l'image existante côté édition :
            tu peux injecter via JS plus bas une URL si entite.logo / entite.logoMenu existent.
            Je te fournis le JS qui le fait. #}
        </div>
    </div>

    

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-theme-tertiaire text-theme-quaternaire">
            <i class="fa-solid fa-align-left text-theme-secondaire me-2"></i> Présentation du club
        </div>
        <div class="card-body">
            {{ form_row(form.description) }}
            <p class="text-muted"><small><b>La description apparaîtra sur votre fiche publique.</b></small></p>
            {{ form_row(form.texteAccueil) }}
            <p class="text-muted"><small><b>Le texte d'accueil est un message de bienvenue visible sur votre fiche publique.</b></small></p>
        </div>
    </div>

    <div class="d-flex justify-content-end">
        <button type="submit" class="btn btn-gradiant">
            <i class="fa-solid fa-circle-plus me-1"></i> Ajouter le club
        </button>
    </div>

    {{ form_end(form) }}
</div>

<script
    src="https://maps.googleapis.com/maps/api/js?key=AIzaSyCX1L5c9NLzQKNa0GDexg7w-cbYHwHAwxo&libraries=places&callback=initAutocomplete"
    async defer></script>

<script>
  let autocomplete;

  function initAutocomplete() {
    const input = document.getElementById('autocomplete');
    if (!input || !window.google?.maps?.places) return;

    autocomplete = new google.maps.places.Autocomplete(input, {
      types: ['geocode'], // international OK
      fields: ['address_components', 'geometry'] // ✅ le bon champ
      // ❌ pas de componentRestrictions => tous pays
    });

    autocomplete.addListener('place_changed', fillInAddress);
  }

  function fillInAddress() {
    const place = autocomplete.getPlace();
    if (!place || !place.address_components) return;

    const c = {
      street_number: '',
      route: '',
      locality: '',
      postal_town: '',
      administrative_area_level_3: '',
      sublocality_level_1: '',
      postal_code: '',
      administrative_area_level_1: '',
      administrative_area_level_2: '',
      country: ''
    };

    for (const comp of place.address_components) {
      comp.types.forEach(t => { if (t in c) c[t] = comp.long_name; });
    }

    const ville = (c.locality || c.postal_town || c.administrative_area_level_3 || c.sublocality_level_1 || '').trim();

    document.getElementById('entite_premium_adresse').value = (c.street_number + ' ' + c.route).trim();
    document.getElementById('entite_premium_codePostal').value = c.postal_code;
    document.getElementById('entite_premium_ville').value = ville;
    document.getElementById('entite_premium_departement').value = c.administrative_area_level_2;
    document.getElementById('entite_premium_region').value = c.administrative_area_level_1;
    document.getElementById('entite_premium_pays').value = c.country;
  }





    document.addEventListener('DOMContentLoaded', () => {
        const form = document.querySelector('form[name="entite_premium"]');

        const submitButton = form.querySelector('button[type="submit"]');

        // Crée une alerte d'erreur si elle n'existe pas
        let errorAlert = document.createElement('div');
        errorAlert.classList.add('alert', 'alert-danger', 'd-none');
        errorAlert.setAttribute('role', 'alert');
        errorAlert.id = 'form-error-alert';
        submitButton.parentElement.prepend(errorAlert);

        form.addEventListener('submit', function (e) {
            const invalidFields = form.querySelectorAll(':invalid');

            if (invalidFields.length > 0) {
                e.preventDefault();

                // Nettoie les anciens "is-invalid"
                form.querySelectorAll('.is-invalid').forEach(field => field.classList.remove('is-invalid'));

                const messagesSet = new Set();
                let firstInvalidField = null;

                invalidFields.forEach(field => {
                    field.classList.add('is-invalid');
                    if (!firstInvalidField) {
                        firstInvalidField = field;
                    }

                    // 🔍 Recherche du label associé
                    let labelText = null;

                    // 1. via <label for="id">
                    const label = form.querySelector(`label[for="${field.id}"]`);
                    if (label) {
                        labelText = label.textContent.trim();
                    }

                    // 2. sinon, via .form-group ou .form-floating
                    if (!labelText) {
                        const container = field.closest('.form-floating, .form-group, .form-check, .col-md-4, .col-md-12, .palier-form');
                        if (container) {
                            const altLabel = container.querySelector('label');
                            if (altLabel) {
                                labelText = altLabel.textContent.trim();
                            }
                        }
                    }

                    if (labelText) {
                        messagesSet.add(`- ${labelText}`);
                    }
                });

                // ✅ Affichage
                const messages = [...messagesSet];
                errorAlert.innerHTML = `
                    <strong>Certains champs obligatoires ne sont pas remplis ou invalides :</strong><br>
                    ${messages.join('<br>')}
                `;
                errorAlert.classList.remove('d-none');

                // Scroll vers le champ invalide
                if (firstInvalidField && typeof firstInvalidField.scrollIntoView === 'function') {
                    const scrollTarget = firstInvalidField.closest('.form-floating, .form-group, .form-check, .input-group-number, .col-md-4, .col-md-6, .col-md-12, .palier-form') || firstInvalidField;

                    scrollTarget.scrollIntoView({ behavior: 'smooth', block: 'center' });

                    // Optionnel : un petit flash visuel
                    scrollTarget.classList.add('border', 'border-danger', 'rounded');
                    setTimeout(() => scrollTarget.classList.remove('border', 'border-danger', 'rounded'), 1500);
                }


                // 🔄 Disparition automatique après 6s
                setTimeout(() => {
                    errorAlert.classList.add('fade-out');
                    setTimeout(() => {
                        errorAlert.classList.add('d-none');
                        errorAlert.classList.remove('fade-out');
                    }, 1000);
                }, 6000);
            }
        });
    });
</script>



<script>
  function initPremiumDropzones() {
    const zones = document.querySelectorAll('.dropzone-uploader');

    zones.forEach(zone => {
      const inputId = zone.dataset.inputId;
      const previewId = zone.dataset.previewId;
      const removeId = zone.dataset.removeId;

      const input = document.getElementById(inputId);
      const preview = document.getElementById(previewId);
      const img = preview ? preview.querySelector('.dz-img') : null;
      const btnRemove = preview ? preview.querySelector('.dz-btn-remove') : null;
      const btnChange = preview ? preview.querySelector('.dz-btn-change') : null;
      const removeField = removeId ? document.getElementById(removeId) : null;

      if (!input || !preview || !img) return;

      // helper
      const showPreviewFromFile = (file) => {
        if (!file) return;

        // Si on vient de choisir un fichier => on annule la demande de suppression
        if (removeField) removeField.value = '';

        const reader = new FileReader();
        reader.onload = (e) => {
          img.src = e.target.result;
          preview.classList.add('is-visible');
        };
        reader.readAsDataURL(file);
      };

      const clearAll = () => {
        input.value = '';
        img.removeAttribute('src');
        preview.classList.remove('is-visible');

        // Demande de suppression si image existante côté édition
        if (removeField) {
          removeField.value = '1';
        }
      };

      // Click zone -> ouvre input
      zone.addEventListener('click', (e) => {
        // si click sur boutons, ne pas déclencher la sélection
        if (e.target.closest('.dz-btn')) return;
        input.click();
      });

      // Input change
      input.addEventListener('change', () => {
        if (input.files && input.files[0]) {
          showPreviewFromFile(input.files[0]);
        }
      });

      // Drag events
      zone.addEventListener('dragover', (e) => {
        e.preventDefault();
        zone.classList.add('is-dragover');
      });

      zone.addEventListener('dragleave', () => {
        zone.classList.remove('is-dragover');
      });

      zone.addEventListener('drop', (e) => {
        e.preventDefault();
        zone.classList.remove('is-dragover');

        const files = e.dataTransfer.files;
        if (!files || !files.length) return;

        const file = files[0];
        if (!file.type.startsWith('image/')) return;

        // Inject file into input (via DataTransfer)
        const dt = new DataTransfer();
        dt.items.add(file);
        input.files = dt.files;

        showPreviewFromFile(file);
      });

      // Buttons
      if (btnRemove) {
        btnRemove.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          clearAll();
        });
      }

      if (btnChange) {
        btnChange.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          input.click();
        });
      }
    });
  }
</script>


<script>
  document.addEventListener('DOMContentLoaded', () => {
    initPremiumDropzones();

    const base = "{{ asset('uploads/photos/entite/logo/') }}";

    {% if entite.logo is defined and entite.logo %}
      (function(){
        const p = document.getElementById('preview_logo');
        if (p) {
          const img = p.querySelector('.dz-img');
          img.src = base + "{{ entite.logo }}";
          p.classList.add('is-visible');
          const rm = document.getElementById("{{ form.removeLogo.vars.id }}");
          if (rm) rm.value = '';
        }
      })();
    {% endif %}

    {% if entite.logoMenu is defined and entite.logoMenu %}
      (function(){
        const p = document.getElementById('preview_logoMenu');
        if (p) {
          const img = p.querySelector('.dz-img');
          img.src = base + "{{ entite.logoMenu }}";
          p.classList.add('is-visible');
          const rm = document.getElementById("{{ form.removeLogoMenu.vars.id }}");
          if (rm) rm.value = '';
        }
      })();
    {% endif %}
  });
</script>


{% endblock %}
