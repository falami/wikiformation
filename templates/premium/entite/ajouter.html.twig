                    <div class="dz-icon"><i class="fa-solid fa-cloud-arrow-up"></i></div>
                    <div class="dz-text">
                        <div class="dz-title">Glisse-dépose ton image ici</div>
                        <div class="dz-sub">ou <span class="dz-link">clique pour choisir</span></div>
                    </div>
                    <div class="dz-meta">
                        <span class="dz-chip"><i class="fa-regular fa-image me-1"></i> Aperçu en temps réel</span>
                        <span class="dz-chip"><i class="fa-solid fa-crop me-1"></i> Recadrage serveur</span>
                    </div>
                    </div>

                    <div class="dz-preview" id="preview_logoMenu">
                    <img class="dz-img" alt="Aperçu logoMenu" />
                    <div class="dz-actions">
                        <button type="button" class="btn btn-sm btn-light dz-btn dz-btn-change">
                        <i class="fa-solid fa-pen-to-square me-1"></i> Changer
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-danger dz-btn dz-btn-remove">
