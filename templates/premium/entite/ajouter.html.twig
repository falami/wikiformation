            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-theme-tertiaire text-theme-quaternaire">
            <i class="bi bi-geo-alt-fill text-theme-secondaire me-2"></i> Localisation du club
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-lg-12 mb-3">
                    <label for="autocomplete" class="form-label">Adresse complète</label>
                    <input type="text" id="autocomplete" class="form-control" placeholder="Tapez votre adresse">
                </div>

                <div class="col-lg-12 mb-3">
                    
                    {{ form_row(form.adresse, { attr: { readonly: true, id: 'adresse' } }) }}
                </div>
                <div class="col-lg-12 mb-3">
                    {{ form_row(form.complement, { attr: { readonly: true, id: 'complement' } }) }}
                </div>
                <div class="col-md-4 mb-3">
                    {{ form_row(form.codePostal, { attr: { readonly: true, id: 'codePostal' } }) }}
                </div>
                <div class="col-md-4 mb-3">
                    {{ form_row(form.ville, { attr: { readonly: true, id: 'ville' } }) }}
                </div>
                <div class="col-md-6 mb-3">
                    {{ form_row(form.departement, { attr: { readonly: true, id: 'departement' } }) }}
                </div>
                <div class="col-md-6 mb-3">
                    {{ form_row(form.region, { attr: { readonly: true, id: 'region' } }) }}
                </div>
                <div class="col-lg-12 mb-3">
                    {{ form_row(form.pays, { attr: { readonly: true, id: 'pays' } }) }}
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-theme-tertiaire text-theme-quaternaire">
            <i class="fa-solid fa-image text-theme-secondaire me-2"></i> Logo du club
        </div>

        <div class="card-body">
