{# templates/premium/entite/ajouter.html.twig #}
{% extends 'base_admin.html.twig' %}

{% block title %}Ajout d'un nouveau club{% endblock %}

{% block stylesheets %}
<style>
    :root {
        --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
        --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
        --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
        --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }
    .card-header {
        background-color: var(--theme-color-principal);
        color: white;
        font-weight: 500;
    }
    #form-error-alert {
        position: fixed;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 1050;
        max-width: 90%;
        width: auto;
        padding: 0.75rem 1.25rem;
        background-color: #f8d7da;
        color: #842029;
        border: 1px solid #f5c2c7;
        border-radius: 0.75rem;
        box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.1);
        font-weight: 500;
        font-size: 0.9rem;
        line-height: 1.4;
        text-align: left;
        animation: fadeIn 0.4s ease;
    }

    #form-error-alert strong {
        font-size: 1rem;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateX(-50%) translateY(20px); }
        to { opacity: 1; transform: translateX(-50%) translateY(0); }
    }

    .fade-out {
        opacity: 0;
        transition: opacity 1s ease;
    }


    /* ---------- Premium Upload UI ---------- */
    .upload-card{
    border: 1px solid rgba(15,35,54,.10);
    border-radius: 18px;
    background: linear-gradient(180deg, rgba(255,255,255,.95), rgba(255,255,255,.80));
    box-shadow: 0 10px 30px rgba(15,35,54,.06);
    padding: 14px;
    }

    .upload-head{
    display:flex;
    align-items:flex-start;
    justify-content:space-between;
    gap:12px;
    padding: 6px 2px 12px;
    }

    .upload-badge{
    width:38px;height:38px;border-radius:12px;
    display:grid;place-items:center;
    background: rgba(255,255,255,.75);
    border:1px solid rgba(15,35,54,.10);
    box-shadow: 0 8px 20px rgba(15,35,54,.06);
    color: var(--theme-color-principal);
    }

    .upload-title{ font-weight:700; color: var(--theme-color-principal); line-height:1.1; }
    .upload-sub{ font-size:.86rem; color: rgba(0,0,0,.55); margin-top:2px; }
    .upload-hint{
    font-size:.75rem;
    padding:6px 10px;
    border-radius:999px;
    border: 1px solid rgba(15,35,54,.10);
    background: rgba(255,255,255,.70);
    color: rgba(0,0,0,.55);
    }

    /* Dropzone */
    .dropzone-uploader{
    position: relative;
    border-radius: 18px;
    border: 1.5px dashed rgba(15,35,54,.22);
    background:
        radial-gradient(1200px 200px at 20% 0%, rgba(236,182,47,.18), transparent 55%),
        radial-gradient(900px 220px at 90% 0%, rgba(22,56,96,.18), transparent 60%),
        rgba(255,255,255,.70);
    min-height: 190px;
    overflow: hidden;
    cursor: pointer;
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
    }

    .dropzone-uploader:hover{
    transform: translateY(-2px);
    border-color: rgba(15,35,54,.35);
    box-shadow: 0 14px 35px rgba(15,35,54,.10);
    }

    .dropzone-uploader.is-dragover{
    border-color: var(--theme-color-secondaire);
    box-shadow: 0 16px 40px rgba(15,35,54,.14);
    }

    .dz-inner{
    padding: 18px;
    display:flex;
    flex-direction: column;
    gap: 10px;
    height: 190px;
    justify-content:center;
    align-items:center;
    text-align:center;
    }

    .dz-icon{
    width:52px;height:52px;border-radius:18px;
    display:grid;place-items:center;
    background: rgba(255,255,255,.78);
    border:1px solid rgba(15,35,54,.10);
    color: var(--theme-color-principal);
    box-shadow: 0 10px 24px rgba(15,35,54,.08);
    font-size: 20px;
    }

    .dz-title{ font-weight:800; color: var(--theme-color-principal); }
    .dz-sub{ color: rgba(0,0,0,.60); font-size:.92rem; }
    .dz-link{
    color: var(--theme-color-secondaire);
    font-weight: 800;
    text-decoration: underline;
    text-underline-offset: 3px;
    }

    .dz-meta{ display:flex; gap:8px; flex-wrap:wrap; justify-content:center; margin-top:2px; }
    .dz-chip{
    font-size:.75rem;
    padding:6px 10px;
    border-radius:999px;
    border:1px solid rgba(15,35,54,.10);
    background: rgba(255,255,255,.72);
    color: rgba(0,0,0,.58);
    }

    /* Preview overlay */
    .dz-preview{
    position:absolute; inset:0;
    display:none;
    background: rgba(255,255,255,.80);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    }

    .dz-preview.is-visible{ display:block; }

    .dz-img{
    width:100%;
    height:100%;
    object-fit: contain;
    padding: 16px;
    }

    .dz-actions{
    position:absolute;
    left: 12px;
    right: 12px;
    bottom: 12px;
    display:flex;
    gap:10px;
    justify-content:flex-end;
    }

    .dz-btn{
    border-radius: 12px !important;
    box-shadow: 0 10px 24px rgba(15,35,54,.10);
    }

</style>
<link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
<link rel="stylesheet" href="{{ asset('dist/css/formulaire.css')}}">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
{% endblock %}

{% block javascripts %}
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="{{ asset('dist/vendors/flatpickr/flatpickr.min.js') }}"></script>
<script src="https://npmcdn.com/flatpickr/dist/l10n/fr.js"></script>
<script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
{% endblock %}

{% block body %}
<div class="container my-4">
    <h2><i class="fa-solid fa-plus text-theme-secondaire me-2"></i> Ajouter un nouveau club</h2>

    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
    {{ form_errors(form) }}

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-theme-tertiaire text-theme-quaternaire">
            <i class="fa-solid fa-id-card text-theme-secondaire me-2"></i> Informations générales
        </div>
        <div class="card-body row g-3">
            <div class="col-md-4">{{ form_row(form.nom) }}</div>
            <div class="col-md-4">{{ form_row(form.email) }}</div>
            <div class="col-md-4">{{ form_row(form.telephone) }}</div>
            <div class="col-md-3">{{ form_row(form.couleurPrincipal) }}</div>
            <div class="col-md-3">{{ form_row(form.couleurSecondaire) }}</div>
            <div class="col-md-3">{{ form_row(form.couleurTertiaire) }}</div>
            <div class="col-md-3">{{ form_row(form.couleurQuaternaire) }}</div>
            <div class="form-check form-switch mt-3">
                {{ form_widget(form.scanAutorise, {'attr': {'class': 'form-check-input'}}) }}
