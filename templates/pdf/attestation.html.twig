{# templates/pdf/attestation.html.twig #}
{% set brand = {
  primary:   entite.couleurPrincipal  |default('#1e3a5f'),
  secondary: entite.couleurSecondaire |default('#4ba3ff'),
  accent:    entite.couleurSecondaire |default('#d4a574'),
  ink:       '#0f2336',
  text:      '#1e2d3d',
  muted:     '#5a6b7d',
  line:      '#dce4ed',
  soft:      '#f8fafc',
  paper:     '#ffffff',
  okBg:      '#ecfdf5',
  okLine:    '#34d399',
  badBg:     '#fef2f2',
  badLine:   '#fb7185',
  gold:      '#c9a227',
  gold2:     '#f1d27a'
} %}

{# === Normalisation === #}
{% set insc = inscription %}
{% set stag = stagiaire ?? insc.stagiaire %}
{% set sess = session   ?? insc.session %}
{% set form = formation ?? (sess ? sess.formation : null) %}
{% set ent  = entite %}
{% set preferences = entite.preferences ?? null %}

{% set a = attestation is defined and attestation ? attestation : (insc.attestation ?? null) %}
{% set taux = tauxAssiduite is defined and tauxAssiduite is not null ? tauxAssiduite : (insc.tauxAssiduite ?? null) %}
{% set numeroLocal = a and a.numeroOrNull ? a.numeroOrNull : '-' %}
{% set dateDelivrance = (a and a.dateDelivrance) ? a.dateDelivrance : "now" %}
{% set traineeName = ((stag.prenom ?? '') ~ ' ' ~ (stag.nom ?? ''))|trim %}

{# ===== Durée totale (compatible avec tes entités) ===== #}
{% set dureeLabel = null %}
{% if a and attribute(a, 'dureeHeures') is defined and attribute(a, 'dureeHeures') %}
  {% set dureeLabel = attribute(a, 'dureeHeures') ~ 'h' %}
{% endif %}
{% if dureeLabel is null and form and attribute(form, 'duree') is defined and attribute(form, 'duree') %}
  {% set d = attribute(form, 'duree') %}
  {% if d > 1 %}
    {% set dureeLabel = d ~ ' jours' %}
  {% else %}
    {% set dureeLabel = d ~ ' jour' %}
  {% endif %}
{% endif %}
{% if dureeLabel is null and sess and sess.jours is defined and sess.jours|length > 0 %}
  {% set totalMinutes = 0 %}
  {% for j in sess.jours %}
    {% if j.dateDebut and j.dateFin %}
      {% set diff = date(j.dateFin).timestamp - date(j.dateDebut).timestamp %}
      {% if diff > 0 %}{% set totalMinutes = totalMinutes + (diff / 60) %}{% endif %}
    {% endif %}
  {% endfor %}
  {% if totalMinutes > 0 %}
    {% set totalHeures = (totalMinutes / 60) %}
    {% set dureeLabel = totalHeures|number_format(2, ',', ' ') ~ ' h' %}
  {% endif %}
{% endif %}

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <title>Certificat de réalisation - {{ numeroLocal }}</title>

  <style>
    @page { margin: 8mm; size: A4 portrait; }

    body{
      font-family: DejaVu Sans, Helvetica, Arial, sans-serif;
      color: {{ brand.text }};
      font-size: 9.4pt;
      line-height: 1.22;
      margin: 0;
      padding: 0;
    }

    .muted{ color: {{ brand.muted }}; }
    .small{ font-size: 8.5pt; }
    .xs{ font-size: 8.1pt; }
    .right{ text-align:right; }
    .center{ text-align:center; }
    strong{ font-weight: 900; color: {{ brand.ink }}; }

    /* ========= DIPLOMA FRAME (double border + inner plate) ========= */
    .frame{
      position: relative;
      border: 2.2pt solid {{ brand.primary }};
      border-radius: 16pt;
      padding: 7pt;
      background: {{ brand.paper }};
      overflow: hidden;
    }
    .frame2{
      position: relative;
      border: 1.2pt solid rgba(15,35,54,0.18);
      border-radius: 14pt;
      padding: 10pt 10pt 8pt;
      overflow: hidden;
      background: #fff;
    }

    /* subtle background plate */
    .bg-plate{
      position:absolute;
      inset: 8pt;
      border-radius: 12pt;
      background: {{ brand.soft }};
      opacity: .55;
      z-index: 0;
    }

    /* ========= Corner ribbons (premium template feel) ========= */
    .corner{
      position:absolute;
      width: 240pt;
      height: 28pt;
      transform: rotate(-35deg);
      opacity: .95;
      z-index: 1;
    }
    .c-tl{ top: -20pt; left: -78pt; }
    .c-br{ bottom: -20pt; right: -78pt; }
    .corner table{ width:100%; height:100%; border-collapse: collapse; }
    .corner td{ height: 28pt; }
    .cc1{ width: 62%; background: {{ brand.primary }}; }
    .cc2{ width: 23%; background: {{ brand.secondary }}; }
    .cc3{ width: 15%; background: {{ brand.accent }}; }

    /* ========= Watermark (smaller + safer) ========= */
    .wm{
      position:absolute;
      top: 188pt;
      left: -30pt;
      right: -30pt;
      text-align:center;
      font-size: 42pt;
      font-weight: 900;
      color: rgba(15,35,54,0.040);
      letter-spacing: 2.0pt;
      transform: rotate(-12deg);
      z-index: 1;
      white-space: nowrap;
    }

    .layer{ position:relative; z-index: 2; }

    /* ========= Header ========= */
    .head{ width:100%; border-collapse: collapse; margin-bottom: 6pt !important; height: 150pt; }
    .hl{ width:63%; vertical-align: top; }
    .hr{ width:37%; vertical-align: top; text-align:right; }

    .logo{
      height: 46pt;
      width:auto;
      border: 1pt solid {{ brand.line }};
      padding: 3pt;
      border-radius: 10pt;
      background: #fff;
      display:inline-block;
    }

    .org{
      font-size: 14.2pt;
      font-weight: 900;
      color: {{ brand.primary }};
      margin-top: 2pt;
      letter-spacing: -0.2pt;
    }
    .orgmeta{
      margin-top: 1pt;
      font-size: 8.4pt;
      color: {{ brand.muted }};
      line-height: 1.22;
    }

    .chip{
      display:inline-block;
      background: {{ brand.primary }};
      color:#fff;
      font-weight: 900;
      font-size: 9.5pt;
      letter-spacing: .9pt;
      padding: 6pt 9pt;
      border-radius: 999pt;
      text-transform: uppercase;
    }
    .meta{
      margin-top: 6pt;
      border: 1pt solid {{ brand.line }};
      border-radius: 12pt;
      padding: 6pt 8pt;
      background:#fff;
      text-align:left;
      font-size: 8.35pt;
      color: {{ brand.muted }};
      line-height: 1.28;
    }
    .meta b{ color: {{ brand.ink }}; }

    /* ========= Gold seal (less intrusive) ========= */
    .seal{
      position:absolute;
      left: 12pt;
      top: 120pt;
      width: 70pt;
      height: 62pt;
      border-radius: 999pt;
      border: 2pt solid {{ brand.gold }};
      background: #fff;
      z-index: 2;
      text-align:center;
      padding-top: 9pt;
    }
    .seal .y{ margin-top: 7pt; font-size: 11pt; font-weight: 900; color: {{ brand.gold }}; line-height: 1; }
    .seal .t{ margin-top: 2pt; font-size: 7.2pt; font-weight: 900; letter-spacing: .8pt; color: {{ brand.ink }}; text-transform: uppercase; }
    .seal .r{ margin: 6pt auto 0; width: 34pt; height: 6pt; border-radius: 999pt; background: {{ brand.gold2 }}; }

    /* ========= Diploma title ========= */
    .title{ text-align:center; margin: 4pt 0 45pt; }
    .kicker{
      font-size: 8.1pt;
      color: {{ brand.muted }};
      text-transform: uppercase;
      letter-spacing: 2.6pt;
      font-weight: 900;
    }
    .h1{
      font-family: DejaVu Serif, DejaVu Sans, serif;
      font-size: 22pt;
      font-weight: 900;
      color: {{ brand.ink }};
      margin: 1pt 0 0;
      letter-spacing: .3pt;
    }
    .orn{
      margin: 5pt auto 3pt;
      width: 150pt;
      height: 1pt;
      background: {{ brand.line }};
    }
    .orn2{
      margin: 3pt auto 0;
      width: 46pt;
      height: 3pt;
      background: {{ brand.accent }};
      border-radius: 99pt;
    }
    .sub{
      margin-top: 4pt;
      font-size: 8.6pt;
      color: {{ brand.muted }};
      line-height: 1.25;
    }

    /* ========= Recipient ========= */
    .recipient{
      margin-top: 6pt;
      border: 1pt solid {{ brand.line }};
      border-radius: 12pt;
      padding: 8pt 10pt;
      background: #fff;
    }
    .recipient .label{
      font-size: 8.1pt;
      text-transform: uppercase;
      letter-spacing: 1.4pt;
      font-weight: 900;
      color: {{ brand.muted }};
      margin-bottom: 3pt;
    }
    .recipient .name{
      font-family: DejaVu Serif, DejaVu Sans, serif;
      font-size: 18pt;
      font-weight: 900;
      color: {{ brand.primary }};
      letter-spacing: .2pt;
    }
    .recipient .meta2{
      margin-top: 2pt;
      font-size: 8.3pt;
      color: {{ brand.muted }};
      line-height: 1.2;
    }

    /* ========= Cards grid ========= */
    .grid{ width:100%; border-collapse: collapse; margin-top: 7pt; }
    .grid td{ width:50%; vertical-align: top; }
    .grid td:first-child{ padding-right: 5pt; }
    .grid td:last-child{ padding-left: 5pt; }

    .card{
      border: 1pt solid {{ brand.line }};
      border-radius: 12pt;
      background:#fff;
      padding: 8pt 10pt;
    }
    .card h3{
      margin: 0 0 6pt;
      font-size: 8.9pt;
      font-weight: 900;
      color: {{ brand.primary }};
      text-transform: uppercase;
      letter-spacing: 1pt;
      padding-bottom: 5pt;
      border-bottom: 1pt solid #eef2f6;
    }

    .kv{ margin-bottom: 5pt; }
    .kv:last-child{ margin-bottom:0; }
    .k{
      display:block;
      font-size: 10pt;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: .6pt;
      color: {{ brand.muted }};
      margin-bottom: 1pt;
    }
    .v{
      font-size: 9.4pt;
      color: {{ brand.text }};
      line-height: 1.22;
    }

    .badge{
      display:inline-block;
      font-size: 8.7pt;
      font-weight: 900;
      padding: 3pt 9pt;
      border-radius: 999pt;
      border: 1pt solid {{ brand.line }};
      text-transform: uppercase;
      letter-spacing: .7pt;
    }
    .badge-ok{ background: {{ brand.okBg }}; border-color: {{ brand.okLine }}; color: #065f46; }
    .badge-bad{ background: {{ brand.badBg }}; border-color: {{ brand.badLine }}; color: #9f1239; }

    /* ========= Statement ========= */
    .statement{
      margin-top: 7pt;
      border: 1pt solid {{ brand.line }};
      border-left: 3pt solid {{ brand.accent }};
      border-radius: 12pt;
      padding: 7pt 10pt;
      background:#fff;
      font-size: 9pt;
      line-height: 1.33;
    }

    /* ========= Signatures (more “diploma”) ========= */
    .sig{ width:50%; border-collapse: collapse; margin-top: 8pt; }
    .sig td{ width:50%; vertical-align: top; }
    .sig td:first-child{ padding-right: 5pt; }
    .sig td:last-child{ padding-left: 5pt; }

    .sigBox{
      border-radius: 12pt;
      padding: 7pt 8pt;
      height: 100pt;
      background: #ffffff !important;
      border: 1pt solid {{ brand.line }};
      text-align: center;
    }
    .sigBoxOF{
      font-size: 12.0pt;
    }
    .sigLabel{
      font-size: 8.0pt;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: .9pt;
      color: {{ brand.muted }};
      margin-bottom: 4pt;
    }
    .sigline{
      margin-top: 14pt;
      border-top: 1pt solid {{ brand.line }};
    }
    .sigmeta{
      margin-top: 4pt;
      font-size: 8.0pt;
      color: {{ brand.muted }};
    }
    .sig-img{
      height: 40pt;
      max-width: 100%;
      object-fit: contain;
      display: inline-block;
      margin-top: 3pt;
    }

    /* ========= Footer ========= */
    .footer{
      margin-top: 8pt;
      border-top: 1pt solid {{ brand.line }};
      padding-top: 4pt;
      font-size: 8.35pt;
      color: {{ brand.muted }};
    }
    .footer table{ width:100%; border-collapse: collapse; }

    .bullet{
      color: {{ brand.accent }};
      font-weight: 900;
      margin-right: 4pt;

    }


  </style>
</head>

<body>

  <div class="frame">
    <div class="frame2">

      <div class="bg-plate"></div>

      <div class="corner c-tl">
        <table><tr><td class="cc1"></td><td class="cc2"></td><td class="cc3"></td></tr></table>
      </div>
      <div class="corner c-br">
        <table><tr><td class="cc1"></td><td class="cc2"></td><td class="cc3"></td></tr></table>
      </div>

      <div class="wm">CERTIFICAT</div>

      <div class="layer">

        

        <table class="head">
          <tr>
            <td class="hl">
              {% if ent.logo %}
                <img class="logo"
                     src="{{ absolute_url(asset('uploads/photos/entite/logo/' ~ ent.logo)) }}"
                     alt="Logo {{ ent.nom }}">
              {% endif %}

              <div class="org">{{ ent.nom ?? 'Organisme de formation' }}</div>

              <div class="orgmeta">
                {% if ent.adresse %}{{ ent.adresse }} · {% endif %}
                {{ (ent.codePostal ?? '') ~ ' ' ~ (ent.ville ?? '') }}{% if ent.pays %} · {{ ent.pays }}{% endif %}<br>
                {% if ent.siret %}SIRET : {{ ent.siret }}{% endif %}
                {% if ent.numeroDeclarant is defined and ent.numeroDeclarant %} · NDA : {{ ent.numeroDeclarant }}{% endif %}
              </div>
            </td>

            <td class="hr">
              <div class="chip">Certificat de réalisation</div>
              <div class="meta">
                <div><b>N° :</b> {{ numeroLocal }}</div>
                <div><b>Date :</b> {{ dateDelivrance|date('d/m/Y') }}</div>
                {% if sess and sess.code %}<div><b>Session :</b> {{ sess.code }}</div>{% endif %}
              </div>
            </td>
          </tr>
        </table>

        <div class="seal">
          <div class="y">{{ dateDelivrance|date('Y') }}</div>
          <div class="t">CERTIFIÉ</div>
          <div class="r"></div>
        </div>

        <div class="title">
          <div class="kicker">Attestation de fin de formation</div>
          <div class="h1">Certificat de réalisation</div>
          <div class="orn"></div>
          <div class="orn2"></div>
          <div class="sub">
            Document officiel attestant de la participation et de la réalisation de l’action de formation.
          </div>
        </div>

        <div class="recipient">
          <div class="label">Décerné à</div>
          <div class="name">{{ traineeName ?: '-' }}</div>
          <div class="meta2">{% if stag.email %}{{ stag.email }}{% endif %}</div>
        </div>

        <table class="grid">
          <tr>
            <td>
              <div class="card">
                <h3>Action de formation</h3>
                <div class="kv"><span class="k"><span class="bullet">›</span>Intitulé</span><div class="v">{{ form ? (form.titre ?? '-') : '-' }}</div></div>
                <div class="kv"><span class="k"><span class="bullet">›</span>Session</span><div class="v">{{ sess ? (sess.code ?? '-') : '-' }}</div></div>
                <div class="kv"><span class="k"><span class="bullet">›</span>Durée</span><div class="v">{{ dureeLabel ?? '-' }}</div></div>
                <div class="kv"><span class="k"><span class="bullet">›</span>Assiduité</span><div class="v">{{ taux is not null ? (taux|number_format(1, ',', ' ') ~ ' %') : 'Non calculé' }}</div></div>
              </div>
            </td>

            <td>
              <div class="card">
                <h3>Validation</h3>
                <div class="kv">
                  <span class="k">Statut</span>
                  <div class="v">
                    {% if insc.reussi %}
                      <span class="badge badge-ok">Validée</span>
                    {% else %}
                      <span class="badge badge-bad">Non validée</span>
                    {% endif %}
                  </div>
                </div>
                <div class="kv"><span class="k"><span class="bullet">›</span>Lieu</span><div class="v">{{ ent.ville ?? '-' }}</div></div>
                <div class="kv"><span class="k"><span class="bullet">›</span>Date d’émission</span><div class="v">{{ dateDelivrance|date('d/m/Y') }}</div></div>
                <div class="kv"><span class="k"><span class="bullet">›</span>Référence</span><div class="v"><strong>{{ numeroLocal }}</strong></div></div>
              </div>
            </td>
          </tr>
        </table>

        <div class="statement">
          Je soussigné(e) <strong>{{ ent.nom ?? 'Organisme de formation' }}</strong>,
          atteste que <strong>{{ traineeName ?: 'le bénéficiaire' }}</strong>
          a réalisé l’action de formation intitulée <strong>{{ form ? (form.titre ?? '—') : '—' }}</strong>
          {% if dureeLabel %}d’une durée de <strong>{{ dureeLabel }}</strong>{% endif %}
          {% if sess and sess.jours is defined and sess.jours|length > 0 %}
            , conformément aux modalités prévues, sur la base des feuilles d’émargement.
          {% else %}
            .
          {% endif %}
          <br><span class="muted small">Ce document est valable sans signature manuscrite, sauf mention contraire.</span>
        </div>

        <table class="sig">
          <tr>
            <td>
              <div class="sigLabel">Délivré par</div>
              <div class="sigBox">
                <div class="sigBoxOF"><strong>{{ ent.nom ?? '' }}</strong></div>
                {% if preferences and (preferences.signatureOrganismeNom or preferences.signatureOrganismeFonction) %}
                  <span class="muted xs">
                    {{ preferences.signatureOrganismeNom ? preferences.signatureOrganismeNom : '' }}
                    {% if preferences.signatureOrganismeNom and preferences.signatureOrganismeFonction %} · {% endif %}
                    {{ preferences.signatureOrganismeFonction ? preferences.signatureOrganismeFonction : '' }}
                  </span>
                {% endif %}

                {% if preferences and preferences.signatureOrganismePath %}
                  <div style="margin-top:3pt;">
                    <img class="sig-img" src="{{ absolute_url(asset(preferences.signatureOrganismePath|trim('/'))) }}" alt="Signature">
                  </div>
                  <div class="sig-meta">
                    {{ preferences.signatureOrganismeAt ? ('Signé le ' ~ preferences.signatureOrganismeAt|date('d/m/Y')) : 'Signature configurée' }}
                  </div>
                {% else %}
                  <div class="sig-meta">Signature & cachet</div>
                {% endif %}
              </div>
            </td>
          </tr>
        </table>

        <div class="footer">
          <table>
            <tr>
              <td>{{ ent.nom ?? 'Organisme de formation' }}</td>
              <td class="right">Certificat n° {{ numeroLocal }} · Généré le {{ "now"|date('d/m/Y H:i') }}</td>
            </tr>
          </table>
        </div>

      </div>
    </div>
  </div>

</body>
</html>

