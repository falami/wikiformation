{# templates/pdf/facture.html.twig #}
{% import _self as m %}

{% macro eur(cents) %}{{ ((cents ?? 0) / 100)|number_format(2, ',', ' ') }} €{% endmacro %}
{% macro pct(v) %}{{ (v ?? 0)|number_format(2, ',', ' ') }} %{% endmacro %}

{% set brand = {
  primary: entite.couleurPrincipal ?? '#1e3a5f',
  secondary: entite.couleurSecondaire ?? '#4ba3ff',
  ink: '#0f2336',
  line: '#e6eef5',
  bg: '#f7fafc',
  dark: '#0f1b28'
} %}

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <title>Facture {{ facture.numero }}</title>

  <style>
    @page { margin: 10mm 10mm 0mm; size: A4 portrait; }

    body{
      font-family: -apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Arial,sans-serif;
      color:#14212b; font-size:11px; line-height:1.35;
      padding:0; margin:0;
    }
    .wrap{ padding-bottom:0; }
    h1,h2,h3,p,table{ margin:0; padding:0 }

    .content{ padding-bottom: 45mm; }

    /* HEADER */
    .brand-name{ font-size:20px; font-weight:800; color:{{ brand.primary }}; letter-spacing:.5px }
    .brand-meta{ margin-top:6px; font-size:10px; color:#506576 }
    .brand-meta p{ line-height:1.35 }
    .logo{
      height: 54pt;
      width: auto;
      display: inline-block;
      border: 1pt solid {{ brand.line }};
      padding: 4pt;
      border-radius: 10pt;
      background: #fff;
    }

    .doc-right{ text-align:right }
    .doc-badge{ font-weight:900; font-size:22px; letter-spacing:1.5px; color:{{ brand.primary }}; }
    .doc-meta{ margin-top:8px; font-size:11px; color:#51697c }

    .stamp{
      display:inline-block; margin-top:8px; padding:4px 10px;
      border:1.6px solid #2563eb; color:#2563eb; border-radius:6px;
      font-size:11px; font-weight:800; letter-spacing:.6px;
    }
    .stamp-paid{ border-color:#2a8f4a; color:#2a8f4a }
    .stamp-canceled{ border-color:#9b1c1c; color:#9b1c1c }
    .stamp-due{ border-color:#b45309; color:#b45309 }

    /* TABLE */
    table{ width:100%; border-collapse:collapse }
    th,td{ padding:8px 9px; vertical-align:top }
    thead th{
      font-size:10.5px; letter-spacing:.6px; text-transform:uppercase;
      background:#f3f7fb; color:#2a4154; border-bottom:1px solid {{ brand.line }};
    }
    tbody td{ font-size:11px }
    .num{ text-align:right; white-space:nowrap }
    .ref{ color:#5c7890; font-size:10px }
    .muted{ color:#688296 }

    /* TOTALS */
    .totaux td{ font-size:12px; padding:6px 9px }
    .totaux .label{ text-align:right; color:#355068 }
    .totaux .val{ text-align:right; white-space:nowrap }

    .note{
      margin-top:3mm;
      font-size:10px;
      color:#607384;
      page-break-inside: avoid;
    }

    .rule{ height:2px; background:linear-gradient(90deg, {{ brand.primary }}, {{ brand.line }}); opacity:.25; margin:8mm 0 6mm }
    .titre{
      background:#f3f7fb; font-size:12px; color:#2a4154;
      text-align:center; text-transform:uppercase;
    }

    /* FOOTER BANCAIRE FIXE */

    /* ✅ FOOTER FIXE (NOTE + BANQUE) — même logique que devis */
    .footer-wrapper{
      position: fixed;
      left: 10mm;
      right: 10mm;
      bottom: 10mm;   /* ✅ dans la page */
      page-break-inside: avoid;
    }


    .footer-note{
      text-align:center;
      margin:0 0 6px 0;
      padding:4px 10px;
      border:1px dashed {{ brand.line }};
      border-radius:10px;
      background:#fff;
      color:#6b7f92;
      font-style: italic;
    }

    .footer-banque{
      border:1px solid {{ brand.line }};
      border-radius:10px;
      background:#fff;
      padding:7px 10px;
      text-align:left;
    }

    .footer-banque-title{
      text-align:center;
      font-weight:800;
      font-size:10px;
      text-transform:uppercase;
      color:{{ brand.primary }};
      border-bottom:1px solid {{ brand.line }};
      padding-bottom:3px;
      margin-bottom:3px;
    }
    .footer-banque p{ margin:0; line-height:1.25; }


    /* HEADER (stable DOMPDF) */
    .header{ width:100%; border-collapse:collapse; margin-bottom:10mm; }
    .header td{ vertical-align:top; padding:0; }
    .header .left{ width:62%; }
    .header .right{ width:38%; text-align:right; }


    .totaux{
      width:75%;
      margin-left:auto;
      margin-top:6mm;
      border-collapse:collapse;
      page-break-inside: avoid;
    }
    .totaux td{ border-bottom:1px solid #edf2f7; }
    .totaux .total.titre{
      background:#f3f7fb;
      font-weight:900;
      border-top:2px solid {{ brand.line }};
    }



    .detail-row td{ padding-top:2px; padding-bottom:2px; border-bottom:none; }
    .detail-text{ font-size:10px; color:#2a4154; }

    tr.line-main td{ border-bottom:none; }
    tr.line-end td{ border-bottom:1px solid #edf2f7; }


  </style>
</head>

<body>
<div class="wrap">

  <div class="content">
    <!-- HEADER -->
    <table class="header" cellspacing="0" cellpadding="0">
      <tr>
        <td class="left">
          <div class="brand-left">
            {% if entite.logo %}
              <img class="logo" src="{{ absolute_url(asset('uploads/photos/entite/logo/' ~ entite.logo)) }}" alt="Logo {{ entite.nom }}">
            {% else %}
              <div class="brand-name">{{ entite.nom }}</div>
            {% endif %}

            <div class="brand-meta" style="margin-top:8px">
              {% if entite.nom %}<p><strong>{{ entite.nom }}</strong></p>{% endif %}
              {% if entite.adresse %}<p>{{ entite.adresse }}</p>{% endif %}

              {% set entite_l2 = [] %}
              {% if entite.codePostal %}{% set entite_l2 = entite_l2|merge([entite.codePostal]) %}{% endif %}
              {% if entite.ville %}{% set entite_l2 = entite_l2|merge([entite.ville]) %}{% endif %}
              {% if entite_l2 is not empty or entite.pays %}
                <p>{{ entite_l2|join(' ') }}{% if entite.pays %} - {{ entite.pays }}{% endif %}</p>
              {% endif %}

              {% if entite.telephone %}<p>{{ entite.telephone }}</p>{% endif %}
              {% if entite.email %}<p>{{ entite.email }}</p>{% endif %}
              {% if entite.siret %}<p>SIRET : {{ entite.siret }}</p>{% endif %}
            </div>
          </div>
        </td>

        <td class="right">
          <div class="doc-right">
            <div class="doc-badge">FACTURE</div>
            <div class="doc-meta">
              <div><strong>N°</strong> {{ facture.numero }}</div>
              <div><strong>Émise le</strong> {{ facture.dateEmission|date('d/m/Y') }}</div>

              {% set st = facture.status.value ?? facture.status %}
              {% if st == 'paid' %}
                <div class="stamp stamp-paid">PAYÉ</div>
              {% elseif st == 'canceled' %}
                <div class="stamp stamp-canceled">ANNULÉE</div>
              {% else %}
                <div class="stamp stamp-due">MONTANT DÛ</div>
              {% endif %}
            </div>
          </div>
        </td>
      </tr>
    </table>

    {% set meta = facture.meta ?? {} %}
    {% set u = facture.destinataire %}
    {% set e = facture.entrepriseDestinataire %}

    <table class="head" cellspacing="0" cellpadding="0">
      <tr>
        <td class="titre" style="width:40%"><b>Informations de facturation</b></td>
        <td style="width:20%; border:none;"></td>
        <td class="titre" style="width:40%"><b>Informations du client</b></td>
      </tr>
      <tr>
        <td style="border:1px solid #edf2f7;">
          <p>
            N° client :
            {% if e %}ENT-{{ e.id ?? '-' }}{% elseif u %}CLI-{{ u.id ?? '-' }}{% else %}-{% endif %}
            <br>

            Paiement dû :
            {{ facture.dateEmission|date_modify(meta.echeance ?? '+30 days')|date('d/m/Y') }}<br>

            Modalité paiement : {{ meta.modalite ?? 'Virement' }}<br>
            {% if facture.inscriptions is defined and facture.inscriptions|length > 0 %}
              {% set datePresta = meta.datePrestation|default(null) %}
              {% if datePresta %}
                Date prestation : {{ datePresta|date('d/m/Y') }}<br>
              {% endif %}
            {% endif %}

            {% if facture.inscriptions is defined and facture.inscriptions|length > 0 %}
              <span style="margin-top:6px; display:inline-block;">
                Réf. inscriptions :
                {% for ins in facture.inscriptions %}
                  #{{ ins.id }}{% if not loop.last %}, {% endif %}
                {% endfor %}
              </span>
            {% elseif facture.inscription is defined and facture.inscription %}
              <span style="margin-top:6px; display:inline-block;">
                Réf. inscription : #{{ facture.inscription.id }}
              </span>
            {% endif %}
          </p>
        </td>

        <td style="border:none;"></td>

        <td style="border:1px solid #edf2f7;text-align:left;">
          {% if e %}
            <strong>{{ e.raisonSociale ?? 'Entreprise' }}</strong><br>
            {% if e.adresse is defined and e.adresse %}{{ e.adresse }}<br>{% endif %}
            {% if e.complement is defined and e.complement %}{{ e.complement }}<br>{% endif %}
            {% set cp_ville = [] %}
            {% if e.codePostal is defined and e.codePostal %}{% set cp_ville = cp_ville|merge([e.codePostal]) %}{% endif %}
            {% if e.ville is defined and e.ville %}{% set cp_ville = cp_ville|merge([e.ville]) %}{% endif %}
            {% if cp_ville is not empty %}{{ cp_ville|join(' ') }}<br>{% endif %}
            {% if e.pays is defined and e.pays %}{{ e.pays }}<br>{% endif %}
            {% if e.emailFacturation is defined and e.emailFacturation %}{{ e.emailFacturation }}{% elseif e.email is defined and e.email %}{{ e.email }}{% endif %}
          {% elseif u %}
            {% set nom_aff = (u.civilite is defined ? u.civilite : '') ~ ' ' ~ (u.prenom is defined ? u.prenom : '') ~ ' ' ~ (u.nom is defined ? u.nom : '') %}
            {{ nom_aff|trim ?: (u.email ?? '-') }}<br>
            {% if u.adresse is defined and u.adresse %}{{ u.adresse }}<br>{% endif %}
            {% if u.complement is defined and u.complement %}{{ u.complement }}<br>{% endif %}
            {% set cp_ville = [] %}
            {% if u.codePostal is defined and u.codePostal %}{% set cp_ville = cp_ville|merge([u.codePostal]) %}{% endif %}
            {% if u.ville is defined and u.ville %}{% set cp_ville = cp_ville|merge([u.ville]) %}{% endif %}
            {% if cp_ville is not empty %}{{ cp_ville|join(' ') }}<br>{% endif %}
            {% if u.pays is defined and u.pays %}{{ u.pays }}<br>{% endif %}
            {% if u.email is defined and u.email %}{{ u.email }}{% endif %}
          {% else %}
            -
          {% endif %}
        </td>
      </tr>
    </table>

    <div class="rule"></div>

    {# ===== LIGNES + REMISES ===== #}
    <table>
      <thead>
        <tr>
          <th style="width:8%">Ref.</th>
          <th style="width:40%">Désignation</th>
          <th style="width:7%" class="num">Qté</th>
          <th style="width:11%" class="num">P.U HT</th>
          <th style="width:12%" class="num">Total HT</th>
          <th style="width:12%" class="num">Remise</th>
          <th style="width:12%" class="num">HT net</th>
          <th style="width:10%" class="num">TVA</th>
        </tr>
      </thead>
      <tbody>
        {% set total_ht_brut = 0 %}
        {% set total_remises_lignes = 0 %}
        {% set total_ht_net = 0 %}
        {% set bases_by_rate = {} %}

        {% for l in facture.lignes %}
          {% set qte = l.qte ?? 0 %}
          {% set pu  = l.puHtCents ?? 0 %}
          {% set line_ht = l.totalHtBrutCents ?? (qte * pu) %}
          {% set line_remise = l.remiseCents ?? 0 %}
          {% set line_ht_net = l.totalHtNetCents ?? (line_ht - line_remise) %}

          {% set tva_rate = l.tva ?? 0 %}
          {% set line_tva = (line_ht_net * tva_rate / 100)|round(0, 'floor') %}

          {% set total_ht_brut = total_ht_brut + line_ht %}
          {% set total_remises_lignes = total_remises_lignes + line_remise %}
          {% set total_ht_net = total_ht_net + line_ht_net %}

          {% set rate_key = (tva_rate|number_format(2, '.', '')) %}
          {% set bases_by_rate = bases_by_rate|merge({
            (rate_key): (bases_by_rate[rate_key]|default(0) + line_ht_net)
          }) %}

          {# split main + détails #}
          {% set raw = (l.label ?? '')|replace({"\r\n":"\n", "\r":"\n"}) %}
          {% set parts = raw|split("\n") %}
          {% set main = (parts|first)|default('')|trim %}
          {% set details = parts|slice(1) %}

          <tr class="{% if details|length == 0 %}line-end{% else %}line-main{% endif %}">
            <td><span class="ref">{{ l.id ?? '-' }}</span></td>
            <td>{{ main }}</td>
            <td class="num">{{ qte }}</td>
            <td class="num">{{ m.eur(pu) }}</td>
            <td class="num">{{ m.eur(line_ht) }}</td>

            <td class="num">
              {% if line_remise > 0 %}
                -{{ m.eur(line_remise) }}
                {% if l.remisePourcent is not null and l.remisePourcent > 0 %}
                  <span class="muted">({{ m.pct(l.remisePourcent) }})</span>
                {% endif %}
              {% else %}
                -
              {% endif %}
            </td>

            <td class="num">{{ m.eur(line_ht_net) }}</td>
            <td class="num">{{ m.eur(line_tva) }}</td>
          </tr>

          {% for d in details %}
            {% set d = d|trim %}
            {% if d != '' %}
              <tr class="detail-row {% if loop.last %}line-end{% endif %}">
                <td></td>
                <td class="detail-text">- {{ d }}</td>
                <td></td><td></td><td></td><td></td><td></td><td></td>
              </tr>
            {% endif %}
          {% endfor %}

        {% else %}
          <tr><td colspan="8" class="muted">Aucune ligne de facture</td></tr>
        {% endfor %}
      </tbody>

    </table>

    {# ===== REMISE GLOBALE ===== #}
    {% set rg_pct   = facture.remiseGlobalePourcent ?? null %}
    {% set rg_cents = facture.remiseGlobaleMontantCents ?? null %}

    {% set remise_globale = 0 %}
    {% if rg_cents is not null and rg_cents > 0 %}
      {% set remise_globale = rg_cents %}
    {% elseif rg_pct is not null and rg_pct > 0 %}
      {% set remise_globale = (total_ht_net * rg_pct / 100)|round(0, 'floor') %}
    {% endif %}

    {% if remise_globale > total_ht_net %}{% set remise_globale = total_ht_net %}{% endif %}

    {% set total_ht_apres_rg = total_ht_net - remise_globale %}

    {# ===== TVA APRÈS REMISE GLOBALE (prorata par taux) ===== #}
    {% set total_tva_after_rg = 0 %}
    {% for rate_key, base_ht_net in bases_by_rate %}
      {% set rate = rate_key + 0 %}

      {% set base_after = base_ht_net %}
      {% if remise_globale > 0 and total_ht_net > 0 %}
        {% set share = (remise_globale * base_ht_net / total_ht_net)|round(0, 'floor') %}
        {% set base_after = base_ht_net - share %}
        {% if base_after < 0 %}{% set base_after = 0 %}{% endif %}
      {% endif %}

      {% set tva_rate_amount = (base_after * rate / 100)|round(0, 'floor') %}
      {% set total_tva_after_rg = total_tva_after_rg + tva_rate_amount %}
    {% endfor %}

    {# ===== DÉBOURS ===== #}
    {# Garde uniquement le champ qui existe réellement dans ton entité #}
    {% set debours_cents =
      facture.deboursCents
        ?? facture.montantDeboursCents
        ?? meta.deboursCents
        ?? 0
    %}

    {% set total_ttc_calc = total_ht_apres_rg + total_tva_after_rg %}
    {% set total_a_payer_calc = total_ttc_calc + debours_cents %}

    {# affichage : si la facture est "figée" (montants > 0), on affiche les champs, sinon on affiche le calcul #}
    {% set ht_display = (facture.montantHtCents is defined and facture.montantHtCents > 0) ? facture.montantHtCents : total_ht_apres_rg %}
    {% set tva_display = (facture.montantTvaCents is defined and facture.montantTvaCents > 0) ? facture.montantTvaCents : total_tva_after_rg %}
    {% set ttc_display = (facture.montantTtcCents is defined and facture.montantTtcCents > 0) ? facture.montantTtcCents : total_ttc_calc %}

    {# si tu as déjà un champ figé pour le total avec débours, utilise-le ici #}
    {% set total_a_payer_display =
      (facture.montantTotalCents is defined and facture.montantTotalCents > 0)
        ? facture.montantTotalCents
        : (ttc_display + debours_cents)
    %}

    {# ===== TOTAUX ===== #}
    <table class="totaux" cellspacing="0" cellpadding="0">
      <tr>
        <td style="border:none" style="width:50%"></td>
        <td class="label" style="width:20%">Total HT (brut)</td>
        <td class="val" style="width:30%">{{ m.eur(total_ht_brut) }}</td>
      </tr>

      {% if total_remises_lignes > 0 %}
        <tr>
          <td style="border:none"></td>
          <td class="label">Remises lignes</td>
          <td class="val">-{{ m.eur(total_remises_lignes) }}</td>
        </tr>
      {% endif %}

      {% if remise_globale > 0 %}
        <tr>
          <td style="border:none"></td>
          <td class="label">
            Remise globale
            {% if rg_pct is not null and rg_pct > 0 %}
              <span class="muted">({{ m.pct(rg_pct) }})</span>
            {% endif %}
          </td>
          <td class="val">-{{ m.eur(remise_globale) }}</td>
        </tr>
      {% endif %}

      <tr>
        <td style="border:none"></td>
        <td class="label">Total HT (net)</td>
        <td class="val">{{ m.eur(ht_display) }}</td>
      </tr>

      {% if bases_by_rate|length > 1 %}
        {% for rate_key, base_ht_net in bases_by_rate %}
          {% set rate = rate_key + 0 %}
          {% set base_after = base_ht_net %}
          {% if remise_globale > 0 and total_ht_net > 0 %}
            {% set share = (remise_globale * base_ht_net / total_ht_net)|round(0, 'floor') %}
            {% set base_after = base_ht_net - share %}
            {% if base_after < 0 %}{% set base_after = 0 %}{% endif %}
          {% endif %}
          {% set tva_rate_amount = (base_after * rate / 100)|round(0, 'floor') %}

          <tr>
            <td style="border:none"></td>
            <td class="label">TVA {{ rate|number_format(2, ',', ' ') }}%</td>
            <td class="val">{{ m.eur(tva_rate_amount) }}</td>
          </tr>
        {% endfor %}
      {% else %}
        <tr>
          <td style="border:none"></td>
          <td class="label">Montant TVA</td>
          <td class="val">{{ m.eur(tva_display) }}</td>
        </tr>
      {% endif %}

      <tr>
        <td style="border:none"></td>
        <td class="label">Total TTC</td>
        <td class="val">{{ m.eur(ttc_display) }}</td>
      </tr>

      {% if debours_cents > 0 %}
        <tr>
          <td style="border:none"></td>
          <td class="label">Frais de débours</td>
          <td class="val">{{ m.eur(debours_cents) }}</td>
        </tr>
      {% endif %}

      <tr>
        <td style="border:none"></td>
        <td class="label total titre">Total à payer</td>
        <td class="val total titre">{{ m.eur(total_a_payer_display) }}</td>
      </tr>
    </table>
  </div>
</div>




{% set meta = facture.meta ?? {} %}
{% set noteText = (meta.note is defined and meta.note) ? meta.note : 'Merci pour votre confiance.' %}

<div class="footer-wrapper">
  <div class="footer-note">{{ noteText }}</div>

  {% if entite.banque %}
    <div class="footer-banque">
      <div class="footer-banque-title">Informations bancaires</div>

      <table style="width:100%; border-collapse:collapse; font-size:9.3px;">
        <tr>
          <td style="width:50%; padding:2px 4px; text-align:left;">
            {% if entite.banque %}<strong>Banque :</strong> {{ entite.banque }}<br>{% endif %}
            {% if entite.codeBanque %}<strong>Code :</strong> {{ entite.codeBanque }}<br>{% endif %}
            {% if entite.numeroCompte %}<strong>N° compte :</strong> {{ entite.numeroCompte }}{% endif %}
          </td>

          <td style="width:50%; padding:2px 4px; text-align:left;">
            {% if entite.iban %}<strong>IBAN :</strong> {{ entite.iban }}<br>{% endif %}
            {% if entite.bic %}<strong>BIC :</strong> {{ entite.bic }}<br>{% endif %}
            {% if entite.siret %}<strong>SIRET :</strong> {{ entite.siret }}{% endif %}
            {% if entite.numeroTva %}<br><strong>TVA :</strong> {{ entite.numeroTva }}{% endif %}
          </td>
        </tr>
      </table>
    </div>
  {% endif %}
</div>

</body>
</html>
