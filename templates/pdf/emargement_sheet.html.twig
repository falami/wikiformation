{# templates/pdf/emargement_sheet.html.twig #}
{% set entite = meta.entite ?? null %}
{% set brand = {
  primary:   (entite and entite.couleurPrincipal  is defined and entite.couleurPrincipal)  ? entite.couleurPrincipal  : '#1e3a5f',
  secondary: (entite and entite.couleurSecondaire is defined and entite.couleurSecondaire) ? entite.couleurSecondaire : '#4ba3ff',
  accent:    (entite and entite.couleurSecondaire is defined and entite.couleurSecondaire) ? entite.couleurSecondaire : '#d4a574',
  ink:       '#0f2336',
  text:      '#1e2d3d',
  muted:     '#5a6b7d',
  line:      '#dce4ed',
  soft:      '#f8fafc',
  paper:     '#ffffff',
  zebra:     '#fbfdff'
} %}

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Feuille d’émargement- {{ meta.titre }}</title>

  <style>
    
    @page { margin: 10mm 5mm 0mm; size: A4 landscape; }



    body{
      font-family: DejaVu Sans, Helvetica, Arial, sans-serif;
      color: {{ brand.text }};
      font-size: 10pt;
      line-height: 1.28;
      padding: 0;
      margin: 0;
    }

    /* ===== Helpers ===== */
    strong{ font-weight: 900; color: {{ brand.ink }}; }
    .text-muted{ color: {{ brand.muted }}; }
    .text-small{ font-size: 8.7pt; }
    .text-tiny{ font-size: 8pt; color: {{ brand.muted }}; }
    .avoid-break{ page-break-inside: avoid; }
    .page{ padding: 0 1mm; }

    /* ===== Header ===== */
    .header{
      width:100%;
      padding-bottom: 3pt;
      margin-bottom: 4pt;
      page-break-inside: avoid;
    }
    .header-table{ width:100%; border-collapse: collapse; }
    .header-left{ width:68%; vertical-align: top; padding-right: 10pt; }
    .header-right{ width:32%; vertical-align: top; text-align:right; }

    .brand-row{ width:100%; border-collapse: collapse; }
    .logo{ height: 120pt; width:auto; }
    .doc-title{
      font-size: 15.5pt;
      font-weight: 900;
      color: {{ brand.primary }};
      letter-spacing: .2pt;
      text-transform: uppercase;
      margin-bottom: 2pt;
    }
    .header-bar{
      height: 2pt;
      width: 150pt;
      background: {{ brand.accent }};
      margin-top: 4pt;
    }

    .doc-badge{
      display:inline-block;
      background: {{ brand.primary }};
      color:#fff;
      font-weight: 900;
      font-size: 11pt;
      letter-spacing: .9pt;
      padding: 6pt 9pt;
      border-radius: 6pt;
      text-transform: uppercase;
      border: 1pt solid rgba(255,255,255,0.18);
      text-align:center;
      white-space: nowrap;
    }
    .doc-meta{
      margin-top: 6pt;
      font-size: 8.8pt;
      color: {{ brand.muted }};
      line-height: 1.38;
    }
    .doc-meta div{ margin-bottom: 2pt; }
    .doc-meta strong{ color: {{ brand.ink }}; }

    .qualiopi{
      margin-top: 6pt;
      background: {{ brand.soft }};
      border: 1pt solid {{ brand.line }};
      border-left: 3pt solid {{ brand.primary }};
      border-radius: 7pt;
      padding: 6pt 8pt;
      text-align:left;
      width: 290px;
    }
    .qualiopi-title{ font-weight: 900; color: {{ brand.ink }}; font-size: 8.6pt; }
    .qualiopi-sub{ font-size: 7.9pt; color: {{ brand.muted }}; margin-top: 2pt; }
    .qualiopi-logo{ height: 20pt; width:auto; margin-top: 4pt; }

    /* ===== Card ===== */
    .card{
      background: {{ brand.paper }};
      border: 1pt solid {{ brand.line }};
      border-left: 3pt solid {{ brand.primary }};
      border-radius: 7pt;
      padding: 8pt 10pt;
      margin-bottom: 8pt;
      page-break-inside: avoid;
    }
    .card-highlight{
      background: {{ brand.soft }};
      border-left-color: {{ brand.primary }};
    }

    .section-title{
      font-size: 9.6pt;
      font-weight: 900;
      color: {{ brand.primary }};
      text-transform: uppercase;
      letter-spacing: .7pt;
      margin: 0 0 7pt;
      padding-bottom: 5pt;
      border-bottom: 1pt solid #eef2f6;
    }
    .section-title-accent{
      width: 44pt;
      height: 2pt;
      background: {{ brand.accent }};
      margin-top: -2pt;
    }

    /* ===== Infos grid ===== */
    .info-grid{ width:100%; border-collapse: collapse; }
    .info-grid td{ vertical-align: top; }
    .info-label{
      display:block;
      font-size: 8pt;
      font-weight: 900;
      color: {{ brand.ink }};
      text-transform: uppercase;
      letter-spacing: .45pt;
      margin-bottom: 2pt;
    }
    .info-content{
      font-size: 9.6pt;
      color: {{ brand.text }};
      line-height: 1.35;
    }
    .pill{
      display:inline-block;
      margin-top: 1mm;
      padding: 2pt 6pt;
      border-radius: 999pt;
      border: 1pt solid {{ brand.line }};
      background: rgba(75,163,255,.08);
      color: {{ brand.ink }};
      font-weight: 900;
      font-size: 8pt;
      line-height: 1.1;
      white-space: nowrap;
    }

    /* ===== Tables ===== */
    table{ border-collapse: collapse; }
    .table{
      width:100%;
      border-collapse: collapse;
      font-size: 8.8pt;
      margin-top: 6pt;
    }
    .table th, .table td{
      border: 1pt solid {{ brand.line }};
      padding: 5pt 6pt;               /* ✅ plus dense */
      vertical-align: middle;
      text-align: center;
    }
    .table th{
      background: {{ brand.soft }};
      color: {{ brand.ink }};
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: .33pt;
      font-size: 8pt;
      line-height: 1.15;
      white-space: nowrap;
    }
    .table tbody tr:nth-child(even) td{ background: {{ brand.zebra }}; }

    .col-left{ text-align:left; }
    .dash{ color: {{ brand.muted }}; }

    /* ===== Day band inside table (premium + compact) ===== */
    .day-row td{
      background: {{ brand.soft }} !important;
      border-top: 2pt solid {{ brand.primary }} !important;
      text-align:left;
      padding: 6pt 7pt !important;
    }
    .day-title{ font-weight: 900; color: {{ brand.ink }}; font-size: 9.2pt; }
    .day-sub{ margin-top: 2pt; font-size: 8.2pt; color: {{ brand.muted }}; }

    /* Signature images */
    .sign{
      width: 105px;
      height: 34px;
      object-fit: contain;
      display: block;
      margin: 0 auto;
    }

    /* ===== Footer ===== */
    .footer{
      margin-top: 8pt;
      padding-top: 7pt;
      page-break-inside: avoid;
    }
    .footer-table{ width:100%; border-collapse: collapse; }
    .footer-left{ width:65%; vertical-align: top; }
    .footer-right{ width:35%; vertical-align: top; text-align:right; }
    .sig-line{
      display:inline-block;
      width: 220pt;
      border-bottom: 1pt solid {{ brand.ink }};
      height: 13pt;
      margin-top: 5pt;
    }

    /* ✅ Pagination Dompdf (texte) */
    .page-number{
      position: fixed;
      bottom: 6mm;
      right: 12mm;
      font-size: 8pt;
      color: {{ brand.muted }};
    }


    /* Optionnel : si tu veux une marge différente sur la 1ère page */
    @page:first{
      margin-top: 10mm;         /* tu peux la mettre identique ou différente */
    }

    .table-stagiaire{
      text-align:center;
    }


    body{ font-size: 9.4pt; line-height: 1.18; }  /* densité */

    .card{ padding: 6pt 8pt; margin-bottom: 6pt; }
    .section-title{ margin: 0 0 5pt; padding-bottom: 4pt; font-size: 9.2pt; }

    .table{ font-size: 8.4pt; margin-top: 0; }
    .table th, .table td{ padding: 3.6pt 4.5pt; } /* gain énorme */
    .table th{ font-size: 7.8pt; }

    .sign{ width: 92px; height: 26px; }           /* signatures compactes */

    .footer{ margin-top: 6pt; padding-top: 6pt; }


    .sig-box-org{
      display:inline-block;
      width: 180pt;
      height: 44pt;
      border: 1pt dashed {{ brand.line }};
      border-radius: 7pt;
      background: #fff;
      padding: 4pt 6pt;
      text-align:center;
      vertical-align: top;
    }
    .sig-box-org.is-filled{
      border-style: solid;
      background: {{ brand.soft }};
    }
    .sig-img-org{
      height: 28pt;
      max-width: 100%;
      object-fit: contain;
      display:block;
      margin: 0 auto;
    }
    .sig-meta-org{
      margin-top: 2pt;
      font-size: 7.6pt;
      color: {{ brand.muted }};
      line-height: 1.1;
    }


    /* ===== Session block ultra-compact ===== */
    .session-card{ padding:5pt 7pt !important; margin-bottom:6pt !important; }
    .session-title{ margin:0 0 4pt !important; padding:0 0 3pt !important; font-size:9pt !important; }
    .session-title .section-title-accent{ display:none !important; } /* supprime la barre sous le titre */

    .session-grid{ width:100%; border-collapse:collapse; }
    .session-grid td{ vertical-align:top; padding:0 !important; } /* ✅ supprime les gros espacements */
    .session-item{ padding-right:10pt !important; }
    .session-label{
      display:block;
      font-size:7.4pt;
      font-weight:900;
      color: {{ brand.ink }};
      text-transform:uppercase;
      letter-spacing:.35pt;
      margin:0 0 1pt !important;
      line-height:1.05;
    }
    .session-value{
      font-size:8.9pt;
      line-height:1.1;
    }
    .session-inline{
      font-size:8.7pt;
      line-height:1.1;
    }
    .session-pill{
      display:inline-block;
      padding:1.5pt 5pt;
      border-radius:999pt;
      border:1pt solid {{ brand.line }};
      background: rgba(75,163,255,.08);
      color: {{ brand.ink }};
      font-weight:900;
      font-size:7.4pt;
      line-height:1;
      white-space:nowrap;
      vertical-align:baseline;
    }



    /* ✅ Autorise la coupure sur plusieurs pages (spécial Dompdf) */
    .card.breakable{
      page-break-inside: auto !important;
    }

    /* ✅ Autorise la table à se couper correctement */
    .table.breakable{
      page-break-inside: auto !important;
    }

    /* ✅ Répéter le THEAD sur chaque page (Dompdf) */
    .table.breakable thead{
      display: table-header-group;
    }
    .table.breakable tfoot{
      display: table-footer-group;
    }

    /* ✅ Évite qu'une ligne “Jour : …” se retrouve seule en bas de page */
    tr.day-row{
      page-break-inside: avoid;
      page-break-after: auto;
    }



  </style>
</head>

<body>
  <div class="page">
  {% set preferences = entite and entite.preferences is defined ? entite.preferences : null %}


    {# ===== Header ===== #}
    <div class="header avoid-break">
      <table class="header-table">
        <tr>
          <td class="header-left">
            <table class="brand-row">
              <tr>
                <td style="width:56pt; vertical-align:top;">
                  {% if entite.logo %}
                    <img class="logo"
                      src="{{ absolute_url(asset('uploads/photos/entite/logo/' ~ entite.logo)) }}"
                      alt="Logo {{ entite.nom|default('') }}">
                  {% endif %}
                </td>
                <td style="vertical-align:top;">
                  <div class="doc-title">Feuille d’émargement</div>
                  <div class="text-small text-muted">
                    <strong>{{ meta.entite.nom|default('Organisme de formation') }}</strong>
                    {% if meta.entite.ville %} · {{ meta.entite.ville }}{% endif %}
                  </div>

                  {% if meta.entite.siret is defined and meta.entite.siret %}
                    <div class="text-tiny">SIRET : {{ meta.entite.siret }}</div>
                  {% endif %}
                  {% if meta.entite.numeroDeclarant is defined and meta.entite.numeroDeclarant %}
                    <div class="text-tiny">N° de déclaration d’activité : {{ meta.entite.numeroDeclarant }}</div>
                  {% endif %}
                  <div class="header-bar"></div>
                  <div class="qualiopi">
                    <div class="qualiopi-title">Organisme certifié <span style="color:{{ brand.primary }};">Qualiopi</span></div>
                    <div class="qualiopi-sub">Actions de formation- Référentiel national qualité</div>
                    {% if meta.qualiopiLogoPath is defined and meta.qualiopiLogoPath %}
                      <img src="{{ absolute_url(asset(meta.qualiopiLogoPath)) }}" alt="Qualiopi" class="qualiopi-logo">
                    {% endif %}
                  </div>
                </td>
              </tr>
            </table>
          </td>

          <td class="header-right">
            <div class="doc-badge">ÉMARGEMENT</div>
            <div class="doc-meta">
              <div><strong>Référence :</strong> {{ meta.code ?? '-' }}</div>
              <div><strong>Formation :</strong> {{ meta.titre ?? '-' }}</div>
              <div><strong>Édition :</strong> {{ "now"|date('d/m/Y') }}</div>
            </div>
          </td>
        </tr>
      </table>
    </div>

    {# ===== Infos session (1 seule card compacte) ===== #}
    <div class="card card-highlight avoid-break session-card">
      <div class="section-title session-title">
        Informations de la session
        <div class="section-title-accent"></div>
      </div>

      <table class="session-grid">
        <tr>
          <td class="session-item" style="width:10%;">
            <span class="session-label">Réf.</span>
            <div class="session-value"><strong>{{ meta.code ?? '-' }}</strong></div>
          </td>

          <td class="session-item" style="width:32%;">
            <span class="session-label">Intitulé</span>
            <div class="session-value"><strong>{{ meta.titre ?? '-' }}</strong></div>
          </td>

          <td class="session-item" style="width:23%;">
            <span class="session-label">Période</span>
            <div class="session-inline">
              
              <div>Du <strong>{{ meta.dateDebut ?? '-' }}</strong> au <strong>{{ meta.dateFin ?? '-' }}</strong></div>
              <div>
                {% if meta.jours is defined %}
                ({{ meta.jours }} jour{% if meta.jours > 1 %}s{% endif %})
              {% endif %}
              </div>
            </div>
          </td>

          <td style="width:35%;">
            <span class="session-label">Lieu</span>
            <div class="session-value">{{ meta.adresse ?? '-' }}</div>
          </td>
        </tr>
      </table>
    </div>


{# ===== Participants (table cassable) ===== #}
<div class="card breakable" style="padding:6pt 8pt; margin-bottom:6pt;">
  <div class="section-title" style="margin-bottom:5pt; padding-bottom:4pt;">
    Liste des participants par jour
    <div class="section-title-accent"></div>
  </div>

  <table class="table breakable" style="margin-top:0; font-size:8.4pt;">
    <thead>
      <tr>
        <th style="width:10%;">Date</th>
        <th style="width:30%;">Nom et prénom</th>
        <th style="width:18%;">Société</th>
        <th style="width:12%;">Naissance<br><span class="text-tiny">(SST/CACES)</span></th>
        <th style="width:15%;">Matin</th>
        <th style="width:15%;">Après-midi</th>
      </tr>
    </thead>

    <tbody>
      {% for j in meta.joursList %}
        {% set rows = linesByDate[j.ymd] ?? [] %}

        {# Bandeau jour #}
        <tr class="day-row">
          <td colspan="6"
              style="text-align:left; background:{{ brand.soft }}; border-top:2pt solid {{ brand.primary }}; padding:4pt 6pt;">
            <strong>Jour :</strong> {{ j.label }}
            <span class="text-tiny">
              - Horaires : {{ (j.debut ?? '-') ~ ' à ' ~ (j.fin ?? '-') }}
            </span>
          </td>
        </tr>

        {% if rows is empty %}
          <tr>
            <td class="text-muted">{{ j.label }}</td>
            <td colspan="5" class="text-muted" style="text-align:left;">Aucune signature enregistrée pour ce jour.</td>
          </tr>
        {% else %}
          {% for r in rows %}
            <tr>
              <td>{{ j.label }}</td>

              <td class="col-left">
                <strong>{{ r.name }}</strong>
                {% if r.isTrainer %}
                  <span class="text-tiny"> · Formateur</span>
                {% endif %}
              </td>

              <td>
                  {% if r.raisonSociale %}
                    {{ r.raisonSociale }}
                  {% else %} 
                    - 
                  {% endif %}
              </td>
              <td>{{ r.naissance ?? '-' }}</td>

              <td>
                {% if r.am is defined and r.am.signed %}
                  <img class="sign" style="width:92px; height:26px;" src="{{ r.am.img }}" alt="AM">
                {% else %}
                  <span class="dash">-</span>
                {% endif %}
              </td>

              <td>
                {% if r.pm is defined and r.pm.signed %}
                  <img class="sign" style="width:92px; height:26px;" src="{{ r.pm.img }}" alt="PM">
                {% else %}
                  <span class="dash">-</span>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        {% endif %}
      {% endfor %}
    </tbody>
  </table>
</div>



    {# ===== Footer ===== #}
    <div class="footer avoid-break">
      <table class="footer-table">
        <tr>
          <td class="footer-left">
            <div class="text-small">
              Certifié exact par <strong>{{ meta.entite.nom|default('Organisme de formation') }}</strong>
            </div>

            {% if meta.entite.createur is defined and meta.entite.createur %}
              <div style="margin-top:5pt;">
                {{ meta.entite.createur.civilite }} {{ meta.entite.createur.prenom }} {{ meta.entite.createur.nom }}
              </div>
            {% endif %}

            <div class="text-small text-muted" style="margin-top:5pt;">
              Le : {{ meta.dateFin ?? '-' }}
            </div>
          </td>

          <td class="footer-right">
            <div class="text-small text-muted">Signature / cachet (organisme)</div>

            <div class="sig-box-org {% if preferences and preferences.signatureOrganismePath %}is-filled{% endif %}">
              {% if preferences and preferences.signatureOrganismePath %}
                <img class="sig-img-org"
                    src="{{ absolute_url(asset(preferences.signatureOrganismePath|trim('/'))) }}"
                    alt="Signature organisme">
                <div class="sig-meta-org">
                  {% if preferences.signatureOrganismeAt %}
                    Signé le {{ preferences.signatureOrganismeAt|date('d/m/Y') }}
                  {% else %}
                    Signature configurée
                  {% endif %}
                </div>
              {% else %}
                <div class="sig-meta-org" style="margin-top:16pt;">(non configurée)</div>
              {% endif %}
            </div>
          </td>

        </tr>
      </table>
    </div>

  </div>

  {# ✅ Page number Dompdf #}
  <div class="page-number">
    <script type="text/php">
      if (isset($pdf)) {
        $font = $fontMetrics->get_font("DejaVu Sans", "normal");
        $pdf->page_text(760, 565, "Page {PAGE_NUM} / {PAGE_COUNT}", $font, 8, array(90, 107, 125));
      }
    </script>
  </div>

</body>
</html>
