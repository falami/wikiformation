{# templates/base_public.html.twig #}
{% set brand = public_branding() %}

<!DOCTYPE html>
<html lang="{{ app.request.locale|default('fr') }}">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>{% block title %}{{ brand.name }} - Plateforme de formation{% endblock %}</title>

    <meta name="description" content="{% block meta_description %}Plateforme de gestion et de diffusion de formations.{% endblock %}">
    <meta name="author" content="{{ brand.name }}">

    {% set has_query_search = app.request.query.has('q') and app.request.query.get('q') is not empty %}
    {% if has_query_search %}
      <meta name="robots" content="noindex, nofollow">
    {% else %}
      <meta name="robots" content="index, follow">
    {% endif %}

    {% set canonical_url = absolute_url(app.request.pathInfo) %}
    <link rel="canonical" href="{{ canonical_url }}">

    {% set route = app.request.attributes.get('_route') %}
    {% set params = app.request.attributes.get('_route_params')|default({}) %}
    {% set supported_locales = ['fr', 'en'] %}
    {% if route %}
      {% for loc in supported_locales %}
        <link rel="alternate" hreflang="{{ loc }}" href="{{ absolute_url(path(route, params|merge({'_locale': loc}))) }}">
      {% endfor %}
      <link rel="alternate" hreflang="x-default" href="{{ absolute_url(path(route, params|merge({'_locale': 'fr'}))) }}">
    {% endif %}

    {% set og_title = block('og_title') is defined ? block('og_title') : block('title') %}
    {% set og_desc  = block('og_desc') is defined ? block('og_desc') : block('meta_description') %}
    {% set og_img   = block('og_image') is defined ? block('og_image') : absolute_url(asset(brand.logo)) %}
    {% set og_url   = canonical_url %}

    <meta property="og:title" content="{{ og_title|striptags }}">
    <meta property="og:description" content="{{ og_desc|striptags }}">
    <meta property="og:image" content="{{ og_img }}">
    <meta property="og:url" content="{{ og_url }}">
    <meta property="og:type" content="website">
    <meta property="og:locale" content="{{ app.request.locale == 'en' ? 'en_GB' : 'fr_FR' }}">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ og_title|striptags }}">
    <meta name="twitter:description" content="{{ og_desc|striptags }}">
    <meta name="twitter:image" content="{{ og_img }}">

    {# Favicons #}
    <link rel="icon" type="image/png" href="{{ asset(brand.logo) }}">
    <link rel="apple-touch-icon" href="{{ asset(brand.logo) }}">

    {# Perf #}
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    {# CSS vendors #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
    <link href="//maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

    <style>
      :root{
        --theme-color-principal: {{ brand.primaryColor }};
        --theme-color-secondaire: {{ brand.secondaryColor }};
        --theme-color-tertiaire: {{ brand.tertiaryColor }};
        --theme-color-quaternaire: {{ brand.quaternaryColor }};
      }

      html { scroll-behavior: smooth; }
      body { font-family: Arial, sans-serif; background:#f8f9fa; color:#333; }
      .navbar { background:#212529; }
      .nav-link { color:#fff !important; }
      .card-header { background:var(--theme-color-principal); color:#fff; }
      .hero{
        background:url("{{ asset('dist/img/accueil.jpg') }}") no-repeat center/cover;
        min-height:50vh;
        display:flex;
        align-items:center;
        justify-content:center;
        text-align:center;
        color:#fff;
        position:relative;
      }
      .hero::before{
        content:"";
        position:absolute;
        inset:0;
        background:rgba(0,0,0,.6);
      }
      .hero .container{ position:relative; z-index:1; }

      .section-title{
        font-size:2rem;
        margin-bottom:20px;
        font-weight:700;
        color:var(--theme-color-principal) !important;
      }

      .testimonial{
        background:#fff;
        padding:20px;
        border-radius:8px;
        box-shadow:0 4px 6px rgba(0,0,0,.1);
      }

      .card{
        border:none;
        border-radius:15px;
        box-shadow:0 4px 12px rgba(0,0,0,.1);
        transition:.3s;
      }

      .card:hover{
        transform:translateY(-10px);
        box-shadow:0 8px 24px rgba(0,0,0,.2);
      }

      .btn-primary-dive{
        color:#fff;
        background:var(--theme-color-secondaire);
        border:none;
        border-radius:25px;
        padding:.5rem 1.5rem;
        font-size:.9rem;
      }

      .bg-theme{ background:var(--theme-color-principal); }
      main{ margin-top:56px; }

      .footer-modern{
        background:linear-gradient(135deg, var(--theme-color-principal), #0f1b28 70%);
        position:relative;
        overflow:hidden;
      }

      .footer-modern::before{
        content:"";
        position:absolute;
        top:-80px;
        left:-100px;
        width:200%;
        height:200px;
        background:radial-gradient(circle at 50% 50%, rgba(255,255,255,.05), transparent 70%);
        animation:waveMove 12s infinite linear;
      }

      @keyframes waveMove{
        0%{transform:translateX(0)}
        100%{transform:translateX(-50%)}
      }

      .footer-modern h6,
      .footer-modern h5{
        color:var(--theme-color-secondaire);
      }

      .footer-modern a{
        color:rgba(255,255,255,.8);
        text-decoration:none;
        transition:.3s;
      }

      .footer-modern a:hover{
        color:var(--theme-color-secondaire);
        transform:translateX(3px);
      }

      .footer-modern .social-link{
        color:rgba(255,255,255,.85);
        font-size:1.4rem;
        transition:.3s;
      }

      .footer-modern .social-link:hover{
        color:var(--theme-color-secondaire);
        transform:scale(1.1);
      }

      .footer-modern .footer-form .form-control{
        background:rgba(255,255,255,.05);
        color:#fff;
        border:1px solid rgba(255,255,255,.2);
      }

      .footer-modern .footer-form .form-control:focus{
        background:rgba(255,255,255,.1);
        border-color:var(--theme-color-secondaire);
        box-shadow:none;
        color:#fff;
      }

      .footer-modern .btn-theme{
        background:var(--theme-color-secondaire);
        color:#001f3f;
        border:none;
        border-radius:50px;
        transition:.3s;
      }

      .footer-modern .btn-theme:hover{
        background:#fff;
        color:var(--theme-color-principal);
      }

      .footer-logo{
        max-width: 140px;
        max-height: 60px;
        width: auto;
        height: auto;
        object-fit: contain;
      }
    </style>

    <script src="{{ asset('dist/js/cookie-consent.js') }}"></script>

    {# JSON-LD adapté #}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "{{ brand.name|e('js') }}",
      "url": "{{ absolute_url('/') }}",
      "logo": "{{ absolute_url(asset(brand.logo)) }}"
    }
    </script>

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "url": "{{ absolute_url('/') }}",
      "name": "{{ brand.name|e('js') }}"
    }
    </script>

    {% block stylesheets %}{% endblock %}

    {% if app.request.cookies.get('cookieConsent') == 'accepted' and not brand.hasCustomHost %}
      <script async src="https://www.googletagmanager.com/gtag/js?id=G-1WB960CZ37"></script>
      <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){ dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', 'G-1WB960CZ37');
      </script>
    {% endif %}
  </head>

  <body>
    {% include '_cookie_consent.html.twig' %}

    <main>
      <div class="content">
        {% block body %}
          <h1 class="visually-hidden">{{ brand.name }}</h1>
          <p class="visually-hidden">Plateforme de gestion et diffusion de formations.</p>
        {% endblock %}
      </div>
    </main>

    <footer class="footer-modern text-light pt-5 pb-3 mt-5">
      <div class="container">
        <div class="row gy-4">
          <div class="col-lg-4 col-md-6">
            <h5 class="fw-bold mb-3 d-flex align-items-center gap-2">
              <img class="footer-logo" src="{{ asset(brand.logo) }}" alt="Logo {{ brand.name }}">
            </h5>

            <p class="text-light-50 small mb-3">
              {{ brand.name }}
            </p>

            {% if not brand.hasCustomHost %}
              <div class="d-flex gap-3 mt-3">
                <a href="https://www.facebook.com/wikiformation" class="social-link" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                <a href="https://www.instagram.com/wikiformation" class="social-link" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
              </div>
            {% endif %}
          </div>

          <div class="col-lg-2 col-md-6">
            <h6 class="fw-semibold text-uppercase mb-3">Navigation</h6>
            <ul class="list-unstyled small">
              {% if brand.homeUrl %}
                <li><a href="{{ brand.homeUrl }}"><i class="bi bi-chevron-right"></i> Accueil</a></li>
              {% elseif not brand.hasCustomHost %}
                <li><a href="{{ path('app_public') }}"><i class="bi bi-chevron-right"></i> Accueil</a></li>
              {% endif %}

              <li><a href="{{ path('app_public_formation') }}"><i class="bi bi-chevron-right"></i> Formation</a></li>
              <li><a href="{{ path('app_public_catalogue') }}"><i class="bi bi-chevron-right"></i> Catalogue</a></li>

              {% if brand.showContact %}
                <li><a href="{{ path('app_public_contact') }}"><i class="bi bi-chevron-right"></i> Contact</a></li>
              {% endif %}
            </ul>
          </div>

          {% if not brand.hasCustomHost %}
            <div class="col-lg-3 col-md-6">
              <h6 class="fw-semibold text-uppercase mb-3">Informations</h6>
              <ul class="list-unstyled small">
                <li><a href="{{ path('app_public_politique_confidentialite') }}">Politique de confidentialité</a></li>
                <li><a href="{{ path('app_public_mentions_legales') }}">Mentions légales</a></li>
                <li><a href="{{ path('app_public_cgv') }}">CGV</a></li>
                <li><a href="{{ path('app_public_cgu') }}">CGU</a></li>
                <li><a href="#" id="manage-cookies">Cookies</a></li>
              </ul>
            </div>
          {% endif %}

          {% if brand.showContact %}
            <div class="col-lg-3 col-md-6">
              <h6 class="fw-semibold text-uppercase mb-3">Contact</h6>
              {{ render(path('app_public_footer_contact_form')) }}
            </div>
          {% endif %}
        </div>

        <hr class="border-secondary mt-5 mb-3">

        <div class="text-center small text-light-50">
          © {{ "now"|date("Y") }} <span class="fw-semibold">{{ brand.name }}</span>
        </div>
      </div>
    </footer>

    {% block javascripts %}{% endblock %}

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    {% if not brand.hasCustomHost %}
      <script src="https://www.google.com/recaptcha/api.js?render=6Lejf08sAAAAACFzxVGzBQRBElyWiar71PZwIH3q"></script>
      <script>
        document.addEventListener('DOMContentLoaded', () => {
          const form = document.querySelector('form.footer-form') || document.querySelector('form[name="contact"]');
          if (!form) return;

          const captchaInput = form.querySelector('input[name$="[captcha]"]');
          if (!captchaInput) return;

          form.addEventListener('submit', async (e) => {
            if (captchaInput.value) return;

            e.preventDefault();

            grecaptcha.ready(async () => {
              const token = await grecaptcha.execute("6Lejf08sAAAAACFzxVGzBQRBElyWiar71PZwIH3q", {action: 'contact'});
              captchaInput.value = token;
              form.submit();
            });
          });
        });
      </script>
    {% endif %}
  </body>
</html>