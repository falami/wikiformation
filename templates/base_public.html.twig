{# templates/base_public.html.twig #}
<!DOCTYPE html>
<html lang="{{ app.request.locale|default('fr') }}">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    {# ——— Title & Description (surchargables) ——— #}
    <title>{% block title %}Wikiformation - Plateforme de réservation de formation pour devenir Formateur{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <meta name="description" content="{% block meta_description %}Wiki Formation est la plateforme complète pour les organisme de formation : gérez votre formation, vos stagiaires, vos sessions et vos financements.{% endblock %}">
    <meta name="author" content="Wikiformation">

    {# ——— Robots: noindex si recherche interne ?q= ——— #}
    {% set has_query_search = app.request.query.has('q') and app.request.query.get('q') is not empty %}
    {% if has_query_search %}
      <meta name="robots" content="noindex, nofollow">
    {% else %}
      <meta name="robots" content="index, follow">
    {% endif %}

    {# ——— Canonical absolu sans query ——— #}
    {% set canonical_url = absolute_url(app.request.pathInfo) %}
    <link rel="canonical" href="{{ canonical_url }}">

    {# ——— Hreflang absolus FR/EN (+ x-default) ——— #}
    {% set route   = app.request.attributes.get('_route') %}
    {% set params  = app.request.attributes.get('_route_params')|default({}) %}
    {% set supported_locales = ['fr','en'] %}
    {% if route %}
      {% for loc in supported_locales %}
        <link rel="alternate" hreflang="{{ loc }}" href="{{ absolute_url(path(route, params|merge({'_locale': loc}))) }}">
      {% endfor %}
      <link rel="alternate" hreflang="x-default" href="{{ absolute_url(path(route, params|merge({'_locale':'fr'}))) }}">
    {% endif %}

    {# ——— Social / Open Graph ——— #}
    {% set og_title = block('og_title') is defined ? block('og_title') : block('title') %}
    {% set og_desc  = block('og_desc')  is defined ? block('og_desc')  : block('meta_description') %}
    {% set og_img   = block('og_image') is defined ? block('og_image') : absolute_url(asset('dist/img/vitrine/logo-wikiformation.png')) %}
    {% set og_url   = canonical_url %}

    <meta property="og:title" content="{{ og_title|striptags }}">
    <meta property="og:description" content="{{ og_desc|striptags }}">
    <meta property="og:image" content="{{ og_img }}">
    <meta property="og:url" content="{{ og_url }}">
    <meta property="og:type" content="website">
    <meta property="og:locale" content="{{ app.request.locale == 'en' ? 'en_GB' : 'fr_FR' }}">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ og_title|striptags }}">
    <meta name="twitter:description" content="{{ og_desc|striptags }}">
    <meta name="twitter:image" content="{{ og_img }}">

    {# ——— Favicons ——— #}
      <link rel="icon" type="image/x-icon" href="{{ asset('uploads/photos/entite/favicon/favicon-wikiformation.png')}}">
    <link rel="apple-touch-icon" href="{{ asset('uploads/photos/entite/logo/logo-wikiformation.png') }}">

    {# ——— Preconnect / Perf ——— #}
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    {# ——— CSS vendors ——— #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
    <link href="//maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">


    {# ——— Styles globaux ——— #}
    <style>
      :root{ --theme-color-principal:#0f1b28; --theme-color-secondaire:#0dcaf0; }
      html { scroll-behavior: smooth; }
      body { font-family: Arial, sans-serif; background:#f8f9fa; color:#333; }
      .navbar { background:#212529; }
      .nav-link { color:#fff !important; }
      .card-header { background:#0f1b28; color:#fff; }
      .hero{ background:url("{{ asset('dist/img/accueil.jpg') }}") no-repeat center/cover; min-height:50vh; display:flex; align-items:center; justify-content:center; text-align:center; color:#fff; position:relative; }
      .hero::before{ content:""; position:absolute; inset:0; background:rgba(0,0,0,.6); }
      .hero .container{ position:relative; z-index:1; }
      .section-title{ font-size:2rem; margin-bottom:20px; font-weight:700; color:#0f1b28 !important; }
      .testimonial{ background:#fff; padding:20px; border-radius:8px; box-shadow:0 4px 6px rgba(0,0,0,.1); }
      .card{ border:none; border-radius:15px; box-shadow:0 4px 12px rgba(0,0,0,.1); transition:.3s; }
      .card:hover{ transform:translateY(-10px); box-shadow:0 8px 24px rgba(0,0,0,.2); }
      .btn-primary-dive{ color:#fff; background:#0D6EFD; border:none; border-radius:25px; padding:.5rem 1.5rem; font-size:.9rem; }
      .btn-primary-dive:hover{ background:#0056b3; }
      .bg-theme{ background:#0f1b28; }
      main{ margin-top:56px; }
      .footer-modern{ background:linear-gradient(135deg, var(--theme-color-principal,#001f3f), #0f1b28 70%); position:relative; overflow:hidden; }
      .footer-modern::before{ content:""; position:absolute; top:-80px; left:-100px; width:200%; height:200px; background:radial-gradient(circle at 50% 50%, rgba(255,255,255,.05), transparent 70%); animation:waveMove 12s infinite linear; }
      @keyframes waveMove{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
      .footer-modern h6, .footer-modern h5{ color:var(--theme-color-secondaire,#0dcaf0); }
      .footer-modern a{ color:rgba(255,255,255,.8); text-decoration:none; transition:.3s; }
      .footer-modern a:hover{ color:var(--theme-color-secondaire,#0dcaf0); transform:translateX(3px); }
      .footer-modern .social-link{ color:rgba(255,255,255,.85); font-size:1.4rem; transition:.3s; }
      .footer-modern .social-link:hover{ color:var(--theme-color-secondaire,#0dcaf0); transform:scale(1.1); }
      .footer-modern .footer-form .form-control{ background:rgba(255,255,255,.05); color:#fff; border:1px solid rgba(255,255,255,.2); }
      .footer-modern .footer-form .form-control:focus{ background:rgba(255,255,255,.1); border-color:var(--theme-color-secondaire,#0dcaf0); box-shadow:none; color:#fff; }
      .footer-modern .btn-theme{ background:var(--theme-color-secondaire,#0dcaf0); color:#001f3f; border:none; border-radius:50px; transition:.3s; }
      .footer-modern .btn-theme:hover{ background:#fff; color:var(--theme-color-principal,#001f3f); }
    </style>


    {% set brand = public_branding() %}

    <style>
      :root{
        --theme-color-principal: {{ brand.primaryColor }};
        --theme-color-secondaire: {{ brand.secondaryColor }};
        --theme-color-tertiaire: {{ brand.tertiaryColor }};
        --theme-color-quaternaire: {{ brand.quaternaryColor }};
      }
    </style>

    {# ——— Cookie consent (ton script) ——— #}
    <script src="{{ asset('dist/js/cookie-consent.js') }}"></script>

    {# ——— Données structurées JSON-LD ——— #}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Wiki Formation",
      "url": "https://wikiformation.fr",
      "logo": "{{ absolute_url(asset('dist/img/logos/club/logo-wikiformation.png')) }}",
      "description": "Plateforme de gestion de matériel, sorties et carnets de plongée pour clubs et passionnés.",
      "telephone": "+33627087699",
      "sameAs": [
        "https://www.facebook.com/wikiformation",
        "https://www.instagram.com/wikiformation"
      ],
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "88 chemin de Russaud",
        "addressLocality": "Alès",
        "postalCode": "30100",
        "addressCountry": "FR"
      }
    }
    </script>

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "url": "{{ canonical_url }}",
      "name": "Wikiformation",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "{{ canonical_url }}?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }
    </script>

    {# ——— Bloc CSS page ——— #}
    {% block stylesheets %}{% endblock %}

    {# ——— Google Analytics (avec consentement) ——— #}
    {% if app.request.cookies.get('cookieConsent') == 'accepted' %}
      <script async src="https://www.googletagmanager.com/gtag/js?id=G-1WB960CZ37"></script>
      <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){ dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', 'G-1WB960CZ37');
      </script>
    {% endif %}
  </head>


  <body>
    {# Bandeau consentement #}
    {% include '_cookie_consent.html.twig' %}

    <main>
      <div class="content">
        {% block body %}
          <h1 class="visually-hidden">Wikiformation — Plateforme gestion administrative</h1>
          <p class="visually-hidden">Gestion des formations d'un organisme de formation.</p>
        {% endblock %}
      </div>
    </main>

    {# ——————— JS vendors ——————— #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    {# ——————— Footer ——————— #}
    <footer class="footer-modern text-light pt-5 pb-3 mt-5">
      <div class="container">
        <div class="row gy-4">
          <div class="col-lg-4 col-md-6">
            <h5 class="fw-bold mb-3 d-flex align-items-center">
              <i class="bi bi-water me-2 text-theme-secondaire fs-4" aria-hidden="true"></i>
              <img class="mb-1" src="{{ asset('uploads/photos/entite/logo/logo-wikiformation.png')}}" width="100px">
            </h5>
            <p class="text-light-50 small mb-3">
              {{ 'footer.tagline_1'|trans }}<br>
              {{ 'footer.tagline_2'|trans }}
            </p>
            <div class="d-flex gap-3 mt-3">
              <a href="https://www.facebook.com/wikiformation" class="social-link" aria-label="{{ 'footer.social.facebook_label'|trans }}"><i class="bi bi-facebook" aria-hidden="true"></i></a>
              <a href="https://www.instagram.com/wikiformation" class="social-link" aria-label="{{ 'footer.social.instagram_label'|trans }}"><i class="bi bi-instagram" aria-hidden="true"></i></a>
            </div>
          </div>

          <div class="col-lg-2 col-md-6">
            <h6 class="fw-semibold text-uppercase mb-3">{{ 'footer.nav.title'|trans }}</h6>
            <ul class="list-unstyled small">
              <li><a href="{{ path('app_public') }}"><i class="bi bi-chevron-right"></i> {{ 'footer.nav.home'|trans }}</a></li>
              <li><a href="{{ path('app_public_catalogue') }}"><i class="bi bi-chevron-right"></i> {{ 'footer.nav.catalogue'|trans }}</a></li>
              <li><a href="{{ path('app_public_engin') }}"><i class="bi bi-chevron-right"></i> {{ 'footer.nav.engin'|trans }}</a></li>
              <li><a href="{{ path('app_public_contact') }}"><i class="bi bi-chevron-right"></i> {{ 'footer.nav.contact'|trans }}</a></li>
            </ul>
          </div>

          <div class="col-lg-3 col-md-6">
            <h6 class="fw-semibold text-uppercase mb-3">{{ 'footer.info.title'|trans }}</h6>
            <ul class="list-unstyled small">
              <li><a href="{{ path('app_public_politique_confidentialite') }}">{{ 'footer.info.privacy'|trans }}</a></li>
              <li><a href="{{ path('app_public_mentions_legales') }}">{{ 'footer.info.legal'|trans }}</a></li>
              <li><a href="{{ path('app_public_cgv') }}">{{ 'footer.info.cgv'|trans }}</a></li>
              <li><a href="{{ path('app_public_cgu') }}">{{ 'footer.info.cgu'|trans }}</a></li>
              <li><a href="#" id="manage-cookies">{{ 'footer.info.cookies'|trans }}</a></li>
            </ul>
          </div>

          <div class="col-lg-3 col-md-6">
            <h6 class="fw-semibold text-uppercase mb-3">{{ 'footer.contact.title'|trans }}</h6>
            {{ render(path('app_public_footer_contact_form')) }}
          </div>
        </div>

        <hr class="border-secondary mt-5 mb-3">

        <div class="text-center small text-light-50">
          ©️ {{ "now"|date("Y") }} <span class="fw-semibold text-theme-secondaire">Wikiformation</span> — {{ 'footer.copyright.rights'|trans }}
        </div>
      </div>
    </footer>

    {# ——————— JS page ——————— #}
    {% block javascripts %}{% endblock %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>


    <script src="https://www.google.com/recaptcha/api.js?render=6Lejf08sAAAAACFzxVGzBQRBElyWiar71PZwIH3q"></script>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const form = document.querySelector('form.footer-form') || document.querySelector('form[name="contact"]');
        if (!form) return;

        const captchaInput = form.querySelector('input[name$="[captcha]"]');
        if (!captchaInput) return;

        form.addEventListener('submit', async (e) => {
          // si déjà rempli, on laisse
          if (captchaInput.value) return;

          e.preventDefault();

          grecaptcha.ready(async () => {
            const token = await grecaptcha.execute("6Lejf08sAAAAACFzxVGzBQRBElyWiar71PZwIH3q", {action: 'contact'});
            captchaInput.value = token;
            form.submit();
          });
        });
      });
    </script>

  </body>
</html>
