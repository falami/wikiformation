{# templates/billing/success.html.twig #}
{% extends 'base_public.html.twig' %}
{% block title %}Paiement confirmé{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    .billing-hero{
      border-radius:24px;
      padding:28px;
      background:
        radial-gradient(1200px 400px at 12% 0%, rgba(16,185,129,.22), transparent 60%),
        radial-gradient(900px 350px at 88% 10%, rgba(99,102,241,.18), transparent 55%),
        linear-gradient(180deg, rgba(255,255,255,.92), rgba(255,255,255,.78));
      border:1px solid rgba(15,23,42,.08);
      box-shadow: 0 18px 60px rgba(2,6,23,.08);
      position:relative;
      overflow:hidden;
    }
    .billing-card{
      border-radius:22px;
      border:1px solid rgba(15,23,42,.10);
      background: rgba(255,255,255,.92);
      box-shadow: 0 16px 46px rgba(2,6,23,.08);
      overflow:hidden;
    }
    .muted{ color: rgba(2,6,23,.65); font-size:14px; }
    .chip{
      display:inline-flex; align-items:center; gap:.45rem;
      border:1px solid rgba(15,23,42,.10);
      background: rgba(255,255,255,.75);
      border-radius:999px; padding:.42rem .7rem;
      font-size: 13px; color: rgba(2,6,23,.72);
    }
    .icon-bubble{
      width:64px; height:64px; border-radius:18px;
      display:grid; place-items:center;
      background: rgba(16,185,129,.12);
      border:1px solid rgba(16,185,129,.20);
      box-shadow: 0 12px 30px rgba(16,185,129,.10);
    }
    .step{
      border-radius:18px;
      border:1px solid rgba(15,23,42,.08);
      background: rgba(255,255,255,.72);
      padding:14px 14px;
    }
    .step i{ opacity:.85; }
    .btn-soft{
      border-radius:14px;
      border:1px solid rgba(16,185,129,.25);
      background: rgba(16,185,129,.10);
      color: #0f5132;
    }
    .btn-soft:hover{ background: rgba(16,185,129,.14); color:#0f5132; }
  </style>
{% endblock %}

{% block body %}
  {% include 'header_public.html.twig' %}

  <div class="container py-5">

    <div class="billing-hero mb-4">
      <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
        <div class="d-flex align-items-start gap-3">
          <div class="icon-bubble">
            <i class="bi bi-check2-circle fs-2 text-success"></i>
          </div>
          <div>
            <div class="d-flex flex-wrap gap-2 mb-2">
              <span class="chip"><i class="bi bi-shield-check"></i> Paiement validé</span>
              <span class="chip"><i class="bi bi-stars"></i> Activation en cours</span>
              {% if app.user %}
                <span class="chip"><i class="bi bi-person"></i> {{ app.user.email }}</span>
              {% endif %}
            </div>
            <h1 class="fw-bold mb-1">Votre abonnement est confirmé ✅</h1>
            <div class="muted">
              Merci ! Nous finalisons l’activation. Vous pouvez retourner sur votre espace dès maintenant.
            </div>
          </div>
        </div>

        <div class="text-lg-end">
          <a class="btn btn-success btn-lg px-4" href="{{ path('app_login') }}">
            <i class="bi bi-arrow-right-circle me-2"></i> Continuer
          </a>
          <div class="muted mt-2">Besoin d’un reçu ? Il sera disponible dans votre espace.</div>
        </div>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-12 col-lg-7">
        <div class="billing-card p-4 h-100">
          <h3 class="mb-2">Prochaines étapes</h3>
          <div class="muted mb-3">En moins d’une minute, vous êtes opérationnel.</div>

          <div class="d-grid gap-3">
            <div class="step d-flex gap-3">
              <div class="pt-1"><i class="bi bi-building-check fs-4 text-success"></i></div>
              <div>
                <div class="fw-semibold">Vérifiez votre organisme</div>
                <div class="muted">Logo, coordonnées, mentions et paramètres Qualiopi.</div>
              </div>
            </div>

            <div class="step d-flex gap-3">
              <div class="pt-1"><i class="bi bi-calendar2-week fs-4 text-primary"></i></div>
              <div>
                <div class="fw-semibold">Créez votre première session</div>
                <div class="muted">Planning, participants, documents, émargement.</div>
              </div>
            </div>

            <div class="step d-flex gap-3">
              <div class="pt-1"><i class="bi bi-mortarboard fs-4 text-warning"></i></div>
              <div>
                <div class="fw-semibold">Activez l’espace apprenant</div>
                <div class="muted">Suivi, contenus, questionnaires, attestations.</div>
              </div>
            </div>
          </div>

          <div class="d-flex flex-wrap gap-2 mt-4">
            <a href="{{ path('app_public_pricing') }}" class="btn btn-soft px-3">
              <i class="bi bi-gear me-2"></i> Gérer l’abonnement
            </a>
            <a href="{{ path('app_public_pricing') }}" class="btn btn-outline-dark px-3">
              <i class="bi bi-life-preserver me-2"></i> Support
            </a>
          </div>
        </div>
      </div>

      <div class="col-12 col-lg-5">
        <div class="billing-card p-4 h-100">
          <h3 class="mb-2">Résumé</h3>
          <div class="muted mb-3">Tout est prêt.</div>

          <div class="border rounded-4 p-3" style="border-color: rgba(15,23,42,.10) !important; background: rgba(255,255,255,.65);">
            <div class="d-flex justify-content-between align-items-center">
              <div class="fw-semibold">Statut</div>
              <span class="badge text-bg-success">Actif</span>
            </div>
            <hr class="my-3" style="opacity:.12;">
            <div class="d-flex justify-content-between">
              <div class="muted">Accès</div>
              <div class="fw-semibold">Immédiat</div>
            </div>
            <div class="d-flex justify-content-between mt-2">
              <div class="muted">Facturation</div>
              <div class="fw-semibold">Gérée via Stripe</div>
            </div>
          </div>

          <div class="alert alert-success mt-3 mb-0 d-flex gap-2 align-items-start">
            <i class="bi bi-check-circle-fill mt-1"></i>
            <div>
              <div class="fw-semibold">Confirmation envoyée</div>
              <div class="small">Vous recevrez un email Stripe / WikiFormation si configuré.</div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
{% endblock %}
