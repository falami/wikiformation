{% extends 'base_admin.html.twig' %}
{% block title %}Paiement confirmé{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }
    .hero{ border-radius:22px; overflow:hidden; color:#fff; box-shadow:0 18px 50px rgba(0,0,0,.14);
      background: linear-gradient(135deg,
        color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
        color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
      );
    }
    .card-premium{ border-radius:18px; border:1px solid rgba(0,0,0,.06); box-shadow:0 12px 30px rgba(0,0,0,.06); background:#fff; }
  </style>
{% endblock %}

{% block body %}
  <div class="hero p-3 mb-4 d-flex gap-3 align-items-center">
    <div class="rounded-circle d-flex align-items-center justify-content-center"
         style="width:42px;height:42px;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25)">
      <i class="bi bi-check2-circle fs-4" style="color:var(--theme-color-secondaire)"></i>
    </div>
    <div class="flex-grow-1">
      <h3 class="m-0 fw-bold">Paiement effectué</h3>
      <div class="opacity-75">Ton paiement a été enregistré. Le statut sera confirmé par webhook.</div>
    </div>
  </div>

  <div class="card-premium p-3">
    {% if fc %}
      <div class="small text-muted">Session</div>
      <div class="fw-semibold">{{ fc.stripeCheckoutSessionId }}</div>

      <hr>

      <div class="d-flex flex-wrap gap-3">
        <div>
          <div class="small text-muted">Facture</div>
          <div class="fw-semibold">{{ facture.numero ?? ('#' ~ facture.id) }}</div>
        </div>
        <div>
          <div class="small text-muted">Statut checkout</div>
          <div class="fw-semibold">{{ fc.status }}</div>
        </div>
      </div>

      <div class="mt-3 d-flex gap-2 flex-wrap">
        {% if entite and facture %}
          <a class="btn btn-dark"
             href="{{ path('app_administrateur_facture_show', {entite: entite.id, id: facture.id}) }}">
            <i class="bi bi-receipt me-1"></i> Retour facture
          </a>
        {% endif %}
        <a class="btn btn-outline-secondary" href="{{ path('app_administrateur_billing_connect_index', {entite: entite.id}) }}">
          <i class="bi bi-stripe me-1"></i> Paramètres Stripe
        </a>
      </div>
    {% else %}
      <div class="text-muted">Session inconnue. Si besoin, reviens depuis la facture.</div>
    {% endif %}
  </div>
{% endblock %}