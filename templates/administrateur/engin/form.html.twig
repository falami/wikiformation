  {{ form_end(form) }}
  

{# ================== JS (TomSelect dropdownParent + validation + résumé live + ton upload/sortable) ================== #}
<script>
document.addEventListener('DOMContentLoaded', () => {

  // Flatpickr FR (si un jour tu en ajoutes)
  if (window.flatpickr && window.flatpickr.l10ns && window.flatpickr.l10ns.fr) {
    flatpickr.localize(flatpickr.l10ns.fr);
  }

  // TomSelect avec dropdownParent body (FIX z-index/overflow comme Session)
  function initTomSelectOn(el, opts={}){
    if (!el) return;
    if (el.tomselect) return;
    new TomSelect(el, Object.assign({
      dropdownParent: 'body',
      create:false,
      allowEmptyOption:true,
      sortField:{field:'text',direction:'asc'},
      plugins:['remove_button'],
      onChange: refreshResume
    }, opts));
  }

  const $nom       = document.getElementById('{{ form.nom.vars.id }}');
  const $site      = document.getElementById('{{ form.site.vars.id }}');
  const $type      = document.getElementById('{{ form.type.vars.id }}');
  const $annee     = document.getElementById('{{ form.annee.vars.id }}');
  const $personnes = document.getElementById('{{ form.personnes.vars.id }}');
  const $capacite  = document.getElementById('{{ form.capacite.vars.id }}');
  const $couchage  = document.getElementById('{{ form.capaciteCouchage.vars.id }}');

  initTomSelectOn($site);
  initTomSelectOn($type);

  // Validation (même logique que ta version)
  initFormValidation({
    formName: 'engin_administrateur',
    tomSelectFields: [
      { id:'{{ form.site.vars.id }}', label:'*Site' },
      { id:'{{ form.type.vars.id }}', label:'*Type' },
    ]
  });

  // Résumé live + complétude (style session)
  const formMain = document.querySelector('form[name="engin_administrateur"]');
  const submitButtons = formMain ? [...formMain.querySelectorAll('button[type="submit"]')] : [];

  const $r = {
    nom: document.getElementById('resume-nom'),
    site: document.getElementById('resume-site'),
    type: document.getElementById('resume-type'),
    annee: document.getElementById('resume-annee'),
    personnes: document.getElementById('resume-personnes'),
    capacite: document.getElementById('resume-capacite'),
    couchage: document.getElementById('resume-couchage'),
    pill: document.getElementById('resume-valid-pill')
  };

  function selectedText(selectEl){
    if (!selectEl || !selectEl.value) return '';
    const opt = selectEl.selectedOptions && selectEl.selectedOptions[0];
    return (opt ? opt.textContent : '').trim();
  }

  function refreshResume(){
    if ($r.nom) $r.nom.textContent = ($nom?.value || '').trim() || '—';
    if ($r.site) $r.site.textContent = selectedText($site) || '—';
    if ($r.type) $r.type.textContent = selectedText($type) || '—';
    if ($r.annee) $r.annee.textContent = ($annee?.value || '').trim() || '—';
    if ($r.personnes) $r.personnes.textContent = ($personnes?.value || '').trim() || '—';
    if ($r.capacite) $r.capacite.textContent = ($capacite?.value || '').trim() || '—';
    if ($r.couchage) $r.couchage.textContent = ($couchage?.value || '').trim() || '—';

    const hasNom  = !!(($nom?.value || '').trim());
    const hasSite = !!(($site?.value || '').trim());
    const hasType = !!(($type?.value || '').trim());

    const ok = hasNom && hasSite && hasType && (formMain ? formMain.checkValidity() : true);

    submitButtons.forEach(b => b.disabled = !ok);

    if ($r.pill) {
      if (ok) {
        $r.pill.textContent = '✅ Complet';
        $r.pill.style.background = 'rgba(25,135,84,.15)';
        $r.pill.style.borderColor = 'rgba(25,135,84,.35)';
        $r.pill.style.color = 'var(--ink)';
      } else {
        $r.pill.textContent = '⚠️ Incomplet';
        $r.pill.style.background = 'rgba(255,193,7,.15)';
        $r.pill.style.borderColor = 'rgba(255,193,7,.35)';
        $r.pill.style.color = 'var(--ink)';
      }
    }
  }

  [$nom,$annee,$personnes,$capacite,$couchage].forEach(el=>{
    el?.addEventListener('input', refreshResume);
    el?.addEventListener('change', refreshResume);
  });
  $site?.addEventListener('change', refreshResume);
  $type?.addEventListener('change', refreshResume);

  refreshResume();

  // ===== Uploads / Sortable : TON CODE (repris) =====
  initUploadZone('banniere-zone');
  initUploadZone('cover-zone');
  initUploadZone('gallery-zone', { multiple: true, type: 'gallery' });

  const dbContainer = document.getElementById('gallery-sortable');
  let dbSortable = null;
  if (dbContainer && dbContainer.children.length) {
    dbSortable = new Sortable(dbContainer, {
      animation: 150,
      handle: '.drag-handle',
      ghostClass: 'bg-dark-subtle',
      onEnd: () => updateOrderField()
    });
  }

  function collectIds(){
    if (!dbContainer) return [];
    return [...dbContainer.querySelectorAll('.gallery-item[data-photo-id]')].map(el => el.dataset.photoId);
  }
  function updateOrderField(){
    const ids = collectIds();
    const hidden = document.getElementById('photos_order');
    if (hidden) hidden.value = ids.join(',');
  }
  updateOrderField();

  const saveBtn = document.getElementById('saveOrderBtn');
  const saveMsg = document.getElementById('saveOrderMsg');
  if (saveBtn){
    saveBtn.addEventListener('click', async () => {
      if (!dbContainer) return;
      const url = dbContainer.dataset.reorderUrl;
      const ids = collectIds();
      updateOrderField();
      if (!url) { saveMsg.textContent = "Ordre prêt — sera enregistré à la sauvegarde du formulaire."; return; }
      saveBtn.disabled = true; saveMsg.textContent = "Enregistrement…";
      try{
        const res = await fetch(url, {
          method: 'POST',
          headers: {'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
          body: JSON.stringify({ order: ids })
        });
        if (!res.ok) throw new Error('HTTP '+res.status);
        saveMsg.textContent = "Ordre enregistré.";
      }catch(e){ console.error(e); saveMsg.textContent = "Erreur lors de l’enregistrement."; }
      finally{ saveBtn.disabled = false; setTimeout(()=> saveMsg.textContent = '', 2500); }
    });
  }

  function initUploadZone(wrapperId, opts = {}){
    const zone = document.getElementById(wrapperId);
    if (!zone) return;

    const { multiple=false, type='cover' } = opts;
    const inputId = zone.dataset.inputId;
    const input = document.getElementById(inputId) || zone.querySelector('input[type="file"]');
    const previewImg = zone.querySelector('.preview img');
    const pending = document.getElementById('gallery-pending');
    const emptyMsg = document.getElementById('gallery-empty-msg');

    const toArray = fl => Array.from(fl || []);
    function mergeFiles(existing, added){
      const dt = new DataTransfer();
      toArray(existing).forEach(f => dt.items.add(f));
      toArray(added).forEach(f => dt.items.add(f));
      return dt.files;
    }
    function rebuildFiles(exceptIndex){
      const dt = new DataTransfer();
      toArray(input.files).forEach((f, i) => { if (i !== exceptIndex) dt.items.add(f); });
      input.files = dt.files;
      input.dispatchEvent(new Event('change', { bubbles:true }));
    }
    function showCover(file){
      if (!previewImg) return;
      const rdr = new FileReader();
      rdr.onload = ev => { previewImg.src = ev.target.result; previewImg.classList.remove('d-none'); };
      rdr.readAsDataURL(file);
    }

    zone.addEventListener('click', (e) => {
      if (e.target.closest('button') || e.target.closest('form')) return;
      input?.click();
    });

    input?.addEventListener('change', (e) => {
      const files = e.target.files;
      if (!files || !files.length) return;

      if (type === 'gallery') {
        if (pending) pending.innerHTML = '';
        toArray(files).forEach((file, i) => {
          const url = URL.createObjectURL(file);
          const item = document.createElement('div');
          item.className = 'gallery-item';
          item.setAttribute('data-pending-index', i);
          item.innerHTML = `
            <span class="drag-handle"><i class="fa fa-grip-vertical"></i></span>
            <img src="${url}" alt="">
            <button type="button" class="btn-delete" title="Supprimer"><i class="fa fa-times"></i></button>
          `;
          item.querySelector('.btn-delete').addEventListener('click', (ev)=>{
            ev.stopPropagation();
            const pos = [...pending.children].indexOf(item);
            item.remove();
            [...pending.children].forEach((el, k)=> el.dataset.pendingIndex = k);
            rebuildFiles(pos);
          });
          pending.appendChild(item);
        });

        if (pending && !pending.dataset.sortableInit){
          new Sortable(pending, { animation:150, handle: '.drag-handle' });
          pending.dataset.sortableInit = '1';
        }
        emptyMsg?.remove();
      } else {
        showCover(files[0]);
      }
    });

    zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('dragover'); });
    zone.addEventListener('dragleave', () => zone.classList.remove('dragover'));
    zone.addEventListener('drop', e => {
      e.preventDefault(); zone.classList.remove('dragover');
      if (!input) return;

      const dropped = e.dataTransfer?.files || [];
      if (!dropped.length) return;

      if (multiple) {
        input.files = mergeFiles(input.files, dropped);
      } else {
        const dt = new DataTransfer();
        dt.items.add(dropped[0]);
        input.files = dt.files;
      }
      input.dispatchEvent(new Event('change', { bubbles:true }));
    });
  }

  function initFormValidation({ formName, tomSelectFields=[] }){
    const form = document.querySelector(`form[name="${formName}"]`);
    if (!form) return;

    const submitButton = form.querySelector('button[type="submit"]');
    if (!submitButton) return;

    let errorAlert = document.getElementById('form-error-alert');
    if (!errorAlert) {
      errorAlert = document.createElement('div');
      errorAlert.className = 'alert alert-danger d-none';
      errorAlert.id = 'form-error-alert';
      submitButton.parentElement.prepend(errorAlert);
    }

    form.addEventListener('submit', e=>{
      const messages = new Set();
      let first = null;

      tomSelectFields.forEach(({id,label})=>{
        const f = document.getElementById(id);
        if (f && f.hasAttribute('required') && (!f.value || !f.value.trim())) {
          f.classList.add('is-invalid');
          messages.add(`- ${label}`);
          if(!first) first=f;
        }
      });

      form.querySelectorAll(':invalid').forEach(el=>{
        el.classList.add('is-invalid');
        if(!first) first=el;
        const l = form.querySelector(`label[for="${el.id}"]`);
        if (l) messages.add(`- ${l.textContent.trim()}`);
      });

      if (messages.size) {
        e.preventDefault();
        errorAlert.innerHTML = `<strong>Champs requis manquants :</strong><br>${[...messages].join('<br>')}`;
        errorAlert.classList.remove('d-none');
        if (first && first.scrollIntoView) first.scrollIntoView({behavior:'smooth', block:'center'});
        setTimeout(()=>errorAlert.classList.add('d-none'), 6000);
      }
    });
  }

});

// Suppression photo (POST via fetch) - évite les <form> imbriqués
document.addEventListener('click', async (e) => {
  const btn = e.target.closest('.btn-delete[data-del-url]');
  if (!btn) return;
  e.preventDefault();

  if (!confirm('Supprimer cette photo ?')) return;

  const url = btn.dataset.delUrl;
  const token = btn.dataset.csrf;

  try {
    const res = await fetch(url, {
      method: 'POST',
      headers: {
        'X-Requested-With': 'XMLHttpRequest',
        'Content-Type': 'application/x-www-form-urlencoded'
      },
      body: new URLSearchParams({ _token: token })
    });

    if (!res.ok) throw new Error('HTTP ' + res.status);

    btn.closest('.gallery-item')?.remove();

    // Mets à jour l’ordre
    const hidden = document.getElementById('photos_order');
    const cont = document.getElementById('gallery-sortable');
    if (hidden && cont) {
      hidden.value = [...cont.querySelectorAll('.gallery-item[data-photo-id]')].map(x=>x.dataset.photoId).join(',');
    }
  } catch (err) {
    console.error(err);
    alert("Erreur lors de la suppression de l’image.");
  }
});
</script>
{% endblock %}
