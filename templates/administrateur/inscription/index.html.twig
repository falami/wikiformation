{# templates/administrateur/inscription/index.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}Inscriptions{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }

    /* =========================
      HERO (identique Sessions)
      ========================= */

    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;

      /* Ombre douce premium */
      box-shadow: 0 18px 50px rgba(0,0,0,.14);

      /* Fond piloté par les couleurs de l'entité */
      background:
        /* halo clair (tertiaire) */
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        /* halo accent (secondaire) */
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        /* voile subtil (quaternaire) pour la profondeur */
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        /* dégradé principal (principal -> plus clair) */
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    /* léger glass highlight */
    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    /* barre accent = secondaire (et glow basé sur secondaire) */
    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }

    /* ===== Chips HERO (identique Sessions) ===== */
    .hero .chip{
      display:inline-flex;
      align-items:center;
      gap:.5rem;
      padding:.32rem .7rem;
      border-radius: 999px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(255,255,255,.14);
      font-size:.82rem;
      color: rgba(255,255,255,.92);
      backdrop-filter: blur(6px);
      white-space: nowrap;
    }
    .hero .chip i{
      color: var(--theme-color-secondaire);
    }

    /* chip highlight (optionnel) */
    .hero .chip--pill{
      background: color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
      border-color: color-mix(in srgb, var(--theme-color-secondaire) 28%, rgba(255,255,255,.14));
      color:#fff;
    }

    .hero .btn{
      border-radius: 14px;
      font-weight: 800;
    }
    .hero .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .hero .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }

    @media (max-width: 768px){
      .hero{ border-radius:16px; }
    }

    .hero .btn{
      border-radius: 14px;
      font-weight: 800;
    }

    .hero .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .hero .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }

    @media (max-width:768px){
      .hero{ border-radius:16px; }
    }

    /* ====== KPI CARDS ====== */
    .kpi-card{
      border: 1px solid rgba(0,0,0,.06);
      box-shadow: 0 10px 26px rgba(0,0,0,.06);
      border-radius: 18px;
      overflow:hidden;
      background: #fff;
      position:relative;
    }
    .kpi-card:before{
      content:"";
      position:absolute; inset:0;
      background: radial-gradient(700px 120px at 20% 0%, rgba(255,193,7,.12), transparent 55%);
      pointer-events:none;
    }
    .kpi-ico{
      width:44px; height:44px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }

    .filter-icon{
      width:38px; height:38px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }
    .kpi-label{ color: rgba(0,0,0,.55); font-size:.85rem }
    .kpi-value{ font-weight: 800; font-size: 1.6rem; letter-spacing:-.02em }
    .kpi-sub{ color: rgba(0,0,0,.50); font-size:.82rem }
    .kpi-bar{
      height: 6px; border-radius: 999px;
      background: rgba(0,0,0,.06);
      overflow:hidden;
    }
    .kpi-bar > span{
      display:block; height:100%;
      width: 0%;
      background: var(--theme-color-secondaire);
      border-radius: 999px;
      transition: width .35s ease;
    }

    /* ====== TOOLBAR ====== */
    .toolbar{
      border-radius: 16px;
      background: #fff;
      border: 1px solid rgba(0,0,0,.06);
      box-shadow: 0 10px 24px rgba(0,0,0,.05);
      padding: .85rem;
    }
    .toolbar .hint{
      font-size:.85rem;
      color: rgba(0,0,0,.55);
    }
    .chip{
      display:inline-flex; align-items:center; gap:.5rem;
      padding:.35rem .7rem;
      border-radius:999px;
      background: rgba(0,0,0,.03);
      border: 1px solid rgba(0,0,0,.06);
      font-size:.85rem;
      color: rgba(0,0,0,.65);
    }

    /* ====== DATATABLE CARD ====== */
    .table-card{
      border-radius: 18px;
      background: #fff;
      border: 1px solid rgba(0,0,0,.06);
      box-shadow: 0 12px 30px rgba(0,0,0,.06);
      overflow:hidden;
    }
    table.dataTable{ margin:0 !important; }
    table.dataTable thead th{
      position: sticky; top: 0; z-index: 2;
      background: #f7f8fa !important;
      border-bottom: 1px solid rgba(0,0,0,.08) !important;
      text-transform: uppercase;
      font-size: .78rem;
      letter-spacing:.06em;
      color: rgba(0,0,0,.55);
    }
    #tableauInscriptions tbody tr:hover{
      background: rgba(255,193,7,.06) !important;
    }

    /* DataTables UI polish */
    .dataTables_wrapper .dataTables_filter input{
      border-radius: 999px !important;
      padding: .45rem .85rem !important;
      border: 1px solid rgba(0,0,0,.12) !important;
      outline: none !important;
      box-shadow: none !important;
    }
    .dataTables_wrapper .dataTables_length select{
      border-radius: 999px !important;
      border: 1px solid rgba(0,0,0,.12) !important;
      padding: .35rem .7rem !important;
    }
    .dt-top{
      padding: .75rem .85rem;
      border-bottom: 1px solid rgba(0,0,0,.06);
      background: #fff;
    }
    .dt-bottom-internal{
      margin-top: .75rem !important;
      padding: 1rem .85rem !important;
      border-top: 1px solid rgba(0,0,0,.06);
      background: #fff;
    }

    /* ✅ Zebra propre */
    #tableauInscriptions tbody tr:nth-child(odd) > *{ background-color: #fff !important; }
    #tableauInscriptions tbody tr:nth-child(even) > *{ background-color: rgba(35,51,66,.035) !important; }
    #tableauInscriptions tbody tr:hover > *{ background-color: rgba(255,193,7,.08) !important; }
    #tableauInscriptions tbody td{ padding-top: .75rem !important; padding-bottom: .75rem !important; }




    /* =========================
      ✅ Actions inscriptions — colonne mini + sticky mobile + anti-clipping
      ========================= */

    /* colonne actions : la plus petite possible (TH + TD) */
    #tableauInscriptions th.action-column,
    #tableauInscriptions td.action-column{
      width: 1% !important;
      min-width: 0 !important;
      white-space: nowrap !important;
      text-align: right !important;
    }

    /* cellule actions : padding minimal + PAS de relative */
    #tableauInscriptions td.action-column{
      padding-left: .15rem !important;
      padding-right: .15rem !important;
      overflow: visible !important;
    }

    /* boutons compacts */
    .inscription-actions .btn{
      padding: .28rem .50rem;
    }

    /* bouton principal */
    .inscription-actions .inscription-main{
      background: rgba(255,255,255,.85);
      border-color: rgba(0,0,0,.12);
      box-shadow: 0 10px 22px rgba(0,0,0,.06);
    }
    .inscription-actions .inscription-main:hover{
      box-shadow: 0 14px 28px rgba(0,0,0,.10);
      border-color: rgba(0,0,0,.18);
    }

    /* split */
    .inscription-actions .inscription-split{
      padding-left: .50rem;
      padding-right: .50rem;
      border-color: rgba(0,0,0,.12);
      background: rgba(255,255,255,.85);
    }

    /* fusion pill (main + split) */
    .inscription-actions.btn-group .inscription-main{
      border-top-right-radius: 0 !important;
      border-bottom-right-radius: 0 !important;
    }
    .inscription-actions.btn-group .inscription-split{
      border-top-left-radius: 0 !important;
      border-bottom-left-radius: 0 !important;
      margin-left: -1px;
      position: relative;
    }
    .inscription-actions.btn-group .inscription-split:before{
      content:"";
      position:absolute;
      left:0;
      top:20%;
      bottom:20%;
      width:1px;
      background: rgba(0,0,0,.10);
    }

    /* menu dropdown */
    .inscription-actions .inscription-menu{
      border-radius: 16px;
      border: 1px solid rgba(0,0,0,.10);
      box-shadow: 0 18px 46px rgba(0,0,0,.18);
      padding: .55rem;
      background:
        radial-gradient(900px 220px at 10% 0%, rgba(255,193,7,.10), transparent 55%),
        #fff;
      overflow: hidden;
    }
    .inscription-actions .inscription-menu .dropdown-item{
      border-radius: 12px;
      padding: .50rem .60rem;
      margin: .10rem 0;
      border: 1px solid transparent;
    }
    .inscription-actions .inscription-menu .dropdown-item:hover{
      background: rgba(255,193,7,.10);
      border-color: rgba(255,193,7,.22);
    }

    /* ✅ sticky mobile (TH + TD) + zebra/hover cohérents */
    @media (max-width: 768px){
      #tableauInscriptions th.action-column,
      #tableauInscriptions td.action-column{
        position: sticky;
        right: 0;
        z-index: 5;
        background: #fff !important;
        box-shadow: -12px 0 18px -14px rgba(0,0,0,.22);
      }

      /* zebra/hover sur la cellule sticky */
      #tableauInscriptions tbody tr:nth-child(even) > td.action-column{
        background-color: rgba(35,51,66,.035) !important;
      }
      #tableauInscriptions tbody tr:hover > td.action-column{
        background-color: rgba(255,193,7,.08) !important;
      }
    }

    /* ✅ menu flottant au-dessus de tout */
    body .inscription-floating-dropdown{ z-index: 20000 !important; }


  </style>

  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/style-table.css') }}">
  <link rel="stylesheet" href="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/datatables.min.css"/>
  <link rel="stylesheet" href="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.css"/>
{% endblock %}

{% block javascripts %}
  {{ parent() }}

  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

  <script src="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.js"></script>
{% endblock %}

{% block body %}


  {# ===== HERO (comme Sessions) ===== #}
  {# =========================
    HERO (identique Sessions)
    ========================= #}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>

    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-people me-2" style="color:var(--theme-color-secondaire)"></i>
            Inscriptions
          </h2>
          <div class="opacity-75 mt-1">Pilotage : statut, assiduité, exports & actions rapides.</div>

          <div class="d-flex flex-wrap gap-2 mt-3">
            <span class="chip"><i class="bi bi-people"></i> Inscriptions</span>
            <span class="chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
            <span class="chip chip--pill">
              <i class="bi bi-clock-history"></i> <span id="hero-last-refresh">—</span>
            </span>
          </div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
          <a class="btn btn-light btn-sm fw-semibold"
            href="{{ path('app_administrateur_inscription_new', { entite: entite.id }) }}">
            <i class="bi bi-file-earmark-plus me-1"></i> Nouvelle inscription
          </a>
        </div>
      </div>
    </div>
  </div>

  {# ===== KPI ===== #}
  <div class="row g-3 mb-3">
    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-list-check fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Inscriptions</div>
              <div class="kpi-value" id="kpi-count">—</div>
              <div class="kpi-sub" id="kpi-range">{{ entite.nom }}</div>
            </div>
          </div>
          <div class="mt-3 kpi-bar"><span id="kpi-bar-count"></span></div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-check2-circle fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Terminées</div>
              <div class="kpi-value" id="kpi-terminees">—</div>
              <div class="kpi-sub">Statut : terminé</div>
            </div>
          </div>
          <div class="mt-3 kpi-bar"><span id="kpi-bar-terminees"></span></div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-hourglass-split fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">En cours</div>
              <div class="kpi-value" id="kpi-encours">—</div>
              <div class="kpi-sub">Statut : en cours</div>
            </div>
          </div>
          <div class="mt-3 kpi-bar"><span id="kpi-bar-encours"></span></div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-graph-up fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Assiduité moyenne</div>
              <div class="kpi-value" id="kpi-assiduite">—</div>
              <div class="kpi-sub">Sur inscriptions filtrées</div>
            </div>
          </div>
          <div class="mt-3 kpi-bar"><span id="kpi-bar-assiduite"></span></div>
        </div>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  {# ===== TOOLBAR ===== #}
  <div class="toolbar mb-3">
    <div class="d-flex flex-wrap gap-2 align-items-center">
      <div class="me-auto d-flex flex-wrap gap-2 align-items-center">

        <span class="chip">
          <i class="bi bi-funnel"></i>
          Statut
          <select id="inscriptionStatusFilter" class="form-select form-select-sm ms-2" style="width:auto">
            <option value="all">Toutes</option>
            <option value="preinscrit">Préinscrites</option>
            <option value="confirme">Confirmées</option>
            <option value="en_cours">En cours</option>
            <option value="termine">Terminées</option>
            <option value="annule">Annulées</option>
            <option value="absent">Absents</option>
          </select>
        </span>

        <span class="hint d-none d-lg-inline">
          Recherche : session, stagiaire, email.
        </span>
      </div>

      <div class="d-flex gap-2 align-items-center">
        <button id="btnReset" class="btn btn-outline-secondary btn-sm fw-semibold" type="button">
          <i class="bi bi-arrow-counterclockwise"></i> Reset
        </button>

        <div class="dropdown">
          <button class="btn btn-warning btn-sm fw-semibold dropdown-toggle" type="button"
                  data-bs-toggle="dropdown" aria-expanded="false">
            <i class="bi bi-download"></i> Export
          </button>
          <ul class="dropdown-menu dropdown-menu-end" id="exportMenu"></ul>
        </div>
      </div>
    </div>
  </div>

  {# ===== TABLE ===== #}
  <div class="table-card mb-4 p-3">
    <table id="tableauInscriptions" class="table table-hover align-middle mb-0" style="width:100%">
      <thead>
        <tr>
          <th style="width:80px">#</th>
          <th>Session</th>
          <th>Stagiaire</th>
          <th style="width:170px">Statut</th>
          <th style="width:140px">Assiduité</th>
          <th class="action-column text-end"></th>

        </tr>
      </thead>
      <tbody><tr><td colspan="6"></td></tr></tbody>
    </table>
  </div>

</div>
<script>
$(function () {
  const $filter = $('#inscriptionStatusFilter');

  function nowLabel(){
    const d = new Date();
    return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
  }

  // ===================== KPI (endpoint) =====================
  async function loadKpis(){
    const status = $filter.val() || 'all';
    const search = table ? (table.search() || '') : '';

    const url = new URL("{{ path('app_administrateur_inscription_kpis', { entite: entite.id }) }}", window.location.origin);
    url.searchParams.set('statusFilter', status);
    url.searchParams.set('search', search);

    const res = await fetch(url.toString(), { headers: { 'Accept': 'application/json' }});
    if(!res.ok) return;

    const k = await res.json();

    $('#kpi-count').text(k.count ?? 0);
    $('#kpi-terminees').text(k.terminees ?? 0);
    $('#kpi-encours').text(k.encours ?? 0);

    const avg = (k.avgAssiduite === null || k.avgAssiduite === undefined)
      ? null
      : Number(k.avgAssiduite);

    $('#kpi-assiduite').text(avg === null ? '—' : (avg.toFixed(1).replace('.', ',') + '%'));

    // barres
    const total = Number(k.count || 0);
    const term  = Number(k.terminees || 0);
    const enc   = Number(k.encours || 0);

    $('#kpi-bar-count').css('width', total ? '100%' : '0%');
    $('#kpi-bar-terminees').css('width', total ? Math.round((term/total)*100) + '%' : '0%');
    $('#kpi-bar-encours').css('width', total ? Math.round((enc/total)*100) + '%' : '0%');
    $('#kpi-bar-assiduite').css('width', avg === null ? '0%' : Math.min(100, Math.round(avg)) + '%');

    $('#hero-last-refresh').text('Maj : ' + nowLabel());
  }

  // ===================== DATATABLE =====================
  const table = $('#tableauInscriptions').DataTable({
    serverSide:true,
    processing:true,
    autoWidth: false,
    scrollX: true,
    scrollCollapse: true,
    responsive: false,
    ajax: {
      url: "{{ path('app_administrateur_inscription_ajax', { entite: entite.id }) }}",
      type: "POST",
      data: function (d) {
        d.statusFilter = $filter.val() || 'all'; // important : doit être géré côté PHP
      }
    },

    dom:
      '<"dt-top d-flex flex-wrap gap-2 align-items-center justify-content-between"'
        + '<"dt-actions d-flex gap-2 align-items-center"B>'
        + '<"dt-search"f>'
      + '>'
      + 'rt'
      + '<"dt-bottom-internal d-flex flex-wrap gap-2 align-items-center justify-content-between"lip>',

    buttons: [
      { extend: 'copy',  title: 'Inscriptions', text: 'Copier' },
      { extend: 'csv',   title: 'Inscriptions', text: 'CSV' },
      { extend: 'excel', title: 'Inscriptions', text: 'Excel' },
      { extend: 'pdf',   title: 'Inscriptions', text: 'PDF' },
      { extend: 'print', title: 'Inscriptions', text: 'Imprimer' },
    ],

    lengthMenu: [[10,25,50,100,500],[10,25,50,100,500]],

    columns: [
      { data:'id' },
      { data:'session' },
      { data:'stagiaire' },
      { data:'status' },
      { data:'assiduite' },
      { data:'actions' }
    ],

    columnDefs: [
      { targets:5, className:'action-column text-end', orderable:false, searchable:false },
      { targets:[3,4,5], searchable:false },
      { targets:0, type:'num' }
    ],

    order: [[0,'desc']],
    language: { url:'https://cdn.datatables.net/plug-ins/2.2.2/i18n/fr-FR.json' },
    deferRender: true,

    initComplete: function(){
      // buttons DT => dropdown menu
      const api = this.api();
      const container = api.buttons().container();
      const $btns = $(container).find('button');

      $('#exportMenu').empty();
      $btns.each(function(){
        const $b = $(this);
        const label = $b.text().trim();

        const icon = label === 'Excel' ? 'bi-file-earmark-excel' :
                     label === 'PDF' ? 'bi-file-earmark-pdf' :
                     label === 'CSV' ? 'bi-filetype-csv' :
                     label === 'Imprimer' ? 'bi-printer' :
                     label === 'Copier' ? 'bi-clipboard' : 'bi-download';

        const $item = $(`
          <li>
            <a class="dropdown-item d-flex align-items-center gap-2" href="#">
              <i class="bi ${icon}"></i> <span>${label}</span>
            </a>
          </li>
        `);

        $item.on('click', function(e){
          e.preventDefault();
          $b.trigger('click');
        });

        $('#exportMenu').append($item);
      });

      $(container).hide();

      // ✅ premier chargement KPI
      loadKpis();
    }
  });


  // ✅ Dropdown actions inscriptions : menu "flottant" hors du scroll DT
  (function enableInscriptionActionsFloatingDropdown(){
    document.addEventListener('show.bs.dropdown', function(e){
      const toggle = e.target;
      if (!toggle.closest('.inscription-actions')) return;

      const dd = toggle.closest('.dropdown, .btn-group');
      if (!dd) return;

      const menu = dd.querySelector('.dropdown-menu');
      if (!menu) return;

      if (!menu.__originalParent) menu.__originalParent = dd;

      document.body.appendChild(menu);
      menu.classList.add('inscription-floating-dropdown');

      const rect = toggle.getBoundingClientRect();
      menu.style.position = 'absolute';
      menu.style.top = '0px';
      menu.style.left = '0px';
      menu.style.display = 'block';
      const menuRect = menu.getBoundingClientRect();

      const top = rect.bottom + window.scrollY + 6;
      let left = rect.right + window.scrollX - menuRect.width;

      left = Math.max(8, Math.min(left, window.scrollX + window.innerWidth - menuRect.width - 8));

      menu.style.top = `${top}px`;
      menu.style.left = `${left}px`;
    }, true);


    window.addEventListener('scroll', () => {
      document.querySelectorAll('.inscription-actions [aria-expanded="true"][data-bs-toggle="dropdown"]')
        .forEach(btn => btn.click());
    }, true);

    window.addEventListener('resize', () => {
      document.querySelectorAll('.inscription-actions [aria-expanded="true"][data-bs-toggle="dropdown"]')
        .forEach(btn => btn.click());
    }, true);


    document.addEventListener('hidden.bs.dropdown', function(e){
      const toggle = e.target;
      if (!toggle.closest('.inscription-actions')) return;

      const dd = toggle.closest('.dropdown, .btn-group');
      if (!dd) return;

      document.querySelectorAll('body .inscription-floating-dropdown').forEach(menu => {
        if (menu.__originalParent === dd) {
          dd.appendChild(menu);
          menu.classList.remove('inscription-floating-dropdown');
          menu.style.position = '';
          menu.style.top = '';
          menu.style.left = '';
          menu.style.display = '';
        }
      });
    }, true);
  })();


  // ✅ à chaque draw (pagination / tri / recherche)
  table.on('draw.dt', function(){
    loadKpis();
  });

  // ✅ filtre statut
  $filter.on('change', function(){
    table.ajax.reload(null, true);
    loadKpis();
  });

  // ✅ reset
  $('#btnReset').on('click', function(){
    $filter.val('all');
    table.search('').draw();
    table.ajax.reload(null, true);
    loadKpis();
  });
});
</script>

{% endblock %}
