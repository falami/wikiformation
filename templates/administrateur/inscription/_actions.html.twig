{# templates/administrateur/inscription/_actions.html.twig #}

{% set dossier = inscription.dossier ?? null %}

{% set manquantes = inscription.piecesManquantes is defined
  ? inscription.piecesManquantes
  : (inscription.getPiecesManquantes is defined ? inscription.getPiecesManquantes() : [])
%}

{% set totalRequired = inscription.session.piecesObligatoires|default([])|length %}
{% set dossierComplet = (totalRequired == 0) or (manquantes is empty) %}

{% set status = inscription.status.value ?? (inscription.status ?? '') %}

<div class="btn-group btn-group-sm inscription-actions" role="group">

  {# ✅ Bouton principal (gauche) : Pièces si incomplet, sinon OK #}
  {% if not dossierComplet %}
    <a class="btn btn-light inscription-main"
       data-bs-toggle="tooltip" title="Ajouter / gérer les pièces"
       href="{{ path('app_administrateur_dossier_edit', { entite: entite.id, id: inscription.id }) }}">
      <i class="bi bi-paperclip"></i>
    </a>
  {% else %}
    <button class="btn btn-light inscription-main" disabled
            data-bs-toggle="tooltip" title="Dossier complet">
      <i class="bi bi-check2-circle text-success"></i>
    </button>
  {% endif %}

  {# ✅ Split dropdown (droite) #}
  <button type="button"
          class="btn btn-light dropdown-toggle dropdown-toggle-split inscription-split"
          data-bs-toggle="dropdown" aria-expanded="false">
    <span class="visually-hidden">Actions</span>
  </button>

  <ul class="dropdown-menu dropdown-menu-end inscription-menu">

    <li>
      <a class="dropdown-item d-flex align-items-center"
         href="{{ path('app_administrateur_inscription_show', { entite: entite.id, id: inscription.id }) }}">
        <i class="bi bi-eye me-2"></i> Ouvrir
      </a>
    </li>

    <li>
      <a class="dropdown-item d-flex align-items-center"
         href="{{ path('app_administrateur_inscription_edit', { entite: entite.id, id: inscription.id }) }}">
        <i class="bi bi-pencil-square me-2"></i> Modifier
      </a>
    </li>

    <li>
      <a class="dropdown-item d-flex align-items-center"
         href="{{ path('app_administrateur_dossier_edit', { entite: entite.id, id: inscription.id }) }}">
        <i class="bi bi-folder2-open me-2"></i> Dossier / pièces
      </a>
    </li>

    <li><hr class="dropdown-divider"></li>

    {% if status not in ['termine', 'annule'] %}
      <li>
        <form method="post"
              action="{{ path('app_administrateur_inscription_close', { entite: entite.id, id: inscription.id }) }}"
              onsubmit="return confirm('Clôturer cette inscription ?');">
          <input type="hidden" name="_token" value="{{ csrf_token('close' ~ inscription.id) }}">
          <button class="dropdown-item d-flex align-items-center text-success" type="submit">
            <i class="bi bi-check2-square me-2"></i> Clôturer
          </button>
        </form>
      </li>
    {% endif %}

    <li>
      <form method="post"
            action="{{ path('app_administrateur_inscription_delete', { entite: entite.id, id: inscription.id }) }}"
            onsubmit="return confirm('Supprimer définitivement cette inscription ?');">
        <input type="hidden" name="_token" value="{{ csrf_token('del' ~ inscription.id) }}">
        <button class="dropdown-item d-flex align-items-center text-danger" type="submit">
          <i class="bi bi-trash me-2"></i> Supprimer
        </button>
      </form>
    </li>

  </ul>
</div>
