{# templates/administrateur/site/_actions.html.twig #}

<div class="btn-group btn-group-sm site-actions" role="group">

  {# ✅ bouton principal (gauche) : modifier #}
  <a class="btn btn-light site-main"
     data-bs-toggle="tooltip" title="Modifier"
     href="{{ path('app_administrateur_site_modifier', {id: site.id, entite: entite.id}) }}">
    <i class="bi bi-pencil"></i>
  </a>

  {# ✅ split dropdown (droite) #}
  <button type="button"
          class="btn btn-light dropdown-toggle dropdown-toggle-split site-split"
          data-bs-toggle="dropdown" aria-expanded="false">
    <span class="visually-hidden">Actions</span>
  </button>

  <ul class="dropdown-menu dropdown-menu-end site-menu">

    <li>
      <a class="dropdown-item d-flex align-items-center"
         href="{{ path('app_administrateur_site_modifier', {id: site.id, entite: entite.id}) }}">
        <i class="bi bi-pencil me-2"></i> Modifier
      </a>
    </li>

    <li><hr class="dropdown-divider"></li>

    <li>
      <button type="button"
              class="dropdown-item d-flex align-items-center text-danger delete-btn"
              data-bs-toggle="modal"
              data-bs-target="#deleteModal"
              data-url="{{ path('app_administrateur_site_supprimer', {id: site.id, entite: entite.id}) }}"
              {# ✅ si tu as un token : #}
              {# data-token="{{ csrf_token('delete_site_' ~ site.id) }}" #}
      >
        <i class="bi bi-trash me-2"></i> Supprimer
      </button>
    </li>

  </ul>
</div>
