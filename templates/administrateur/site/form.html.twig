{% extends 'base_admin.html.twig' %}
{% block title %}{{ modeEdition ? 'Modification' : 'Ajout' }} d'un site{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css')}}">
  <link rel="stylesheet" href="{{ asset('dist/css/formulaire.css')}}">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css">

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};

      --bg: #f5f7fb;
      --panel: #ffffff;
      --ink: #0f172a;
      --muted:#64748b;
      --stroke: rgba(15, 23, 42, .10);
      --shadow: 0 18px 55px rgba(15, 23, 42, .10);
      --radius: 18px;

      --theme-glow: color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      --theme-soft: color-mix(in srgb, var(--theme-color-principal) 10%, #ffffff);
      --secondary-soft: color-mix(in srgb, var(--theme-color-secondaire) 16%, #ffffff);
    }


    /* HERO (comme Sessions) */
    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;

      /* Ombre douce premium */
      box-shadow: 0 18px 50px rgba(0,0,0,.14);

      /* Fond piloté par les couleurs de l'entité */
      background:
        /* halo clair (tertiaire) */
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        /* halo accent (secondaire) */
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        /* voile subtil (quaternaire) pour la profondeur */
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        /* dégradé principal (principal -> plus clair) */
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    /* léger glass highlight */
    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    /* barre accent = secondaire (et glow basé sur secondaire) */
    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }
    /* ===== Chips HERO (comme Sessions) ===== */
    .hero .chip{
      display:inline-flex;
      align-items:center;
      gap:.5rem;
      padding:.32rem .7rem;
      border-radius: 999px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(255,255,255,.14);
      font-size:.82rem;
      color: rgba(255,255,255,.92);
      backdrop-filter: blur(6px);
      white-space: nowrap;
    }
    .hero .chip i{ color: var(--theme-color-secondaire); }

    /* chip highlight */
    .hero .chip--pill{
      background: color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
      border-color: color-mix(in srgb, var(--theme-color-secondaire) 28%, rgba(255,255,255,.14));
      color:#fff;
    }


    .hero .btn{
      border-radius: 14px;
      font-weight: 800;
    }
    .hero .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .hero .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }



    body{ background: var(--bg); }

    .crumb{ color: var(--muted); font-size:.9rem; }
    .crumb a{ color: inherit; text-decoration:none; }
    .crumb a:hover{ text-decoration:underline; }
    .hero-sub{ color: var(--muted); margin:0; }

    .cardx{
      background: var(--panel);
      border: 1px solid var(--stroke);
      border-radius: var(--radius);
      box-shadow: 0 10px 28px rgba(15,23,42,.08);
      overflow:hidden;
    }
    .cardx-h{
      padding: .95rem 1.05rem;
      display:flex; align-items:center; justify-content:space-between; gap:1rem;
      background: linear-gradient(180deg, rgba(0,0,0,.015), transparent);
      border-bottom: 1px solid var(--stroke);
    }
    .cardx-title{
      margin:0; font-weight:800; letter-spacing:-.01em; color: var(--ink);
      display:flex; align-items:center; gap:.6rem;
    }
    .chip{
      font-size:.78rem; padding:.25rem .55rem; border-radius:999px;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, var(--stroke));
      color: var(--muted);
      white-space:nowrap;
    }

    label.form-label{ font-weight: 700; color: var(--ink); }
    .form-text, .text-muted, .small{ color: var(--muted) !important; }
    .form-control, .form-select{
      border-radius: 14px;
      border: 1px solid var(--stroke);
      padding: .65rem .85rem;
    }
    .form-control:focus, .form-select:focus{
      border-color: color-mix(in srgb, var(--theme-color-principal) 55%, var(--stroke));
      box-shadow: 0 0 0 .2rem color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
    }

    .ts-wrapper .ts-control{
      border-radius: 14px !important;
      padding: .55rem .75rem !important;
      border-color: var(--stroke) !important;
    }
    .ts-wrapper.focus .ts-control{
      box-shadow: 0 0 0 .2rem color-mix(in srgb, var(--theme-color-principal) 18%, transparent) !important;
      border-color: color-mix(in srgb, var(--theme-color-principal) 55%, var(--stroke)) !important;
    }

    .btn-outline-theme{
      border-color: color-mix(in srgb, var(--theme-color-principal) 35%, var(--stroke));
      color: var(--theme-color-principal);
    }
    .btn-outline-theme:hover{
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border-color: color-mix(in srgb, var(--theme-color-principal) 55%, var(--stroke));
      color: var(--theme-color-principal);
    }

    .sticky-actions{
      position: sticky; bottom: 14px; z-index: 5;
      background: color-mix(in srgb, var(--panel) 82%, transparent);
      backdrop-filter: blur(10px);
      border: 1px solid var(--stroke);
      border-radius: var(--radius);
      padding: .75rem;
      box-shadow: var(--shadow);
    }
    /* HERO (même rendu que site/index) */
    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;

      /* Ombre douce premium */
      box-shadow: 0 18px 50px rgba(0,0,0,.14);

      /* Fond piloté par les couleurs de l'entité */
      background:
        /* halo clair (tertiaire) */
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        /* halo accent (secondaire) */
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        /* voile subtil (quaternaire) pour la profondeur */
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        /* dégradé principal (principal -> plus clair) */
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    /* léger glass highlight */
    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    /* barre accent = secondaire (et glow basé sur secondaire) */
    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }
.meta-chip{
  display:inline-flex; align-items:center; gap:.45rem;
  padding:.35rem .65rem; border-radius:999px;
  background:rgba(255,255,255,.12);
  border:1px solid rgba(255,255,255,.14);
  font-size:.82rem;
  white-space: nowrap;
}
@media (max-width:768px){
  .hero{ border-radius:16px; }
}

.pac-container{
  z-index: 20000 !important;
}


  </style>



  <link rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
      crossorigin=""/>
<style>
  #site-map{
    height: 340px;
    border-radius: 16px;
    border: 1px solid var(--stroke);
    box-shadow: 0 10px 28px rgba(15,23,42,.08);
  }
  .map-hint{
    display:flex; gap:.5rem; align-items:center;
    padding:.55rem .75rem;
    border-radius: 14px;
    border: 1px dashed color-mix(in srgb, var(--theme-color-principal) 25%, var(--stroke));
    background: color-mix(in srgb, var(--theme-color-principal) 6%, transparent);
    color: var(--muted);
  }
</style>

{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
        crossorigin=""></script>
  {% if googleMapsBrowserKey %}
    <script
      src="https://maps.googleapis.com/maps/api/js?key={{ googleMapsBrowserKey }}&libraries=places&v=weekly&loading=async"
      async defer></script>
  {% endif %}


{% endblock %}

{% block body %}
  {# HERO style index (même rendu) #}
  {# HERO (identique Sessions / site/index) #}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>

    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-geo-alt me-2" style="color:var(--theme-color-secondaire)"></i>
            {{ modeEdition ? 'Modifier un site' : 'Créer un site' }}
          </h2>

          <div class="opacity-75 mt-1">
            Identité, adresse et localisation avec contrôle en temps réel.
          </div>

          <div class="d-flex flex-wrap gap-2 mt-3">
            <span class="chip">
              <i class="bi bi-geo-alt"></i>
              {{ modeEdition ? 'Modification site' : 'Nouveau site' }}
            </span>

            <span class="chip">
              <i class="bi bi-building"></i>
              {{ entite.nom }}
            </span>

            <span class="chip chip--pill">
              <i class="bi bi-pencil-square"></i>
              {{ modeEdition ? 'Édition' : 'Création' }}
            </span>

            {# Optionnel : affiche l'ID si édition #}
            {% if form.vars.value and form.vars.value.id %}
              <span class="chip">
                <i class="bi bi-hash"></i>
                #{{ form.vars.value.id }}
              </span>
            {% endif %}
          </div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
          <a href="javascript:history.back()"
            class="btn btn-outline-theme btn-sm fw-semibold">
            <i class="bi bi-arrow-left me-1"></i> Retour
          </a>

          <button form="{{ form.vars.id }}"
                  type="submit"
                  class="btn btn-light btn-sm fw-semibold">
            <i class="bi bi-check2 me-1"></i> {{ modeEdition ? 'Enregistrer' : 'Créer' }}
          </button>
        </div>
      </div>
    </div>
  </div>


  {% include 'flagMessage.html.twig' %}

  {{ form_start(form, {
    'attr': {
      'id': form.vars.id,
      'novalidate': 'novalidate',
      'name':'site_administrateur'
    }
  }) }}
  {{ form_errors(form) }}

  <div class="row g-4">
    {# ===== COL LEFT ===== #}
    <div class="col-lg-7">

      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="fa fa-info-circle text-warning"></i> Identité</h5>
          <span class="chip">Étape 1</span>
        </div>
        <div class="p-3 p-md-4">
          <div class="row g-3">
            <div class="col-md-6">{{ form_row(form.nom) }}</div>
            <div class="col-md-6">{{ form_row(form.slug) }}</div>
          </div>
        </div>
      </div>

      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="fa fa-map text-warning"></i> Adresse</h5>
          <span class="chip">Étape 2</span>
        </div>
        <div class="p-3 p-md-4">
          <div class="row g-3">
            <div class="col-md-12">{{ form_row(form.adresse) }}</div>
            <div class="col-md-6">{{ form_row(form.complement) }}</div>
            <div class="col-md-3">{{ form_row(form.codePostal) }}</div>
            <div class="col-md-3">{{ form_row(form.ville) }}</div>
            <div class="col-md-4">{{ form_row(form.departement) }}</div>
            <div class="col-md-4">{{ form_row(form.region) }}</div>
            <div class="col-md-4">{{ form_row(form.pays) }}</div>
          </div>
        </div>
      </div>

      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="fa fa-crosshairs text-warning"></i> Localisation</h5>
          <span class="chip">Étape 3</span>
        </div>
        <div class="p-3 p-md-4">
          <div class="row g-3">
            {# on garde les champs mais on les masque (ou readonly si tu préfères) #}
            <div class="col-md-4 d-none">{{ form_row(form.latitude) }}</div>
            <div class="col-md-4 d-none">{{ form_row(form.longitude) }}</div>
            <div class="col-md-6 d-none">{{ form_row(form.googlePlaceId) }}</div>
            <div class="col-md-6 d-none">{{ form_row(form.formattedAddress) }}</div>


            <div class="col-md-12">
              <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
                <div class="map-hint">
                  <i class="bi bi-cursor-fill"></i>
                  Clique sur la carte pour poser le point, puis déplace le marqueur si besoin.
                </div>

                <div class="d-flex gap-2">
                  <button type="button" class="btn btn-outline-theme btn-sm" id="btn-geoloc">
                    <i class="bi bi-crosshair"></i> Me localiser
                  </button>
                  <button type="button" class="btn btn-outline-theme btn-sm" id="btn-clear-marker">
                    <i class="bi bi-x-circle"></i> Effacer
                  </button>
                </div>
              </div>

              <div id="site-map"></div>

              <div class="form-text mt-2">
                Lat/Lng se remplissent automatiquement. (Tu peux les rendre obligatoires si tu veux.)
              </div>
            </div>

            <div class="col-md-6">{{ form_row(form.timezone) }}</div>

            <div class="col-md-6">
              <label class="form-label">Coordonnées</label>
              <div class="form-control" id="latlng-display">
                —
              </div>
              <div class="form-text">Affichage lecture seule (les champs sont dans le formulaire).</div>
            </div>
          </div>

          <div class="form-text mt-2">Astuce : tu pourras brancher Leaflet/autocomplete plus tard.</div>
        </div>
      </div>

    </div>

    {# ===== COL RIGHT (Résumé + live validation) ===== #}
    <div class="col-lg-5">

      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="fa fa-circle-info text-warning"></i> Résumé</h5>
          <span class="chip">Contrôle</span>
        </div>

        <div class="p-3 p-md-4">
          <div class="small text-muted mb-3">Vérifie rapidement avant d’enregistrer.</div>

          <div class="p-3 rounded-4 border mb-3"
