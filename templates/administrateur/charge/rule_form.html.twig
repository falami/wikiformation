{# templates/administrateur/charge/rule_form.html.twig #}
{% extends 'base_admin.html.twig' %}
{% set r = form.vars.value %}

{% block title %}{{ title|default(r and r.id ? 'Modifier une règle' : 'Nouvelle règle') }}{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/formulaire.css') }}">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
      --bg:#f5f7fb; --panel:#fff; --ink:#0f172a; --muted:#64748b; --stroke: rgba(15,23,42,.10); --radius:18px;
      --shadow: 0 18px 55px rgba(15, 23, 42, .10);
    }

    
    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;

      /* Ombre douce premium */
      box-shadow: 0 18px 50px rgba(0,0,0,.14);

      /* Fond piloté par les couleurs de l'entité */
      background:
        /* halo clair (tertiaire) */
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        /* halo accent (secondaire) */
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        /* voile subtil (quaternaire) pour la profondeur */
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        /* dégradé principal (principal -> plus clair) */
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    /* léger glass highlight */
    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    /* barre accent = secondaire (et glow basé sur secondaire) */
    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }
    /* ===== Chips HERO (comme facture) ===== */
    .hero .chip{
      display:inline-flex;
      align-items:center;
      gap:.5rem;
      padding:.32rem .7rem;
      border-radius: 999px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(255,255,255,.14);
      font-size:.82rem;
      color: rgba(255,255,255,.92);
      backdrop-filter: blur(6px);
      white-space: nowrap;
    }
    

    .hero .chip i{
      color: var(--theme-color-secondaire);
    }

    /* chip highlight (optionnel) */
    .hero .chip--pill{
      background: color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
      border-color: color-mix(in srgb, var(--theme-color-secondaire) 28%, rgba(255,255,255,.14));
      color:#fff;
    }

    .hero .btn{
      border-radius: 14px;
      font-weight: 800;
    }
    .hero .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .hero .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }

    .cardx{
      background:var(--panel);
      border:1px solid var(--stroke);
      border-radius:var(--radius);
      box-shadow:0 10px 28px rgba(15,23,42,.08);
      overflow:visible;
    }
    .cardx-h{
      padding: .95rem 1.05rem;
      display:flex; align-items:center; justify-content:space-between; gap:1rem;
      background: linear-gradient(180deg, rgba(0,0,0,.015), transparent);
      border-bottom: 1px solid var(--stroke);
      border-top-left-radius: var(--radius);
      border-top-right-radius: var(--radius);
    }
    .cardx-title{
      margin:0; font-weight:800; letter-spacing:-.01em; color: var(--ink);
      display:flex; align-items:center; gap:.6rem;
    }
    .chip{
      font-size:.78rem; padding:.25rem .55rem; border-radius:999px;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, var(--stroke));
      color: var(--muted);
      white-space:nowrap;
    }

    .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }

    label.form-label{ font-weight: 800; color: var(--ink); }
    .form-text, .text-muted, .small{ color: var(--muted) !important; }
    .form-control, .form-select{
      border-radius: 14px;
      border: 1px solid var(--stroke);
      padding: .65rem .85rem;
    }
    .form-control:focus, .form-select:focus{
      border-color: color-mix(in srgb, var(--theme-color-principal) 55%, var(--stroke));
      box-shadow: 0 0 0 .2rem color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
    }

    .mono{ font-variant-numeric: tabular-nums; white-space:nowrap; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace; }

    .json-help{ font-size:.86rem; color: var(--muted); }
    .json-example{
      border: 1px solid var(--stroke);
      border-radius: 14px;
      background: #f8f9fa;
      padding: .85rem;
      font-size: .85rem;
      overflow:auto;
    }

    .hint-box{
      border: 1px solid var(--stroke);
      border-radius: 18px;
      background: linear-gradient(180deg, color-mix(in srgb, var(--theme-color-secondaire) 10%, transparent), transparent);
      padding: 1rem;
    }

    @media (max-width:768px){
      .hero{ border-radius:16px; }
    }
  </style>
{% endblock %}

{% block body %}

  {# ===== HERO (comme Sessions) ===== #}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>

    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-sliders me-2" style="color:var(--theme-color-secondaire)"></i>
            {{ title|default(r and r.id ? 'Modifier la règle' : 'Nouvelle règle') }}
          </h2>
          <div class="opacity-75 mt-1">Type, base, taux/forfait, dates et conditions d’application.</div>

          <div class="d-flex flex-wrap gap-2 mt-3">
            <span class="chip"><i class="bi bi-sliders"></i> Charges</span>
            <span class="chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
            <span class="chip chip--pill">
              <i class="bi bi-pencil-square"></i> {{ r and r.id ? 'Édition' : 'Création' }}
            </span>
          </div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
          <a class="btn btn-outline-theme btn-sm fw-semibold"
            href="{{ path('app_administrateur_charge_rule_index', { entite: entite.id }) }}">
            <i class="bi bi-arrow-left me-1"></i> Retour
          </a>

          <a class="btn btn-outline-theme btn-sm fw-semibold"
            href="{{ path('app_administrateur_charge_preview', { entite: entite.id }) }}">
            <i class="bi bi-eye me-1"></i> Preview
          </a>

          <button form="{{ form.vars.id }}" type="submit" class="btn btn-light btn-sm fw-semibold">
            <i class="bi bi-check2 me-1"></i> Enregistrer
          </button>
        </div>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  {{ form_start(form, { attr: { id: form.vars.id, novalidate:'novalidate', name:'tax_rule_form' } }) }}
  {{ form_errors(form) }}

  <div class="row g-4">

    <div class="col-lg-8">

      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-tag-fill text-warning"></i> Identification</h5>
          <span class="chip">Étape 1</span>
        </div>

        <div class="p-3 p-md-4">
          <div class="row g-3">
            <div class="col-md-6">
              {{ form_row(form.code) }}
              <div class="form-text">Code unique stable (ex: <span class="mono">URSSAF_MICRO_BIC</span>).</div>
            </div>
            <div class="col-md-6">
              {{ form_row(form.label) }}
              <div class="form-text">Libellé lisible pour l’écran “Charges”.</div>
            </div>

            <div class="col-md-6">{{ form_row(form.kind) }}</div>
            <div class="col-md-6">{{ form_row(form.base) }}</div>

            {% if form.priority is defined %}
              <div class="col-md-6">
                {{ form_row(form.priority) }}
                <div class="form-text">Plus grand = appliqué en premier.</div>
              </div>
            {% endif %}

            {% if form.isActive is defined %}
              <div class="col-md-6 d-flex align-items-end">
                <div class="w-100">
                  {{ form_row(form.isActive) }}
                  <div class="form-text">Désactiver une règle sans la supprimer.</div>
                </div>
              </div>
            {% endif %}
          </div>
        </div>
      </div>

      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-calculator-fill text-warning"></i> Calcul</h5>
          <span class="chip">Taux / Forfait</span>
        </div>

        <div class="p-3 p-md-4">
          <div class="row g-3">
            <div class="col-md-6">
              {{ form_row(form.rate) }}
              <div class="form-text">En % (ex: 21,20). Laisse vide si forfait uniquement.</div>
            </div>
            <div class="col-md-6">
              {{ form_row(form.flatCents) }}
              <div class="form-text">En centimes (ex: 12000 = 120,00 €). Laisse vide si taux uniquement.</div>
            </div>
          </div>

          <div class="hint-box mt-3">
            <div class="fw-bold mb-1"><i class="bi bi-lightbulb"></i> Rappel</div>
            <div class="small">
              • <strong>Taux</strong> : appliqué sur la base sélectionnée<br>
              • <strong>Forfait</strong> : ajouté au total<br>
              • Les deux peuvent coexister
            </div>
          </div>
        </div>
      </div>

      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-calendar2-week-fill text-warning"></i> Validité</h5>
          <span class="chip">Dates</span>
        </div>

        <div class="p-3 p-md-4">
          <div class="row g-3">
            <div class="col-md-6">{{ form_row(form.validFrom) }}</div>
            <div class="col-md-6">{{ form_row(form.validTo) }}</div>
          </div>
          <div class="form-text mt-2">Si <span class="mono">validTo</span> est vide → “∞”.</div>
        </div>
      </div>

      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-braces-asterisk text-warning"></i> Conditions & meta</h5>
          <span class="chip">JSON</span>
        </div>

        <div class="p-3 p-md-4">
          {% if form.conditionsJson is defined %}
            {{ form_row(form.conditionsJson) }}
            <div class="json-help mt-2">
              S’applique si le snapshot contient ces valeurs (champs absents = non contraignants).
            </div>

            <div class="json-example mt-3">
            <pre>{
              "country": "FR",
              "regime": "MICRO",
              "activity": ["BNC", "BIC_SERVICES"],
              "options": { "cma": true, "accre": false }
            }</pre>
            </div>
          {% endif %}

          {% if form.metaJson is defined %}
            <hr class="my-3" style="border-color: var(--stroke);">
            {{ form_row(form.metaJson) }}
            <div class="json-help mt-2">
              Meta = infos libres (tags, aide, source…).
            </div>
          {% endif %}
        </div>
      </div>

      <div class="d-flex gap-2">
        <a class="btn btn-light fw-semibold" href="{{ path('app_administrateur_charge_rule_index', {entite: entite.id}) }}">
          Annuler
        </a>
        <button type="submit" class="btn btn-gradient fw-semibold">
          <i class="bi bi-check2"></i> Enregistrer
        </button>
      </div>

    </div>

    <div class="col-lg-4">
      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-shield-check text-warning"></i> Conseils</h5>
          <span class="chip">Robuste</span>
        </div>

        <div class="p-3 p-md-4">
          <div class="hint-box mb-3">
            <div class="fw-bold mb-1"><i class="bi bi-asterisk"></i> Codes stables</div>
            <div class="small">
              Si le taux change, crée une nouvelle règle + dates, au lieu de modifier l’ancienne.
            </div>
          </div>

          <div class="hint-box mb-3">
            <div class="fw-bold mb-1"><i class="bi bi-calendar-event"></i> Changement en cours d’année</div>
            <div class="small">
              Ancienne règle : <span class="mono">validTo</span> ; nouvelle : <span class="mono">validFrom</span>.
            </div>
          </div>

          <div class="hint-box">
            <div class="fw-bold mb-1"><i class="bi bi-filter-circle"></i> Conditions</div>
            <div class="small">
              Mets seulement ce qui discrimine vraiment (simple = maintenable).
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>

  {{ form_end(form) }}
  

<script>
/* garde-fou JSON (si tes champs conditions/meta sont des Textarea JSON) */
(function(){
  const form = document.getElementById('{{ form.vars.id }}');

  if(!form) return;

  function tryParseJson(text){
    const v = (text || '').trim();
    if(!v) return { ok:true };
    try { JSON.parse(v); return { ok:true }; }
    catch(e){ return { ok:false, err:e.message || 'JSON invalide' }; }
  }

  const cond = form.querySelector('[name$="[conditionsJson]"]');
  const meta = form.querySelector('[name$="[metaJson]"]');

  function mark(el, ok, msg){
    if(!el) return;
    el.classList.toggle('is-invalid', !ok);
    el.classList.toggle('is-valid', ok && (el.value||'').trim().length);
    el.parentElement?.querySelectorAll('.invalid-feedback.d-block').forEach(n => n.remove());
    if(!ok){
      const div = document.createElement('div');
      div.className = 'invalid-feedback d-block';
      div.textContent = msg;
      el.parentElement?.appendChild(div);
    }
  }

  [cond, meta].forEach(el=>{
    if(!el) return;
    el.addEventListener('input', ()=>{
      const r = tryParseJson(el.value);
      mark(el, r.ok, r.err || '');
    });
  });

  form.addEventListener('submit', (e)=>{
    const tests = [];
    if(cond) tests.push({ el:cond, r: tryParseJson(cond.value) });
    if(meta) tests.push({ el:meta, r: tryParseJson(meta.value) });

    const bad = tests.find(t => !t.r.ok);
    if(bad){
      e.preventDefault();
      mark(bad.el, false, bad.r.err || 'JSON invalide');
      bad.el.scrollIntoView({ behavior:'smooth', block:'center' });
      bad.el.focus({ preventScroll:true });
    }
  });
})();
</script>


<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/fr.js"></script>

<script>
(function(){
  const from = document.getElementById('{{ form.validFrom.vars.id }}');
  const to   = document.getElementById('{{ form.validTo.vars.id }}');
  if(!from || !to) return;

  const pad = (n)=> String(n).padStart(2,'0');
  const fmt = (d)=> pad(d.getDate()) + "/" + pad(d.getMonth()+1) + "/" + d.getFullYear();

  to.readOnly = true;

  flatpickr(from, {
    locale: flatpickr.l10ns.fr,
    dateFormat: "d/m/Y",
    mode: "range",
    allowInput: true,
    onChange: function(selectedDates){
      if(selectedDates.length === 0){
        from.value = "";
        to.value = "";
        return;
      }
      if(selectedDates.length === 1){
        from.value = fmt(selectedDates[0]); // ✅ début
        to.value = "";
        return;
      }
      from.value = fmt(selectedDates[0]);   // ✅ début
      to.value   = fmt(selectedDates[1]);   // ✅ fin
    }
  });
})();
</script>


{% endblock %}
