{# templates/administrateur/charge/rule_index.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}Règles de charges{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/style-table.css') }}">
  <link rel="stylesheet" href="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/datatables.min.css"/>
  <link rel="stylesheet" href="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.css"/>

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }


    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;

      /* Ombre douce premium */
      box-shadow: 0 18px 50px rgba(0,0,0,.14);

      /* Fond piloté par les couleurs de l'entité */
      background:
        /* halo clair (tertiaire) */
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        /* halo accent (secondaire) */
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        /* voile subtil (quaternaire) pour la profondeur */
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        /* dégradé principal (principal -> plus clair) */
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    /* léger glass highlight */
    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    /* barre accent = secondaire (et glow basé sur secondaire) */
    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }
    .hero .meta-chip{
      display:inline-flex; align-items:center; gap:.5rem;
      padding:.35rem .65rem;
      border-radius:999px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(255,255,255,.14);
      backdrop-filter: blur(6px);
      font-size:.825rem;
      white-space: nowrap;
    }
    .hero .subtitle{ opacity:.86 }

    .toolbar{
      border-radius: 16px;
      background: #fff;
      border: 1px solid rgba(0,0,0,.06);
      box-shadow: 0 10px 24px rgba(0,0,0,.05);
      padding: .85rem;
    }
    .toolbar .hint{ font-size:.85rem; color: rgba(0,0,0,.55); }
    .chip{
      display:inline-flex; align-items:center; gap:.5rem;
      padding:.35rem .7rem;
      border-radius:999px;
      background: rgba(0,0,0,.03);
      border: 1px solid rgba(0,0,0,.06);
      font-size:.85rem;
      color: rgba(0,0,0,.65);
      white-space: nowrap;
    }

    .table-card{
      border-radius: 18px;
      background: #fff;
      border: 1px solid rgba(0,0,0,.06);
      box-shadow: 0 12px 30px rgba(0,0,0,.06);
      overflow:hidden;
    }

    table.dataTable{ margin:0 !important; }
    table.dataTable thead th{
      position: sticky; top: 0; z-index: 2;
      background: #f7f8fa !important;
      border-bottom: 1px solid rgba(0,0,0,.08) !important;
      text-transform: uppercase;
      font-size: .78rem;
      letter-spacing:.06em;
      color: rgba(0,0,0,.55);
      white-space: nowrap;
    }

    /* Zebra */
    #tableauRules tbody tr:nth-child(odd) > *{ background-color:#fff !important; }
    #tableauRules tbody tr:nth-child(even) > *{ background-color: rgba(35,51,66,.035) !important; }
    #tableauRules tbody tr:hover > *{ background-color: rgba(255,193,7,.08) !important; }

    #tableauRules tbody td{
      padding-top: .75rem !important;
      padding-bottom: .75rem !important;
      vertical-align: middle !important;
    }

    .mono{ font-variant-numeric: tabular-nums; white-space: nowrap; }

    /* DataTables UI polish */
    .dataTables_wrapper .dataTables_filter input{
      border-radius: 999px !important;
      padding: .45rem .85rem !important;
      border: 1px solid rgba(0,0,0,.12) !important;
      outline: none !important;
      box-shadow: none !important;
    }
    .dataTables_wrapper .dataTables_length select{
      border-radius: 999px !important;
      border: 1px solid rgba(0,0,0,.12) !important;
      padding: .35rem .7rem !important;
    }
    .dt-top{
      padding: .75rem .85rem;
      border-bottom: 1px solid rgba(0,0,0,.06);
      background: #fff;
    }
    .dt-bottom-internal{
      padding: 1rem .85rem !important;
      background: #fff;
      border-top: 1px solid rgba(0,0,0,.06);
      margin-top: .75rem !important;
    }

    /* Actions */
    #tableauRules th.action-column,
    #tableauRules td.action-column{
      width: 1% !important;
      min-width: 1% !important;
      max-width: 1% !important;
      white-space: nowrap !important;
      padding-left: .25rem !important;
      padding-right: .25rem !important;
      text-align: right;
    }

    /* dropdown au-dessus */
    body .dt-floating-dropdown{ z-index: 9999 !important; }

    @media (max-width: 768px){
      #tableauRules td.action-column{
        position: sticky; right:0; background:#fff; z-index:5;
        box-shadow: -12px 0 18px -14px rgba(0,0,0,.22);
      }
      .hero{ border-radius: 16px; }
    }
  </style>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

  <script src="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.js"></script>
{% endblock %}

{% block body %}


  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>
    <div class="flex-grow-1">

      <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
        <span class="meta-chip"><i class="bi bi-calculator"></i> Charges</span>
        <span class="meta-chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
        <span class="meta-chip"><i class="bi bi-sliders"></i> Règles</span>
        <span class="meta-chip"><i class="bi bi-clock-history"></i> <span id="hero-last-refresh">—</span></span>
      </div>

      <div class="d-flex flex-wrap align-items-end gap-3">
        <div class="me-auto">
          <h2 class="fw-bold mb-1">Règles de charges</h2>
          <div class="subtitle">Liste paginée, recherche, tri, exports.</div>
        </div>

        <div class="d-flex flex-wrap gap-2">
          <a class="btn btn-light btn-sm fw-semibold"
             href="{{ path('app_administrateur_charge_preview', { entite: entite.id }) }}">
            <i class="bi bi-eye"></i> Preview
          </a>

          <a class="btn btn-warning btn-sm fw-semibold"
             href="{{ path('app_administrateur_charge_rule_new', { entite: entite.id }) }}">
            <i class="bi bi-plus"></i> Nouvelle règle
          </a>
        </div>
      </div>

    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  <div class="toolbar mb-3">
    <div class="d-flex flex-wrap gap-2 align-items-center">
      <div class="me-auto d-flex flex-wrap gap-2 align-items-center">
        <span class="chip">
          <i class="bi bi-search"></i>
          Recherche : code, libellé, type, base
        </span>
      </div>

      <div class="d-flex gap-2 align-items-center">
        <button id="btnReset" class="btn btn-outline-secondary btn-sm fw-semibold" type="button">
          <i class="bi bi-arrow-counterclockwise"></i> Reset
        </button>

        <div class="dropdown">
          <button class="btn btn-warning btn-sm fw-semibold dropdown-toggle" type="button"
                  data-bs-toggle="dropdown" aria-expanded="false">
            <i class="bi bi-download"></i> Export
          </button>
          <ul class="dropdown-menu dropdown-menu-end" id="exportMenu"></ul>
        </div>
      </div>
    </div>
  </div>

  <div class="table-card mb-4 p-3">
    <table id="tableauRules" class="table table-hover align-middle mb-0" style="width:100%">
      <thead>
        <tr>
          <th style="width:80px">#</th>
          <th style="width:140px">Code</th>
          <th>Libellé</th>
          <th style="width:140px">Type</th>
          <th style="width:140px">Base</th>
          <th class="text-end" style="width:120px">Taux</th>
          <th class="text-end" style="width:140px">Forfait</th>
          <th style="width:210px">Validité</th>
          <th class="text-end action-column" style="width:170px">Actions</th>
        </tr>
      </thead>
      <tbody><tr><td colspan="9"></td></tr></tbody>
    </table>
  </div>


<script>
$(function () {
  function nowLabel(){
    const d = new Date();
    return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
  }

  function initTooltips(){
    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => {
      bootstrap.Tooltip.getOrCreateInstance(el);
    });
  }

  function fmtRate(v){
    if(v === null || v === undefined || v === '' || Number(v) === 0) return '—';
    const n = Number(v);
    return n.toLocaleString('fr-FR', {minimumFractionDigits:4, maximumFractionDigits:4}) + ' %';
  }

  function euroFromCents(cents){
    const v = (cents || 0) / 100;
    if(!cents) return '—';
    return v.toLocaleString('fr-FR', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €';
  }

  const table = $('#tableauRules').DataTable({
    serverSide: true,
    processing: true,
    autoWidth: false,
    scrollX: true,
    scrollCollapse: true,
    responsive: false,

    ajax: {
      url: "{{ path('app_administrateur_charge_rule_ajax', { entite: entite.id }) }}",
      type: "POST"
    },

    dom:
      '<"dt-top d-flex flex-wrap gap-2 align-items-center justify-content-between"'
        + '<"dt-actions d-flex gap-2 align-items-center"B>'
        + '<"dt-search"f>'
      + '>'
      + 'rt'
      + '<"dt-bottom-internal d-flex flex-wrap gap-2 align-items-center justify-content-between"lip>',

    buttons: [
      { extend: 'copy',  title: 'Règles de charges', text: 'Copier' },
      { extend: 'csv',   title: 'Règles de charges', text: 'CSV' },
      { extend: 'excel', title: 'Règles de charges', text: 'Excel' },
      { extend: 'pdf',   title: 'Règles de charges', text: 'PDF' },
      { extend: 'print', title: 'Règles de charges', text: 'Imprimer' },
    ],

    lengthMenu: [[10,25,50,100],[10,25,50,100]],
    order: [[1, 'asc']], // code

    columns: [
      { data: 'id' },
      { data: 'code' },
      { data: 'label' },
      { data: 'kind' },
      { data: 'base' },
      { data: 'rate' },
      { data: 'flatCents' },
      { data: null },       // validité (render)
      { data: 'actions' },  // html
    ],

    columnDefs: [
      { targets: [0], width:'80px' },

      { targets: [5], className: 'text-end mono', render: function(data){ return fmtRate(data); } },
      { targets: [6], className: 'text-end mono', render: function(data){ return euroFromCents(data); } },

      { targets: [7], className: 'mono', render: function(_, __, row){
          const from = row.validFrom ? row.validFrom : '—';
          const to   = row.validTo ? row.validTo : '∞';
          return `${from} → ${to}`;
        }
      },

      { targets: [8], className: 'action-column text-end', orderable:false, searchable:false },

      // évite de rechercher sur la colonne actions + validité construite
      { targets: [7,8], searchable:false },
    ],

    language: { url:'https://cdn.datatables.net/plug-ins/2.2.2/i18n/fr-FR.json' },
    deferRender: true,

    initComplete: function(){
      const api = this.api();
      const container = api.buttons().container();
      const $btns = $(container).find('button');

      $('#exportMenu').empty();
      $btns.each(function(){
        const $b = $(this);
        const label = $b.text().trim();

        const icon = label === 'Excel' ? 'bi-file-earmark-excel' :
                     label === 'PDF' ? 'bi-file-earmark-pdf' :
                     label === 'CSV' ? 'bi-filetype-csv' :
                     label === 'Imprimer' ? 'bi-printer' :
                     label === 'Copier' ? 'bi-clipboard' : 'bi-download';

        const $item = $(`
          <li>
            <a class="dropdown-item d-flex align-items-center gap-2" href="#">
              <i class="bi ${icon}"></i> <span>${label}</span>
            </a>
          </li>
        `);

        $item.on('click', function(e){
          e.preventDefault();
          $b.trigger('click');
        });

        $('#exportMenu').append($item);
      });

      $(container).hide();
    }
  });

  enableDtDropdownOutsideScroll();

  function enableDtDropdownOutsideScroll(){
    document.addEventListener('show.bs.dropdown', function (e) {
      const toggle = e.target;
      const dd = toggle.closest('.dropdown, .btn-group');
      if (!dd) return;

      const menu = dd.querySelector('.dropdown-menu');
      if (!menu) return;

      if (!menu.__originalParent) menu.__originalParent = dd;

      document.body.appendChild(menu);
      menu.classList.add('dt-floating-dropdown');

      const rect = toggle.getBoundingClientRect();
      const menuRect = menu.getBoundingClientRect();
      const isEnd = menu.classList.contains('dropdown-menu-end');

      const top = rect.bottom + window.scrollY + 6;
      let left = isEnd ? (rect.right + window.scrollX - menuRect.width) : (rect.left + window.scrollX);
      left = Math.max(8, Math.min(left, window.scrollX + window.innerWidth - menuRect.width - 8));

      menu.style.position = 'absolute';
      menu.style.top = `${top}px`;
      menu.style.left = `${left}px`;
    });

    document.addEventListener('hidden.bs.dropdown', function (e) {
      const toggle = e.target;
      const dd = toggle.closest('.dropdown, .btn-group');
      if (!dd) return;

      document.querySelectorAll('body .dt-floating-dropdown').forEach(m => {
        if (m.__originalParent === dd) {
          dd.appendChild(m);
          m.classList.remove('dt-floating-dropdown');
          m.style.position = '';
          m.style.top = '';
          m.style.left = '';
        }
      });
    });

    window.addEventListener('scroll', () => {
      document.querySelectorAll('[aria-expanded="true"][data-bs-toggle="dropdown"]').forEach(btn => btn.click());
    }, true);

    window.addEventListener('resize', () => {
      document.querySelectorAll('[aria-expanded="true"][data-bs-toggle="dropdown"]').forEach(btn => btn.click());
    });
  }

  initTooltips();
  table.on('draw.dt', function(){
    initTooltips();
    $('#hero-last-refresh').text('Maj : ' + nowLabel());
  });

  $('#btnReset').on('click', function(){
    table.search('').draw();
    table.ajax.reload(null, true);
  });
});
</script>
{% endblock %}
