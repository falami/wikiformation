<script>
$(function(){
  const $status = $('#reservationStatusFilter');

  function nowLabel(){
    const d = new Date();
    return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
  }

  async function loadKpis(){
    const url = "{{ path('app_administrateur_reservation_kpis', { entite: entite.id }) }}?status=" + encodeURIComponent($status.val() || 'all');
    const res = await fetch(url, { headers: { 'Accept':'application/json' }});
    if(!res.ok) return;
    const k = await res.json();

    $('#kpi-count').text(k.count ?? '—');
    $('#kpi-pending').text(k.pending ?? '—');
    $('#kpi-confirmed').text(k.confirmed ?? '—');

    // montant affiché en €
    const amount = (k.amountCents || 0) / 100;
    $('#kpi-amount').text(amount.toLocaleString('fr-FR', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €');

    $('#kpi-range').text('{{ entite.nom }}');
    $('#hero-last-refresh').text('Maj : ' + nowLabel());
  }

  const table = $('#tableauReservation').DataTable({
    serverSide:true,
    processing:true,
    autoWidth: false,
    scrollX: true,
    scrollCollapse: true,
    responsive: false,
    
    ajax:{
      url:"{{ path('app_administrateur_reservation_ajax', { entite: entite.id }) }}",
      type:"POST",
      data:d => d.statusFilter = $status.val()
    },
    dom:
      '<"dt-top d-flex flex-wrap gap-2 align-items-center justify-content-between"'
        + '<"dt-actions d-flex gap-2 align-items-center"B>'
        + '<"dt-search"f>'
      + '>'
      + 'rt'
      + '<"dt-bottom-internal d-flex flex-wrap gap-2 align-items-center justify-content-between"lip>',
    buttons:['copy','csv','excel','pdf','print'],
    columns:[
      {data:'id'},
      {data:'session'},
      {data:'utilisateur'},
      {data:'place'},
      {data:'dateReservation'},
      {data:'montant'},
      {data:'status'},
      {data:'actions'}
    ],
    columnDefs:[
      {targets:[4,7], className:'text-end'},               // montant + actions
      {targets:7, orderable:false, searchable:false, className:'action-column'},
      {targets:[5,7], orderable:false},                    // statut + actions non triables
    ],
    order:[[0,'desc']],

    language:{ url:'https://cdn.datatables.net/plug-ins/2.2.2/i18n/fr-FR.json' },

    initComplete:function(){
      const api = this.api();
      const $btns = $(api.buttons().container()).find('button');

      $('#exportMenu').empty();
      $btns.each(function(){
        const $b=$(this);
        $('<li><a class="dropdown-item" href="#">'+$b.text()+'</a></li>')
          .on('click',e=>{e.preventDefault();$b.click();})
          .appendTo('#exportMenu');
      });
      $(api.buttons().container()).hide();
    }
    
  });

  // ===== Modal Confirm Inscription (Réservation -> Inscription) =====
  const confirmModalEl = document.getElementById('confirmInscriptionModal');
  const confirmModal = confirmModalEl ? new bootstrap.Modal(confirmModalEl) : null;

  const $ciCheck = $('#ci-confirmCheck');
  const $ciBtn   = $('#ci-confirmBtn');
  const $ciErr   = $('#ci-error');

  let ciUrl = null;
  let ciBusy = false;

  // (1) ouverture modale depuis le bouton action
  $(document).on('click', '.js-confirm-resa', function(e){
    e.preventDefault();

    if(!confirmModal) return;

    const $btn = $(this);

    ciUrl = $btn.data('url') || null;

    // ⚠️ On récupère des infos depuis data-* si tu les ajoutes, sinon on fallback
    const resaId   = $btn.data('id') || $btn.closest('tr').find('td:eq(0)').text().trim() || '—';
    const userLbl  = $btn.data('user') || '—';
    const sessLbl  = $btn.data('session') || '—';
    const places   = $btn.data('places') || '—';

    $('#ci-reservationId').text('#' + resaId);
    $('#ci-user').text(userLbl);
    $('#ci-session').text(sessLbl);
    $('#ci-places').text(places);

    $ciErr.addClass('d-none').text('');
    $ciCheck.prop('checked', false);
    $ciBtn.prop('disabled', true);

    ciBusy = false;
    confirmModal.show();
  });

  // (2) checkbox => active le bouton
  $ciCheck.on('change', function(){
    if(ciBusy) { $ciBtn.prop('disabled', true); return; }
    $ciBtn.prop('disabled', !this.checked);
  });

  // (3) click confirmer => fetch AJAX
  $ciBtn.on('click', async function(){
    if(ciBusy) return;
    if(!$ciCheck.prop('checked')) return;
    if(!ciUrl) return;

    ciBusy = true;
    $ciErr.addClass('d-none').text('');

    const originalHtml = $ciBtn.html();
    $ciBtn.prop('disabled', true).html(
      '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Création...'
    );

    try {
      const res = await fetch(ciUrl, {
        method: 'POST',
        headers: {
          'X-Requested-With': 'XMLHttpRequest',
          'Accept': 'application/json'
        }
      });

      const json = await res.json().catch(() => ({}));

      if(!res.ok || !json?.ok){
        const msg = json?.message || "Impossible de confirmer la réservation.";
        $ciErr.removeClass('d-none').text(msg);
        ciBusy = false;
        $ciBtn.html(originalHtml);
        $ciBtn.prop('disabled', !$ciCheck.prop('checked'));
        return;
      }

      // ✅ succès : ferme modal + refresh table & kpis
      confirmModal.hide();
      table.ajax.reload(null, false);
      loadKpis();

    } catch (err) {
      $ciErr.removeClass('d-none').text("Erreur réseau. Réessaie.");
      ciBusy = false;
      $ciBtn.html(originalHtml);
      $ciBtn.prop('disabled', !$ciCheck.prop('checked'));
    }
  });

  // (4) reset à la fermeture
  confirmModalEl?.addEventListener('hidden.bs.modal', () => {
    ciUrl = null;
    ciBusy = false;
    $ciErr.addClass('d-none').text('');
    $ciCheck.prop('checked', false);
    $ciBtn.prop('disabled', true).html('<i class="bi bi-check2-circle me-1"></i> Créer l’inscription');
  });

  $status.on('change', function(){
    table.ajax.reload(null, true);
    loadKpis();
  });

  $('#btnReset').on('click', function(){
    $status.val('all');
    table.search('').draw();
    table.ajax.reload(null, true);
    loadKpis();
  });

  table.on('draw', ()=>$('#hero-last-refresh').text('Maj : ' + nowLabel()));

  loadKpis();
  
});
</script>
{% endblock %}
