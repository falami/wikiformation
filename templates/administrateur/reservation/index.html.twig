{% extends 'base_admin.html.twig' %}
{% block title %}Réservations{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }
    /* ===== HERO ===== */
    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;

      /* Ombre douce premium */
      box-shadow: 0 18px 50px rgba(0,0,0,.14);

      /* Fond piloté par les couleurs de l'entité */
      background:
        /* halo clair (tertiaire) */
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        /* halo accent (secondaire) */
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        /* voile subtil (quaternaire) pour la profondeur */
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        /* dégradé principal (principal -> plus clair) */
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    /* léger glass highlight */
    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    /* barre accent = secondaire (et glow basé sur secondaire) */
    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }

    /* ===== Chips HERO (comme facture) ===== */
    .hero .chip{
      display:inline-flex;
      align-items:center;
      gap:.5rem;
      padding:.32rem .7rem;
      border-radius: 999px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(255,255,255,.14);
      font-size:.82rem;
      color: rgba(255,255,255,.92);
      backdrop-filter: blur(6px);
      white-space: nowrap;
    }
    .hero .chip i{
      color: var(--theme-color-secondaire);
    }

    /* chip highlight (optionnel) */
    .hero .chip--pill{
      background: color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
      border-color: color-mix(in srgb, var(--theme-color-secondaire) 28%, rgba(255,255,255,.14));
      color:#fff;
    }

    .hero .btn{
      border-radius: 14px;
      font-weight: 800;
    }
    .hero .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .hero .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }

    @media (max-width: 768px){
      .hero{ border-radius:16px; }
    }

    /* KPI */
    .kpi-card{
      border: 1px solid rgba(0,0,0,.06);
      box-shadow: 0 10px 26px rgba(0,0,0,.06);
      border-radius: 18px;
      overflow:hidden;
      background:#fff;
      position:relative;
    }
    .kpi-ico{
      width:44px; height:44px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }

    .filter-icon{
      width:38px; height:38px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }
    .kpi-label{ color: rgba(0,0,0,.55); font-size:.85rem }
    .kpi-value{ font-weight:800; font-size:1.6rem; letter-spacing:-.02em }
    .kpi-sub{ color: rgba(0,0,0,.50); font-size:.82rem }

    /* TOOLBAR */
    .toolbar{
      background:#fff;
      border-radius:16px;
      border:1px solid rgba(0,0,0,.06);
      padding:.85rem;
      box-shadow:0 10px 24px rgba(0,0,0,.05);
    }
    .chip{
      display:inline-flex; align-items:center; gap:.5rem;
      padding:.35rem .7rem;
      border-radius:999px;
      background:rgba(0,0,0,.03);
      border:1px solid rgba(0,0,0,.06);
      font-size:.85rem;
      color:rgba(0,0,0,.65);
    }

    /* DATATABLE CARD */
    .table-card{
      background:#fff;
      border-radius:18px;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 12px 30px rgba(0,0,0,.06);
      overflow:hidden;
    }
    table.dataTable{ margin:0 !important; }
    table.dataTable thead th{
      background:#f7f8fa!important;
      border-bottom:1px solid rgba(0,0,0,.08)!important;
      font-size:.78rem;
      text-transform:uppercase;
      letter-spacing:.05em;
      color: rgba(0,0,0,.55);
    }

    /* DT top/bottom spacing like Factures */
    .dt-top{
      padding:.75rem .85rem;
      border-bottom:1px solid rgba(0,0,0,.06);
      background:#fff;
    }
    .dt-bottom-internal{
      padding:1rem .85rem!important;
      border-top:1px solid rgba(0,0,0,.06);
      background:#fff;
      margin-top:.75rem!important;
    }

    /* Zebra */
    #tableauReservation tbody tr:nth-child(even) > *{
      background:rgba(35,51,66,.035)!important;
    }
    #tableauReservation tbody tr:hover > *{
      background:rgba(255,193,7,.08)!important;
    }
    #tableauReservation tbody td{
      padding-top:.75rem!important;
      padding-bottom:.75rem!important;
    }

    /* Sticky actions mobile */
    @media (max-width:768px){
      td.action-column{
        position:sticky;
        right:0;
        background:#fff;
        box-shadow:-12px 0 18px -14px rgba(0,0,0,.22);
        z-index:5;
      }
      .hero{ border-radius:16px; }
    }

    /* ===== MODAL PREMIUM (Réservations) ===== */
    .modal-premium .modal-content{
      border:1px solid rgba(0,0,0,.10);
      border-radius: 20px;
      overflow:hidden;
      background:
        radial-gradient(900px 240px at 10% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent),
          transparent 55%
        ),
        radial-gradient(900px 260px at 90% 0%,
          color-mix(in srgb, var(--theme-color-tertiaire) 22%, transparent),
          transparent 60%
        ),
        #fff;
      box-shadow: 0 26px 70px rgba(0,0,0,.18);
    }

    .modal-premium .modal-header{
      border:0;
      padding: 1rem 1.1rem .75rem;
    }

    .modal-premium .modal-title{
      font-weight: 900;
      letter-spacing: -.02em;
    }

    .modal-premium .modal-body{
      padding: .95rem 1.1rem 1rem;
    }

    .modal-premium .modal-footer{
      border:0;
      padding: .85rem 1.1rem 1.05rem;
      gap:.5rem;
    }

    .mp-icon{
      width:46px;height:46px;border-radius:16px;
      display:grid;place-items:center;
      background: color-mix(in srgb, var(--theme-color-secondaire) 14%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-secondaire) 24%, rgba(0,0,0,.08));
      color: color-mix(in srgb, var(--theme-color-principal) 80%, #000 20%);
      flex:0 0 auto;
    }

    .mp-card{
      border:1px solid rgba(0,0,0,.08);
      border-radius:16px;
      padding:.75rem .85rem;
      background: rgba(255,255,255,.9);
      box-shadow: 0 10px 22px rgba(0,0,0,.06);
    }

    .mp-kv{
      display:grid;
      grid-template-columns: 130px 1fr;
      gap:.35rem .75rem;
      font-size:.92rem;
    }
    .mp-kv .k{ color: rgba(0,0,0,.55); font-weight:800; text-transform:uppercase; letter-spacing:.05em; font-size:.72rem; }
    .mp-kv .v{ color: rgba(0,0,0,.85); font-weight:700; }

    .mp-warn{
      display:flex;
      gap:.65rem;
      align-items:flex-start;
      margin-top:.75rem;
      color: rgba(0,0,0,.65);
      font-size:.9rem;
    }
    .mp-warn i{ color: var(--theme-color-secondaire); margin-top:.15rem; }

    .btn-premium-primary{
      border:0;
      font-weight:900;
      border-radius:14px;
      padding:.65rem .95rem;
      background:
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
      box-shadow:0 14px 30px rgba(0,0,0,.14);
      color:#fff;
    }
    .btn-premium-primary:hover{ filter: brightness(1.04); }

    .btn-premium-ghost{
      border-radius:14px;
      font-weight:800;
    }
</style>

  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/style-table.css') }}">
