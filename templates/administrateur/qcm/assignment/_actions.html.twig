{# vars attendues :
  - entite (Entite)
  - a : { id, hasAttempt, showUrl, forceUrl }
#}

<div class="btn-group btn-group-sm qcm-actions" role="group">

  {# ✅ Bouton principal = Voir tentative (ou disabled) #}
  {% if a.hasAttempt and a.showUrl %}
    <a class="btn btn-light qcm-main"
       href="{{ a.showUrl }}"
       data-bs-toggle="tooltip" title="Voir la tentative">
      <i class="bi bi-eye"></i>
    </a>
  {% else %}
    <button class="btn btn-light qcm-main" type="button" disabled
            data-bs-toggle="tooltip" title="Aucune tentative">
      <i class="bi bi-eye"></i>
    </button>
  {% endif %}

  {# ✅ Split dropdown #}
  <button type="button"
          class="btn btn-light dropdown-toggle dropdown-toggle-split qcm-split"
          data-bs-toggle="dropdown" aria-expanded="false">
    <span class="visually-hidden">Actions</span>
  </button>

  <ul class="dropdown-menu dropdown-menu-end qcm-menu">

    <li>
      <button class="dropdown-item d-flex align-items-center js-force-attempt"
              type="button"
              data-url="{{ a.forceUrl }}">
        <i class="bi bi-magic me-2"></i> Créer la tentative
      </button>
    </li>

    {% if a.hasAttempt and a.showUrl %}
      <li><hr class="dropdown-divider"></li>
      <li>
        <a class="dropdown-item d-flex align-items-center"
           href="{{ a.showUrl }}">
          <i class="bi bi-eye me-2"></i> Voir la tentative
        </a>
      </li>
    {% endif %}

  </ul>
</div>
