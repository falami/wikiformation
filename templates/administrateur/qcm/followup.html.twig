{% extends 'base_admin.html.twig' %}
{% block title %}Action corrective QCM{% endblock %}

{% block body %}
<div class="container-fluid py-3">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h1 class="h4 mb-0">Action corrective requise</h1>
      <div class="text-muted small">
        Le stagiaire a obtenu une note de fin inférieure à la note de début.
      </div>
    </div>
    <a class="btn btn-outline-secondary" href="{{ path('app_administrateur_qcm_index', {entite: entite.id}) }}">
      <i class="bi bi-arrow-left"></i> Retour
    </a>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-body">
      <div class="mb-3">
        <div class="fw-semibold">{{ a.inscription.stagiaire.prenom }} {{ a.inscription.stagiaire.nom|upper }}</div>
        <div class="text-muted small">{{ a.session.label }}</div>
      </div>

      <form method="post">
        <input type="hidden" name="_token" value="{{ csrf_token('qcm_followup_'~a.id) }}">
        <label class="form-label fw-semibold">Ce que vous avez fait par la suite (obligatoire)</label>
        <textarea class="form-control" rows="5" name="note" required placeholder="Ex: proposition d'heures complémentaires, suivi, plan d'action..."></textarea>

        <div class="d-flex justify-content-end mt-3">
          <button class="btn btn-theme-secondaire" type="submit">
            <i class="bi bi-check2-circle"></i> Enregistrer
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
{% endblock %}
