{# templates/administrateur/prospects/index.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}Prospection{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/style-table.css') }}">
  <link rel="stylesheet" href="https://cdn.datatables.net/v/bs5/dt-2.2.2/datatables.min.css"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css">
  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }

    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;

      /* Ombre douce premium */
      box-shadow: 0 18px 50px rgba(0,0,0,.14);

      /* Fond piloté par les couleurs de l'entité */
      background:
        /* halo clair (tertiaire) */
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        /* halo accent (secondaire) */
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        /* voile subtil (quaternaire) pour la profondeur */
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        /* dégradé principal (principal -> plus clair) */
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    /* léger glass highlight */
    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    /* barre accent = secondaire (et glow basé sur secondaire) */
    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }
    
    .chip{
      display:inline-flex; align-items:center; gap:.45rem;
      padding:.28rem .65rem; border-radius:999px; font-size:.82rem;
      background: rgba(255,255,255,.10);
      border:1px solid rgba(255,255,255,.14);
      white-space: nowrap;
    }
    .chip i{ color: var(--theme-color-secondaire); }
    .hero .btn{
      border-radius: 14px;
      font-weight: 800;
    }
    .hero .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .hero .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }
    
    .kpi-card{
      border: 1px solid rgba(0,0,0,.06);
      box-shadow: 0 10px 26px rgba(0,0,0,.06);
      border-radius: 18px;
      overflow:hidden;
      background:#fff;
    }
    
    .kpi-ico{
      width:44px; height:44px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }

    .kpi-label{ color: rgba(0,0,0,.55); font-size:.85rem }
    .kpi-value{ font-weight:800; font-size:1.6rem; letter-spacing:-.02em }

    .filterbar{
      background:#fff; border-radius:18px; border:1px solid rgba(0,0,0,.06);
      box-shadow:0 10px 24px rgba(0,0,0,.05);
      overflow: visible;
    }
    .filterbar__top{ padding: .9rem 1rem; border-bottom:1px solid rgba(0,0,0,.06); background: linear-gradient(180deg, rgba(0,0,0,.015), transparent); display:flex; align-items:center; gap:.75rem; }
    .filterbar__title{ font-weight:800; letter-spacing:-.01em; margin:0; font-size:1rem; }
    .filterbar__hint{ color: rgba(0,0,0,.55); font-size:.85rem; margin-left:.25rem; }
    .filterbar__body{ padding: 1rem; }

    .filtergrid{ display:grid; grid-template-columns: repeat(12, minmax(0, 1fr)); gap: .75rem; align-items:end; }

    
    .fcol-status{ grid-column: span 3; }
    .fcol-source{ grid-column: span 3; }
    .fcol-active{ grid-column: span 2; }
    .fcol-next{ grid-column: span 2; }
    .fcol-search{ grid-column: span 2; }
    @media (max-width: 992px){
      .fcol-status, .fcol-source, .fcol-active, .fcol-next, .fcol-search{ grid-column: span 12; }
    }

    .filter-control .form-label{ font-size:.78rem; font-weight:700; color: rgba(0,0,0,.55); text-transform:uppercase; letter-spacing:.06em; margin-bottom:.25rem; }
    .filterbox{ border:1px solid rgba(0,0,0,.08); border-radius:14px; padding:.55rem .6rem; background:#fff; box-shadow: 0 8px 18px rgba(0,0,0,.04); }
    .filterbox:focus-within{ border-color: rgba(255,193,7,.55); box-shadow: 0 0 0 .2rem rgba(255,193,7,.18), 0 10px 18px rgba(0,0,0,.06); }
    .filterrow{ display:flex; gap:.6rem; align-items:center; }
    
    .filter-icon{
      width:38px; height:38px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }
    .filterbox .form-select, .filterbox .form-control{ border:0 !important; box-shadow:none !important; padding-left:0 !important; padding-right:0 !important; background:transparent !important; }

    .table-card{ background:#fff; border-radius:18px; border:1px solid rgba(0,0,0,.06); box-shadow:0 12px 30px rgba(0,0,0,.06); overflow: visible; }
    table.dataTable thead th{
      background:#f7f8fa!important; border-bottom:1px solid rgba(0,0,0,.08)!important;
      font-size:.78rem; text-transform:uppercase; letter-spacing:.05em; color: rgba(0,0,0,.55); text-align:center !important; vertical-align: middle;
    }
    #tableauProspects tbody td{ padding-top:.65rem!important; padding-bottom:.65rem!important; vertical-align: middle; }
    #tableauProspects tbody tr:nth-child(even) > *{ background:rgba(35,51,66,.035)!important; }
    #tableauProspects tbody tr:hover > *{ background:rgba(255,193,7,.08)!important; }

    #tableauProspects td.action-column{ overflow: visible !important; position: relative; white-space: nowrap !important; min-width: 170px; text-align:right !important; }
    .filterbar .ts-dropdown{ z-index: 2000 !important; }

    /* =========================
      ✅ Actions prospects (même design que Devis)
      ========================= */

    /* largeur mini colonne actions */
    #tableauProspects th:last-child,
    #tableauProspects td:last-child{
      width: 1% !important;
      min-width: 0 !important;
      white-space: nowrap;
    }

    /* boutons compacts */
    .prospect-actions .btn{
      padding: .32rem .55rem;
    }

    /* bouton principal */
    .prospect-actions .prospect-main{
      background: rgba(255,255,255,.85);
      border-color: rgba(0,0,0,.12);
      box-shadow: 0 10px 22px rgba(0,0,0,.06);
    }
    .prospect-actions .prospect-main:hover{
      box-shadow: 0 14px 28px rgba(0,0,0,.10);
      border-color: rgba(0,0,0,.18);
    }

    /* split */
    .prospect-actions .prospect-split{
      padding-left: .55rem;
      padding-right: .55rem;
      border-color: rgba(0,0,0,.12);
      background: rgba(255,255,255,.85);
    }

    /* menu dropdown */
    .prospect-actions .prospect-menu{
      border-radius: 16px;
      border: 1px solid rgba(0,0,0,.10);
      box-shadow: 0 18px 46px rgba(0,0,0,.18);
      padding: .55rem;
      background:
        radial-gradient(900px 220px at 10% 0%, rgba(255,193,7,.10), transparent 55%),
        #fff;
      overflow: hidden;
    }
    .prospect-actions .prospect-menu .dropdown-item{
      border-radius: 12px;
      padding: .50rem .60rem;
      margin: .10rem 0;
      border: 1px solid transparent;
    }
    .prospect-actions .prospect-menu .dropdown-item:hover{
      background: rgba(255,193,7,.10);
      border-color: rgba(255,193,7,.22);
    }

    /* fusion pill (main + split) */
    .prospect-actions.btn-group .prospect-main{
      border-top-right-radius: 0 !important;
      border-bottom-right-radius: 0 !important;
    }
    .prospect-actions.btn-group .prospect-split{
      border-top-left-radius: 0 !important;
      border-bottom-left-radius: 0 !important;
      margin-left: -1px;
      position: relative;
    }
    .prospect-actions.btn-group .prospect-split:before{
      content:"";
      position:absolute;
      left:0;
      top:20%;
      bottom:20%;
      width:1px;
      background: rgba(0,0,0,.10);
    }

    /* alignement colonne */
    #tableauProspects td.action-column{
      padding-left: 0 !important;
      padding-right: .15rem !important;
      text-align: right;
    }

    /* ✅ Menu actions "floaté" au-dessus de tout */
    body .prospect-floating-dropdown{
      z-index: 20000 !important;
    }

    /* =========================
      ✅ Prospect status (premium)
      ========================= */
    .ps-wrap{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:.45rem;
      flex-wrap:wrap;
      line-height:1;
    }

    .ps-badge{
      --bg: rgba(0,0,0,.04);
      --bd: rgba(0,0,0,.10);
      --fg: rgba(15,35,54,.95);

      display:inline-flex;
      align-items:center;
      gap:.50rem;
      padding:.42rem .68rem;
      border-radius:999px;
      background: var(--bg);
      border:1px solid var(--bd);
      color: var(--fg);
      font-weight:900;
      font-size:.78rem;
      letter-spacing:.01em;
      box-shadow: 0 10px 22px rgba(0,0,0,.06);
      white-space:nowrap;
    }

    .ps-ico{
      width:22px; height:22px;
      border-radius:999px;
      display:grid; place-items:center;
      background: rgba(255,255,255,.70);
      border:1px solid rgba(0,0,0,.10);
      box-shadow: inset 0 0 0 1px rgba(255,255,255,.35);
    }

    .ps-text{ transform: translateY(.5px); }

    /* Variantes (douces, premium, pas "Bootstrap brut") */
    .ps--new       { --bg: rgba(13,110,253,.10); --bd: rgba(13,110,253,.22); --fg: rgba(13,110,253,.98); }
    .ps--contacted { --bg: rgba(32,201,151,.12); --bd: rgba(32,201,151,.24); --fg: rgba(18,140,104,.98); }
    .ps--qualified { --bg: rgba(255,193,7,.18); --bd: rgba(255,193,7,.30); --fg: rgba(156,110,0,.98); }
    .ps--proposal  { --bg: rgba(13,202,240,.14); --bd: rgba(13,202,240,.28); --fg: rgba(0,129,153,.98); }
    .ps--nego      { --bg: rgba(102,16,242,.12); --bd: rgba(102,16,242,.24); --fg: rgba(102,16,242,.98); }
    .ps--won       { --bg: rgba(25,135,84,.14); --bd: rgba(25,135,84,.26); --fg: rgba(25,135,84,.98); }
    .ps--lost      { --bg: rgba(220,53,69,.12); --bd: rgba(220,53,69,.24); --fg: rgba(220,53,69,.98); }
    .ps--nurture   { --bg: rgba(108,117,125,.12); --bd: rgba(108,117,125,.22); --fg: rgba(73,80,87,.98); }
    .ps--converted { --bg: rgba(35,51,66,.10); --bd: rgba(35,51,66,.18); --fg: rgba(35,51,66,.98); }
    .ps--unknown   { --bg: rgba(0,0,0,.03); --bd: rgba(0,0,0,.10); --fg: rgba(90,107,125,.98); }

    /* Mini badge Actif / Inactif */
    .ps-mini{
      display:inline-flex;
      align-items:center;
      gap:.35rem;
      padding:.30rem .56rem;
      border-radius:999px;
      font-size:.72rem;
      font-weight:900;
      letter-spacing:.02em;
      border:1px solid rgba(0,0,0,.10);
      background: rgba(255,255,255,.85);
      box-shadow: 0 8px 18px rgba(0,0,0,.05);
      white-space:nowrap;
    }
    .ps-mini .dot{
      width:8px; height:8px;
      border-radius:999px;
      background: currentColor;
      box-shadow: 0 0 0 3px rgba(0,0,0,.05);
    }
    .ps-mini--on  { color: rgba(25,135,84,.98); border-color: rgba(25,135,84,.20); background: rgba(25,135,84,.08); }
    .ps-mini--off { color: rgba(108,117,125,.98); border-color: rgba(108,117,125,.22); background: rgba(108,117,125,.10); }




    @media (max-width: 768px){
      /* ✅ Colonne actions sticky à droite */
      #tableauProspects td.action-column,
      #tableauProspects th.action-column{
        position: sticky;
        right: 0;
        z-index: 5;
        background: #fff;
        box-shadow: -12px 0 18px -14px rgba(0,0,0,.22);
      }

      /* évite que la zone sticky "mange" le padding */
      #tableauProspects td.action-column{
        padding-left: .25rem !important;
        padding-right: .15rem !important;
      }
    }

    @media (max-width: 768px){
      /* ✅ Zebra identique même sur la cellule sticky */
      #tableauProspects tbody tr:nth-child(even) > td.action-column{
        background: rgba(35,51,66,.035) !important;
      }

      #tableauProspects tbody tr:hover > td.action-column{
        background: rgba(255,193,7,.08) !important;
      }
    }



  </style>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.datatables.net/v/bs5/dt-2.2.2/datatables.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
{% endblock %}

{% block body %}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>

    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-bullseye me-2" style="color:var(--theme-color-secondaire)"></i>
            Prospection
          </h2>

          <div class="opacity-75 mt-1">
            Pipeline, relances, devis & analyse.
          </div>

          <div class="d-flex gap-2 flex-wrap mt-3">
            <span class="chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
            <span class="chip"><i class="bi bi-lightning-charge"></i> Pipeline</span>
            <span class="chip"><i class="bi bi-clock-history"></i> <span id="hero-last-refresh">—</span></span>
          </div>
        </div>

        <div class="d-flex gap-2">
          <a class="btn btn-light btn-sm fw-semibold"
            href="{{ path('app_administrateur_prospect_new', { entite: entite.id }) }}">
            <i class="bi bi-plus-circle me-1"></i> Nouveau prospect
          </a>

          <button type="button" class="btn btn-outline-light btn-sm fw-semibold"
                  onclick="document.querySelector('.filterbar')?.scrollIntoView({behavior:'smooth'})">
            <i class="bi bi-funnel me-1"></i> Filtres
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-3">
    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100"><div class="p-3">
        <div class="d-flex align-items-center gap-3">
          <div class="kpi-ico"><i class="bi bi-people fs-4"></i></div>
          <div class="flex-grow-1">
            <div class="kpi-label">Prospects actifs</div>
            <div class="kpi-value" id="kpi-total">—</div>
            <div class="text-muted small">Base exploitable</div>
          </div>
        </div>
      </div></div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100"><div class="p-3">
        <div class="d-flex align-items-center gap-3">
          <div class="kpi-ico"><i class="bi bi-alarm fs-4"></i></div>
          <div class="flex-grow-1">
            <div class="kpi-label">Relances en retard</div>
            <div class="kpi-value" id="kpi-due">—</div>
            <div class="text-muted small">NextAction ≤ maintenant</div>
          </div>
        </div>
      </div></div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100"><div class="p-3">
        <div class="d-flex align-items-center gap-3">
          <div class="kpi-ico"><i class="bi bi-fire fs-4"></i></div>
          <div class="flex-grow-1">
            <div class="kpi-label">Chauds</div>
            <div class="kpi-value" id="kpi-hot">—</div>
            <div class="text-muted small">Qualifié / Devis / Négo</div>
          </div>
        </div>
      </div></div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100"><div class="p-3">
        <div class="d-flex align-items-center gap-3">
          <div class="kpi-ico"><i class="bi bi-cash-coin fs-4"></i></div>
          <div class="flex-grow-1">
            <div class="kpi-label">Pipeline estimé</div>
            <div class="kpi-value" id="kpi-pipeline">—</div>
            <div class="text-muted small">Somme des valeurs</div>
          </div>
        </div>
      </div></div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  <div class="filterbar mb-3">
    <div class="filterbar__top">
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <div class="filter-icon"><i class="bi bi-funnel"></i></div>
        <div>
          <div class="filterbar__title">Filtres</div>
          <div class="filterbar__hint">Statut, source, actif, relances…</div>
        </div>
      </div>
    </div>

    <div class="filterbar__body">
      <div class="filtergrid">
        <div class="filter-control fcol-status">
          <div class="form-label">Statut</div>
          <div class="filterbox">
            <div class="filterrow">
              <div class="filter-icon"><i class="bi bi-kanban"></i></div>
              <select id="statusFilter" class="form-select form-select-sm">
                <option value="all">Tous</option>
                <option value="new">Nouveau</option>
                <option value="contacted">Contacté</option>
                <option value="qualified">Qualifié</option>
                <option value="proposal_sent">Devis envoyé</option>
                <option value="negotiation">Négociation</option>
                <option value="won">Gagné</option>
                <option value="lost">Perdu</option>
                <option value="nurturing">À nourrir</option>
              </select>
            </div>
          </div>
        </div>

        <div class="filter-control fcol-source">
          <div class="form-label">Source</div>
          <div class="filterbox">
            <div class="filterrow">
              <div class="filter-icon"><i class="bi bi-radar"></i></div>
              <select id="sourceFilter" class="form-select form-select-sm">
                <option value="all">Toutes</option>
                <option value="website">Site</option>
                <option value="referral">Recommandation</option>
                <option value="linkedin">LinkedIn</option>
                <option value="email">Email</option>
                <option value="phone">Téléphone</option>
                <option value="event">Évènement</option>
                <option value="partner">Partenaire</option>
                <option value="other">Autre</option>
              </select>
            </div>
          </div>
        </div>

        <div class="filter-control fcol-active">
          <div class="form-label">Actif</div>
          <div class="filterbox">
            <div class="filterrow">
              <div class="filter-icon"><i class="bi bi-toggle-on"></i></div>
              <select id="activeFilter" class="form-select form-select-sm">
                <option value="all">Tous</option>
                <option value="1">Actifs</option>
                <option value="0">Inactifs</option>
              </select>
            </div>
          </div>
        </div>

        <div class="filter-control fcol-next">
          <div class="form-label">Relances</div>
          <div class="filterbox">
            <div class="filterrow">
              <div class="filter-icon"><i class="bi bi-alarm"></i></div>
              <select id="nextFilter" class="form-select form-select-sm">
                <option value="all">Toutes</option>
                <option value="due">En retard</option>
              </select>
            </div>
          </div>
        </div>

        <div class="filter-control fcol-search">
          <div class="form-label">Recherche</div>
          <div class="filterbox">
            <div class="filterrow">
              <div class="filter-icon"><i class="bi bi-search"></i></div>
              <input id="quickSearch" class="form-control form-control-sm" placeholder="Nom, email, société…" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="table-card p-3">
    <table id="tableauProspects" class="table table-hover align-middle mb-0 w-100">
      <thead>
        <tr>
          <th>#</th>
          <th>Maj</th>
          <th>Prospect</th>
          <th>Contact</th>
          <th>Statut</th>
          <th>Score</th>
          <th>Prochaine action</th>
          <th class="action-column text-end"></th>
        </tr>
      </thead>
      <tbody></tbody>
    </table>
  </div>


<script>
$(function(){
  const $status = $('#statusFilter');
  const $source = $('#sourceFilter');
  const $active = $('#activeFilter');
  const $next   = $('#nextFilter');
  const $q      = $('#quickSearch');

  function nowLabel(){
    const d = new Date();
    return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
  }

  // URLs robustes (placeholder)
  const toggleUrlTpl = "{{ path('app_administrateur_prospect_toggle', { entite: entite.id, id: '__ID__' }) }}";
  const devisUrlTpl  = "{{ path('app_administrateur_prospect_devis_create', { entite: entite.id, id: '__ID__' }) }}";

  let tsStatus=null, tsSource=null, tsActive=null, tsNext=null;
  function initTom(){
    const common = { create:false, allowEmptyOption:true, maxItems:1, plugins:['clear_button'] };

    tsStatus?.destroy(); tsSource?.destroy(); tsActive?.destroy(); tsNext?.destroy();

    tsStatus = new TomSelect('#statusFilter', {...common});
    tsSource = new TomSelect('#sourceFilter', {...common});
    tsActive = new TomSelect('#activeFilter', {...common});
    tsNext   = new TomSelect('#nextFilter', {...common});

    [tsStatus, tsSource, tsActive, tsNext].forEach(ts => ts.on('change', ()=>refresh(true)));
  }

  async function loadKpis(){
    const params = new URLSearchParams();
    params.set('status', $status.val() || 'all');
    const url = "{{ path('app_administrateur_prospect_kpis', { entite: entite.id }) }}?" + params.toString();

    const res = await fetch(url, { headers: { 'Accept':'application/json' }});
    if(!res.ok) return;

    const k = await res.json();
    $('#kpi-total').text(k.total ?? '—');
    $('#kpi-due').text(k.due ?? '—');
    $('#kpi-hot').text(k.hot ?? '—');

    const euros = ((k.pipelineCents ?? 0) / 100).toLocaleString('fr-FR', { style:'currency', currency:'EUR' });
    $('#kpi-pipeline').text(euros);

    $('#hero-last-refresh').text('Maj : ' + nowLabel());
  }

  const table = $('#tableauProspects').DataTable({
    serverSide:true,
    processing:true,
    autoWidth: false,
    scrollX: true,
    scrollCollapse: true,
    responsive: false,
    ajax:{
      url:"{{ path('app_administrateur_prospect_ajax', { entite: entite.id }) }}",
      type:"POST",
      data: d => {
        d.statusFilter = $status.val() || 'all';
        d.sourceFilter = $source.val() || 'all';
        d.activeFilter = $active.val() || 'all';
        d.nextFilter   = $next.val() || 'all';
      }
    },
    columns:[
      {data:'id'},
      {data:'updatedAt'},
      {data:'name'},
      {data:'contact', orderable:false, searchable:false},
      {data:'status', orderable:true, searchable:false},
      {data:'score', orderable:true, searchable:false},
      {data:'nextAction', orderable:true, searchable:false},
      {data:'actions', orderable:false, searchable:false},
    ],
    columnDefs:[
      {targets: 7, className:'action-column text-end'},
      {targets: [0,1,2,4,5,6], className:'text-center'},
      {targets: 3, className:'text-start'}
    ],
    order:[[0,'desc']],
    language:{ url:'https://cdn.datatables.net/plug-ins/2.2.2/i18n/fr-FR.json' },
  });



  // ✅ Dropdown actions prospects : on "flotte" le menu hors du scroll DataTables (sinon il est clippé)
  (function enableProspectActionsFloatingDropdown(){
    document.addEventListener('show.bs.dropdown', function(e){
      const toggle = e.target;
      if (!toggle.closest('.prospect-actions')) return;

      const dd = toggle.closest('.dropdown, .btn-group');
      if (!dd) return;

      const menu = dd.querySelector('.dropdown-menu');
      if (!menu) return;

      if (!menu.__originalParent) menu.__originalParent = dd;

      document.body.appendChild(menu);
      menu.classList.add('prospect-floating-dropdown');

      const rect = toggle.getBoundingClientRect();

      menu.style.position = 'absolute';
      menu.style.top = '0px';
      menu.style.left = '0px';
      menu.style.display = 'block';
      const menuRect = menu.getBoundingClientRect();

      const isEnd = menu.classList.contains('dropdown-menu-end') || menu.classList.contains('dropdown-menu-end');
      const top = rect.bottom + window.scrollY + 6;

      let left = isEnd
        ? (rect.right + window.scrollX - menuRect.width)
        : (rect.left + window.scrollX);

      left = Math.max(8, Math.min(left, window.scrollX + window.innerWidth - menuRect.width - 8));

      menu.style.top = `${top}px`;
      menu.style.left = `${left}px`;
    }, true);

    document.addEventListener('hidden.bs.dropdown', function(e){
      const toggle = e.target;
      if (!toggle.closest('.prospect-actions')) return;

      const dd = toggle.closest('.dropdown, .btn-group');
      if (!dd) return;

      document.querySelectorAll('body .prospect-floating-dropdown').forEach(menu => {
        if (menu.__originalParent === dd) {
          dd.appendChild(menu);
          menu.classList.remove('prospect-floating-dropdown');
          menu.style.position = '';
          menu.style.top = '';
          menu.style.left = '';
          menu.style.display = '';
        }
      });
    }, true);

    window.addEventListener('scroll', () => {
      document.querySelectorAll('.prospect-actions [aria-expanded="true"][data-bs-toggle="dropdown"]')
        .forEach(btn => btn.click());
    }, true);

    window.addEventListener('resize', () => {
      document.querySelectorAll('.prospect-actions [aria-expanded="true"][data-bs-toggle="dropdown"]')
        .forEach(btn => btn.click());
    }, true);
  })();


  function refresh(resetPaging){
    table.ajax.reload(null, !!resetPaging);
    loadKpis();
  }

  // Recherche globale DataTables
  let t=null;
  $q.on('input', ()=>{
    clearTimeout(t);
    t=setTimeout(()=>{
      table.search($q.val() || '').draw();
      loadKpis();
    }, 250);
  });

  // Actions AJAX (appelées depuis _actions.html.twig)
  window.prospectToggle = async function(id){
    const url = toggleUrlTpl.replace('__ID__', String(id));
    const res = await fetch(url, { method:'POST', headers:{ 'X-Requested-With':'XMLHttpRequest' } });
    if(res.ok) refresh(false);
  }

  window.prospectCreateDevis = async function(id){
    const url = devisUrlTpl.replace('__ID__', String(id));
    const res = await fetch(url, { method:'POST', headers:{ 'X-Requested-With':'XMLHttpRequest' }});
    if(!res.ok) return;

    const json = await res.json();
    if(json.redirect) window.location.href = json.redirect;
  }

  initTom();
  loadKpis();
  $('#hero-last-refresh').text('Maj : ' + nowLabel());
});
</script>
{% endblock %}
