{# templates/administrateur/prospects/_actions.html.twig #}
{% set pid = p.id %}

<div class="btn-group btn-group-sm prospect-actions" role="group">

  {# ✅ Bouton principal (gauche) = Modifier (comme Devis) #}
  <a class="btn btn-light prospect-main"
     data-bs-toggle="tooltip" title="Modifier"
     href="{{ path('app_administrateur_prospect_edit', { entite: entite.id, prospect: pid }) }}">
    <i class="bi bi-pencil-square"></i>
  </a>

  {# ✅ Split dropdown (droite) #}
  <button type="button"
          class="btn btn-light dropdown-toggle dropdown-toggle-split prospect-split"
          data-bs-toggle="dropdown" aria-expanded="false">
    <span class="visually-hidden">Actions</span>
  </button>

  <ul class="dropdown-menu dropdown-menu-end prospect-menu">

    {# Voir #}
    <li>
      <a class="dropdown-item d-flex align-items-center"
         href="{{ path('app_administrateur_prospect_show', { entite: entite.id, prospect: pid }) }}">
        <i class="bi bi-eye me-2"></i> Ouvrir
      </a>
    </li>

    <li><hr class="dropdown-divider"></li>

    {# Toggle actif (AJAX) #}
    <li>
      <button type="button"
              class="dropdown-item d-flex align-items-center {% if p.isActive %}text-dark{% else %}text-success{% endif %}"
              onclick="prospectToggle({{ pid }})">
        <i class="bi {{ p.isActive ? 'bi-toggle-off' : 'bi-toggle-on' }} me-2"></i>
        {{ p.isActive ? 'Désactiver' : 'Activer' }}
      </button>
    </li>

    {# Créer devis (AJAX) #}
    <li>
      <button type="button"
              class="dropdown-item d-flex align-items-center text-success"
              onclick="prospectCreateDevis({{ pid }})">
        <i class="bi bi-file-earmark-text me-2"></i> Créer un devis
      </button>
    </li>

  </ul>
</div>
