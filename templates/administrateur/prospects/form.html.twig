<script>
document.addEventListener('DOMContentLoaded', function () {
  const deviseId = {{ (form.devise is defined ? form.devise.vars.id : '')|json_encode|raw }};
  const deviseEl = deviseId ? document.getElementById(deviseId) : null;

  const suffixEl = document.getElementById('prospect-devise-suffix');

  function currencySymbol(code){
    if (!code) return '€';
    try{
      const parts = new Intl.NumberFormat('fr-FR', { style:'currency', currency: code }).formatToParts(1);
      const sym = parts.find(p => p.type === 'currency')?.value;
      return sym || code;
    }catch(e){
      return code;
    }
  }

  function refreshSuffix(){
    if (!deviseEl || !suffixEl) return;
    suffixEl.textContent = currencySymbol(deviseEl.value);
  }

  // ✅ si TomSelect est déjà initialisé chez toi, ça marche pareil :
  deviseEl?.addEventListener('change', refreshSuffix);
  refreshSuffix();
});
</script>

{# ================== JS (TomSelect + Flatpickr + résumé live) ================== #}
<script>
document.addEventListener('DOMContentLoaded', function () {

  function getEl(id){ return id ? document.getElementById(id) : null; }

  // IDs safe (évite les soucis de guillemets)
  const idPrenom = {{ form.prenom is defined ? form.prenom.vars.id|json_encode|raw : 'null' }};
  const idNom    = {{ form.nom is defined ? form.nom.vars.id|json_encode|raw : 'null' }};
  const idEmail  = {{ form.email is defined ? form.email.vars.id|json_encode|raw : 'null' }};
  const idTel    = {{ form.telephone is defined ? form.telephone.vars.id|json_encode|raw : 'null' }};
  const idCivilite = {{ form.civilite is defined ? form.civilite.vars.id|json_encode|raw : 'null' }};
  const idAdresse  = {{ form.adresse is defined ? form.adresse.vars.id|json_encode|raw : 'null' }};
  const idCp       = {{ form.codePostal is defined ? form.codePostal.vars.id|json_encode|raw : 'null' }};
  const idVille    = {{ form.ville is defined ? form.ville.vars.id|json_encode|raw : 'null' }};

  const idStatus = {{ form.status is defined ? form.status.vars.id|json_encode|raw : 'null' }};
  const idSource = {{ form.source is defined ? form.source.vars.id|json_encode|raw : 'null' }};
  const idNext   = {{ form.nextActionAt is defined ? form.nextActionAt.vars.id|json_encode|raw : 'null' }};
  const idActive = {{ form.isActive is defined ? form.isActive.vars.id|json_encode|raw : 'null' }};
  const idDevise = {{ form.devise is defined ? form.devise.vars.id|json_encode|raw : 'null' }};
  const idPoste  = {{ form.poste  is defined ? form.poste.vars.id|json_encode|raw  : 'null' }};

  const prenomEl = getEl(idPrenom);
  const nomEl    = getEl(idNom);
  const emailEl  = getEl(idEmail);
  const telEl    = getEl(idTel);
  const civiliteEl = getEl(idCivilite);
  const adresseEl  = getEl(idAdresse);
  const cpEl       = getEl(idCp);
  const ville2El   = getEl(idVille);

  const statusEl = getEl(idStatus);
  const sourceEl = getEl(idSource);
  const nextEl   = getEl(idNext);
  const activeEl = getEl(idActive); 
  const posteEl  = getEl(idPoste);
  const deviseEl = getEl(idDevise);

  




  // Résumé DOM
  const $r = {
    pill:   document.getElementById('resume-valid-pill'),
    nom:    document.getElementById('resume-nom'),
    email:  document.getElementById('resume-email'),
    tel:    document.getElementById('resume-tel'),
    status: document.getElementById('resume-status'),
    source: document.getElementById('resume-source'),
    next:   document.getElementById('resume-next'),
    active: document.getElementById('resume-active'),
    adresse: document.getElementById('resume-adresse'),
  };

  function selectedText(selectEl){
    if (!selectEl) return '';
    if (selectEl.tomselect) {
      const v = selectEl.tomselect.getValue();
      if (!v) return '';
      return (selectEl.tomselect.options[v]?.text || '').trim();
    }
    const opt = selectEl.options?.[selectEl.selectedIndex];
    return opt ? (opt.textContent || '').trim() : '';
  }

  // TomSelect (1 item)
  function initTom(el){
    if (!el || el.tomselect) return;
    new TomSelect(el, {
      dropdownParent: 'body',
      create: false,
      allowEmptyOption: true,
      maxItems: 1,
      plugins: ['clear_button']
    });
  }

  initTom(deviseEl);
  initTom(posteEl);
  initTom(statusEl);
  initTom(sourceEl);

  // Flatpickr date+heure
  if (window.flatpickr) {
    flatpickr.localize(flatpickr.l10ns.fr);
    if (nextEl && !nextEl._flatpickr) {
      flatpickr(nextEl, {
        enableTime: true,
        time_24hr: true,
        dateFormat: "d/m/Y H:i",
        allowInput: true,
        disableMobile: true
      });
    }
  }

  function refreshResume(){
    const civ = selectedText(civiliteEl) || '';
    const fullName = `${civ ? civ + ' ' : ''}${(prenomEl?.value||'').trim()} ${(nomEl?.value||'').trim()}`.trim();


    if ($r.nom) $r.nom.textContent = fullName || '—';
    if ($r.email) $r.email.textContent = (emailEl?.value||'').trim() || '—';
    if ($r.tel) $r.tel.textContent = (telEl?.value||'').trim() || '—';

    if ($r.status) $r.status.textContent = selectedText(statusEl) || '—';
    if ($r.source) $r.source.textContent = selectedText(sourceEl) || '—';
    if ($r.next)   $r.next.textContent   = (nextEl?.value||'').trim() || '—';
    if ($r.active) $r.active.textContent = activeEl ? (activeEl.checked ? 'Oui' : 'Non') : '—';

    if ($r.nom) $r.nom.textContent = fullName || '—';
    if ($r.email) $r.email.textContent = (emailEl?.value||'').trim() || '—';
    if ($r.tel) $r.tel.textContent = (telEl?.value||'').trim() || '—';


    // complétude minimale
    const ok = !!((nomEl?.value||'').trim()) && !!((emailEl?.value||'').trim()) && !!(selectedText(statusEl));
    const adr = (adresseEl?.value||'').trim();
    const cp  = (cpEl?.value||'').trim();
    const vil = (ville2El?.value||'').trim();
    const adrLine = [adr, [cp, vil].filter(Boolean).join(' ')].filter(Boolean).join(' — ');
    if ($r.adresse) $r.adresse.textContent = adrLine || '—';

    if ($r.pill) {
      if (ok) {
        $r.pill.textContent = '✅ Complet';
        $r.pill.style.background = 'rgba(25,135,84,.15)';
        $r.pill.style.borderColor = 'rgba(25,135,84,.35)';
      } else {
        $r.pill.textContent = '⚠️ Incomplet';
        $r.pill.style.background = 'rgba(255,193,7,.15)';
        $r.pill.style.borderColor = 'rgba(255,193,7,.35)';
      }
    }
  }

  // Bind
  [civiliteEl, adresseEl, cpEl, ville2El, prenomEl, nomEl, emailEl, telEl, nextEl].forEach(el => {
    el?.addEventListener('input', refreshResume);
    el?.addEventListener('change', refreshResume);
  });

  statusEl?.tomselect?.on('change', refreshResume);
  sourceEl?.tomselect?.on('change', refreshResume);
  activeEl?.addEventListener('change', refreshResume);

  refreshResume();
});
</script>


