{# templates/administrateur/prospects/form.html.twig #}
{% extends 'base_admin.html.twig' %}
{% set is_edit = (prospect is defined and prospect and prospect.id) %}

{% block title %}{{ is_edit ? 'Modification' : 'Ajout' }} d’un prospect{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/formulaire.css') }}">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css">

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};

      --bg: #f5f7fb;
      --panel: #ffffff;
      --ink: #0f172a;
      --muted:#64748b;
      --stroke: rgba(15, 23, 42, .10);
      --shadow: 0 18px 55px rgba(15, 23, 42, .10);
      --radius: 18px;
    }

    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;
      box-shadow: 0 18px 50px rgba(0,0,0,.14);
      background:
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
      flex: 0 0 auto;
    }

    /* ✅ Chips HERO (comme session) */
    .hero .chip{
      display:inline-flex;
      align-items:center;
      gap:.5rem;
      padding:.32rem .7rem;
      border-radius: 999px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(255,255,255,.14);
      font-size:.82rem;
      color: rgba(255,255,255,.92);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      white-space: nowrap;
    }
    .hero .chip i{ color: var(--theme-color-secondaire); }

    .hero .chip--pill{
      background: color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
      border-color: color-mix(in srgb, var(--theme-color-secondaire) 28%, rgba(255,255,255,.14));
      color:#fff;
    }

    .hero .btn{
      border-radius: 14px;
      font-weight: 800;
    }

    .hero .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .hero .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }

    /* ===== Cards premium (mêmes classes) ===== */
    .cardx{
      background: var(--panel);
      border: 1px solid var(--stroke);
      border-radius: var(--radius);
      box-shadow: 0 10px 28px rgba(15,23,42,.08);
      overflow:hidden;
    }
    .cardx-h{
      padding: .95rem 1.05rem;
      display:flex; align-items:center; justify-content:space-between; gap:1rem;
      background: linear-gradient(180deg, rgba(0,0,0,.015), transparent);
      border-bottom: 1px solid var(--stroke);
    }
    .cardx-title{
      margin:0; font-weight:800; letter-spacing:-.01em; color: var(--ink);
      display:flex; align-items:center; gap:.6rem;
    }
    .chip{
      font-size:.78rem; padding:.25rem .55rem; border-radius:999px;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, var(--stroke));
      color: var(--muted);
      white-space:nowrap;
    }

    /* ===== Form polish ===== */
    label.form-label{ font-weight: 700; color: var(--ink); }
    .form-text, .text-muted, .small{ color: var(--muted) !important; }
    .form-control, .form-select{
      border-radius: 14px;
      border: 1px solid var(--stroke);
      padding: .65rem .85rem;
      min-height: 44px;
    }
    .form-control:focus, .form-select:focus{
      border-color: color-mix(in srgb, var(--theme-color-principal) 55%, var(--stroke));
      box-shadow: 0 0 0 .2rem color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
    }

    /* TomSelect polish + FIX dropdown */
    .ts-wrapper .ts-control{
      border-radius: 14px !important;
      padding: .55rem .75rem !important;
      border-color: var(--stroke) !important;
      min-height: 44px !important;
    }
    .ts-wrapper.focus .ts-control{
      box-shadow: 0 0 0 .2rem color-mix(in srgb, var(--theme-color-principal) 18%, transparent) !important;
      border-color: color-mix(in srgb, var(--theme-color-principal) 55%, var(--stroke)) !important;
    }
    .ts-dropdown{ z-index: 9999 !important; }
    .ts-wrapper.focus, .ts-wrapper.dropdown-active{ z-index: 9999; }
    .card, .card-body, .container, .container-fluid, .cardx, .cardx *{ overflow: visible; }

    /* ===== Sticky actions (col droite) ===== */
    .sticky-actions{
      position: sticky; bottom: 14px; z-index: 5;
      background: color-mix(in srgb, var(--panel) 82%, transparent);
      backdrop-filter: blur(10px);
      border: 1px solid var(--stroke);
      border-radius: var(--radius);
      padding: .75rem;
      box-shadow: var(--shadow);
    }

    /* ===== Soft blocks (switch style) ===== */
    .soft-box{
      border-radius: 16px;
      border: 1px dashed rgba(15,35,54,.18);
      background: rgba(248,251,254,.75);
      padding: 1rem;
    }

    @media (max-width:768px){
      .hero{ border-radius:16px; }
    }


    /* ===== MODAL PREMIUM ===== */
.modal-premium{
  border: 1px solid var(--stroke);
  border-radius: 22px;
  overflow: hidden;
  box-shadow: 0 30px 80px rgba(15,23,42,.18);
}
.premium-header{
  background:
    radial-gradient(900px 260px at 0% 0%,
      color-mix(in srgb, var(--theme-color-secondaire) 20%, transparent),
      transparent 55%
    ),
    linear-gradient(135deg,
      color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
      color-mix(in srgb, var(--theme-color-principal) 68%, #fff 32%)
    );
  color: #fff;
  border-bottom: 1px solid rgba(255,255,255,.14);
}
.premium-icon{
  width: 44px; height: 44px;
  border-radius: 14px;
  display:flex; align-items:center; justify-content:center;
  background: rgba(255,255,255,.14);
  border: 1px solid rgba(255,255,255,.18);
  box-shadow: 0 12px 30px rgba(0,0,0,.12);
}
.premium-icon i{ font-size: 1.25rem; color: var(--theme-color-secondaire); }

.premium-pill{
  background: rgba(255,255,255,.14);
  border: 1px solid rgba(255,255,255,.18);
  color: #fff;
}
.premium-pill2{
  background: color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
  border: 1px solid color-mix(in srgb, var(--theme-color-secondaire) 28%, rgba(15,23,42,.10));
  color: var(--ink);
}

.premium-block{
  border: 1px solid var(--stroke);
  border-radius: 18px;
  background: linear-gradient(180deg, rgba(0,0,0,.012), transparent);
  padding: 1rem;
}
.input-group-premium .input-group-text{
  border-radius: 14px 0 0 14px;
  border-color: var(--stroke);
  background: rgba(248,251,254,.75);
}
.input-group-premium .form-control{
  border-left: 0;
}
.input-group-premium .btn{
  border-radius: 0 14px 14px 0;
}

.premium-preview{
  position: sticky;
  top: 10px;
  border: 1px solid var(--stroke);
  border-radius: 18px;
  background: rgba(248,251,254,.75);
  padding: 1rem;
}
.preview-card{
  border-radius: 18px;
  background: var(--panel);
  border: 1px solid var(--stroke);
  padding: 1rem;
  box-shadow: 0 12px 35px rgba(15,23,42,.08);
}
.logo-skeleton{
  width: 54px; height: 54px;
  border-radius: 16px;
  display:flex; align-items:center; justify-content:center;
  border: 1px solid var(--stroke);
  background: linear-gradient(135deg, rgba(255,193,7,.18), rgba(35,51,66,.04));
}
.logo-skeleton i{ font-size: 1.35rem; color: color-mix(in srgb, var(--theme-color-principal) 70%, #000 30%); }
.preview-title{ font-weight: 900; color: var(--ink); letter-spacing: -.01em; }
.preview-sub{ color: var(--muted); margin-top: .15rem; }
.preview-meta{ display:flex; flex-wrap: wrap; gap: .4rem; }
.tag{
  display:inline-flex; align-items:center; gap:.35rem;
  padding: .22rem .55rem;
  border-radius: 999px;
  border: 1px solid var(--stroke);
  background: rgba(15,23,42,.03);
  color: var(--muted);
  font-weight: 600;
  white-space: nowrap;
}

.mini-map{
  border-radius: 18px;
  border: 1px solid var(--stroke);
  overflow: hidden;
  background: #fff;
  min-height: 220px;
}
.mini-map-placeholder{
  height: 220px;
  display:flex;
  align-items:center;
  justify-content:center;
  gap:.5rem;
  color: var(--muted);
  background: linear-gradient(180deg, rgba(0,0,0,.02), transparent);
}
.mini-map-placeholder i{ color: var(--theme-color-secondaire); }

.premium-footer{
  border-top: 1px solid var(--stroke);
  background: color-mix(in srgb, var(--panel) 85%, transparent);
  backdrop-filter: blur(10px);
}
.btn-premium{
  border-radius: 14px;
  font-weight: 900;
  padding: .65rem 1rem;
}


/* Dropdown Google Places au-dessus Bootstrap modal */
.pac-container{
  z-index: 10650 !important; /* > 1055 (modal) */
  border-radius: 14px;
  box-shadow: 0 18px 55px rgba(15,23,42,.18);
  border: 1px solid rgba(15,23,42,.10);
}
.pac-item{ padding: .5rem .75rem; }
.pac-item:hover{ background: rgba(15,23,42,.04); }


/* ===== SCORE SLIDER ULTRA PREMIUM ===== */
.score-premium{
  border: 1px solid var(--stroke);
  border-radius: 18px;
  padding: .95rem;
  background:
    radial-gradient(900px 200px at 10% 0%,
      color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent),
      transparent 60%),
    linear-gradient(180deg, rgba(0,0,0,.012), transparent);
  box-shadow: 0 12px 35px rgba(15,23,42,.06);
}

.score-pill{
  border: 1px solid var(--stroke);
  background: rgba(255,193,7,.14);
  color: var(--ink);
  font-weight: 900;
}

.score-track{
  position: relative;
  height: 14px;
  border-radius: 999px;
  background: rgba(15,23,42,.06);
  border: 1px solid rgba(15,23,42,.10);
  overflow: hidden;
  box-shadow: inset 0 1px 0 rgba(255,255,255,.65);
  margin-bottom: .6rem;
}

.score-fill{
  height: 100%;
  width: 0%;
  border-radius: 999px;
  background: linear-gradient(90deg,
    color-mix(in srgb, var(--theme-color-principal) 70%, #000 30%),
    var(--theme-color-secondaire)
  );
  box-shadow: 0 10px 25px color-mix(in srgb, var(--theme-color-secondaire) 22%, transparent);
}

.score-bubble{
  position: absolute;
  top: -38px;
  left: 0%;
  transform: translateX(-50%);
  padding: .25rem .55rem;
  border-radius: 999px;
  font-size: .82rem;
  font-weight: 900;
  color: #fff;
  background: rgba(15,23,42,.92);
  border: 1px solid rgba(255,255,255,.12);
  box-shadow: 0 12px 30px rgba(0,0,0,.18);
  pointer-events: none;
  white-space: nowrap;
}
.score-bubble::after{
  content:"";
  position:absolute;
  left: 50%;
  bottom: -7px;
  transform: translateX(-50%);
  width: 12px; height: 12px;
  background: rgba(15,23,42,.92);
  border-left: 1px solid rgba(255,255,255,.12);
  border-bottom: 1px solid rgba(255,255,255,.12);
  transform: translateX(-50%) rotate(45deg);
}

.score-range{
  width: 100%;
  margin: 0;
  height: 22px;
  background: transparent;
}

/* Webkit thumb */
.score-range::-webkit-slider-thumb{
  -webkit-appearance: none;
  appearance: none;
  width: 22px; height: 22px;
  border-radius: 999px;
  background: #fff;
  border: 3px solid var(--theme-color-secondaire);
  box-shadow: 0 12px 28px rgba(15,23,42,.18);
  cursor: pointer;
}
.score-range::-webkit-slider-runnable-track{
  height: 14px;
  background: transparent; /* on utilise score-track */
}

/* Firefox thumb */
.score-range::-moz-range-thumb{
  width: 22px; height: 22px;
  border-radius: 999px;
  background: #fff;
  border: 3px solid var(--theme-color-secondaire);
  box-shadow: 0 12px 28px rgba(15,23,42,.18);
  cursor: pointer;
}
.score-range::-moz-range-track{
  height: 14px;
  background: transparent;
}

.score-ticks{
  display:flex;
  gap: .75rem;
  opacity: .9;
}
.score-number{
  border-radius: 12px;
  font-weight: 800;
}
.score-scale{
  display:flex;
  justify-content: space-between;
  align-items:center;

  /* important : on “rentre” un peu pour compenser la largeur du thumb */
  padding: 0 11px; /* = 22px thumb / 2 */
  user-select:none;
}
.score-scale span{ line-height:1; }




/* ===== Switch rows (même style que session/form) ===== */
.switch-row{
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap: 1rem;
  padding:.8rem .9rem;
  border-radius:14px;
  border:1px solid rgba(15,35,54,.08);
  background:#fff;
}
.switch-row + .switch-row{ margin-top:.65rem; }
.switch-row .title{ font-weight:700; line-height:1.15; }
.switch-row .desc{
  margin-top:.25rem;
  font-size:.85rem;
  color:#6b7280;
}
.switch-row .form-check.form-switch{ margin:0; }
.switch-row .form-check-input{ width:2.6em; height:1.35em; }
.switch-row .form-check-input:checked{
  background-color: var(--theme-color-secondaire);
  border-color: var(--theme-color-secondaire);
}

/* petit état "désactivé" propre */
.switch-row.is-disabled{
  opacity:.65;
  filter:saturate(.9);
}
.switch-row.is-disabled .title{
  text-decoration: line-through;
}

  </style>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/fr.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
{% endblock %}

{% block body %}

  {# ===== HERO ===== #}
  {# ===== HERO (comme session) ===== #}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>

    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">

        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-funnel me-2" style="color:var(--theme-color-secondaire)"></i>
            {{ is_edit ? 'Modifier' : 'Créer' }} un prospect
          </h2>

          <div class="opacity-75 mt-1">
            Contact, statut, relances et conversion vers devis.
          </div>

          <div class="d-flex flex-wrap gap-2 mt-3">
            <span class="chip"><i class="bi bi-funnel"></i> Prospection</span>
            <span class="chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
            <span class="chip"><i class="bi bi-pencil-square"></i> {{ is_edit ? 'Modification' : 'Création' }}</span>

            {% if is_edit %}
              <span class="chip"><i class="bi bi-hash"></i> #{{ prospect.id }}</span>
            {% endif %}

            <span class="chip chip--pill">
              <i class="bi bi-clock-history"></i>
              <span id="hero-last-refresh">—</span>
            </span>
          </div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
          <a class="btn btn-outline-theme btn-sm fw-semibold"
            href="{{ path('app_administrateur_prospect_index', { entite: entite.id }) }}">
            <i class="bi bi-arrow-left me-1"></i> Retour
          </a>

          {% if is_edit %}
            <a class="btn btn-light btn-sm fw-semibold"
              href="{{ path('app_administrateur_devis_new', { entite: entite.id, destinataire: prospect.id }) }}">
              <i class="bi bi-file-earmark-text me-1"></i> Créer un devis
            </a>

            <form method="post"
                  action="{{ path('app_administrateur_prospect_convert', { entite: entite.id, id: prospect.id }) }}"
                  onsubmit="return confirm('Convertir ce prospect en client ? Les devis seront rattachés.');"
                  class="d-inline">
              <input type="hidden" name="_token" value="{{ csrf_token('convert_prospect_' ~ prospect.id) }}">
              <button class="btn btn-success btn-sm fw-semibold" type="submit"
                      {% if not prospect.email %}disabled{% endif %}>
                <i class="bi bi-arrow-repeat me-1"></i>
                Convertir en client
              </button>
            </form>
          {% endif %}

          <button form="prospectForm" type="submit" class="btn btn-light btn-sm fw-semibold">
            <i class="bi bi-check2 me-1"></i> Enregistrer
          </button>
        </div>

      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  {{ form_start(form, { attr: { novalidate: 'novalidate', id: 'prospectForm' } }) }}
  {{ form_errors(form) }}

  <div class="row g-4">
    {# ====================== COL LEFT ====================== #}
    <div class="col-lg-8">

      {# ===== IDENTITÉ ===== #}
      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-person-vcard text-warning"></i> Identité</h5>
          <span class="chip">Étape 1</span>
        </div>
        <div class="p-3 p-md-4">
          <div class="row g-3">
            {# --- Civilité + Nom/Prénom --- #}
            {% if form.civilite is defined %}<div class="col-12 col-md-3">{{ form_row(form.civilite) }}</div>{% endif %}
            {% if form.prenom is defined %}<div class="col-12 col-md-4">{{ form_row(form.prenom) }}</div>{% endif %}
            {% if form.nom is defined %}<div class="col-12 col-md-5">{{ form_row(form.nom) }}</div>{% endif %}

            {% if form.email is defined %}<div class="col-12 col-md-6">{{ form_row(form.email) }}</div>{% endif %}
            {% if form.telephone is defined %}<div class="col-12 col-md-6">{{ form_row(form.telephone) }}</div>{% endif %}

            {% if form.poste is defined %}<div class="col-12 col-md-6">{{ form_row(form.poste) }}</div>{% endif %}

            {# --- Adresse complète --- #}
            {% if form.adresse is defined or form.complement is defined or form.codePostal is defined or form.departement is defined or form.region is defined %}
              <div class="col-12">
                <div class="soft-box">
                  <div class="fw-semibold mb-2"><i class="bi bi-geo-alt me-2"></i>Adresse</div>
                  <div class="row g-3">
                    {% if form.adresse is defined %}<div class="col-12">{{ form_row(form.adresse) }}</div>{% endif %}
                    {% if form.complement is defined %}<div class="col-12">{{ form_row(form.complement) }}</div>{% endif %}

                    {% if form.codePostal is defined %}<div class="col-12 col-md-4">{{ form_row(form.codePostal) }}</div>{% endif %}
                    {% if form.ville is defined %}<div class="col-12 col-md-8">{{ form_row(form.ville) }}</div>{% endif %}

                    {% if form.departement is defined %}<div class="col-12 col-md-6">{{ form_row(form.departement) }}</div>{% endif %}
                    {% if form.region is defined %}<div class="col-12 col-md-6">{{ form_row(form.region) }}</div>{% endif %}

                    {% if form.pays is defined %}<div class="col-12 col-md-6">{{ form_row(form.pays) }}</div>{% endif %}
                  </div>
                </div>
              </div>
            {% else %}
              {# fallback si tu n'as pas ces champs dans ce form #}
              {% if form.ville is defined %}<div class="col-12 col-md-6">{{ form_row(form.ville) }}</div>{% endif %}
              {% if form.pays is defined %}<div class="col-12 col-md-6">{{ form_row(form.pays) }}</div>{% endif %}
            {% endif %}
          </div>

          <div class="form-text mt-2">Ces infos seront reprises automatiquement lors de la création d’un devis.</div>
        </div>
      </div>


      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-building text-warning"></i> Entreprise</h5>
          <span class="chip">Étape 2</span>
        </div>

        <div class="p-3 p-md-4">
          <div class="row g-3">

            {# ✅ select entreprise + bouton modal #}
            <div class="col-12">
              <div class="d-flex align-items-end gap-2">
                <div class="flex-grow-1">
                  {{ form_row(form.linkedEntreprise) }}
                </div>

                <button type="button" class="btn btn-outline-secondary"
                        data-bs-toggle="modal" data-bs-target="#modal-new-entreprise"
                        title="Créer une entreprise">
                  <i class="bi bi-plus"></i>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>




      {# ===== PROSPECTION ===== #}
      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-funnel text-warning"></i> Prospection</h5>
          <span class="chip">Étape 3</span>
        </div>
