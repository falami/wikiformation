  // ====== Elements ======
  const formNewEntreprise = document.getElementById('form-new-entreprise');
  const errEl = document.getElementById('new-entreprise-error');
  const okEl  = document.getElementById('new-entreprise-success');

  const inputSearch = document.getElementById('entreprise-google-search');
  const btnClear = document.getElementById('btn-clear-place');
  const modalEl = document.getElementById('modal-new-entreprise');

  function initPlacesIfReady(){
    if (window.__entreprisePlacesInited) return;
    if (!inputSearch) return;
    if (!window.google?.maps?.places) return; // Google pas encore chargé

    const options = {
      types: ['establishment'],
      componentRestrictions: { country: ['fr'] },
      fields: ['place_id','name','formatted_address','address_components','geometry'],
    };

    const ac = new google.maps.places.Autocomplete(inputSearch, options);

    ac.addListener('place_changed', function(){
      clearErr();
      const place = ac.getPlace();
      if (!place || !place.place_id) {
        showErr("Aucun résultat exploitable. Essayez 'Nom + Ville'.");
        return;
      }
      applyPlace(place);
      resolveSiretTva();
    });

    window.__entreprisePlacesInited = true;

    // Fix dropdown au-dessus de la modale
    setTimeout(() => inputSearch.focus(), 50);
  }

  if (modalEl) {
    modalEl.addEventListener('shown.bs.modal', function(){
      initPlacesIfReady();
      resetMiniMap();
      refreshPreview();
    });
  }

  const f = {
    raison: document.getElementById('entreprise-raison'),
    siret: document.getElementById('entreprise-siret'),
    emailFactu: document.getElementById('entreprise-emailFacturation'),
    adresse: document.getElementById('entreprise-adresse'),
    cp: document.getElementById('entreprise-cp'),
    ville: document.getElementById('entreprise-ville'),
    pays: document.getElementById('entreprise-pays'),
    tva: document.getElementById('entreprise-tva'),
    placeId: document.getElementById('entreprise-place-id'),
    formattedAddress: document.getElementById('entreprise-formatted-address'),
  };

  const preview = {
    raison: document.getElementById('preview-raison'),
    address: document.getElementById('preview-address'),
    cpville: document.getElementById('preview-cpville'),
    pays: document.getElementById('preview-pays'),
    siret: document.getElementById('preview-siret'),
    email: document.getElementById('preview-email'),
  };

  // TomSelect select entreprise (déjà chez toi)
  const idEntreprise = {{ form.linkedEntreprise.vars.id|json_encode|raw }};
  const entrepriseSelect = document.getElementById(idEntreprise);

  const newEntrepriseUrl = "{{ path('app_administrateur_prospect_entreprise_new', { entite: entite.id }) }}";

  function showErr(msg){
    if (!errEl) return;
    errEl.textContent = msg || 'Erreur.';
    errEl.classList.remove('d-none');
    okEl?.classList.add('d-none');
  }
  function clearErr(){
    errEl?.classList.add('d-none');
    if (errEl) errEl.textContent = '';
  }
  function showOk(){
    okEl?.classList.remove('d-none');
  }

  // ====== Preview live ======
  function setText(el, v){ if (el) el.textContent = (v && String(v).trim()) ? String(v).trim() : '—'; }
  function refreshPreview(){
    setText(preview.raison, f.raison?.value);
    setText(preview.address, f.adresse?.value);
    setText(preview.cpville, [f.cp?.value, f.ville?.value].filter(Boolean).join(' ') || null);
    setText(preview.pays, f.pays?.value);
    setText(preview.siret, f.siret?.value);
    setText(preview.email, f.emailFactu?.value);
  }
  ['input','change'].forEach(evt => {
    Object.values(f).forEach(el => el?.addEventListener?.(evt, refreshPreview));
  });

  // ====== Clear place ======
  function clearPlace(){
    if (inputSearch) inputSearch.value = '';
    if (f.placeId) f.placeId.value = '';
    if (f.formattedAddress) f.formattedAddress.value = '';
    // (on ne wipe pas les champs saisis manuellement, sauf si tu veux)
    refreshPreview();
    resetMiniMap();
  }
  btnClear?.addEventListener('click', clearPlace);

  // ====== Mini map (simple) ======
  let gMap = null;
  let gMarker = null;

  function resetMiniMap(){
    const wrap = document.getElementById('entreprise-mini-map');
    if (!wrap) return;
    wrap.innerHTML = `
      <div class="mini-map-placeholder">
        <i class="bi bi-geo-alt"></i>
        <span class="small">Sélectionne une entreprise pour afficher l’emplacement</span>
      </div>
    `;
    gMap = null;
    gMarker = null;
  }

  function renderMiniMap(latLng){
    const wrap = document.getElementById('entreprise-mini-map');
    if (!wrap || !window.google?.maps || !latLng) return;

    wrap.innerHTML = ''; // clear placeholder

    gMap = new google.maps.Map(wrap, {
      center: latLng,
      zoom: 16,
      mapTypeControl: false,
      streetViewControl: false,
      fullscreenControl: false,
    });

    gMarker = new google.maps.Marker({
      map: gMap,
      position: latLng,
    });
  }

  // ====== Google Places: parse address components ======
  function getComp(components, type){
    const c = components?.find(x => x.types?.includes(type));
    return c ? (c.long_name || c.short_name || '') : '';
  }

  function applyPlace(place){
    // place.name, place.formatted_address, place.address_components, place.geometry.location
    const name = place?.name || '';
    const formatted = place?.formatted_address || '';
    const comps = place?.address_components || [];

    const streetNumber = getComp(comps, 'street_number');
    const route = getComp(comps, 'route');
    const postal = getComp(comps, 'postal_code');
    const locality =
      getComp(comps, 'locality') ||
      getComp(comps, 'postal_town') ||
      getComp(comps, 'administrative_area_level_2') ||
      getComp(comps, 'administrative_area_level_1');

    const country = getComp(comps, 'country');

    if (f.raison && name) f.raison.value = name;
    if (f.formattedAddress) f.formattedAddress.value = formatted;
    if (f.placeId && place?.place_id) f.placeId.value = place.place_id;

    const street = [streetNumber, route].filter(Boolean).join(' ').trim();
    if (f.adresse && street) f.adresse.value = street;
    if (f.cp && postal) f.cp.value = postal;
    if (f.ville && locality) f.ville.value = locality;
    if (f.pays && country) f.pays.value = country;

    refreshPreview();
    showOk();

    const loc = place?.geometry?.location;
    if (loc && typeof loc.lat === 'function') {
      renderMiniMap({ lat: loc.lat(), lng: loc.lng() });
    }
  }


  async function resolveSiretTva() {
    const fd = new FormData();
    fd.append('raisonSociale', f.raison?.value || '');
    fd.append('codePostal', f.cp?.value || '');
    fd.append('ville', f.ville?.value || '');

    const resp = await fetch("{{ path('app_administrateur_prospect_entreprise_resolve', { entite: entite.id }) }}", {
      method: 'POST',
      body: fd,
      headers: { 'X-Requested-With': 'XMLHttpRequest' }
    });

    const data = await resp.json().catch(() => null);
    if (!resp.ok || !data?.success) return;

    if (data.siret && f.siret && !f.siret.value) f.siret.value = data.siret;
    if (data.tva && f.tva && !f.tva.value) f.tva.value = data.tva;

    refreshPreview();
  }


  // ====== Submit AJAX (comme chez toi) ======
  if (formNewEntreprise && entrepriseSelect) {
    formNewEntreprise.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearErr();

      // validation minimal
      const raison = (f.raison?.value || '').trim();
      if (!raison) {
        showErr("Raison sociale obligatoire.");
        f.raison?.focus();
        return;
      }

      const fd = new FormData(formNewEntreprise);

      try {
        const resp = await fetch(newEntrepriseUrl, {
          method: 'POST',
          body: fd,
          headers: { 'X-Requested-With': 'XMLHttpRequest' }
        });

        const data = await resp.json().catch(() => null);

        if (!resp.ok || !data || data.success === false) {
          showErr(data?.message || `Erreur serveur (${resp.status}).`);
          return;
        }

        const value = String(data.id);
        const label = data.label;

        // add + select in TomSelect
        if (entrepriseSelect.tomselect) {
          entrepriseSelect.tomselect.addOption({ value, text: label });
          entrepriseSelect.tomselect.addItem(value, true);
        } else {
          const opt = new Option(label, value, true, true);
          entrepriseSelect.add(opt);
          entrepriseSelect.value = value;
          entrepriseSelect.dispatchEvent(new Event('change', { bubbles: true }));
        }

        // close modal
        const modalEl = document.getElementById('modal-new-entreprise');
        const modal = bootstrap.Modal.getInstance(modalEl) || new bootstrap.Modal(modalEl);
        modal.hide();

        // reset form
        formNewEntreprise.reset();
        clearPlace();
        okEl?.classList.add('d-none');

      } catch (err) {
        showErr("Erreur réseau / JS : " + (err?.message || err));
      }
    });
  }

  // Init preview at start
  refreshPreview();
});
</script>




<script>
document.addEventListener('DOMContentLoaded', function () {
  const rangeId = {{ (form.score is defined ? form.score.vars.id : '')|json_encode|raw }};
  const range = rangeId ? document.getElementById(rangeId) : null;

  const fill = document.getElementById('scoreFill');
  const bubble = document.getElementById('scoreBubble');
  const pill = document.getElementById('scorePill');
  const number = document.getElementById('scoreNumber');

  if (!range) return;

  const min = Number(range.getAttribute('min') || 0);
  const max = Number(range.getAttribute('max') || 100);

  function clamp(v){
    v = Number(v);
    if (Number.isNaN(v)) v = 0;
    return Math.min(max, Math.max(min, v));
  }

  function pillLabel(v){
    if (v >= 80) return '🔥 Très chaud';
    if (v >= 60) return '✅ Chaud';
    if (v >= 40) return '🟡 Tiède';
    if (v >= 20) return '🧊 Froid';
    return '—';
  }

  function refresh(){
    const v = clamp(range.value);
    const pct = ((v - min) / (max - min)) * 100;

    if (fill) fill.style.width = pct + '%';
    if (bubble) {
      bubble.textContent = String(v);
      bubble.style.left = pct + '%';
    }
    if (pill) pill.textContent = `${v}/100 • ${pillLabel(v)}`;
    if (number && document.activeElement !== number) number.value = v;
  }

  // ✅ Important: input + change
  range.addEventListener('input', refresh, { passive: true });
  range.addEventListener('change', refresh, { passive: true });

  if (number) {
    number.addEventListener('input', function(){
      range.value = String(clamp(number.value));
      refresh();
    });
  }

  // init (si null -> on met 0)
  // ✅ init robuste : vide / NaN => 50
  const current = Number(range.value);
  if (range.value === '' || Number.isNaN(current)) {
    range.value = '50';
  }
  refresh();
});
</script>


