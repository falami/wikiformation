<script>
document.addEventListener('DOMContentLoaded', function () {
  const idStatus = {{ form.status is defined ? form.status.vars.id|json_encode|raw : 'null' }};
  const idActive = {{ form.isActive is defined ? form.isActive.vars.id|json_encode|raw : 'null' }};

  const statusEl = idStatus ? document.getElementById(idStatus) : null;
  const activeEl = idActive ? document.getElementById(idActive) : null;

  const wrap = document.getElementById('wrap-prospect-active');
  const hint = document.getElementById('hint-prospect-closed');

  if (!statusEl || !activeEl || !wrap) return;

  // ✅ Mets ici les "values" de tes statuts clos si tu les connais (recommandé)
  // Exemple: ['perdu','non_pertinent','clos']
  const CLOSED_VALUES = new Set(['perdu', 'non_pertinent', 'clos']);

  function selectedText(el){
    if (!el) return '';
    if (el.tomselect) {
      const v = el.tomselect.getValue();
      return (el.tomselect.options?.[v]?.text || '').trim();
    }
    const opt = el.options?.[el.selectedIndex];
    return (opt?.textContent || '').trim();
  }

  function isClosedStatus(){
    const val = (statusEl.value || '').trim();
    const txt = selectedText(statusEl).toLowerCase();

    // 1) check par value (le plus fiable)
    if (val && CLOSED_VALUES.has(val)) return true;

    // 2) fallback par libellé (si tu ne connais pas les values)
    return (
      txt.includes('perdu') ||
      txt.includes('non pertinent') ||
      txt.includes('clos') ||
      txt.includes('clôt')
    );
  }

  function syncActive(){
    const closed = isClosedStatus();

    if (closed) {
      activeEl.checked = false;
      activeEl.disabled = true;
      wrap.classList.add('is-disabled');
      hint?.classList.remove('d-none');

      // important : notifie tes autres scripts (résumé live, etc.)
      activeEl.dispatchEvent(new Event('change', { bubbles:true }));
    } else {
      activeEl.disabled = false;
      wrap.classList.remove('is-disabled');
      hint?.classList.add('d-none');
    }
  }

  // écoute change (TomSelect + natif)
  if (statusEl.tomselect) {
    statusEl.tomselect.on('change', syncActive);
  } else {
    statusEl.addEventListener('change', syncActive);
  }

  // init
  syncActive();
});
</script>

