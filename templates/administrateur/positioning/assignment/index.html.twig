{# templates/administrateur/positioning/assignment/index.html.twig #}
{% extends 'base_admin.html.twig' %}

{% block title %}Affectations positionnements{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/style-table.css') }}">
  <link rel="stylesheet" href="https://cdn.datatables.net/v/bs5/dt-2.2.2/datatables.min.css"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css">

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }

    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;
      box-shadow: 0 18px 50px rgba(0,0,0,.14);
      background:
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }
    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }
    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
      flex: 0 0 auto;
    }
    .hero .chip{
      display:inline-flex;
      align-items:center;
      gap:.5rem;
      padding:.32rem .7rem;
      border-radius: 999px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(255,255,255,.14);
      font-size:.82rem;
      color: rgba(255,255,255,.92);
      backdrop-filter: blur(6px);
      white-space: nowrap;
    }
    .hero .chip i{ color: var(--theme-color-secondaire); }
    .hero .chip--pill{
      background: color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
      border-color: color-mix(in srgb, var(--theme-color-secondaire) 28%, rgba(255,255,255,.14));
      color:#fff;
    }
    .hero .btn{ border-radius: 14px; font-weight: 800; }
    .hero .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .hero .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }
    @media (max-width: 768px){
      .hero{ border-radius:16px; }
    }

    .filterbar{ background:#fff; border-radius:18px; border:1px solid rgba(0,0,0,.06); box-shadow:0 10px 24px rgba(0,0,0,.05); }
    .table-card{ background:#fff; border-radius:18px; border:1px solid rgba(0,0,0,.06); box-shadow:0 12px 30px rgba(0,0,0,.06); overflow:visible; }
    table.dataTable thead th{ background:#f7f8fa!important; font-size:.78rem; text-transform:uppercase; letter-spacing:.05em; color:rgba(0,0,0,.55); }

    #tableauAssignments{
      table-layout: fixed !important;
      width: 100% !important;
    }

    #tableauAssignments th.action-column,
    #tableauAssignments td.action-column{
      width: 80px !important;
      max-width: 80px !important;
      min-width: 80px !important;
      padding-left: .25rem !important;
      padding-right: .25rem !important;
      white-space: nowrap !important;
      overflow: visible !important;
    }

    /* Actions cachées par défaut */
    #tableauAssignments td.action-column .d-inline-flex{
      gap: .2rem !important;
      opacity: 0;
      visibility: hidden;
      transform: translateY(2px);
      pointer-events: none;
      transition: opacity .15s ease, transform .15s ease, visibility .15s ease;
    }
    /* Affiche au survol / focus */
    #tableauAssignments tbody tr:hover td.action-column .d-inline-flex,
    #tableauAssignments td.action-column:focus-within .d-inline-flex{
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
      pointer-events: auto;
    }
    /* Mobile: toujours visible */
    @media (hover: none){
      #tableauAssignments td.action-column .d-inline-flex{
        opacity: 1;
        visibility: visible;
        transform: none;
        pointer-events: auto;
      }
    }
  </style>
{% endblock %}

{% block body %}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>

    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-clipboard-check me-2" style="color:var(--theme-color-secondaire)"></i>
            Affectations de questionnaires
          </h2>
          <div class="opacity-75 mt-1">Affecter, suivre et accéder aux réponses de positionnement.</div>

          <div class="d-flex flex-wrap gap-2 mt-3">
            <span class="chip"><i class="bi bi-clipboard-check"></i> Affectations</span>
            <span class="chip"><i class="bi bi-ui-checks"></i> Positionnement</span>
            <span class="chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
            <span class="chip chip--pill"><i class="bi bi-clock-history"></i> <span id="hero-last-refresh">—</span></span>
          </div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
          <a class="btn btn-light btn-sm fw-semibold" href="#nouvelle-affectation">
            <i class="bi bi-plus-circle me-1"></i> Nouvelle affectation
          </a>

          <a class="btn btn-outline-theme btn-sm fw-semibold" href="{{ path('app_administrateur_positioning_questionnaire_index', { entite: entite.id }) }}">
            <i class="bi bi-journal-text me-1"></i> Questionnaires
          </a>
        </div>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  <div class="row g-3 mb-3">
    <div class="col-12 col-xl-5">
      <div class="card border-0 shadow-sm" id="nouvelle-affectation" style="border-radius:18px;">
        <div class="card-body">
          <div class="fw-bold mb-2"><i class="bi bi-plus-circle"></i> Nouvelle affectation</div>
          {{ form_start(form) }}
            <div class="row g-2">
              <div class="col-md-5">{{ form_row(form.stagiaire) }}</div>
              <div class="col-md-5">{{ form_row(form.questionnaire) }}</div>
              <div class="col-md-2 d-flex align-items-end">
                <div class="w-100">
                  {{ form_row(form.isRequired) }}
                </div>
              </div>
              <div class="col-12">
                <button class="btn btn-warning fw-semibold w-100" type="submit">
                  <i class="bi bi-check2-circle"></i> Affecter
                </button>
              </div>
            </div>
          {{ form_end(form) }}
        </div>
      </div>
    </div>

    <div class="col-12 col-xl-7">
      <div class="filterbar p-3">
        <div class="fw-bold mb-2"><i class="bi bi-funnel"></i> Filtres</div>
        <div class="row g-2 align-items-end">
          <div class="col-md-4">
            <label class="form-label small text-muted fw-bold">Stagiaire</label>
            <input id="stagiaireFilter" class="form-control form-control-sm" placeholder="Nom / prénom / email">
          </div>
          <div class="col-md-3">
            <label class="form-label small text-muted fw-bold">Obligatoire</label>
            <select id="requiredFilter" class="form-select form-select-sm">
              <option value="all">Tous</option>
              <option value="yes">Oui</option>
              <option value="no">Non</option>
            </select>
          </div>
          <div class="col-md-3">
            <label class="form-label small text-muted fw-bold">Soumis</label>
            <select id="submittedFilter" class="form-select form-select-sm">
              <option value="all">Tous</option>
              <option value="yes">Oui</option>
              <option value="no">Non</option>
            </select>
          </div>
          <div class="col-md-2">
            <button id="btnReset" class="btn btn-outline-secondary btn-sm fw-semibold w-100" type="button">
              <i class="bi bi-arrow-counterclockwise"></i> Reset
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="table-card p-2">
    <table id="tableauAssignments" class="table table-hover align-middle mb-0 w-100">
      <thead>
        <tr>
          <th>#</th>
          <th>Stagiaire</th>
          <th>Questionnaire</th>
          <th>Niveau estimé</th>
          <th>Formateur</th>
          <th>Suggestion formateur</th>
          <th>Oblig.</th>
          <th>Statut</th>
          <th>Créé</th>
          <th>Soumis</th>
          <th class="action-column text-end"></th>
        </tr>
      </thead>
      <tbody></tbody>
    </table>
  </div>

  {# ===== Modal formateur ===== #}
  <div class="modal fade" id="modalEvaluator" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content" style="border-radius:18px;">
        <div class="modal-header">
          <h5 class="modal-title"><i class="bi bi-person-check"></i> Affecter un formateur</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <label class="form-label small text-muted fw-bold">Formateur évaluateur</label>
          <select id="evaluatorSelect" class="form-select js-tomselect" data-placeholder="Choisir un formateur…">
            <option value="">— Aucun —</option>
            {% for f in formateurs %}
              <option value="{{ f.id }}">{{ f.prenom }} {{ f.nom }} — {{ f.email }}</option>
            {% endfor %}
          </select>
          <input type="hidden" id="evaluatorUrl" value="">
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary fw-semibold" data-bs-dismiss="modal">Annuler</button>
          <button type="button" id="btnSaveEvaluator" class="btn btn-warning fw-semibold">
            <i class="bi bi-check2-circle"></i> Enregistrer
          </button>
        </div>
      </div>
    </div>
  </div>

  {# ===== Modal session ===== #}
  <div class="modal fade" id="modalSession" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content" style="border-radius:18px;">
        <div class="modal-header">
          <h5 class="modal-title"><i class="bi bi-mortarboard"></i> Affecter une session</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>

        <div class="modal-body">
          <label class="form-label small text-muted fw-bold">Session</label>
          <select id="sessionSelect" class="form-select js-tomselect" data-placeholder="Choisir une session…">
            <option value="">— Aucune —</option>
            {% for s in sessions %}
              <option value="{{ s.id }}">
                {% if s.code is defined %}{{ s.code }}{% else %}Session #{{ s.id }}{% endif %}
                {% if s.titre is defined %} — {{ s.titre }}{% endif %}
              </option>
            {% endfor %}
          </select>
          <input type="hidden" id="sessionUrl" value="">
        </div>

        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary fw-semibold" data-bs-dismiss="modal">Annuler</button>
          <button type="button" id="btnSaveSession" class="btn btn-warning fw-semibold">
            <i class="bi bi-check2-circle"></i> Enregistrer
          </button>
        </div>
      </div>
    </div>
  </div>
{% endblock %}

{% block javascripts %}
  {{ parent() }}

  {# ⚠️ Si base_admin.html.twig inclut déjà jQuery, enlève celle-ci pour éviter double chargement #}
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.datatables.net/v/bs5/dt-2.2.2/datatables.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>

  <script>
    $(function () {
      function nowLabel(){
        const d = new Date();
        return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
      }
      $('#hero-last-refresh').text('Maj : ' + nowLabel());

      // TomSelect (1 seule init)
      document.querySelectorAll('select.js-tomselect').forEach((el) => {
        if (el.tomselect) return;

        new TomSelect(el, {
          plugins: ['clear_button'],
          create: false,
          allowEmptyOption: true,
          maxItems: 1,
          placeholder: el.dataset.placeholder || 'Rechercher…',
          render: {
            no_results: () => '<div class="px-2 py-1 text-muted">Aucun résultat</div>'
          }
        });
      });

      const $stagiaire = $('#stagiaireFilter');
      const $required  = $('#requiredFilter');
      const $submitted = $('#submittedFilter');

      const table = $('#tableauAssignments').DataTable({
        serverSide: true,
        processing: true,
        autoWidth: false,
        scrollX: true,
        ajax:{
          url: "{{ path('app_administrateur_positioning_assignment_ajax', { entite: entite.id }) }}",
          type: "POST",
          data: function(d){
            d.stagiaireFilter = $stagiaire.val() || '';
            d.requiredFilter  = $required.val() || 'all';
            d.submittedFilter = $submitted.val() || 'all';
          }
        },
        columns:[
          {data:'id'},
          {data:'stagiaire'},
          {data:'questionnaire'},
          {data:'computedLevel', orderable:false, searchable:false},
          {data:'evaluator', orderable:false, searchable:false},
          {data:'suggestedLevel', orderable:false, searchable:false},
          {data:'required', orderable:false, searchable:false},
          {data:'status', orderable:false, searchable:false},
          {data:'createdAt'},
          {data:'submittedAt'},
          {data:'actions', orderable:false, searchable:false}
        ],
        columnDefs: [
          { targets: 10, className: 'action-column text-end', orderable:false, searchable:false },
          { targets: [0,6,7,8,9], className:'text-center' }
        ],
        order:[[0,'desc']],
        language:{ url:'https://cdn.datatables.net/plug-ins/2.2.2/i18n/fr-FR.json' },
      });

      table.on('draw.dt', function(){
        $('#hero-last-refresh').text('Maj : ' + nowLabel());
      });

      let t = null;
      $stagiaire.on('input', function(){
        clearTimeout(t);
        t = setTimeout(function(){ table.ajax.reload(null, true); }, 250);
      });
      $required.on('change', function(){ table.ajax.reload(null, true); });
      $submitted.on('change', function(){ table.ajax.reload(null, true); });

      $('#btnReset').on('click', function(){
        $stagiaire.val('');
        $required.val('all');
        $submitted.val('all');
        table.search('');
        table.ajax.reload(null, true);
      });

      // Toggle required
      $(document).on('click', '.js-toggle-required', async function(){
        const url = $(this).data('url');
        const res = await fetch(url, {method:'POST', headers:{'X-Requested-With':'XMLHttpRequest'}});
        if(res.ok){
          table.ajax.reload(null, false);
        }
      });

      // Modal evaluator
      let evaluatorModal = null;
      $(document).on('click', '.js-assign-evaluator', function(){
        const url = $(this).data('url');
        const current = parseInt($(this).data('current') || 0, 10);

        $('#evaluatorUrl').val(url);

        const sel = document.getElementById('evaluatorSelect');
        if (sel.tomselect) sel.tomselect.setValue(current ? String(current) : '');
        else sel.value = current ? String(current) : '';

        evaluatorModal = evaluatorModal || new bootstrap.Modal(document.getElementById('modalEvaluator'));
        evaluatorModal.show();
      });

      $('#btnSaveEvaluator').on('click', async function(){
        const url = $('#evaluatorUrl').val();
        const sel = document.getElementById('evaluatorSelect');
        const evaluatorId = sel.tomselect ? sel.tomselect.getValue() : sel.value;

        const fd = new FormData();
        fd.append('evaluatorId', evaluatorId);

        const res = await fetch(url, {
          method: 'POST',
          body: fd,
          headers: {'X-Requested-With':'XMLHttpRequest'}
        });

        if (res.ok) {
          evaluatorModal?.hide();
          table.ajax.reload(null, false);
        } else {
          alert("Impossible d'affecter ce formateur.");
        }
      });

      // Modal session
      let sessionModal = null;
      $(document).on('click', '.js-assign-session', function(){
        const url = $(this).data('url');
        const current = parseInt($(this).data('current') || 0, 10);

        $('#sessionUrl').val(url);

        const sel = document.getElementById('sessionSelect');
        if (sel.tomselect) sel.tomselect.setValue(current ? String(current) : '');
        else sel.value = current ? String(current) : '';

        sessionModal = sessionModal || new bootstrap.Modal(document.getElementById('modalSession'));
        sessionModal.show();
      });

      $('#btnSaveSession').on('click', async function(){
        const url = $('#sessionUrl').val();
        const sel = document.getElementById('sessionSelect');
        const sessionId = sel.tomselect ? sel.tomselect.getValue() : sel.value;

        const fd = new FormData();
        fd.append('sessionId', sessionId);

        const res = await fetch(url, {
          method: 'POST',
          body: fd,
          headers: {'X-Requested-With':'XMLHttpRequest'}
        });

        if (res.ok) {
          sessionModal?.hide();
          table.ajax.reload(null, false);
        } else {
          alert("Impossible d'affecter cette session.");
        }
      });
    });
  </script>
{% endblock %}