{# templates/administrateur/positioning/assignment/_form.html.twig #}
{{ form_start(form) }}

<div class="row g-3">

  <div class="col-12 col-lg-6">
    <div class="form-label">Stagiaire</div>
    <div class="form-box">
      <div class="d-flex gap-2 align-items-center">
        <div class="rounded-4 d-grid place-items-center"
             style="width:34px;height:34px;background:rgba(0,0,0,.04);border:1px solid rgba(0,0,0,.06);">
          <i class="bi bi-person"></i>
        </div>
        <div class="flex-grow-1">
          {{ form_widget(form.stagiaire, { attr: { class: 'form-select form-select-sm' } }) }}
        </div>
      </div>
      {{ form_errors(form.stagiaire) }}
    </div>
  </div>

  <div class="col-12 col-lg-6">
    <div class="form-label">Questionnaire</div>
    <div class="form-box">
      <div class="d-flex gap-2 align-items-center">
        <div class="rounded-4 d-grid place-items-center"
             style="width:34px;height:34px;background:rgba(0,0,0,.04);border:1px solid rgba(0,0,0,.06);">
          <i class="bi bi-journal-text"></i>
        </div>
        <div class="flex-grow-1">
          {{ form_widget(form.questionnaire, { attr: { class: 'form-select form-select-sm' } }) }}
        </div>
      </div>
      {{ form_errors(form.questionnaire) }}
    </div>
  </div>

  <div class="col-12 col-lg-4">
    <div class="form-label">Obligatoire</div>
    <div class="form-box">
      <div class="form-check form-switch m-0">
        {{ form_widget(form.isRequired, { attr: { class: 'form-check-input' } }) }}
        <label class="form-check-label fw-semibold" for="{{ form.isRequired.vars.id }}">
          Oui, ce questionnaire est requis
        </label>
      </div>
      {{ form_errors(form.isRequired) }}
    </div>
  </div>

  <div class="col-12 col-lg-8 d-flex align-items-end justify-content-end">
    <button class="btn btn-primary-soft btn-sm px-3 py-2">
      <i class="bi bi-check2-circle me-1"></i> Attribuer
    </button>
  </div>

</div>

{{ form_end(form) }}
