{# templates/administrateur/positioning/item/form.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}{{ is_edit ? 'Modifier' : 'Nouveau' }} item{% endblock %}



{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }
    .cardx{ background:#fff; border-radius:18px; border:1px solid rgba(0,0,0,.06); box-shadow:0 12px 30px rgba(0,0,0,.06); overflow:hidden; }
  </style>
{% endblock %}


{% block body %}
<div class="container-fluid px-3">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h2 class="fw-bold mb-0">{{ is_edit ? 'Modifier' : 'Créer' }} un item</h2>
      <div class="text-muted">
        Questionnaire : {{ questionnaire.title }} — Chapitre : {{ chapter.title }}
      </div>
    </div>
    <a class="btn btn-outline-secondary fw-semibold"
       href="{{ path('app_administrateur_positioning_questionnaire_edit', { entite: entite.id, id: questionnaire.id }) }}">
      <i class="bi bi-arrow-left"></i> Retour
    </a>
  </div>

  {% include 'flagMessage.html.twig' %}

  <div class="card p-3">
    {{ form_start(form) }}
      <div class="mb-3">
        <label class="form-label fw-bold">Libellé</label>
        {{ form_widget(form.label, { attr: { class:'form-control' }}) }}
      </div>

      <div class="row g-2">
        <div class="col-md-6">
          <label class="form-label fw-bold">Niveau (1: Initial, 2: Intermadiaire, 3: Avancé, 4: Expert)</label>
          {{ form_widget(form.level, { attr: { class:'form-control' }}) }}
        </div>
      </div>

      <div class="d-grid mt-3">
        <button class="btn btn-warning fw-semibold"><i class="bi bi-save"></i> Enregistrer</button>
      </div>
    {{ form_end(form) }}
  </div>
</div>
{% endblock %}
