{# templates/administrateur/positioning/questionnaire/show.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}Questionnaire — {{ q.title }}{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }

    .p-hero{
      border-radius: 18px;
      background:
        radial-gradient(900px 280px at 10% 0%, rgba(255,255,255,.10), transparent 55%),
        radial-gradient(700px 240px at 90% 10%, rgba(255,193,7,.18), transparent 55%),
        linear-gradient(135deg, rgba(35,51,66,.98), rgba(35,51,66,.78));
      color:#fff;
      box-shadow: 0 18px 50px rgba(0,0,0,.14);
      overflow:hidden;
    }
    .meta-chip{
      display:inline-flex; align-items:center; gap:.45rem;
      padding:.35rem .65rem; border-radius:999px;
      background:rgba(255,255,255,.12);
      border:1px solid rgba(255,255,255,.14);
      font-size:.82rem;
      white-space:nowrap;
    }

    .cardx{
      background:#fff;
      border-radius:18px;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 12px 30px rgba(0,0,0,.06);
      overflow:hidden;
    }
    .cardx-h{
      padding: .9rem 1rem;
      border-bottom:1px solid rgba(0,0,0,.06);
      background: linear-gradient(180deg, rgba(0,0,0,.015), transparent);
      display:flex; align-items:center; justify-content:space-between; gap:.75rem; flex-wrap:wrap;
    }
    .chip-soft{
      display:inline-flex; align-items:center; gap:.35rem;
      padding:.25rem .55rem; border-radius:999px;
      border:1px solid rgba(0,0,0,.10);
      background: rgba(0,0,0,.03);
      font-size:.82rem; font-weight:800;
      white-space:nowrap;
    }
    .chip-soft.ok{
      background: rgba(25,135,84,.12);
      border-color: rgba(25,135,84,.35);
      color:#146c43;
    }
    .chip-soft.no{
      background: rgba(108,117,125,.12);
      border-color: rgba(108,117,125,.35);
      color:#495057;
    }

    .list-wrap{ overflow:auto; }
    .grid-table{
      width:100%;
      border-collapse: separate;
      border-spacing: 0;
      min-width: 900px;
    }
    .grid-table thead th{
      position: sticky;
      top: 0;
      z-index: 5;
      background: #f7f8fa;
      border-bottom: 1px solid rgba(0,0,0,.10);
      font-size:.78rem;
      text-transform: uppercase;
      letter-spacing: .06em;
      color: rgba(0,0,0,.60);
      padding: .65rem .75rem;
      text-align:center;
      white-space: nowrap;
    }
    .grid-table thead th:first-child{ text-align:left; min-width: 520px; }
    .grid-table tbody td{
      border-bottom: 1px solid rgba(0,0,0,.06);
      padding: .65rem .75rem;
      vertical-align: middle;
      background:#fff;
    }
    .row-chapter td{
      background: #eef0f3 !important;
      border-bottom: 1px solid rgba(0,0,0,.10) !important;
      padding:.55rem .75rem !important;
    }
    .chapter-title{
      font-weight: 900;
      letter-spacing: -.01em;
      color: rgba(0,0,0,.78);
      display:flex; align-items:center; gap:.55rem;
    }
    .muted{ color: rgba(0,0,0,.55); }
    .badge-mini{
      font-size:.75rem;
      padding:.25rem .55rem;
      border-radius:999px;
      border:1px solid rgba(0,0,0,.12);
      background: rgba(255,255,255,.65);
      color: rgba(0,0,0,.65);
      font-weight: 800;
      white-space:nowrap;
    }
  </style>
{% endblock %}

{% block body %}
<div class="container-fluid px-3">

  <div class="p-hero p-4 mb-3">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
      <div class="flex-grow-1">
        <div class="d-flex flex-wrap gap-2 mb-2">
          <span class="meta-chip"><i class="bi bi-journal-text"></i> Questionnaire</span>
          <span class="meta-chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
          <span class="meta-chip"><i class="bi bi-hash"></i> #{{ q.id }}</span>
          <span class="meta-chip"><i class="bi bi-clock-history"></i> {{ q.createdAt ? q.createdAt|date('d/m/Y H:i') : '—' }}</span>
        </div>

        <h2 class="fw-bold mb-1">{{ q.title }}</h2>
        <div class="opacity-75">
          Structure du questionnaire (chapitres + items).
        </div>
      </div>

      <div class="d-flex gap-2">
        <a class="btn btn-light btn-sm fw-semibold"
           href="{{ path('app_administrateur_positioning_questionnaire_index', {entite: entite.id}) }}">
          <i class="bi bi-arrow-left"></i> Retour
        </a>

        <a class="btn btn-warning btn-sm fw-semibold"
           href="{{ path('app_administrateur_positioning_questionnaire_edit', {entite: entite.id, id: q.id}) }}">
          <i class="bi bi-pencil"></i> Modifier
        </a>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  <div class="row g-3 mb-3">
    <div class="col-12 col-lg-6">
      <div class="cardx">
        <div class="cardx-h">
          <div class="fw-bold"><i class="bi bi-info-circle"></i> Infos</div>
          {% if q.isPublished %}
            <span class="chip-soft ok"><i class="bi bi-broadcast-pin"></i> Publié</span>
          {% else %}
            <span class="chip-soft no"><i class="bi bi-eye-slash"></i> Non publié</span>
          {% endif %}
        </div>
        <div class="p-3">
          <div class="row g-2">
            <div class="col-12 col-md-6">
              <div class="muted small">Logiciel</div>
              <div class="fw-semibold">{{ q.software ?: '—' }}</div>
            </div>
            <div class="col-12 col-md-6">
              <div class="muted small">Créé par</div>
              <div class="fw-semibold">
                {{ q.createur ? (q.createur.nomComplet|default(q.createur.email|default('—'))) : '—' }}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-6">
      <div class="cardx">
        <div class="cardx-h">
          <div class="fw-bold"><i class="bi bi-collection"></i> Statistiques</div>
        </div>
        <div class="p-3">
          {% set chapCount = chapters|length %}
          {% set itemCount = 0 %}
          {% for ch in chapters %}{% set itemCount = itemCount + (ch.items|length) %}{% endfor %}

          <div class="d-flex flex-wrap gap-2">
            <span class="badge-mini"><i class="bi bi-folder2-open"></i> {{ chapCount }} chapitre(s)</span>
            <span class="badge-mini"><i class="bi bi-list-check"></i> {{ itemCount }} item(s)</span>
          </div>
          <div class="text-muted small mt-2">Tri : position puis id.</div>
        </div>
      </div>
    </div>
  </div>

  <div class="cardx">
    <div class="cardx-h">
      <div class="fw-bold"><i class="bi bi-diagram-3"></i> Contenu</div>
      <div class="text-muted small">Chapitres + items</div>
    </div>

    <div class="list-wrap">
      <table class="grid-table">
        <thead>
          <tr>
            <th>Chapitre / item</th>
            <th>Pos.</th>
            <th>Niveau</th>
            <th>ID</th>
          </tr>
        </thead>
        <tbody>
        {% if chapters|length == 0 %}
          <tr>
            <td colspan="4" class="text-center text-muted py-4">Aucun chapitre.</td>
          </tr>
        {% else %}
          {% for ch in chapters %}
            <tr class="row-chapter">
              <td colspan="4">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                  <div class="chapter-title">
                    <i class="bi bi-folder2-open"></i>
                    {{ ch.title }}
                    <span class="badge-mini">{{ ch.items|length }} item(s)</span>
                  </div>
                  <span class="badge-mini">Position : {{ ch.position }}</span>
                </div>
              </td>
            </tr>

            {% if ch.items|length == 0 %}
              <tr>
                <td class="text-muted">— Aucun item —</td>
                <td class="text-center">—</td>
                <td class="text-center">—</td>
                <td class="text-center">—</td>
              </tr>
            {% else %}
              {% for it in ch.items %}
                <tr>
                  <td>
                    <div class="fw-semibold">{{ it.label }}</div>
                  </td>
                  <td class="text-center">{{ it.position }}</td>
                  <td class="text-center">{{ it.level }}</td>
                  <td class="text-center">#{{ it.id }}</td>
                </tr>
              {% endfor %}
            {% endif %}
          {% endfor %}
        {% endif %}
        </tbody>
      </table>
    </div>
  </div>

</div>
{% endblock %}
