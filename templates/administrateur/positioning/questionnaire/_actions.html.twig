{# templates/administrateur/positioning/questionnaire/_actions.html.twig #}
<div class="btn-group btn-group-sm questionnaire-actions" role="group">

  {# ✅ bouton principal : modifier #}
  <a class="btn btn-light questionnaire-main"
     data-bs-toggle="tooltip" title="Modifier"
     href="{{ path('app_administrateur_positioning_questionnaire_edit', { entite: entite.id, id: q.id }) }}">
    <i class="bi bi-pencil"></i>
  </a>

  {# ✅ split dropdown #}
  <button type="button"
          class="btn btn-light dropdown-toggle dropdown-toggle-split questionnaire-split"
          data-bs-toggle="dropdown" aria-expanded="false">
    <span class="visually-hidden">Actions</span>
  </button>

  <ul class="dropdown-menu dropdown-menu-end questionnaire-menu">

    <li>
      <a class="dropdown-item d-flex align-items-center"
         href="{{ path('app_administrateur_positioning_questionnaire_edit', { entite: entite.id, id: q.id }) }}">
        <i class="bi bi-pencil me-2"></i> Modifier
      </a>
    </li>

    <li>
      <a class="dropdown-item d-flex align-items-center"
         href="{{ path('app_administrateur_positioning_questionnaire_show', { entite: entite.id, id: q.id }) }}">
        <i class="bi bi-eye me-2"></i> Ouvrir
      </a>
    </li>

    <li><hr class="dropdown-divider"></li>

    <li>
      <button type="button"
              class="dropdown-item d-flex align-items-center text-danger delete-btn"
              data-bs-toggle="modal"
              data-bs-target="#deleteModal"
              data-url="{{ path('app_administrateur_positioning_questionnaire_delete', { entite: entite.id, id: q.id }) }}"
              data-token="{{ csrf_token('del_q_' ~ q.id) }}">
        <i class="bi bi-trash me-2"></i> Supprimer
      </button>
    </li>

  </ul>
</div>
