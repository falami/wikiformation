{# templates/administrateur/finance/dashboard.html.twig #}
{% extends 'base_admin.html.twig' %}

{% block title %}Dashboard Financier{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/formulaire.css') }}">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
  <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css">

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};

      --bg:#f5f7fb; --panel:#fff; --ink:#0f172a; --muted:#64748b;
      --stroke: rgba(15, 23, 42, .10); --shadow: 0 18px 55px rgba(15, 23, 42, .10);
      --radius:18px;
    }


    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;

      /* Ombre douce premium */
      box-shadow: 0 18px 50px rgba(0,0,0,.14);

      /* Fond piloté par les couleurs de l'entité */
      background:
        /* halo clair (tertiaire) */
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        /* halo accent (secondaire) */
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        /* voile subtil (quaternaire) pour la profondeur */
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        /* dégradé principal (principal -> plus clair) */
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    /* léger glass highlight */
    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    /* barre accent = secondaire (et glow basé sur secondaire) */
    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }

    /* ===== Chips HERO (comme Sessions) ===== */
    .hero .chip{
      display:inline-flex;
      align-items:center;
      gap:.5rem;
      padding:.32rem .7rem;
      border-radius:999px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(255,255,255,.14);
      font-size:.82rem;
      color: rgba(255,255,255,.92);
      backdrop-filter: blur(6px);
      white-space: nowrap;
    }
    .hero .chip i{ color: var(--theme-color-secondaire); }

    /* chip highlight */
    .hero .chip--pill{
      background: color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
      border-color: color-mix(in srgb, var(--theme-color-secondaire) 28%, rgba(255,255,255,.14));
      color:#fff;
    }

    .hero .btn{
      border-radius:14px;
      font-weight:800;
    }
    .meta-chip{ display:inline-flex; align-items:center; gap:.45rem; padding:.35rem .65rem; border-radius:999px; background:rgba(255,255,255,.12); border:1px solid rgba(255,255,255,.14); font-size:.82rem; white-space:nowrap; }
    .btn-outline-theme{ border-color: rgba(255,255,255,.35); color:#fff; }
    .btn-outline-theme:hover{ background: rgba(255,255,255,.10); border-color: rgba(255,255,255,.55); color:#fff; }

    .cardx{ background: var(--panel); border: 1px solid var(--stroke); border-radius: var(--radius); box-shadow: 0 10px 28px rgba(15,23,42,.08); overflow:visible; }
    .cardx-h{ padding: .95rem 1.05rem; display:flex; align-items:center; justify-content:space-between; gap:1rem; background: linear-gradient(180deg, rgba(0,0,0,.015), transparent); border-bottom: 1px solid var(--stroke); }
    .cardx-title{ margin:0; font-weight:800; letter-spacing:-.01em; color: var(--ink); display:flex; align-items:center; gap:.6rem; }
    .chip{ font-size:.78rem; padding:.25rem .55rem; border-radius:999px; background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent); border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, var(--stroke)); color: var(--muted); white-space:nowrap; }

    .kpi-grid{ display:grid; grid-template-columns: repeat(12, 1fr); gap: 12px; }
    .kpi{ grid-column: span 3; padding: 14px 14px; border: 1px solid var(--stroke); border-radius: 18px;
      background: white;
    }
    .kpi .label{ color: var(--muted); font-size: .85rem; }
    .kpi .value{ font-weight: 900; font-size: 1.25rem; color: var(--ink); letter-spacing:-.01em;}
    .kpi .sub{ color: var(--muted); font-size: .82rem; margin-top: 2px;}

    @media (max-width: 1200px){ .kpi{ grid-column: span 4; } }
    @media (max-width: 768px){ .kpi{ grid-column: span 12; } .hero{ border-radius:16px; } }

    .nav-pills .nav-link{
      border-radius: 999px;
      border: 1px solid var(--stroke);
      color: var(--ink);
      font-weight: 800;
      background: color-mix(in srgb, var(--panel) 85%, transparent);
    }
    .nav-pills .nav-link.active{
      background: color-mix(in srgb, var(--theme-color-principal) 85%, #0000);
      border-color: color-mix(in srgb, var(--theme-color-principal) 50%, var(--stroke));
      color: #fff;
    }

    .chart-box{ height: 360px; }
    .chart-box.sm{ height: 340px; }  /* ✅ plus gros */

    @media (max-width: 768px){
      .chart-box{ height: 340px; }
      .chart-box.sm{ height: 320px; } /* ✅ garde grand sur mobile */
    }


    /* DataTables polish */
    .dataTables_wrapper .dataTables_filter input,
    .dataTables_wrapper .dataTables_length select{
      border-radius: 999px !important;
      border: 1px solid var(--stroke) !important;
      background: var(--panel) !important;
      color: var(--ink) !important;
      padding: .35rem .75rem !important;
      box-shadow: none !important;
      outline: none !important;
    }
    .dataTables_wrapper .dataTables_paginate .pagination .page-link{
      border-radius: 999px !important;
      border:1px solid var(--stroke) !important;
      color: var(--ink) !important;
      background: var(--panel) !important;
    }
    .dataTables_wrapper .dataTables_paginate .pagination .active .page-link{
      background: color-mix(in srgb, var(--theme-color-principal) 14%, var(--panel)) !important;
      border-color: color-mix(in srgb, var(--theme-color-principal) 35%, var(--stroke)) !important;
      font-weight: 900;
    }
    .money{ font-variant-numeric: tabular-nums; font-weight: 900; white-space: nowrap; }
    .badge-soft{
      border:1px solid var(--stroke);
      background: color-mix(in srgb, var(--theme-color-secondaire) 16%, var(--panel));
      color: var(--ink);
      border-radius: 999px;
      padding: .35rem .6rem;
      font-weight: 800;
      font-size:.78rem;
      white-space: nowrap;
    }

    #fYear{
      border-radius: 999px;
      border: 1px solid var(--stroke);
      background: var(--panel);
      color: var(--ink);
      font-weight: 800;
    }


    /* ===== Filtres : version compacte ===== */
    .filters-compact .row{ --bs-gutter-y: .6rem; --bs-gutter-x: .75rem; }

    .filters-compact .form-label{
      font-size: .78rem;
      margin-bottom: .15rem;
      color: var(--muted);
      font-weight: 800;
    }

    .filters-compact .form-control,
    .filters-compact .form-select{
      padding: .34rem .65rem;
      min-height: 34px;
      border-radius: 12px;
      font-size: .9rem;
    }

    .filters-compact .btn{
      padding: .32rem .6rem;
      border-radius: 12px;
    }

    .filters-compact .btn-group .btn{
      padding: .28rem .55rem;
    }

    .filters-compact .input-inline{
      display:flex;
      align-items:center;
      gap:.5rem;
    }

    .filters-compact .input-inline .form-label{
      margin: 0;
      white-space: nowrap;
      font-size: .78rem;
    }

    /* TomSelect compact */
    .filters-compact .ts-control{
      min-height: 34px !important;
      padding: .18rem .55rem !important;
      border-radius: 12px !important;
    }
    .filters-compact .ts-control .item,
    .filters-compact .ts-control input{
      font-size: .9rem !important;
    }
    .filters-compact .ts-dropdown .option{
      padding: .35rem .6rem !important;
      font-size: .9rem !important;
    }

    /* Flatpickr input compact (utilise ton #fRange) */
    .filters-compact #fRange{
      min-height: 34px;
    }



    /* --- Filtres avancés repliables --- */
    .filters-advanced{
      overflow: hidden;
      transition: max-height .22s ease, opacity .18s ease;
      max-height: 1200px;
      opacity: 1;
    }

    .filters-collapsed .filters-advanced{
      max-height: 0;
      opacity: 0;
      pointer-events: none;
      margin-top: 0 !important;
    }

    .filters-collapsed .cardx-h .chip{
      opacity: .9;
    }

    /* petit bonus : bouton toggle plus “chip” */
    #btnToggleFilters{
      border-radius: 999px;
      border: 1px solid var(--stroke);
      background: color-mix(in srgb, var(--panel) 85%, transparent);
    }


    /* Liste scrollable (comme Dépenses) */
    .dropdown-list{
      border-radius: 12px;
      border: 1px solid var(--stroke);
      background: color-mix(in srgb, var(--panel) 92%, transparent);
      padding: .25rem;
      max-height: 280px;
      overflow: auto;
    }


  </style>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  <script src="https://npmcdn.com/flatpickr/dist/l10n/fr.js"></script>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
  <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
{% endblock %}

{% block body %}


  {# HERO (identique Sessions / site/index) #}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>

    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-graph-up-arrow me-2" style="color:var(--theme-color-secondaire)"></i>
            Dashboard financier
          </h2>
          <div class="opacity-75 mt-1">
            Filtres, KPI, tendances, répartition, cash-in/cash-out, pipeline.
          </div>

          <div class="d-flex flex-wrap gap-2 mt-3">
            <span class="chip">
              <i class="bi bi-graph-up-arrow"></i>
              Finance
            </span>

            <span class="chip">
              <i class="bi bi-building"></i>
              {{ entite.nom }}
            </span>

            <span class="chip chip--pill">
              <i class="bi bi-stars"></i>
              Dashboard premium
            </span>
          </div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
          <button class="btn btn-light btn-sm fw-semibold" id="btnRefresh">
            <i class="bi bi-arrow-repeat me-1"></i> Actualiser
          </button>
        </div>
      </div>
    </div>
  </div>

  {# ===== FILTRES ===== #}
  <div class="cardx mb-4">
    <div class="cardx-h">
      <h5 class="cardx-title"><i class="bi bi-funnel-fill text-warning"></i> Filtres</h5>

      <div class="d-flex align-items-center gap-2">
        <button type="button" class="btn btn-light btn-sm" id="btnToggleFilters">
          <i class="bi bi-sliders"></i>
          <span>Plus de filtres</span>
        </button>
        <span class="chip">Global</span>
      </div>
    </div>

    <div class="p-3 filters-compact">
      <div class="row g-3 align-items-end">

        <div class="col-lg-6">
          <div class="input-inline flex-wrap">
            <label class="form-label">Année</label>

            <div class="btn-group btn-group-sm" role="group" aria-label="Raccourcis année">
              <button type="button" class="btn btn-light" id="btnYearNow">
                <i class="bi bi-calendar-event"></i> Année
              </button>
              <button type="button" class="btn btn-light" id="btnYearPrev1">N-1</button>
              <button type="button" class="btn btn-light" id="btnYearPrev2">N-2</button>
            </div>

            <select class="form-select form-select-sm w-auto" id="fYear" style="min-width:110px"></select>
          </div>
        </div>

        <div class="col-lg-6">
          <label class="form-label">Période</label>
          <input class="form-control" id="fRange" placeholder="Période" />
          <input type="hidden" id="fStart" value="{{ start }}">
          <input type="hidden" id="fEnd" value="{{ end }}">
        </div>

        <div id="filtersAdvanced" class="filters-advanced">

          <div class="row g-3 align-items-end">
            {# ✅ Catégorie (multi) - version “chip dropdown” comme Dépenses #}
            <div class="col-md-4 col-lg-3">
              <label class="form-label">Catégorie</label>

              <div class="chip w-100 d-flex align-items-center justify-content-between" style="gap:.5rem;">
                <span class="d-flex align-items-center gap-2">
                  <i class="bi bi-tags"></i>
                  <span id="fCatSelectedCount">Toutes</span>
                </span>

                <button class="btn btn-sm btn-light dropdown-toggle" type="button"
                        data-bs-toggle="dropdown" aria-expanded="false"
                        style="border-radius:999px;">
                  Choisir
                </button>

                <div class="dropdown-menu p-2" style="min-width:340px;">
                  <input type="text" class="form-control form-control-sm mb-2"
                        placeholder="Rechercher..." data-filter="fcat">

                  <div class="d-flex gap-2 mb-2">
                    <button class="btn btn-sm btn-outline-secondary" type="button" data-check-all="fcat">Tout</button>
                    <button class="btn btn-sm btn-outline-secondary" type="button" data-uncheck-all="fcat">Aucun</button>
                  </div>

                  <div id="fCatList" class="dropdown-list">
                    {% for c in categories %}
                      <label class="dropdown-item d-flex align-items-center gap-2" style="white-space:normal;">
                        <input class="form-check-input m-0 f-filter-cat" type="checkbox" value="{{ c.id }}">
                        <span>{{ c.libelle }}</span>
                      </label>
                    {% endfor %}
                  </div>
                </div>
              </div>
            </div>


            {# ✅ Fournisseur (multi) - version “chip dropdown” comme Dépenses #}
            <div class="col-md-4 col-lg-3">
              <label class="form-label">Fournisseur</label>

              <div class="chip w-100 d-flex align-items-center justify-content-between" style="gap:.5rem;">
                <span class="d-flex align-items-center gap-2">
                  <i class="bi bi-truck"></i>
                  <span id="fFourSelectedCount">Tous</span>
                </span>

                <button class="btn btn-sm btn-light dropdown-toggle" type="button"
                        data-bs-toggle="dropdown" aria-expanded="false"
                        style="border-radius:999px;">
                  Choisir
                </button>

                <div class="dropdown-menu p-2" style="min-width:340px;">
                  <input type="text" class="form-control form-control-sm mb-2"
                        placeholder="Rechercher..." data-filter="ffour">

                  <div class="d-flex gap-2 mb-2">
                    <button class="btn btn-sm btn-outline-secondary" type="button" data-check-all="ffour">Tout</button>
                    <button class="btn btn-sm btn-outline-secondary" type="button" data-uncheck-all="ffour">Aucun</button>
                  </div>

                  <div id="fFourList" class="dropdown-list">
                    {% for f in fournisseurs %}
                      <label class="dropdown-item d-flex align-items-center gap-2" style="white-space:normal;">
                        <input class="form-check-input m-0 f-filter-four" type="checkbox" value="{{ f.id }}">
                        {# optionnel: pastille couleur si tu l’as #}
                        {% if f.couleurHex %}
                          <span style="display:inline-block;width:10px;height:10px;border-radius:999px;background:{{ f.couleurHex }};"></span>
                        {% endif %}
                        <span>{{ f.nom }}</span>
                      </label>
                    {% endfor %}
                  </div>
                </div>
              </div>
            </div>


            <div class="col-md-4 col-lg-2">
              <label class="form-label">Devise</label>
              <select class="form-select" id="fDevise">
                <option value="">Toutes</option>
                <option value="EUR">EUR</option>
              </select>
            </div>

            <div class="col-md-4 col-lg-2">
              <label class="form-label">TVA</label>
              <select class="form-select" id="fTvaOnly">
                <option value="all">Toutes</option>
                <option value="deductible">Déductibles</option>
                <option value="nodeductible">Non déductibles</option>
              </select>
            </div>

            <div class="col-md-4 col-lg-3">
              <label class="form-label">Statut facture</label>
              <select class="form-select" id="fFactureStatus">
                <option value="">Tous</option>
                {% for s in factureStatuses %}<option value="{{ s.value }}">{{ s.label()|capitalize }}</option>{% endfor %}
              </select>
            </div>

            <div class="col-md-4 col-lg-2">
              <label class="form-label">Statut devis</label>
              <select class="form-select" id="fDevisStatus">
                <option value="">Tous</option>
                {% for s in devisStatuses %}<option value="{{ s.value }}">{{ s.label()|capitalize }}</option>{% endfor %}
              </select>
            </div>

            <div class="col-md-4 col-lg-2">
              <label class="form-label">Mode paiement</label>
              <select class="form-select" id="fPayMode">
                <option value="">Tous</option>
                {% for m in modePaiements %}<option value="{{ m.value }}">{{ m.label() }}</option>{% endfor %}
              </select>
            </div>
          </div>
        </div>

        <div class="col-12 d-flex gap-2">
          <button class="btn btn-gradient fw-semibold" id="btnApply"><i class="bi bi-check2"></i> Appliquer</button>
          <button class="btn btn-light" id="btnReset">Réinitialiser</button>
        </div>

      </div>
    </div>

  </div>

  {# ===== KPI ===== #}
  <div class="cardx mb-4">
    <div class="cardx-h">
      <h5 class="cardx-title"><i class="bi bi-speedometer2 text-warning"></i> Indicateurs</h5>
      <span class="chip">Live</span>
    </div>
    <div class="p-3 p-md-4">
      <div class="kpi-grid">
        <div class="kpi">
          <div class="label">Dépenses (TTC)</div>
          <div class="value" id="kpiDepTtc">—</div>
          <div class="sub" id="kpiDepCount">—</div>
        </div>
        <div class="kpi">
          <div class="label">TVA déductible</div>
          <div class="value" id="kpiTvaDed">—</div>
          <div class="sub">Selon % déductible</div>
        </div>
        <div class="kpi">
          <div class="label">Factures (TTC)</div>
          <div class="value" id="kpiFacTtc">—</div>
          <div class="sub" id="kpiFacCount">—</div>
        </div>
        <div class="kpi">
          <div class="label">Paiements encaissés</div>
          <div class="value" id="kpiPayTotal">—</div>
          <div class="sub" id="kpiPayCount">—</div>
        </div>
        <div class="kpi">
          <div class="label">Résultat (Factures - Dépenses)</div>
          <div class="value" id="kpiNet">—</div>
          <div class="sub">Sur la période</div>
        </div>
        <div class="kpi">
          <div class="label">Cash gap (Paiements - Dépenses)</div>
          <div class="value" id="kpiCashGap">—</div>
          <div class="sub">Trésorerie nette</div>
        </div>
        <div class="kpi">
          <div class="label">Devis (pipeline TTC)</div>
          <div class="value" id="kpiDevisTtc">—</div>
          <div class="sub" id="kpiDevisCount">—</div>
        </div>
        <div class="kpi">
          <div class="label">Avoirs (TTC)</div>
          <div class="value" id="kpiAvoTotal">—</div>
          <div class="sub" id="kpiAvoCount">—</div>
        </div>
        {# sous tes KPI existants #}
        <div class="kpi">
          <div class="label">Dépenses moy./mois</div>
          <div class="value" id="kpiDepAvgMonth">—</div>
          <div class="sub" id="kpiAvgHint">—</div>
        </div>

        <div class="kpi">
          <div class="label">Factures moy./mois</div>
          <div class="value" id="kpiFacAvgMonth">—</div>
          <div class="sub">Lissé sur la période</div>
        </div>

        <div class="kpi">
          <div class="label">Paiements moy./mois</div>
          <div class="value" id="kpiPayAvgMonth">—</div>
          <div class="sub">Encaissements</div>
        </div>

        <div class="kpi">
          <div class="label">Devis moy./mois</div>
          <div class="value" id="kpiDevisAvgMonth">—</div>
          <div class="sub">Pipeline</div>
        </div>

      </div>
    </div>
  </div>

  {# ===== ONGLET NAV ===== #}
  <div class="d-flex flex-wrap gap-2 mb-3">
    <ul class="nav nav-pills gap-2" id="financeTabs" role="tablist">
      <li class="nav-item"><button class="nav-link active" data-bs-toggle="pill" data-bs-target="#tab-all" type="button">Analyse complète</button></li>
      <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#tab-dep" type="button">Dépenses</button></li>
      <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#tab-pay" type="button">Paiements</button></li>
      <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#tab-fac" type="button">Factures</button></li>
      <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#tab-dev" type="button">Devis</button></li>
      <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#tab-avo" type="button">Avoirs</button></li>
    </ul>
  </div>

