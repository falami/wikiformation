<script>
(function(){
  // ===========================
  // Helpers
  // ===========================




  // ===========================
  // Toggle filtres avancés
  // ===========================
  const $filtersCard = document.querySelector('.cardx.mb-4'); // ta card filtres (si c'est la 1ère mb-4)
  const $btnToggle   = document.getElementById('btnToggleFilters');
  const $adv         = document.getElementById('filtersAdvanced');

  (function initFiltersToggle(){
    if (!$filtersCard || !$btnToggle || !$adv) return;

    const KEY = 'finance_filters_advanced_open';
    const saved = localStorage.getItem(KEY);

    // par défaut: fermé (compact)
    const open = saved === '1';
    $filtersCard.classList.toggle('filters-collapsed', !open);
    $btnToggle.querySelector('span').textContent = open ? 'Moins de filtres' : 'Plus de filtres';
    $btnToggle.querySelector('i').className = open ? 'bi bi-chevron-up' : 'bi bi-sliders';

    $btnToggle.addEventListener('click', () => {
      const isCollapsed = $filtersCard.classList.toggle('filters-collapsed');
      const isOpen = !isCollapsed;

      localStorage.setItem(KEY, isOpen ? '1' : '0');
      $btnToggle.querySelector('span').textContent = isOpen ? 'Moins de filtres' : 'Plus de filtres';
      $btnToggle.querySelector('i').className = isOpen ? 'bi bi-chevron-up' : 'bi bi-sliders';

      // TomSelect/Flatpickr : quand on ré-affiche, on rafraîchit la taille des dropdowns
      if (isOpen){
        setTimeout(() => {
          document.querySelectorAll('.tomselect').forEach(() => {});
        }, 50);
      }
    });
  })();



  const FAC_STATUS_FR = {
    due: 'À payer',
    paid: 'Payée',
    canceled: 'Annulée',
  };

  const DV_STATUS_FR = {
    // adapte à ton enum DevisStatus
    draft: 'Brouillon',
    sent: 'Envoyé',
    accepted: 'Accepté',
    refused: 'Refusé',
    canceled: 'Annulé',
  };

  function labelFactureStatus(v){
    const k = String(v || '').toLowerCase();
    return FAC_STATUS_FR[k] || v || '—';
  }

  function labelDevisStatus(v){
    const k = String(v || '').toLowerCase();
    return DV_STATUS_FR[k] || v || '—';
  }




  // ✅ Toujours afficher en EUR pour les graphiques
  const eur = (cents) => {
    const n = Number(cents || 0) / 100;
    try {
      return new Intl.NumberFormat('fr-FR', { style: 'currency', currency: 'EUR' }).format(n);
    } catch (e) {
      return (n.toFixed(2)).replace('.', ',') + ' €';
    }
  };


  const safe = (v) => (v === null || v === undefined || v === '') ? '—' : v;

  const badgeBool = (v) => v
    ? `<span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle">Oui</span>`
    : `<span class="badge rounded-pill bg-secondary-subtle text-secondary border border-secondary-subtle">Non</span>`;

  const badgePill = (t) => `<span class="badge-soft">${t}</span>`;

  // ===========================
  // Flatpickr + TomSelect
  // ===========================
  if (window.flatpickr && window.flatpickr.l10ns?.fr) flatpickr.localize(flatpickr.l10ns.fr);

  const $range = document.getElementById('fRange');
  const $start = document.getElementById('fStart');
  const $end   = document.getElementById('fEnd');

  let fpRange = null;

  function formatFr(d){
    // d = Date
    const dd = String(d.getDate()).padStart(2,'0');
    const mm = String(d.getMonth()+1).padStart(2,'0');
    const yy = d.getFullYear();
    return `${dd}/${mm}/${yy}`;
  }
  function iso(d){
    return d.toISOString().slice(0,10);
  }

  function isoLocal(d){
    const y = d.getFullYear();
    const m = String(d.getMonth()+1).padStart(2,'0');
    const day = String(d.getDate()).padStart(2,'0');
    return `${y}-${m}-${day}`;
  }

  function dateFromIso(isoStr){
    // isoStr = "YYYY-MM-DD"
    if (!isoStr) return null;
    const [y,m,d] = isoStr.split('-').map(Number);
    if (!y || !m || !d) return null;
    return new Date(y, m-1, d); // ✅ date locale sans timezone ISO
  }

  function setYearRange(year){
    const y = Number(year);
    if (!y) return;

    const d1 = new Date(y, 0, 1);
    const d2 = new Date(y, 11, 31);

    // hidden inputs (format ISO)
    $start.value = isoLocal(d1);
    $end.value   = isoLocal(d2);

    // flatpickr
    fpRange?.setDate([d1, d2], true); // true => déclenche onChange
  }

  function getYearFromIso(isoStr){
    if (!isoStr) return null;
    const y = Number(String(isoStr).slice(0,4));
    return Number.isFinite(y) ? y : null;
  }


  function initRangePicker(){
    fpRange?.destroy?.();

    const initStartIso = ($start.value || '').trim();
    const initEndIso   = ($end.value || '').trim();

    const dStart = dateFromIso(initStartIso);
    const dEnd   = dateFromIso(initEndIso);

    fpRange = flatpickr($range, {
      locale: {
        ...flatpickr.l10ns.fr,
        rangeSeparator: " → ",
      },
      mode: "range",
      dateFormat: "d/m/Y",
      allowInput: true,
      disableMobile: true,

      // ✅ on passe des Date, plus des strings
      defaultDate: [dStart, dEnd].filter(Boolean),

      onChange: function(selectedDates){
        const from = selectedDates[0] ? isoLocal(selectedDates[0]) : '';
        const to   = selectedDates[1] ? isoLocal(selectedDates[1]) : from;
        $start.value = from;
        $end.value   = to;
        syncYearSelectFromRange();

      }
    });

    // ✅ force l’affichage du champ visible (range complet)
    if (dStart && dEnd) {
      fpRange.setDate([dStart, dEnd], false);
    }
  }

  initRangePicker();

  // ===========================
  // Year selector helpers
  // ===========================
  const $year = document.getElementById('fYear');

  (function initYearSelect(){
    if (!$year) return;

    // base : année de la période actuelle, sinon année courante
    const currentY = getYearFromIso($start.value) || (new Date()).getFullYear();

    // plage affichée : de (année courante - 6) à (année courante + 1)
    const nowY = (new Date()).getFullYear();
    const minY = nowY - 6;
    const maxY = nowY + 1;

    $year.innerHTML = '';
    for (let y = maxY; y >= minY; y--){
      const opt = document.createElement('option');
      opt.value = String(y);
      opt.textContent = String(y);
      $year.appendChild(opt);
    }

    $year.value = String(currentY);

    // si la période n’est PAS déjà une année complète, on ne force rien
    // sinon, on synchronise l’affichage de la période
  })();

  // changements select => applique l'année complète
  $year?.addEventListener('change', (e) => {
    setYearRange(e.target.value);
    refresh(); // ✅ applique direct
  });



  // ===========================
  // ✅ Multi filtres Cat/Four (comme Dépenses)
  // ===========================
  function getCheckedValues(selector){
    return Array.from(document.querySelectorAll(selector + ':checked'))
      .map(el => parseInt(el.value, 10))
      .filter(n => Number.isFinite(n));
  }

  function setAll(selector, checked){
    document.querySelectorAll(selector).forEach(el => el.checked = checked);
  }

  function updateSelectedCounts(){
    const catChecked  = getCheckedValues('.f-filter-cat');
    const fourChecked = getCheckedValues('.f-filter-four');

    const totalCat  = document.querySelectorAll('.f-filter-cat').length;
    const totalFour = document.querySelectorAll('.f-filter-four').length;

    // texte bouton
    document.getElementById('fCatSelectedCount').textContent =
      (catChecked.length === 0) ? 'Aucune' :
      (catChecked.length === totalCat) ? 'Toutes' :
      `${catChecked.length} sel.`;

    document.getElementById('fFourSelectedCount').textContent =
      (fourChecked.length === 0) ? 'Aucun' :
      (fourChecked.length === totalFour) ? 'Tous' :
      `${fourChecked.length} sel.`;

    // modes (all|some|none) pour serveur
    window.__finCatMode  =
      (catChecked.length === 0) ? 'none' :
      (catChecked.length === totalCat) ? 'all' : 'some';

    window.__finFourMode =
      (fourChecked.length === 0) ? 'none' :
      (fourChecked.length === totalFour) ? 'all' : 'some';
  }

  // init: tout coché => mode "all"
  setAll('.f-filter-cat', true);
  setAll('.f-filter-four', true);
  updateSelectedCounts();

  // events check/uncheck
  let refreshTimer = null;
  function refreshDebounced(){
    clearTimeout(refreshTimer);
    refreshTimer = setTimeout(() => refresh(), 250);
  }

  document.addEventListener('change', (e) => {
    if (e.target.matches('.f-filter-cat, .f-filter-four')){
      updateSelectedCounts();
      refreshDebounced(); // ✅ applique direct après sélection
    }
  });


  // Tout / Aucun
  document.addEventListener('click', (e) => {
    const btnAll = e.target.closest('[data-check-all]');
    const btnNone = e.target.closest('[data-uncheck-all]');
    if (!btnAll && !btnNone) return;

    const key = (btnAll || btnNone).getAttribute(btnAll ? 'data-check-all' : 'data-uncheck-all');
    const checked = !!btnAll;

    if (key === 'fcat')  setAll('.f-filter-cat', checked);
    if (key === 'ffour') setAll('.f-filter-four', checked);

    updateSelectedCounts();
  });

  // Recherche dropdown
  document.addEventListener('input', (e) => {
    const input = e.target.closest('input[data-filter]');
    if (!input) return;

    const q = (input.value || '').toLowerCase();
    const t = input.getAttribute('data-filter');

    if (t === 'fcat'){
      document.querySelectorAll('#fCatList label').forEach(l => {
        l.style.display = l.textContent.toLowerCase().includes(q) ? '' : 'none';
      });
    }
    if (t === 'ffour'){
      document.querySelectorAll('#fFourList label').forEach(l => {
        l.style.display = l.textContent.toLowerCase().includes(q) ? '' : 'none';
      });
    }
  });





  



  const initTS = (id) => {
    const el = document.getElementById(id);
    if (!el || el.tomselect) return;
    new TomSelect(el, { create:false, allowEmptyOption:true, sortField:{field:'text',direction:'asc'} });
  };
  initTS('fDevise');
  initTS('fTvaOnly');
  initTS('fFactureStatus');
  initTS('fDevisStatus');
  initTS('fPayMode');


  // ===========================
  // Filters
  // ===========================
  function getFilters(){
    const catIds  = getCheckedValues('.f-filter-cat');
    const fourIds = getCheckedValues('.f-filter-four');

    return {
      dateStart: document.getElementById('fStart').value,
      dateEnd: document.getElementById('fEnd').value,

      // ✅ multi
      catIds,
      fourIds,
      catMode:  window.__finCatMode  || 'all',   // all|some|none
      fourMode: window.__finFourMode || 'all',   // all|some|none

      // autres filtres inchangés
      devise: document.getElementById('fDevise').value,
      tvaOnly: document.getElementById('fTvaOnly').value,
      factureStatus: document.getElementById('fFactureStatus').value,
      devisStatus: document.getElementById('fDevisStatus').value,
      payMode: document.getElementById('fPayMode').value,
    };
  }




  // ===========================
  // KPI + Charts (inchangés)
  // ===========================
  let chTrend, chCat, chFourn, chFacStatus;

  function ensureChart(ref, ctx, cfg){
    if (ref) ref.destroy();
    return new Chart(ctx, cfg);
  }

  function num(v){ return Number(v||0); }

  function buildMonthIndex(series){
    const map = new Map();
    series.forEach(r => map.set(r.ym, num(r.ttc || r.total || 0)));
    const labels = Array.from(map.keys()).sort();
    return { labels, values: labels.map(l => map.get(l) || 0) };
  }

  function buildQuery(filters){
    const q = new URLSearchParams();

    Object.entries(filters).forEach(([k,v]) => {
      if (v === null || v === undefined) return;

      // ✅ arrays -> k[]=1&k[]=2
      if (Array.isArray(v)){
        // si mode=all, on peut éviter d'envoyer les IDs (optionnel)
        v.forEach(x => q.append(k + '[]', String(x)));
        return;
      }

      if (typeof v === 'string' && v.trim() === '') return;
      q.set(k, String(v));
    });

    // ✅ optimisation : si "all", on n'envoie pas les ids (ça évite URL longue)
    if (filters.catMode === 'all')  q.delete('catIds[]');
    if (filters.fourMode === 'all') q.delete('fourIds[]');

    return q;
  }


  async function loadSummary(){
    const q = buildQuery(getFilters());
    const url = "{{ path('app_administrateur_finance_api_summary', {entite: entite.id}) }}" + "?" + q.toString();
    const r = await fetch(url, { headers: { 'Accept':'application/json' }});
    if (!r.ok) throw new Error('Erreur chargement dashboard');
    return r.json();
  }


  const money = (cents) => {
    const n = (Number(cents || 0) / 100);
    const cur = document.getElementById('fDevise')?.value || 'EUR';
    try { return new Intl.NumberFormat('fr-FR',{style:'currency',currency:cur}).format(n); }
    catch(e){ return (n.toFixed(2)).replace('.',',')+' '+cur; }
  };




  function applyKpis(k, filters){
    document.getElementById('kpiDepTtc').textContent = money(k.dep.ttc);
    document.getElementById('kpiDepCount').textContent = `${k.dep.cnt} dépense(s) — HT ${money(k.dep.ht)} — TVA ${money(k.dep.tva)}`;
    document.getElementById('kpiTvaDed').textContent = money(k.dep.tvaDed);

    document.getElementById('kpiFacTtc').textContent = money(k.fac.ttc);
    document.getElementById('kpiFacCount').textContent = `${k.fac.cnt} facture(s) — HT ${money(k.fac.ht)} — TVA ${money(k.fac.tva)}`;

    document.getElementById('kpiPayTotal').textContent = money(k.pay.total);
    document.getElementById('kpiPayCount').textContent = `${k.pay.cnt} paiement(s)`;

    document.getElementById('kpiNet').textContent = money(k.netTtc);
    document.getElementById('kpiCashGap').textContent = money(k.cashGap);

    document.getElementById('kpiDevisTtc').textContent = money(k.devis.ttc);
    document.getElementById('kpiDevisCount').textContent = `${k.devis.cnt} devis`;

    document.getElementById('kpiAvoTotal').textContent = money(k.avo.total);
    document.getElementById('kpiAvoCount').textContent = `${k.avo.cnt} avoir(s)`;


    if (k.avgMonthly) {
      document.getElementById('kpiDepAvgMonth').textContent   = money(k.avgMonthly.depTtc);
      document.getElementById('kpiFacAvgMonth').textContent   = money(k.avgMonthly.facTtc);
      document.getElementById('kpiPayAvgMonth').textContent   = money(k.avgMonthly.pay);
      document.getElementById('kpiDevisAvgMonth').textContent = money(k.avgMonthly.devisTtc);
    }

    // ✅ hint “lissé sur X mois”
    const months = k?.filters?.monthsCovered || null; // si tu le mets dans kpis.filters, sinon data.filters
    if (document.getElementById('kpiAvgHint')) {
      document.getElementById('kpiAvgHint').textContent =
        months ? `Lissé sur ${months} mois` : 'Lissé sur la période';
    }
  }


  // ✅ Chart.js - lisibilité globale
  Chart.defaults.font.size = 13;
  Chart.defaults.plugins.legend.labels.boxWidth = 14;
  Chart.defaults.plugins.legend.labels.boxHeight = 14;
  Chart.defaults.plugins.legend.labels.padding = 14;
  Chart.defaults.plugins.legend.labels.usePointStyle = true;


  function applyCharts(c){
    const dep = buildMonthIndex(c.depMonthly.map(x => ({ym:x.ym, total:x.ttc})));
    const fac = buildMonthIndex(c.facMonthly.map(x => ({ym:x.ym, total:x.ttc})));
    const pay = buildMonthIndex(c.payMonthly.map(x => ({ym:x.ym, total:x.total})));

    const labels = Array.from(new Set([...dep.labels, ...fac.labels, ...pay.labels])).sort();
    const at = (s) => {
      const map = new Map(s.labels.map((l,i)=>[l, s.values[i]]));
      return labels.map(l => map.get(l) || 0);
    };

    chTrend = ensureChart(chTrend, document.getElementById('chTrend'), {
      type: 'line',
      data: {
        labels,
        datasets: [
          { label: 'Dépenses TTC', data: at(dep) },
          { label: 'Factures TTC', data: at(fac) },
          { label: 'Paiements', data: at(pay) },
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false }, // ✅ tooltip “groupé” par mois
        plugins: {
          legend: { position: 'bottom' },
          tooltip: {
            callbacks: {
              // ✅ titre (mois)
              title: (items) => items?.[0]?.label ? items[0].label : '',
              // ✅ valeurs en €
              label: (ctx) => {
                const v = Number(ctx.parsed?.y ?? ctx.raw ?? 0);
                return `${ctx.dataset.label}: ${eur(v)}`;
              }
            }
          }
        },
        scales: {
          y: {
            ticks: { callback: (v) => eur(v) } // ✅ axe Y en €
          }
        }
      }
    });

    const defaultPalette = [
      '#2563eb','#16a34a','#f59e0b','#ef4444','#8b5cf6',
      '#06b6d4','#f97316','#22c55e','#e11d48','#64748b'
    ];



    const catLabels = c.depByCat.map(x => x.label);
    const catValues = c.depByCat.map(x => num(x.v)); // cents

    const catColors = catLabels.map((_, i) => defaultPalette[i % defaultPalette.length]);

    chCat = ensureChart(chCat, document.getElementById('chCat'), {
      type: 'polarArea',
      data: {
        labels: catLabels,
        datasets: [{
          data: catValues,
          backgroundColor: catColors,
          borderColor: catColors,
          borderWidth: 1
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        layout: { padding: { top: 6, right: 8, bottom: 0, left: 8 } },
        plugins: {
          legend: {
            position: 'bottom',
            labels: { font: { size: 12 } } // ✅ légende plus lisible
          },
          tooltip: {
            callbacks: {
              label: (ctx) => {
                const label = ctx.label ? `${ctx.label}: ` : '';
                const v = Number(ctx.raw || 0);
                return label + money(v);
              },
              footer: (items) => {
                const vals = items?.[0]?.dataset?.data || [];
                const total = vals.reduce((a,b)=>a+Number(b||0), 0);
                const v = Number(items?.[0]?.raw || 0);
                const pct = total ? (v/total*100) : 0;
                return `Part: ${pct.toFixed(1).replace('.', ',')} %`;
              }
            }
          }
        },
        scales: {
          r: {
            ticks: {
              backdropColor: 'transparent',  // ✅ pas de “boîte” grise derrière le texte
              font: { size: 12 },
              callback: (v) => {
                // ✅ ticks plus courts (sinon c’est illisible)
                const euros = Number(v || 0) / 100;
                if (euros >= 10000) return `${Math.round(euros/1000)}k€`;
                if (euros >= 1000)  return `${(euros/1000).toFixed(1).replace('.', ',')}k€`;
                return `${Math.round(euros)}€`;
              }
            },
            pointLabels: {
              font: { size: 12 }, // ✅ labels radiaux
            }
          }
        }
      }

    });

    const colorsFourn = c.depByFour.map((x, i) => x.color || defaultPalette[i % defaultPalette.length]);

    chFourn = ensureChart(chFourn, document.getElementById('chFourn'), {
      type:'bar',
      data:{
        labels: c.depByFour.map(x=>x.label),
        datasets:[{
          label:'Dépenses TTC',
          data: c.depByFour.map(x=>num(x.v)),
          backgroundColor: colorsFourn, // ✅ couleur par fournisseur
          borderColor: colorsFourn,
          borderWidth: 1
        }]
      },
      options:{
        responsive:true,
        maintainAspectRatio:false,
        plugins:{
          legend:{ display:false },
          tooltip:{
            callbacks:{
              label: (ctx) => `${ctx.dataset.label}: ${money(ctx.parsed.y || 0)}`
            }
          }
        },
        scales:{
          y:{ ticks:{ callback:(v)=> money(v) } }
        }
      }
    });



    const statusPalette = {
      due:      '#f59e0b', // orange
      paid:     '#16a34a', // vert
      canceled: '#ef4444', // rouge
    };

    const facStatusLabelsRaw = c.facByStatus.map(x => String(x.label || '').toLowerCase());
    const facStatusLabels    = c.facByStatus.map(x => labelFactureStatus(x.label));
    const facStatusValues    = c.facByStatus.map(x => num(x.v));

    const facStatusColors = facStatusLabelsRaw.map((k, i) =>
      statusPalette[k] || defaultPalette[i % defaultPalette.length]
    );

    chFacStatus = ensureChart(chFacStatus, document.getElementById('chFacStatus'), {
      type: 'polarArea',
      data: {
        labels: facStatusLabels,
        datasets: [{
          data: facStatusValues,
          backgroundColor: facStatusColors,
          borderColor: facStatusColors,
          borderWidth: 1
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { position: 'bottom' },
          tooltip: {
            callbacks: {
              label: (ctx) => {
                const label = ctx.label ? `${ctx.label}: ` : '';
                const v = Number(ctx.raw || 0);
                return label + money(v);
              },
              footer: (items) => {
                const vals = items?.[0]?.dataset?.data || [];
                const total = vals.reduce((a,b)=>a+Number(b||0), 0);
                const v = Number(items?.[0]?.raw || 0);
                const pct = total ? (v/total*100) : 0;
                return `Part: ${pct.toFixed(1).replace('.', ',')} %`;
              }
            }
          }
        }
      }
    });

  }

  // ===========================
  // DataTables (ALL tabs)
  // ===========================
  let dtDep, dtPay, dtFac, dtDev, dtAvo;

  function dtCommonOptions(){
    return {
      processing:true,
      serverSide:true,
      pageLength: 25,
      lengthMenu: [[10,25,50,100],[10,25,50,100]],
      deferRender:true,
      autoWidth:false,
      responsive:false, // garde bootstrap table responsive
      language: {
        url: "https://cdn.datatables.net/plug-ins/1.13.8/i18n/fr-FR.json"
      }
    };
  }



  function syncYearSelectFromRange(){
    const y = getYearFromIso($start.value);
    if ($year && y) $year.value = String(y);
  }

  document.getElementById('btnYearNow')?.addEventListener('click', () => {
    const y = (new Date()).getFullYear();
    setYearRange(y);
    if ($year) $year.value = String(y);
    refresh(); // ✅
  });


  document.getElementById('btnYearPrev1')?.addEventListener('click', () => {
    const y = (new Date()).getFullYear() - 1;
    setYearRange(y);
    if ($year) $year.value = String(y);
    refresh();
  });

  document.getElementById('btnYearPrev2')?.addEventListener('click', () => {
    const y = (new Date()).getFullYear() - 2;
    setYearRange(y);
    if ($year) $year.value = String(y);
    refresh();
  });


  function dtFilters(d){
    const f = getFilters();

    // strings
    ['dateStart','dateEnd','devise','tvaOnly','factureStatus','devisStatus','payMode','catMode','fourMode']
      .forEach((k) => {
        const v = f[k];
        if (v === null || v === undefined) return;
        if (typeof v === 'string' && v.trim() === '') return;
        d[k] = v;
      });

    // ✅ arrays -> Symfony attend souvent catIds[] / fourIds[]
    if (f.catMode !== 'all')  d['catIds[]']  = f.catIds;
    if (f.fourMode !== 'all') d['fourIds[]'] = f.fourIds;
  }




  function initDtDepenses(){
    if (dtDep) return;
    dtDep = $('#dtDepenses').DataTable(Object.assign(dtCommonOptions(),{
      order:[[0,'desc']],
      ajax:{
        url: "{{ path('app_administrateur_finance_dt_depenses', {entite: entite.id}) }}",
        type:"GET",
        data: dtFilters
      },
      columnDefs:[
        { targets:[4,5,6,9], className:'text-end' },
        { targets:[4,5,6], render:(d)=> `<span class="money">${money(d)}</span>` },
        { targets:[7], render:(d)=> badgeBool(!!d) },
        { targets:[9], orderable:false, searchable:false },
      ]
    }));
  }

  function initDtPaiements(){
    if (dtPay) return;
    dtPay = $('#dtPaiements').DataTable(Object.assign(dtCommonOptions(),{
      order:[[0,'desc']],
      ajax:{
        url: "{{ path('app_administrateur_finance_dt_paiements', {entite: entite.id}) }}",
        type:"GET",
        data: dtFilters
      },
      columnDefs:[
        { targets:[3,7], className:'text-end' },
        { targets:[3], render:(d)=> `<span class="money">${money(d)}</span>` },
        { targets:[5], render:(d)=> d ? `<code>${d}</code>` : '—' },
        { targets:[6], render:(d)=> d ? `<a class="badge-soft" target="_blank" href="/uploads/paiements/${encodeURIComponent(d)}">Justif</a>` : '—' },
        { targets:[7], orderable:false, searchable:false },
      ]
    }));
  }

  function initDtFactures(){
    if (dtFac) return;
    dtFac = $('#dtFactures').DataTable(Object.assign(dtCommonOptions(),{
      order:[[0,'desc']],
      ajax:{
        url: "{{ path('app_administrateur_finance_dt_factures', {entite: entite.id}) }}",
        type:"GET",
        data: dtFilters
      },
      columnDefs:[
        { targets:[4,5,6,8], className:'text-end' },
        { targets:[4,5,6], render:(d)=> `<span class="money">${money(d)}</span>` },
        { targets:[3], render:(d)=> d ? badgePill(labelFactureStatus(d)) : '—' },
        { targets:[8], orderable:false, searchable:false },
      ]
    }));
  }

  function initDtDevis(){
    if (dtDev) return;
    dtDev = $('#dtDevis').DataTable(Object.assign(dtCommonOptions(),{
      order:[[0,'desc']],
      ajax:{
        url: "{{ path('app_administrateur_finance_dt_devis', {entite: entite.id}) }}",
        type:"GET",
        data: dtFilters
      },
      columnDefs:[
        { targets:[4,5,6,9], className:'text-end' },
        { targets:[4,5,6], render:(d)=> `<span class="money">${money(d)}</span>` },
        { targets:[3], render:(d)=> d ? badgePill(labelDevisStatus(d)) : '—' },
        { targets:[8], render:(d)=> d ? badgePill('PDF') : '—' },
        { targets:[9], orderable:false, searchable:false },
      ]
    }));
  }

  function initDtAvoirs(){
    if (dtAvo) return;
    dtAvo = $('#dtAvoirs').DataTable(Object.assign(dtCommonOptions(),{
      order:[[0,'desc']],
      ajax:{
        url: "{{ path('app_administrateur_finance_dt_avoirs', {entite: entite.id}) }}",
        type:"GET",
        data: dtFilters
      },
      columnDefs:[
        { targets:[3,4], className:'text-end' },
        { targets:[3], render:(d)=> `<span class="money">${money(d)}</span>` },
        { targets:[4], orderable:false, searchable:false },
      ]
    }));
  }

  function reloadAllDt(){
    dtDep?.ajax.reload(null,false);
    dtPay?.ajax.reload(null,false);
    dtFac?.ajax.reload(null,false);
    dtDev?.ajax.reload(null,false);
    dtAvo?.ajax.reload(null,false);
  }

  // ===========================
  // Refresh
  // ===========================
  async function refresh(){
    document.getElementById('btnRefresh').disabled = true;
    document.getElementById('btnApply').disabled = true;
    try{
      const data = await loadSummary();
      applyKpis(data.kpis, data.filters);
      applyCharts(data.charts);

      // si l'utilisateur est sur un onglet data, on reload la table active
      reloadAllDt();
    }catch(e){
      console.error(e);
      alert(e.message || 'Erreur');
    }finally{
      document.getElementById('btnRefresh').disabled = false;
      document.getElementById('btnApply').disabled = false;
    }
  }

  // ===========================
  // Events
  // ===========================
  document.getElementById('btnApply').addEventListener('click', refresh);
  document.getElementById('btnRefresh').addEventListener('click', refresh);

  document.getElementById('btnReset').addEventListener('click', () => {
    document.getElementById('fDevise')?.tomselect?.clear(true);
    document.getElementById('fTvaOnly')?.tomselect?.setValue('all', true);
    document.getElementById('fFactureStatus')?.tomselect?.clear(true);
    document.getElementById('fDevisStatus')?.tomselect?.clear(true);
    document.getElementById('fPayMode')?.tomselect?.clear(true);



    // ✅ reset période : on remet start/end à celles du contrôleur (Twig)
    document.getElementById('fStart').value = "{{ start }}";
    document.getElementById('fEnd').value   = "{{ end }}";

    const yReset = getYearFromIso("{{ start }}");
    if ($year && yReset) $year.value = String(yReset);


    const d1 = dateFromIso("{{ start }}");
    const d2 = dateFromIso("{{ end }}");
    fpRange?.setDate([d1, d2], true);
    $range.value = `${formatFr(d1)} → ${formatFr(d2)}`; // ✅ force affichage

    // ✅ reset multi cat/four : tout coché
    setAll('.f-filter-cat', true);
    setAll('.f-filter-four', true);
    document.querySelectorAll('input[data-filter="fcat"], input[data-filter="ffour"]').forEach(i => i.value = '');
    updateSelectedCounts();




    refresh();
  });


  // Lazy init DataTables when tab is shown
  document.querySelectorAll('#financeTabs button[data-bs-toggle="pill"]').forEach(btn => {
    btn.addEventListener('shown.bs.tab', (e) => {
      const target = e.target.getAttribute('data-bs-target');
      if (target === '#tab-dep') initDtDepenses();
      if (target === '#tab-pay') initDtPaiements();
      if (target === '#tab-fac') initDtFactures();
      if (target === '#tab-dev') initDtDevis();
      if (target === '#tab-avo') initDtAvoirs();
    });
  });

  // Init (charts + KPIs)
  refresh();
})();
</script>
{% endblock %}
