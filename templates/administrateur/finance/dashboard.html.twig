<script>
  window.__ALL_FIN_CAT_IDS__  = {{ categories|map(c => c.id)|json_encode|raw }};
  window.__ALL_FIN_FOUR_IDS__ = {{ fournisseurs|map(f => f.id)|json_encode|raw }};
