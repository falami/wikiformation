<script>
(function(){
  /* =========================
     Helpers (robustes)
  ========================= */
  const fmtMoney = (cents) => (Number(cents||0)/100).toLocaleString('fr-FR', {style:'currency', currency:'EUR'});
  const safeText = (v, fallback='—') => (v === null || v === undefined || v === '') ? fallback : String(v);
  const escapeHtml = (s) => String(s ?? '').replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[m]));
  const nowLabel = () => {
    const d = new Date();
    return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
  };

  /* =========================
     DOM
  ========================= */
  const $formation     = document.getElementById('formationFilter');
  const $formateur     = document.getElementById('formateurFilter');
  const $sessionStatus = document.getElementById('sessionStatusFilter');
  const $insStatus     = document.getElementById('inscriptionStatusFilter');

  let tsFormation=null, tsFormateur=null, tsSessStatus=null, tsInsStatus=null;
  let fpRange=null;

  function buildParams(){
    const p = new URLSearchParams();
    p.set('formation', $formation?.value || 'all');
    p.set('formateur', $formateur?.value || 'all');
    p.set('sessionStatus', $sessionStatus?.value || 'all');
    p.set('inscriptionStatus', $insStatus?.value || 'all');
    p.set('from', (document.getElementById('dateFrom')?.value || '').trim());
    p.set('to', (document.getElementById('dateTo')?.value || '').trim());
    return p;
  }

  /* =========================
     TomSelect / Flatpickr
  ========================= */
  function initTomSelect(){
    const common = { create:false, maxItems:1, allowEmptyOption:true, plugins:['clear_button'] };

    tsFormation?.destroy(); tsFormateur?.destroy(); tsSessStatus?.destroy(); tsInsStatus?.destroy();

    if (document.querySelector('#formationFilter'))         tsFormation = new TomSelect('#formationFilter', {...common});
    if (document.querySelector('#formateurFilter'))         tsFormateur = new TomSelect('#formateurFilter', {...common});
    if (document.querySelector('#sessionStatusFilter'))     tsSessStatus = new TomSelect('#sessionStatusFilter', {...common});
    if (document.querySelector('#inscriptionStatusFilter')) tsInsStatus  = new TomSelect('#inscriptionStatusFilter', {...common});

    [tsFormation, tsFormateur, tsSessStatus, tsInsStatus].filter(Boolean).forEach(ts=>{
      ts.on('change', ()=> refreshAll());
    });
  }

  function initFlatpickr(){
    fpRange?.destroy?.();
    if (!document.querySelector('#dateRange')) return;

    fpRange = flatpickr("#dateRange", {
      locale: "fr",
      mode: "range",
      dateFormat: "d/m/Y",
      allowInput: true,
      disableMobile: true,
      onClose: function(selectedDates){
        const from = selectedDates[0] ? selectedDates[0].toISOString().slice(0,10) : '';
        const to   = selectedDates[1] ? selectedDates[1].toISOString().slice(0,10) : '';
        document.getElementById('dateFrom').value = from;
        document.getElementById('dateTo').value = to;
        refreshAll();
      }
    });
  }

  /* =========================
     Load META
  ========================= */
  async function loadMeta(){
    const url = "{{ path('app_administrateur_dashboard_meta', { entite: entite.id }) }}";
    const res = await fetch(url, {headers:{'Accept':'application/json'}});
    if(!res.ok) return;
    const json = await res.json().catch(()=>null);
    if (!json) return;

    if (tsFormation){
      tsFormation.clearOptions();
      tsFormation.addOption({value:'all', text:'Toutes'});
      (json.formations||[]).forEach(f=> tsFormation.addOption({value:String(f.id), text:f.label}));
      tsFormation.refreshOptions(false);
      tsFormation.setValue('all', true);
    }
    if (tsFormateur){
      tsFormateur.clearOptions();
      tsFormateur.addOption({value:'all', text:'Tous'});
      (json.formateurs||[]).forEach(f=> tsFormateur.addOption({value:String(f.id), text:f.label}));
      tsFormateur.refreshOptions(false);
      tsFormateur.setValue('all', true);
    }
  }

  /* =========================
     KPI
  ========================= */
  async function loadKpis(){
    const url = "{{ path('app_administrateur_dashboard_kpis', { entite: entite.id }) }}?" + buildParams().toString();
    const res = await fetch(url, {headers:{'Accept':'application/json'}});
    if(!res.ok) return;
    const k = await res.json().catch(()=>null);
    if (!k) return;

    const setTxt = (id, v) => { const el=document.getElementById(id); if(el) el.textContent = safeText(v); };

    setTxt('kpi-sessions', k.sessions);
    setTxt('kpi-inscriptions', k.inscriptions);
    setTxt('kpi-reussite', (k.tauxReussite ?? 0) + '%');
    setTxt('kpi-reussis', k.reussis);

    document.getElementById('kpi-facture')?.replaceChildren(document.createTextNode(fmtMoney(k.caFactureCents)));
    document.getElementById('kpi-encaisse')?.replaceChildren(document.createTextNode(fmtMoney(k.encaisseCents)));
    document.getElementById('kpi-reste')?.replaceChildren(document.createTextNode(fmtMoney(k.resteCents)));

    setTxt('kpi-factures-due', fmtMoney(k.facturesDueCents));
    setTxt('kpi-factures-due-count', k.facturesEnAttente);

    setTxt('kpi-docs-missing', k.dossiersSansDossier);
    setTxt('kpi-em-missing', k.unsignedEmargements);

    setTxt('kpi-upcoming', k.sessionsAVenir);
    setTxt('kpi-past', k.sessionsPassees);

    const kpiDays = document.getElementById('kpi-days');
    if (kpiDays) kpiDays.textContent = (k.jours ?? '—') + ' j';
    setTxt('kpi-halfdays', k.demiJournees);

    setTxt('kpi-devis', k.devis);
    setTxt('kpi-attestations', k.attestations);

    document.getElementById('hero-last-refresh')?.replaceChildren(document.createTextNode('Maj : ' + nowLabel()));
  }

  /* =========================
     Charts
  ========================= */
  let chartInscriptions=null, chartCash=null, chartSessionsFormation=null;

  function baseChartOptions(){
    return { responsive:true, maintainAspectRatio:false, plugins:{ legend:{ position:'bottom' } } };
  }

  async function loadCharts(){
    const url = "{{ path('app_administrateur_dashboard_charts', { entite: entite.id }) }}?" + buildParams().toString();
    const res = await fetch(url, {headers:{'Accept':'application/json'}});
    if(!res.ok) return;
    const d = await res.json().catch(()=>null);
    if (!d) return;

    const elIns = document.getElementById('chartInscriptions');
    if (elIns){
      chartInscriptions?.destroy();
      chartInscriptions = new Chart(elIns, {
        type:'doughnut',
        data:{ labels: d.inscriptionsByStatus?.labels || [], datasets:[{ data: d.inscriptionsByStatus?.data || [] }]},
        options: baseChartOptions()
      });
    }

    const elCash = document.getElementById('chartCash');
    if (elCash){
      chartCash?.destroy();
      chartCash = new Chart(elCash, {
        type:'line',
        data:{
          labels: d.cashByMonth?.labels || [],
          datasets:[{ label:'€ encaissés', data: d.cashByMonth?.data || [], tension: 0.25 }]
        },
        options:{
          ...baseChartOptions(),
          scales:{ y:{ ticks:{ callback:(v)=> (Number(v)).toLocaleString('fr-FR') + ' €' } } }
        }
      });
    }

    const elSF = document.getElementById('chartSessionsFormation');
    if (elSF){
      chartSessionsFormation?.destroy();
      chartSessionsFormation = new Chart(elSF, {
        type:'bar',
        data:{ labels: d.sessionsByFormation?.labels || [], datasets:[{ label:'Sessions', data: d.sessionsByFormation?.data || [] }]},
        options:{ ...baseChartOptions(), scales:{ y:{ beginAtZero:true, ticks:{ precision:0 } } } }
      });
    }
  }

  /* =========================
     Plain tables search (Top 20)
  ========================= */
  function bindPlainSearch(){
    document.querySelectorAll('[data-plain-search]').forEach(input=>{
      const sel = input.getAttribute('data-plain-search');
      const table = sel ? document.querySelector(sel) : null;
      if (!table) return;

      input.addEventListener('input', ()=>{
        const q = (input.value || '').toLowerCase();
        const rows = table.querySelectorAll('tbody tr');
        rows.forEach(tr=>{
          const txt = (tr.innerText || '').toLowerCase();
          tr.style.display = txt.includes(q) ? '' : 'none';
        });
      });
    });
  }

  /* =========================
     DataTables tools (premium wrapper)
  ========================= */
  function bindTableProTools(){
    // Search
    document.querySelectorAll('[data-dt-search]').forEach(input=>{
      const sel = input.getAttribute('data-dt-search');
      const table = sel ? document.querySelector(sel) : null;
      if (!table) return;

      input.addEventListener('input', ()=>{
        const dt = DataTable.getInstance(table);
        if (!dt) return;
        dt.search(input.value).draw();
      });
    });

    // Length
    document.querySelectorAll('[data-dt-length]').forEach(btn=>{
      btn.addEventListener('click', ()=>{
        const len = Number(btn.getAttribute('data-dt-length')||10);
        const sel = btn.getAttribute('data-dt') || '';
        const table = sel ? document.querySelector(sel) : null;
        if (!table) return;

        const dt = DataTable.getInstance(table);
        if (!dt) return;
        dt.page.len(len).draw();
      });
    });

    // Info
    document.querySelectorAll('[data-dt-info]').forEach(el=>{
      const sel = el.getAttribute('data-dt-info');
      const table = sel ? document.querySelector(sel) : null;
      if (!table) return;

      const dt = DataTable.getInstance(table);
      if (!dt) return;

      const refresh = ()=>{
        const info = dt.page.info();
        el.textContent = `Affichage ${info.start + 1} → ${info.end} sur ${info.recordsDisplay} (total ${info.recordsTotal})`;
        const countEl = document.getElementById('dtAvenirCount');
        if (countEl) countEl.textContent = `${info.recordsDisplay} résultats`;
      };

      table.addEventListener('draw.dt', refresh);
      refresh();
    });

    // Pager injection
    document.querySelectorAll('[data-dt-pager]').forEach(el=>{
      const sel = el.getAttribute('data-dt-pager');
      const table = sel ? document.querySelector(sel) : null;
      if (!table) return;

      const wrapper = table.closest('.dataTables_wrapper');
      if (!wrapper) return;

      const paginate = wrapper.querySelector('.dataTables_paginate');
      if (paginate){
        el.innerHTML = '';
        el.appendChild(paginate);
      }
    });
  }

  /* =========================
     TODO lists + Top tables
  ========================= */
  async function loadTodo(){
    const url = "{{ path('app_administrateur_dashboard_todo', { entite: entite.id }) }}?" + buildParams().toString();
    const res = await fetch(url, {headers:{'Accept':'application/json'}});
    if(!res.ok) return;
    const t = await res.json().catch(()=>null);
    if (!t) return;

    const docs = t.docsMissing || [];
    const em   = t.unsignedEmargements || [];

    // counts top tables
    document.getElementById('tblDocsMissingCount')?.replaceChildren(document.createTextNode(`${docs.length} lignes`));
    document.getElementById('tblUnsignedCount')?.replaceChildren(document.createTextNode(`${em.length} lignes`));
    document.getElementById('tblDocsMissingInfo')?.replaceChildren(document.createTextNode(`${docs.length} résultat(s)`));
    document.getElementById('tblUnsignedInfo')?.replaceChildren(document.createTextNode(`${em.length} résultat(s)`));

    // docs list
    const docsCount = document.getElementById('docs-count');
    if (docsCount) docsCount.textContent = docs.length ? (docs.length + ' alertes') : 'Aucune alerte';

    const docsList = document.getElementById('docs-list');
    if (docsList){
      docsList.innerHTML = docs.length ? '' : '<div class="text-muted small">Rien à signaler ✅</div>';
      docs.forEach(x=>{
        const li = document.createElement('li');
        li.className = 'mini-item';
        li.innerHTML = `
          <span class="badge-pro badge-pro--warn"><i class="bi bi-exclamation-triangle"></i>${escapeHtml(x.missingCount ?? 0)}</span>
          <div class="flex-grow-1">
            <div class="fw-semibold">${escapeHtml(x.userLabel ?? '—')}</div>
            <div class="text-muted small">Session: <span class="mono">${escapeHtml(x.sessionLabel ?? '—')}</span></div>

            ${(x.missingLabels && x.missingLabels.length) ? `
              <div class="small mt-2">
                ${x.missingLabels.map(l=>`
                  <span class="badge-pro badge-pro--danger me-1 mb-1"><i class="bi bi-x-circle"></i>${escapeHtml(l)}</span>
                `).join('')}
              </div>
            ` : ''}

            ${(x.pendingPieces && x.pendingPieces.length) ? `
              <div class="small mt-2">
                ${x.pendingPieces.map(p=>`
                  <button type="button"
                          class="btn btn-sm btn-outline-warning me-1 mb-1 js-open-piece"
                          data-piece-id="${escapeHtml(p.pieceId)}"
                          style="border-radius:999px">
                    <i class="bi bi-hourglass-split me-1"></i>${escapeHtml(p.label)}
                    ${p.uploadedAt ? `<span class="opacity-75 ms-1">(${escapeHtml(p.uploadedAt)})</span>` : ''}
                    <i class="bi bi-chevron-right ms-1"></i>
                  </button>
                `).join('')}
              </div>
            ` : ''}

          </div>
        `;
        docsList.appendChild(li);
      });
    }

    // emargements accordion
    const emCount = document.getElementById('em-unsigned-count');
    if (emCount) emCount.textContent = em.length ? (em.length + ' signatures manquantes') : 'Aucune';

    const emList = document.getElementById('em-unsigned-list');
    if (emList){
      if (!em.length){
        emList.innerHTML = '<div class="text-muted small">Rien à signer ✅</div>';
      } else {
        const groups = new Map();
        for (const x of em){
          const key = String(x.sessionId ?? x.sessionLabel ?? 'unknown');
          if (!groups.has(key)){
            groups.set(key, { sessionId: x.sessionId ?? null, sessionLabel: x.sessionLabel ?? '—', items: [] });
          }
          groups.get(key).items.push(x);
        }

        const sortedGroups = Array.from(groups.values()).sort((a,b)=> (b.items.length - a.items.length));

        const accId = 'emAcc';
        emList.innerHTML = `
          <div class="accordion em-acc" id="${accId}">
            ${sortedGroups.map((g, idx)=>{
              const items = (g.items||[]).slice().sort((a,b)=>{
                const da = a.date || ''; const db = b.date || '';
                if (da !== db) return da.localeCompare(db);
                const pa = (a.periode||''); const pb = (b.periode||'');
                return pa.localeCompare(pb);
              });

              const headId = `emHead${idx}`;
              const bodyId = `emBody${idx}`;
              const previewMax = 4;
              const preview = items.slice(0, previewMax);
              const rest = items.slice(previewMax);
              const badgeDanger = items.filter(i=>i.type==='unsigned').length;
              const badgeWarn   = items.filter(i=>i.type==='missing').length;

              return `
                <div class="accordion-item mb-2">
                  <h2 class="accordion-header" id="${headId}">
                    <button class="accordion-button ${idx===0?'':'collapsed'}" type="button"
                            data-bs-toggle="collapse" data-bs-target="#${bodyId}"
                            aria-expanded="${idx===0?'true':'false'}" aria-controls="${bodyId}">
                      <div class="d-flex w-100 align-items-center gap-2">
                        <span class="mono">${escapeHtml(g.sessionLabel)}</span>
                        <div class="ms-auto em-badges d-flex gap-1">
                          ${badgeWarn ? `<span class="badge text-bg-warning">Manquants ${badgeWarn}</span>` : ``}
                          ${badgeDanger ? `<span class="badge text-bg-danger">Non signés ${badgeDanger}</span>` : ``}
                          <span class="badge text-bg-secondary">Total ${items.length}</span>
                        </div>
                      </div>
                    </button>
                  </h2>

                  <div id="${bodyId}" class="accordion-collapse collapse ${idx===0?'show':''}"
                      aria-labelledby="${headId}" data-bs-parent="#${accId}">
                    <div class="accordion-body">

                      ${preview.map(x=>{
                        const isMissing = (x.type === 'missing');
                        const badgeCls = isMissing ? 'text-bg-warning' : 'text-bg-danger';
                        const badgeTxt = x.badge ?? (isMissing ? 'Manquant' : 'Non signé');

                        return `
                          <div class="em-row bg-white border">
                            <span class="badge ${badgeCls}">${escapeHtml(badgeTxt)}</span>
                            <div class="flex-grow-1">
                              <div class="fw-semibold">${escapeHtml(x.userLabel ?? '—')}</div>
                              <div class="em-meta">${escapeHtml(x.date ?? '—')} • ${escapeHtml(x.periode ?? '—')}</div>
                            </div>
                          </div>
                        `;
                      }).join('')}

                      ${rest.length ? `
                        <div class="mt-2">
                          <button class="btn btn-sm btn-outline-secondary w-100 js-em-showmore"
                                  data-target="#emMore${idx}">
                            Voir +${rest.length} lignes
                          </button>
                          <div id="emMore${idx}" class="collapse mt-2">
                            ${rest.map(x=>{
                              const isMissing = (x.type === 'missing');
                              const badgeCls = isMissing ? 'text-bg-warning' : 'text-bg-danger';
                              const badgeTxt = x.badge ?? (isMissing ? 'Manquant' : 'Non signé');

                              return `
                                <div class="em-row bg-white border">
                                  <span class="badge ${badgeCls}">${escapeHtml(badgeTxt)}</span>
                                  <div class="flex-grow-1">
                                    <div class="fw-semibold">${escapeHtml(x.userLabel ?? '—')}</div>
                                    <div class="em-meta">${escapeHtml(x.date ?? '—')} • ${escapeHtml(x.periode ?? '—')}</div>
                                  </div>
                                </div>
                              `;
                            }).join('')}
                          </div>
                        </div>
                      ` : ''}

                    </div>
                  </div>
                </div>
              `;
            }).join('')}
          </div>
        `;

        emList.querySelectorAll('.js-em-showmore').forEach(btn=>{
          btn.addEventListener('click', ()=>{
            const target = btn.getAttribute('data-target');
            const el = emList.querySelector(target);
            if (!el) return;
            const c = bootstrap.Collapse.getOrCreateInstance(el, {toggle:false});
            const isShown = el.classList.contains('show');
            if (isShown) c.hide(); else c.show();
            btn.textContent = isShown ? 'Voir plus' : 'Masquer';
          });
        });
      }
    }

    // TOP tables fill
    const tbody1 = document.querySelector('#tblDocsMissing tbody');
    if (tbody1){
      tbody1.innerHTML = '';
      docs.forEach(r=>{
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td>${escapeHtml(r.sessionLabel ?? '—')}</td>
          <td>${escapeHtml(r.userLabel ?? '—')}</td>
          <td><span class="badge-pro badge-pro--warn">${escapeHtml(r.missingCount ?? 0)}</span></td>
        `;
        tbody1.appendChild(tr);
      });
    }

    const tbody2 = document.querySelector('#tblUnsigned tbody');
    if (tbody2){
      tbody2.innerHTML = '';
      em.forEach(r=>{
        const tr = document.createElement('tr');
        const isMissing = (r.type === 'missing');
        const badgeTxt = r.badge ?? (isMissing ? 'Manquant' : 'Non signé');
        const cls = isMissing ? 'badge-pro--warn' : 'badge-pro--danger';

        tr.innerHTML = `
          <td>${escapeHtml(r.sessionLabel ?? '—')}</td>
          <td>${escapeHtml(r.userLabel ?? '—')}</td>
          <td>${escapeHtml(r.date ?? '—')}</td>
          <td><span class="badge-pro ${cls}">${escapeHtml(badgeTxt)}</span> ${escapeHtml(r.periode ?? '—')}</td>
        `;
        tbody2.appendChild(tr);
      });
    }

    // bind search for top tables (once)
    bindPlainSearch();
  }

  /* =========================
     Modal Piece
  ========================= */
  let currentPieceId = null;
  const modalEl = document.getElementById('pieceModal');
  const pieceModal = modalEl ? new bootstrap.Modal(modalEl) : null;

  async function openPieceModal(pieceId){
    currentPieceId = pieceId;

    const infoUrl = "{{ path('app_administrateur_dashboard_piece_info', { entite: entite.id, id: 0 }) }}"
      .replace('/0/info', `/${pieceId}/info`);

    const res = await fetch(infoUrl, { headers:{'Accept':'application/json'} });
    const json = await res.json().catch(()=>null);

    if (!res.ok || !json?.ok) {
      alert(json?.error || "Impossible d’ouvrir la pièce.");
      return;
    }

    document.getElementById('pieceModalTitle').textContent = json.label || 'Pièce';
    document.getElementById('pieceModalMeta').textContent  = json.meta || '—';

    const fileUrl = json.fileUrl;
    const dlUrl   = json.downloadUrl || fileUrl;

    const $open = document.getElementById('pieceModalOpen');
    const $dl   = document.getElementById('pieceModalDownload');
    const $frm  = document.getElementById('pieceModalFrame');
    const $img  = document.getElementById('pieceModalImg');
    const $val  = document.getElementById('pieceModalValidate');

    if ($open) $open.href = fileUrl;
    if ($dl)   $dl.href = dlUrl;

    // reset
    if ($img) { $img.style.display = 'none'; $img.removeAttribute('src'); }
    if ($frm) { $frm.style.display = 'none'; $frm.src = 'about:blank'; }

    if (json.isImage) {
      $img.src = fileUrl;
      $img.style.display = 'block';
    } else {
      $frm.src = fileUrl;
      $frm.style.display = 'block';
    }

    if ($val) $val.disabled = !!json.isValide;
    pieceModal?.show();
  }

  // listener global unique
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('.js-open-piece');
    if (!btn) return;
    const pieceId = btn.dataset.pieceId;
    if (!pieceId) return;
    openPieceModal(pieceId);
  });

  // validation depuis le modal
  document.getElementById('pieceModalValidate')?.addEventListener('click', async () => {
    if (!currentPieceId) return;

    const btn = document.getElementById('pieceModalValidate');
    btn.disabled = true;

    try {
      const url = "{{ path('app_administrateur_dashboard_piece_validate', { entite: entite.id, id: 0 }) }}"
        .replace('/0/validate', `/${currentPieceId}/validate`);

      const res = await fetch(url, {
        method: 'POST',
        headers: {
          'Accept': 'application/json',
          'X-CSRF-TOKEN': window.CSRF_VALIDATE_PIECE || ''
        }
      });

      const json = await res.json().catch(()=>null);
      if (!res.ok || !json?.ok) {
        alert(json?.error || "Impossible de valider la pièce.");
        btn.disabled = false;
        return;
      }

      pieceModal?.hide();
      await refreshAll();
    } catch (err) {
      btn.disabled = false;
      alert("Erreur réseau.");
    }
  });

  // clean preview on close
  modalEl?.addEventListener('hidden.bs.modal', () => {
    currentPieceId = null;
    const $frm = document.getElementById('pieceModalFrame');
    const $img = document.getElementById('pieceModalImg');
    if ($frm) { $frm.src = 'about:blank'; $frm.style.display = 'none'; }
    if ($img) { $img.removeAttribute('src'); $img.style.display = 'none'; }
  });

  /* =========================
     DataTables
  ========================= */
  let dtAvenir = null;
  let dtReady = false;
  let toolsBound = false;

  function initDataTables(){
    if (dtReady) return;
    dtReady = true;

    const baseParams = () => Object.fromEntries(buildParams().entries());

    if (document.querySelector('#dtSessionsAvenir')) {
      dtAvenir = new DataTable('#dtSessionsAvenir', {
        ajax: {
          url: "{{ path('app_administrateur_dashboard_sessions_avenir', { entite: entite.id }) }}",
          data: baseParams,
          dataSrc: 'data'
        },
        columns: [
          { data: 'code' },
          { data: 'formation' },
          { data: 'dates' },
          { data: 'status' },
        ],
        pageLength: 10,
        order: [[2,'asc']],
        language: { url: "https://cdn.datatables.net/plug-ins/2.2.2/i18n/fr-FR.json" }
      });

      // bind tools after DT created (once)
      if (!toolsBound){
        toolsBound = true;
        bindTableProTools();
      }
    }
  }

  /* =========================
     Refresh global (robuste)
  ========================= */
  let isRefreshing = false;

  async function refreshAll(){
    if (isRefreshing) return;
    isRefreshing = true;

    try {
      await Promise.all([loadKpis(), loadCharts(), loadTodo()]);
      initDataTables();
      dtAvenir?.ajax?.reload?.();
    } finally {
      isRefreshing = false;
    }
  }

  /* =========================
     UI actions
  ========================= */
  document.getElementById('btnRefresh')?.addEventListener('click', refreshAll);

  document.getElementById('btnReset')?.addEventListener('click', ()=>{
    tsFormation?.setValue('all', true);
    tsFormateur?.setValue('all', true);
    tsSessStatus?.setValue('all', true);
    tsInsStatus?.setValue('all', true);

    fpRange?.clear();
    document.getElementById('dateRange')?.setAttribute('value','');
    const df = document.getElementById('dateFrom');
    const dt = document.getElementById('dateTo');
    if (df) df.value = '';
    if (dt) dt.value = '';
    refreshAll();
  });

  /* =========================
     INIT
  ========================= */
  initTomSelect();
  initFlatpickr();
  loadMeta().then(refreshAll);

})();
</script>


<script>
  (function(){
    function nowLabel(){
      const d = new Date();
      return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
    }
    const el = document.getElementById('hero-last-refresh');
    if(el) el.textContent = 'Maj : ' + nowLabel();
  })();
</script>
{% endblock %}
