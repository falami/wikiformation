{# templates/administrateur/dashboard/index.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}{{ title }}{% endblock %}

{% block stylesheets %}
  {{ parent() }}

  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css">
  <link rel="stylesheet" href="https://cdn.datatables.net/2.2.2/css/dataTables.dataTables.min.css">

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }

    /* ===== HERO ===== */
    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;

      /* Ombre douce premium */
      box-shadow: 0 18px 50px rgba(0,0,0,.14);

      /* Fond piloté par les couleurs de l'entité */
      background:
        /* halo clair (tertiaire) */
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        /* halo accent (secondaire) */
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        /* voile subtil (quaternaire) pour la profondeur */
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        /* dégradé principal (principal -> plus clair) */
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    /* léger glass highlight */
    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    /* barre accent = secondaire (et glow basé sur secondaire) */
    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }
    /* ===== Chips HERO (comme facture) ===== */
    .hero .chip{
      display:inline-flex;
      align-items:center;
      gap:.5rem;
      padding:.32rem .7rem;
      border-radius: 999px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(255,255,255,.14);
      font-size:.82rem;
      color: rgba(255,255,255,.92);
      backdrop-filter: blur(6px);
      white-space: nowrap;
    }
    .hero .chip i{
      color: var(--theme-color-secondaire);
    }

    /* chip highlight (optionnel) */
    .hero .chip--pill{
      background: color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
      border-color: color-mix(in srgb, var(--theme-color-secondaire) 28%, rgba(255,255,255,.14));
      color:#fff;
    }

    .hero .btn{
      border-radius: 14px;
      font-weight: 800;
    }
    .hero .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .hero .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }

    

    /* ===== KPI ===== */
    .kpi-card{
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 10px 26px rgba(0,0,0,.06);
      border-radius:18px;
      background:#fff;
      overflow:hidden;
    }
    .kpi-ico{
      width:46px;height:46px;border-radius:16px;
      display:grid;place-items:center;
      background:rgba(0,0,0,.03);
      border:1px solid rgba(0,0,0,.06);
    }
    .kpi-label{ color:rgba(0,0,0,.55); font-size:.85rem }
    .kpi-value{ font-weight:900; font-size:1.55rem; letter-spacing:-.02em }
    .kpi-sub{ color:rgba(0,0,0,.50); font-size:.82rem }

    /* ===== PANELS ===== */
    .panel{
      background:#fff;
      border-radius:18px;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 12px 30px rgba(0,0,0,.06);
      overflow:hidden;
    }
    .panel .head{
      padding:.85rem 1rem;
      border-bottom:1px solid rgba(0,0,0,.06);
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:.75rem;
    }
    .panel .title{ font-weight:900; margin:0; }
    .panel .body{ padding:1rem; }

    /* ===== MINI LISTS ===== */
    .mini-list{
      list-style:none;
      padding:0;
      margin:0;
      display:flex;
      flex-direction:column;
      gap:.5rem;
    }
    .mini-item{
      padding:.65rem .75rem;
      border:1px solid rgba(0,0,0,.06);
      border-radius:14px;
      display:flex;
      gap:.75rem;
      align-items:flex-start;
      background:linear-gradient(180deg, rgba(0,0,0,.012), transparent);
    }
    .mini-item .badge{ border-radius:999px; }
    .mono{ font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace; }

    /* ===== FILTERBAR ===== */
    .filterbar{
      background:#fff;
      border-radius:18px;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 10px 24px rgba(0,0,0,.05);
      overflow-y:visible;
    }
    .filterbar__top{
      padding:.9rem 1rem;
      border-bottom:1px solid rgba(0,0,0,.06);
      background: linear-gradient(180deg, rgba(0,0,0,.015), transparent);
      display:flex;align-items:center;gap:.75rem;
    }
    .filterbar__title{ font-weight:900; margin:0; font-size:1rem }
    .filterbar__hint{ color:rgba(0,0,0,.55); font-size:.85rem }
    .filterbar__body{ padding:1rem; }
    .filtergrid{
      display:grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap:.75rem;
      align-items:end;
    }
    .fcol-formation{ grid-column: span 3; }
    .fcol-formateur{ grid-column: span 3; }
    .fcol-sessionstatus{ grid-column: span 2; }
    .fcol-insstatus{ grid-column: span 2; }
    .fcol-period{ grid-column: span 2; }
    @media (max-width: 1200px){
      .fcol-formation{ grid-column: span 6; }
      .fcol-formateur{ grid-column: span 6; }
      .fcol-sessionstatus{ grid-column: span 6; }
      .fcol-insstatus{ grid-column: span 6; }
      .fcol-period{ grid-column: span 12; }
    }
    .filter-control .form-label{
      font-size:.78rem;font-weight:800;color:rgba(0,0,0,.55);
      text-transform:uppercase;letter-spacing:.06em;margin-bottom:.25rem;
    }
    .filterbox{
      border:1px solid rgba(0,0,0,.08);
      border-radius:14px;
      padding:.55rem .6rem;
      background:#fff;
      box-shadow:0 8px 18px rgba(0,0,0,.04);
    }
    .filterbox:focus-within{
      border-color: rgba(255,193,7,.55);
      box-shadow: 0 0 0 .2rem rgba(255,193,7,.18), 0 10px 18px rgba(0,0,0,.06);
    }
    .filterbox .form-select,.filterbox .form-control{
      border:0!important;
      box-shadow:none!important;
      padding-left:0!important;
      padding-right:0!important;
      background:transparent!important;
    }
    .filterrow{ display:flex; gap:.6rem; align-items:center; }
    .filter-icon{
      width:34px;height:34px;border-radius:12px;
      display:grid;place-items:center;
      background:rgba(0,0,0,.04);
      border:1px solid rgba(0,0,0,.06);
      color:rgba(0,0,0,.55);
      flex:0 0 auto;
    }

    /* ===== TABLE PRO (premium for all tables) ===== */
    .table-pro{
      background:#fff;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 14px 36px rgba(0,0,0,.06);
      border-radius:18px;
      overflow:hidden;
    }
    .table-pro__head{
      padding:.85rem 1rem;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:.75rem;
      border-bottom:1px solid rgba(0,0,0,.06);
      background:
        radial-gradient(900px 220px at 20% 0%, rgba(255,193,7,.10), transparent 60%),
        linear-gradient(180deg, rgba(0,0,0,.015), transparent);
    }
    .table-pro__title{
      font-weight:900;
      display:flex;
      align-items:center;
      gap:.5rem;
      flex-wrap:wrap;
      margin:0;
    }
    .table-pro__count{
      font-weight:900;
      font-size:.78rem;
      padding:.2rem .55rem;
      border-radius:999px;
      border:1px solid rgba(0,0,0,.08);
      background:rgba(0,0,0,.03);
      color:rgba(0,0,0,.65);
    }
    .table-pro__tools{ display:flex; gap:.5rem; align-items:center; }
    .table-pro__search{ position:relative; min-width:240px; }
    .table-pro__search i{
      position:absolute; top:50%; left:.6rem; transform:translateY(-50%);
      color:rgba(0,0,0,.45);
    }
    .table-pro__search input{
      padding-left:2rem;
      border-radius:999px;
      border:1px solid rgba(0,0,0,.10);
      box-shadow:0 10px 18px rgba(0,0,0,.04);
    }
    .table-pro__search input:focus{
      border-color:rgba(255,193,7,.55);
      box-shadow:0 0 0 .2rem rgba(255,193,7,.18), 0 12px 22px rgba(0,0,0,.05);
    }
    .table-pro__body{ padding:0; }
    .table-pro__table{ margin:0; border-collapse:separate; border-spacing:0; }
    .table-pro__table thead th{
      position:sticky; top:0; z-index:2;
      font-size:.78rem;
      text-transform:uppercase;
      letter-spacing:.06em;
      font-weight:900;
      color:rgba(0,0,0,.58);
      background:rgba(0,0,0,.02);
      border-bottom:1px solid rgba(0,0,0,.06);
      padding:.75rem .75rem;
      white-space:nowrap;
    }
    .table-pro__table tbody td{
      padding:.72rem .75rem;
      border-top:1px solid rgba(0,0,0,.04);
      vertical-align:middle;
    }
    .table-pro__table tbody tr{ transition:background .12s ease; }
    .table-pro__table tbody tr:hover{ background:rgba(255,193,7,.06); }
    .table-pro__foot{
      padding:.65rem 1rem;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:.75rem;
      border-top:1px solid rgba(0,0,0,.06);
      background:linear-gradient(180deg, transparent, rgba(0,0,0,.015));
    }
    @media (max-width: 768px){
      .table-pro__head{ flex-direction:column; align-items:stretch; }
      .table-pro__search{ min-width:100%; }
    }

    /* badges premium */
    .badge-pro{
      border-radius:999px;
      padding:.25rem .55rem;
      font-weight:900;
      font-size:.76rem;
      border:1px solid rgba(0,0,0,.08);
      background:rgba(0,0,0,.03);
      display:inline-flex;
      align-items:center;
      gap:.35rem;
    }
    .badge-pro--danger{ background:rgba(220,53,69,.10); border-color:rgba(220,53,69,.20); color:#b02a37; }
    .badge-pro--warn{ background:rgba(255,193,7,.14); border-color:rgba(255,193,7,.25); color:#7a5b00; }
    .badge-pro--ok{ background:rgba(25,135,84,.10); border-color:rgba(25,135,84,.20); color:#0f5132; }

    /* DataTables integration */
    .dataTables_wrapper .dataTables_filter,
    .dataTables_wrapper .dataTables_length{ display:none !important; }
    .dataTables_wrapper .dataTables_paginate{
      display:flex;
      gap:.35rem;
      align-items:center;
    }
    .dataTables_wrapper .dataTables_paginate .paginate_button{
      border:1px solid rgba(0,0,0,.10) !important;
      border-radius:999px !important;
      padding:.25rem .55rem !important;
      background:rgba(0,0,0,.02) !important;
      color:rgba(0,0,0,.70) !important;
      margin:0 !important;
    }
    .dataTables_wrapper .dataTables_paginate .paginate_button.current{
      background:rgba(255,193,7,.20) !important;
      border-color:rgba(255,193,7,.35) !important;
      font-weight:900 !important;
    }
    .dataTables_wrapper .dataTables_paginate .paginate_button:hover{
      background:rgba(0,0,0,.04) !important;
    }

    /* ===== CHARTS / TOMSELECT ===== */
    canvas{ max-height:320px; }
    .ts-dropdown{ z-index: 2000 !important; }

    /* ===== MODAL PIECE : aperçu plus petit ===== */
    #pieceModal .modal-dialog{ max-width: 980px; }
    #pieceModal .preview-wrap{
      height: 52vh; max-height: 520px; min-height: 260px;
    }
    @media (max-width: 768px){
      #pieceModal .modal-dialog{ max-width: 95vw; margin: .75rem auto; }
      #pieceModal .preview-wrap{ height: 42vh; max-height: 420px; min-height: 220px; }
    }

    /* accordion emargements */
    .em-acc .accordion-item { border-radius: 14px; overflow: hidden; border:1px solid rgba(0,0,0,.06); }
    .em-acc .accordion-button { padding:.65rem .85rem; font-weight:800; }
    .em-acc .accordion-body { padding:.65rem .85rem; background: rgba(0,0,0,.015); }
    .em-row { display:flex; gap:.6rem; align-items:flex-start; padding:.45rem .5rem; border-radius:12px; }
    .em-row + .em-row { margin-top:.35rem; }
    .em-meta { color: rgba(0,0,0,.55); font-size:.82rem; }
    .em-badges .badge { border-radius:999px; }
  </style>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/fr.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <script src="https://cdn.datatables.net/2.2.2/js/dataTables.min.js"></script>
{% endblock %}

{% block body %}





  {# ===== HERO (comme session) ===== #}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>

    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-speedometer2"></i> Tableau de bord
          </h2>

          <div class="opacity-75 mt-1">
            Tout ce qui manque : documents, émargements, finances, sessions à venir.
          </div>

          <div class="d-flex flex-wrap gap-2 mt-3">
            <span class="chip"><i class="bi bi-speedometer2"></i> Tableau de bord</span>
            <span class="chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
            <span class="chip chip--pill"><i class="bi bi-clock-history"></i> <span id="hero-last-refresh">—</span></span>
          </div>
        </div>

        <div class="d-flex gap-2 flex-wrap">

          <button class="btn btn-light btn-sm fw-semibold" id="btnRefresh">
            <i class="bi bi-arrow-repeat"></i> Actualiser
          </button>
        </div>
      </div>
    </div>
  </div>

  {# Filterbar #}
  <div class="filterbar mb-3">
    <div class="filterbar__top">
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <div class="filter-icon"><i class="bi bi-funnel"></i></div>
        <div>
          <div class="filterbar__title">Filtres</div>
          <div class="filterbar__hint">Formation • Formateur • Statuts • Période</div>
        </div>
      </div>
      <div class="ms-auto d-flex gap-2 align-items-center">
        <button class="btn btn-outline-secondary btn-sm fw-semibold" id="btnReset">
          <i class="bi bi-arrow-counterclockwise"></i> Reset
        </button>
      </div>
    </div>

    <div class="filterbar__body">
      <div class="filtergrid">
        <div class="filter-control fcol-formation">
          <div class="form-label">Formation</div>
          <div class="filterbox">
            <div class="filterrow">
              <div class="filter-icon"><i class="bi bi-mortarboard"></i></div>
              <select id="formationFilter" class="form-select form-select-sm">
                <option value="all">Toutes</option>
              </select>
            </div>
          </div>
        </div>

        <div class="filter-control fcol-formateur">
          <div class="form-label">Formateur</div>
          <div class="filterbox">
            <div class="filterrow">
              <div class="filter-icon"><i class="bi bi-person-badge"></i></div>
              <select id="formateurFilter" class="form-select form-select-sm">
                <option value="all">Tous</option>
              </select>
            </div>
          </div>
        </div>

        <div class="filter-control fcol-sessionstatus">
          <div class="form-label">Statut session</div>
          <div class="filterbox">
            <div class="filterrow">
              <div class="filter-icon"><i class="bi bi-flag"></i></div>
              <select id="sessionStatusFilter" class="form-select form-select-sm">
                <option value="all">Tous</option>
                <option value="draft">Brouillon</option>
                <option value="published">Publié</option>
                <option value="full">Complet</option>
                <option value="canceled">Annulé</option>
                <option value="done">Terminée</option>
              </select>
            </div>
          </div>
        </div>

        <div class="filter-control fcol-insstatus">
          <div class="form-label">Statut inscription</div>
          <div class="filterbox">
            <div class="filterrow">
              <div class="filter-icon"><i class="bi bi-person-check"></i></div>
              <select id="inscriptionStatusFilter" class="form-select form-select-sm">
                <option value="all">Tous</option>
                <option value="preinscrit">Préinscrit</option>
                <option value="confirme">Confirmé</option>
                <option value="en_cours">En cours</option>
                <option value="termine">Terminé</option>
                <option value="annule">Annulé</option>
                <option value="absent">Absent</option>
              </select>
            </div>
          </div>
        </div>

        <div class="filter-control fcol-period">
          <div class="form-label">Période</div>
          <div class="filterbox">
            <div class="filterrow">
              <div class="filter-icon"><i class="bi bi-calendar-range"></i></div>
              <input type="text" id="dateRange" class="form-control form-control-sm" placeholder="Période" />
              <input type="hidden" id="dateFrom" />
              <input type="hidden" id="dateTo" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {# KPIs #}
  <div class="row g-3 mb-3">
    {% set cards = [
      ['Sessions', 'bi-collection', 'kpi-sessions', 'Selon filtres'],
      ['Inscriptions', 'bi-people', 'kpi-inscriptions', 'Stagiaires engagés'],
      ['Taux de réussite', 'bi-award', 'kpi-reussite', '<span id="kpi-reussis">—</span> réussites'],
      ['Encaissements', 'bi-currency-euro', 'kpi-encaisse', 'Facturé <span id="kpi-facture">—</span> • Reste <span id="kpi-reste">—</span>'],
      ['Factures dues', 'bi-receipt', 'kpi-factures-due', '<span class="mono" id="kpi-factures-due-count">—</span> factures'],
      ['Docs manquants', 'bi-folder-x', 'kpi-docs-missing', 'Dossiers incomplets'],
      ['Émargements manquants', 'bi-pen', 'kpi-em-missing', 'Signatures / lignes absentes'],
      ['Sessions à venir', 'bi-calendar-event', 'kpi-upcoming', 'Planification'],
      ['Sessions passées', 'bi-calendar-check', 'kpi-past', 'Historique'],
      ['Jours / demi-journées', 'bi-calendar-range', 'kpi-days', '<span id="kpi-halfdays">—</span> demi-journées'],
      ['Devis', 'bi-file-earmark-text', 'kpi-devis', 'Sur la période'],
      ['Attestations', 'bi-file-earmark-check', 'kpi-attestations', 'Délivrées'],
    ] %}
    {% for c in cards %}
      <div class="col-12 col-md-6 col-xl-3">
        <div class="kpi-card h-100">
          <div class="p-3 d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi {{ c[1] }} fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">{{ c[0] }}</div>
              <div class="kpi-value" id="{{ c[2] }}">—</div>
              <div class="kpi-sub">{{ c[3]|raw }}</div>
            </div>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>

  {# Alertes (listes) #}
  <div class="row g-3 mb-4 mt-1">
    <div class="col-12 col-xl-6">
      <div class="panel">
        <div class="head">
          <h6 class="title mb-0"><i class="bi bi-folder-x me-2"></i>Documents manquants (Top)</h6>
          <span class="text-muted small" id="docs-count">—</span>
        </div>
        <div class="body">
          <ul class="mini-list" id="docs-list"></ul>
        </div>
      </div>
    </div>

    <div class="col-12 col-xl-6">
      <div class="panel">
        <div class="head">
          <h6 class="title mb-0"><i class="bi bi-pen me-2"></i>Émargements non signés</h6>
          <span class="text-muted small" id="em-unsigned-count">—</span>
        </div>
        <div class="body">
          <div id="em-unsigned-list"></div>
        </div>
      </div>
    </div>
  </div>

  {# Tables TOP 20 – premium #}
  <div class="row g-3 mt-1">

    <div class="col-12 col-xl-6 mb-3">
      <div class="table-pro p-3">
        <div class="table-pro__head">
          <h6 class="table-pro__title mb-0">
            <i class="bi bi-folder-x me-1"></i> Dossiers incomplets (Top 20)
            <span class="table-pro__count" id="tblDocsMissingCount">—</span>
          </h6>
          <div class="table-pro__tools">
            <div class="table-pro__search">
              <i class="bi bi-search"></i>
              <input type="text" class="form-control form-control-sm" placeholder="Rechercher..." data-plain-search="#tblDocsMissing">
            </div>
          </div>
        </div>
