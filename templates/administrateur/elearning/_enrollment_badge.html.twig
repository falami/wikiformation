{# templates/administrateur/elearning/_enrollment_badge.html.twig #}
{% set s = (state ?? '')|lower %}
{% set cls =
  s == 'active' ? 'active' :
  s == 'upcoming' ? 'upcoming' :
  s == 'expired' ? 'expired' :
  s == 'suspended' ? 'suspended' :
  s == 'completed' ? 'completed' : 'expired'
%}

<span class="badge-state {{ cls }}">
  <span class="dot"></span>
  {{ label ?? '—' }}
</span>
