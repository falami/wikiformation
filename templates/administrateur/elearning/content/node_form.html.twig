{% extends 'base_admin.html.twig' %}

{% block title %}
  {{ modeEdition ? 'Modification' : 'Ajout' }} d’un chapitre — {{ course.titre }}
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
<link rel="stylesheet" href="{{ asset('dist/css/formulaire.css') }}">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css">

<style>
:root{
  --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
  --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
  --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
  --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};

  --p: var(--theme-color-principal);
  --s: var(--theme-color-secondaire);
  --t: var(--theme-color-tertiaire);
  --q: var(--theme-color-quaternaire);

  /* ✅ LIGHT PREMIUM TOKENS (lisible sur fond clair) */
  --bg: #f5f7fb;
  --panel: #ffffff;
  --stroke: rgba(15, 23, 42, .10);
  --stroke2: rgba(15, 23, 42, .14);
  --ink: #0f172a;
  --muted: #64748b;
  --muted2: rgba(100,116,139,.85);

  --shadow: 0 18px 50px rgba(15, 23, 42, .12);
  --shadow2: 0 22px 70px rgba(15, 23, 42, .16);

  --r: 18px;

  /* extras premium */
  --ok: rgba(34,197,94,.95);
  --warn: rgba(245,158,11,.95);
  --err: rgba(239,68,68,.95);

  --glass: rgba(15,23,42,.04);
  --glass2: rgba(15,23,42,.06);
}


/* ============ Header ============ */
.h-title{
  display:flex; align-items:flex-end; justify-content:space-between; gap:1rem;
  margin: 1.25rem 0 1rem;
}
.h-title h2{
  margin:0; color: var(--ink); font-weight: 900; letter-spacing: .2px;
}
.h-title small{ color: var(--muted2); font-weight: 650; }
.h-title .subtitle{ color: var(--muted); font-weight: 650; }

/* ============ Cards ============ */
.p-card{
  background: var(--panel);
  border: 1px solid var(--stroke);
  border-radius: var(--r);
  box-shadow: var(--shadow);
  overflow: hidden;
}
.p-card .p-head{
  padding: .9rem 1rem;
  display:flex; align-items:center; justify-content:space-between; gap:.75rem;
  background: linear-gradient(90deg, rgba(15,23,42,.04), rgba(15,23,42,.02));
  border-bottom: 1px solid var(--stroke);
}
.p-head .ttl{
  color: var(--ink);
  font-weight: 950;
  letter-spacing: .15px;
  display:flex; align-items:center; gap:.6rem;
}
.p-head .ttl i{ color: var(--s); }
.p-card .p-body{ padding: 1rem; }

/* ============ Badges ============ */
.badge-soft{
  display:inline-flex; align-items:center; gap:.4rem;
  background: rgba(15,23,42,.04);
  border: 1px solid rgba(15,23,42,.10);
  color: var(--ink);
  padding:.25rem .55rem;
  border-radius: 999px;
  font-size:.7rem;
  font-weight: 800;
}
.badge-soft.muted{ color: var(--muted); }

/* ============ Divider ============ */
.hr-soft{
  height:1px; background: rgba(15,23,42,.10); border:0; margin: .9rem 0;
}

/* ============ Form ============ */
.form-floating > .form-control,
.form-floating > .form-select{
  background: #fff !important;
  border: 1px solid rgba(15,23,42,.12) !important;
  color: var(--ink) !important;
  border-radius: 16px !important;
}
.form-control::placeholder{ color: rgba(15,23,42,.35) !important; }
.form-floating > label{ color: rgba(15,23,42,.60) !important; }
.form-text{ color: var(--muted) !important; }

.form-control:focus, .form-select:focus{
  box-shadow: 0 0 0 .22rem rgba(255,193,7,.20) !important;
  border-color: rgba(255,193,7,.55) !important;
}

.form-icon{ pointer-events:none; z-index:2; }
.with-icon{ padding-left: 2.45rem !important; }
.with-icon ~ label{ padding-left: 2.45rem !important; }

/* Invalid */
.is-invalid{
  border-color: rgba(239,68,68,.55) !important;
  box-shadow: 0 0 0 .22rem rgba(239,68,68,.12) !important;
}

/* ============ Buttons ============ */
.btn-premium{
  border-radius: 999px;
  padding: .6rem 1rem;
  font-weight: 900;
}

.btn-premium.btn-outline-light{
  border-color: rgba(15,23,42,.18) !important;
  color: var(--ink) !important;
  background: rgba(255,255,255,.88) !important;
}
.btn-premium.btn-outline-light:hover{
  background: rgba(15,23,42,.04) !important;
}

.btn-gradient{
  border: 0 !important;
  background: linear-gradient(90deg, var(--s), rgba(255,193,7,.65));
  color: #1b1b1b !important;
  font-weight: 950;
  border-radius: 999px;
  padding: .65rem 1.1rem;
  box-shadow: 0 14px 30px rgba(255,193,7,.18);
}
.btn-gradient:hover{ filter: brightness(1.03); }

/* ============ Tree ============ */
.tree{ list-style:none; padding:0; margin:0; }
.tree > li{ margin-bottom:.7rem; }

.node{
  border-radius: 16px;
  background: #fff;
  border: 1px solid rgba(15,23,42,.10);
  overflow:hidden;
}
.node-head{
  padding: .75rem .8rem;
  display:flex; align-items:center; justify-content:space-between; gap: .75rem;
}
.node-left{ display:flex; align-items:center; gap:.55rem; min-width: 0; }
.node-title{
  color: var(--ink);
  font-weight: 950;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.node-meta{ color: var(--muted); font-weight: 850; font-size: .85rem; }



.drag{
  cursor:grab;
  width: 32px; height: 32px;
  display:grid; place-items:center;
  border-radius: 10px;
  border: 1px solid rgba(15,23,42,.12);
  background: rgba(15,23,42,.03);
  color: rgba(15,23,42,.70);
}
.drag:active{ cursor:grabbing; }

.node-sub{ padding: 0 .8rem .8rem; }

.child-list{
  list-style:none;
  margin:.55rem 0 0 1.3rem;
  padding:0;
}

.child-list:empty{
  margin-left: 1.1rem;
  padding: .4rem .55rem;
  border-radius: 12px;
  border: 1px dashed rgba(15,23,42,.18);
  color: var(--muted);
  font-weight: 800;
  font-size: .85rem;
  background: rgba(15,23,42,.02);
}
.child-list:empty::before{ content:"Dépose un sous-chapitre ici"; }

/* ============ Blocks preview chips ============ */
.block-preview{
  display:flex; flex-wrap:wrap; gap:.4rem;
  margin-top:.55rem;
}
.block-chip{
  display:inline-flex; align-items:center; gap:.45rem;
  padding:.22rem .55rem;
  border-radius: 999px;
  border: 1px solid rgba(15,23,42,.12);
  background: rgba(15,23,42,.03);
  color: rgba(15,23,42,.85);
  font-weight: 900;
  font-size: .78rem;
}
.block-chip i{ color: var(--s); }

/* ============ Responsive ============ */
@media (max-width: 992px){
  .h-title{ flex-direction: column; align-items: flex-start; }
}
@media (max-width: 576px){
  .node-actions .btn span{ display:none; }
  .node-left{ gap:.45rem; }
  .drag{ width: 30px; height: 30px; }
}

/* =============================
   EXTRAS PREMIUM (SANS toucher au Twig body)
   ============================= */

/* sortable feedback */
.sortable-ghost{
  opacity: .85 !important;
  background: rgba(255,193,7,.08) !important;
  border: 1px dashed rgba(255,193,7,.35) !important;
  border-radius: 16px !important;
}
.sortable-chosen .node{
  box-shadow: 0 0 0 .22rem rgba(255,193,7,.14), var(--shadow);
}

/* current node highlight */
.node-item.is-current > .node{
  border-color: rgba(255,193,7,.55) !important;
  box-shadow: 0 0 0 .22rem rgba(255,193,7,.16), var(--shadow);
}
.node-item.is-current .node-title{
  text-shadow: 0 0 18px rgba(255,193,7,.18);
}

/* saving pill (injected via JS) */
.save-pill{
  display:inline-flex; align-items:center; gap:.45rem;
  border-radius: 999px;
  padding:.35rem .65rem;
  border: 1px solid rgba(15,23,42,.12);
  background: rgba(255,255,255,.92);
  color: var(--ink);
  font-weight: 950;
  font-size: .82rem;
  backdrop-filter: blur(8px);
}
.save-pill .dot{
  width: 9px; height: 9px; border-radius: 999px;
  background: rgba(15,23,42,.25);
}
.save-pill.is-saving .dot{ background: var(--warn); box-shadow: 0 0 0 6px rgba(245,158,11,.12); }
.save-pill.is-ok .dot{ background: var(--ok); box-shadow: 0 0 0 6px rgba(34,197,94,.12); }
.save-pill.is-error .dot{ background: var(--err); box-shadow: 0 0 0 6px rgba(239,68,68,.12); }

/* toast stack (injected via JS) */
.toast-stack{
  position: fixed;
  top: 18px;
  right: 18px;
  display:flex;
  flex-direction: column;
  gap: 10px;
  z-index: 9999;
}

.toastx{
  width: min(360px, calc(100vw - 36px));
  border-radius: 16px;
  border: 1px solid rgba(15,23,42,.12);
  background: #fff;
  box-shadow: 0 18px 55px rgba(15,23,42,.14);
  padding: 10px 12px;
  color: var(--ink);
}
.toastx .top{
  display:flex; align-items:center; justify-content:space-between; gap:.75rem;
  margin-bottom:.25rem;
}
.toastx .ttl{ font-weight: 950; letter-spacing:.15px; }
.toastx .msg{ color: var(--muted); font-weight: 650; }

.toastx .xbtn{
  border:0; background: transparent; color: rgba(15,23,42,.70);
  width: 30px; height: 30px; border-radius: 10px;
}
.toastx .xbtn:hover{ background: rgba(15,23,42,.06); }

.toastx.ok{ border-color: rgba(34,197,94,.25); }
.toastx.warn{ border-color: rgba(245,158,11,.25); }
.toastx.err{ border-color: rgba(239,68,68,.28); }

/* sticky action bar (mobile only, injected via JS) */
.sticky-actions{
  position: fixed;
  left: 12px; right: 12px; bottom: 12px;
  z-index: 9990;
  display:none;
  gap: 10px;
  padding: 10px;
  border-radius: 18px;
  border: 1px solid rgba(15,23,42,.12);
  background: rgba(255,255,255,.92);
  backdrop-filter: blur(12px);
  box-shadow: var(--shadow2);
}
.sticky-actions .btn{ flex: 1; }

@media (max-width: 768px){
  .sticky-actions{ display:flex; }
}


/* slug helper */
.slug-help{
  margin-top: .45rem;
  display:flex;
  flex-wrap: wrap;
  gap: .5rem;
  align-items: center;
}
.slug-help .hint{
  font-size: .86rem;
  color: var(--muted);
  font-weight: 650;
}
.slug-help code{
  padding: .15rem .45rem;
  border-radius: 999px;
  background: rgba(15,23,42,.04);
  border: 1px solid rgba(15,23,42,.10);
  color: var(--ink);
  font-weight: 900;
}
.slug-help .btn-mini{
  border: 1px solid rgba(15,23,42,.14);
  background: #fff;
  color: var(--ink);
  border-radius: 999px;
  padding: .25rem .55rem;
  font-weight: 900;
  font-size: .82rem;
}
.slug-help .btn-mini:hover{ background: rgba(15,23,42,.04); }
.slug-help .state{
  display:inline-flex;
  align-items:center;
  gap:.35rem;
  padding: .18rem .55rem;
  border-radius: 999px;
  border: 1px solid rgba(15,23,42,.12);
  background: rgba(255,255,255,.92);
  font-size:.82rem;
  font-weight: 900;
  color: var(--ink);
}
.slug-help .dot{
  width:8px;height:8px;border-radius:999px;
  background: rgba(100,116,139,.45);
}
.slug-help .state.auto .dot{ background: rgba(245,158,11,.9); }
.slug-help .state.manual .dot{ background: rgba(34,197,94,.9); }

.slug-flash{
  animation: slugFlash .55s ease;
}
@keyframes slugFlash{
  0%{ box-shadow: 0 0 0 .22rem rgba(255,193,7,.20); }
  100%{ box-shadow: none; }
}



.slug-help .avail{
  display:inline-flex;
  align-items:center;
  gap:.35rem;
  padding: .18rem .55rem;
  border-radius: 999px;
  border: 1px solid rgba(15,23,42,.12);
  background: rgba(255,255,255,.92);
  font-size:.82rem;
  font-weight: 900;
  color: var(--ink);
}
.slug-help .avail .dot{ width:8px;height:8px;border-radius:999px; background: rgba(100,116,139,.45); }
.slug-help .avail.ok{ border-color: rgba(34,197,94,.25); background: rgba(34,197,94,.08); }
.slug-help .avail.ok .dot{ background: var(--ok); }
.slug-help .avail.bad{ border-color: rgba(239,68,68,.25); background: rgba(239,68,68,.08); }
.slug-help .avail.bad .dot{ background: var(--err); }
.slug-help .avail.wait{ border-color: rgba(245,158,11,.25); background: rgba(245,158,11,.08); }
.slug-help .avail.wait .dot{ background: var(--warn); }





/* =========================
   STICKY HEADER (desktop)
   ========================= */
@media (min-width: 992px){
  .h-title{
    position: sticky;
    top: 10px;
    z-index: 20;
    padding: 10px 10px;
    border-radius: 18px;
    border: 1px solid rgba(15,23,42,.10);
    background: rgba(255,255,255,.80);
    backdrop-filter: blur(12px);
    box-shadow: 0 18px 50px rgba(15,23,42,.10);
    margin: 1rem 0 1.15rem;
  }
  .h-title h2{
    font-size: 1.55rem;
    line-height: 1.15;
  }
  .h-title .subtitle{
    display:flex;
    flex-wrap: wrap;
    gap:.45rem;
  }
}

/* =========================
   CARDS : glass + edges
   ========================= */
.p-card{
  background: rgba(255,255,255,.92);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(15,23,42,.10);
  box-shadow: 0 18px 55px rgba(15,23,42,.10);
}

.p-card .p-head{
  background:
    linear-gradient(90deg, rgba(15,23,42,.035), rgba(15,23,42,.015));
}

.p-head .ttl{
  font-size: .98rem;
}

.p-card:hover{
  box-shadow: 0 22px 70px rgba(15,23,42,.14);
  transform: translateY(-1px);
  transition: box-shadow .18s ease, transform .18s ease;
}

/* =========================
   GRID DESKTOP : hauteur égale + scroll zone droite
   ========================= */
@media (min-width: 992px){
  /* colonne gauche et droite alignées */
  .row.g-4{
    align-items: stretch;
  }

  /* colonne gauche: les 2 cards bien espacées */
  .col-lg-5{
    display:flex;
    flex-direction: column;
    gap: 16px;
  }
  .col-lg-5 .p-card.mb-4{ margin-bottom: 0 !important; }

  /* colonne droite: card structure prend la hauteur dispo */
  .col-lg-7{
    display:flex;
  }
  #tree-card{
    width: 100%;
  }

  /* Body de la structure scrollable => page plus compacte */
  #tree-card .p-body{
    max-height: calc(150vh - 240px);
    overflow: auto;
    padding-right: 12px;
    scrollbar-gutter: stable;
  }

  /* Scrollbar premium (webkit) */
  #tree-card .p-body::-webkit-scrollbar{ width: 10px; }
  #tree-card .p-body::-webkit-scrollbar-thumb{
    background: rgba(15,23,42,.12);
    border-radius: 999px;
    border: 2px solid rgba(255,255,255,.8);
  }
  #tree-card .p-body::-webkit-scrollbar-thumb:hover{
    background: rgba(15,23,42,.18);
  }
}

/* =========================
   BADGES : plus “design system”
   ========================= */
.badge-soft{
  background: rgba(15,23,42,.035);
  border-color: rgba(15,23,42,.12);
}
.badge-soft i{ opacity: .9; }

/* =========================
   FORM : focus plus premium
   ========================= */
.form-floating > .form-control,
.form-floating > .form-select{
  transition: box-shadow .15s ease, border-color .15s ease, transform .15s ease;
}
.form-floating:focus-within{
  transform: translateY(-1px);
}
.form-control:focus, .form-select:focus{
  box-shadow:
    0 0 0 .22rem rgba(255,193,7,.18),
    0 14px 30px rgba(15,23,42,.06) !important;
}

/* =========================
   BUTTONS : micro-interactions
   ========================= */
.btn-premium, .btn-gradient{
  transition: transform .12s ease, box-shadow .12s ease, filter .12s ease;
}
.btn-premium:hover{
  transform: translateY(-1px);
  box-shadow: 0 14px 26px rgba(15,23,42,.10);
}
.btn-gradient:hover{
  transform: translateY(-1px);
  box-shadow: 0 18px 34px rgba(255,193,7,.20);
}

/* =========================
   TREE : nodes plus "app"
   ========================= */
.node{
  background: rgba(255,255,255,.95);
  border-color: rgba(15,23,42,.10);
  transition: box-shadow .16s ease, transform .16s ease, border-color .16s ease;
}
.node:hover{
  transform: translateY(-1px);
  border-color: rgba(15,23,42,.16);
  box-shadow: 0 18px 44px rgba(15,23,42,.10);
}

.node-head{
  background: linear-gradient(180deg, rgba(15,23,42,.015), transparent);
}

/* Titre plus “premium” */
.node-title{
  letter-spacing: .1px;
}

/* handle drag plus visible */
.drag{
  background: rgba(15,23,42,.035);
  border-color: rgba(15,23,42,.14);
  transition: background .12s ease, transform .12s ease;
}
.node:hover .drag{
  background: rgba(255,193,7,.10);
  border-color: rgba(255,193,7,.22);
}
.drag:hover{ transform: scale(1.03); }


/* =========================
   CHILD LIST : indentation plus élégante
   ========================= */
.child-list{
  margin-left: 1.45rem;
  position: relative;
}
.child-list::before{
  content:"";
  position:absolute;
  left:-.75rem;
  top:.2rem;
  bottom:.2rem;
  width: 2px;
  border-radius: 999px;
  background: rgba(15,23,42,.06);
}

/* empty drop zone : mieux */
.child-list:empty{
  background: linear-gradient(180deg, rgba(255,193,7,.06), rgba(15,23,42,.015));
  border-color: rgba(255,193,7,.22);
}

/* =========================
   BLOCK CHIPS : plus clean
   ========================= */
.block-chip{
  background: rgba(15,23,42,.028);
  border-color: rgba(15,23,42,.11);
}
.block-chip:hover{
  background: rgba(255,193,7,.10);
  border-color: rgba(255,193,7,.22);
}



/* =========================================================
   FIX : TomSelect + form-floating (Type / Parent)
   FIX : icônes qui recouvrent le label (Titre / Slug)
   ========================================================= */

/* 1) Empêcher les overflow bizarres dans les wrappers */
.form-floating{
  overflow: visible; /* important pour TomSelect */
}

/* 2) Les labels doivent être au-dessus et lisibles */
.form-floating > label{
  z-index: 5 !important;
  pointer-events: none;
  /* petit fond pour éviter que le texte passe dessous */
  background: linear-gradient(180deg, rgba(255,255,255,.92), rgba(255,255,255,0));
  padding-right: .4rem;
}

/* 3) FIX ICONS : l’icône doit être derrière le texte */
.form-icon{
  z-index: 1 !important;      /* ⬅️ avant : 2, ça recouvrait tout */
  opacity: .55;
}

/* 4) Les inputs avec icône doivent être au-dessus */
.form-floating > .form-control,
.form-floating > .form-select{
  position: relative;
  z-index: 2;
}

/* 5) Ajuster padding-left pour que le texte ne touche jamais l’icône */
.with-icon{
  padding-left: 3.0rem !important; /* un poil plus large */
}
.with-icon ~ label{
  padding-left: 3.0rem !important;
}

/* =========================================================
   TOMSELECT : rendre compatible avec form-floating
   TomSelect remplace le <select> par .ts-wrapper + .ts-control
   ========================================================= */

/* le wrapper prend la place du select dans le floating */
.form-floating > .ts-wrapper{
  width: 100%;
}

/* donner à TomSelect exactement la "height" Bootstrap floating */
.form-floating > .ts-wrapper .ts-control{
  min-height: calc(3.5rem + 2px);  /* hauteur standard BS */
  border-radius: 16px !important;
  border: 1px solid rgba(15,23,42,.12) !important;
  background: #fff !important;
  box-shadow: none !important;

  /* padding TOP important: laisse la place au label flottant */
  padding-top: 1.35rem !important;
  padding-bottom: .55rem !important;
  padding-left: .95rem !important;
  padding-right: .95rem !important;

  display: flex;
  align-items: center;
}

/* la valeur sélectionnée doit couper proprement */
.form-floating > .ts-wrapper .ts-control .item,
.form-floating > .ts-wrapper .ts-control .ts-input{
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* focus : même glow que tes inputs */
.form-floating > .ts-wrapper.focus .ts-control,
.form-floating > .ts-wrapper .ts-control:focus-within{
  border-color: rgba(255,193,7,.55) !important;
  box-shadow: 0 0 0 .22rem rgba(255,193,7,.18) !important;
}

/* dropdown TomSelect : premium + cohérent */
.ts-dropdown{
  border-radius: 14px !important;
  border: 1px solid rgba(15,23,42,.12) !important;
  box-shadow: 0 18px 55px rgba(15,23,42,.14) !important;
  overflow: hidden;
}
.ts-dropdown .option{
  padding: .65rem .8rem !important;
}
.ts-dropdown .option.active{
  background: rgba(255,193,7,.14) !important;
}

/* =========================================================
   BONUS : empêche le "label" de paraître décalé sur select
   (uniquement quand TomSelect est présent)
   ========================================================= */
.form-floating > .ts-wrapper ~ label{
  transform-origin: 0 0;
}



/* =========================================================
   FIX 1 : stop blur (transform) sur les form-floating
   ========================================================= */
.form-floating:focus-within{
  transform: none !important; /* supprime l'effet qui "floute" sur mobile */
}

/* =========================================================
   FIX 2 : icônes inputs (Titre/Slug) qui doivent rester derrière
   ========================================================= */
.form-floating.position-relative{ overflow: visible; }
.form-icon{ z-index: 0 !important; opacity: .55; }
.form-floating > .form-control{ position: relative; z-index: 1; }

/* =========================================================
   FIX 3 : TomSelect ne doit PAS être en form-floating
   On va ajouter une classe .ts-off via JS (voir plus bas)
   ========================================================= */
.form-floating.ts-off{
  /* on transforme visuellement en "label au dessus" */
