  <script>
  /* =========================
     DRAG & DROP + SAVE
     ========================= */
  (function(){
    const treeCard   = document.getElementById('tree-card');
    const reorderUrl = treeCard?.dataset?.reorderUrl || '';
    if (!reorderUrl || typeof Sortable === 'undefined') return;

    function closestNodeIdFromUl(ul){
      if (!ul || ul.id === 'tree-root') return null;
      const li = ul.closest('li.node-item');
      return li ? (li.dataset.nodeId || null) : null;
    }

    function serializeAll(){
      const items = [];
      const root = document.getElementById('tree-root');
      if (root){
        [...root.children].forEach((li, idx)=>{
          const id = li?.dataset?.nodeId;
          if (!id) return;
          items.push({ id: parseInt(id,10), position: idx, parentId: null });
        });
      }

      document.querySelectorAll('.child-list').forEach(ul=>{
        const parentId = closestNodeIdFromUl(ul);
        [...ul.children].forEach((li, idx)=>{
          const id = li?.dataset?.nodeId;
          if (!id) return;
          items.push({ id: parseInt(id,10), position: idx, parentId: parentId ? parseInt(parentId,10) : null });
        });
      });

      return items;
    }

    let saveTimer = null;
    let lastHash = '';

    function hashPayload(p){
      try{ return JSON.stringify(p); }catch(e){ return String(Date.now()); }
    }

    async function postReorderAll(){
      const payload = serializeAll();
      const h = hashPayload(payload);
      if (h === lastHash) return;
      lastHash = h;

      window.setSaveState?.('is-saving','Sauvegarde…');

      try{
        const res = await fetch(reorderUrl, {
          method:'POST',
          headers:{ 'Content-Type':'application/json', 'X-Requested-With':'XMLHttpRequest' },
          body: JSON.stringify(payload)
        });
        if (!res.ok) throw new Error('HTTP '+res.status);

        window.setSaveState?.('is-ok','OK');
        window.showToastX?.('ok', 'Structure', 'Ordre enregistré.');
      }catch(e){
        console.error('Reorder error:', e);
        window.setSaveState?.('is-error','Erreur');
        window.showToastX?.('err', 'Structure', "Impossible d’enregistrer le nouvel ordre.");
      }
    }

    function scheduleSave(){
      if (saveTimer) clearTimeout(saveTimer);
      saveTimer = setTimeout(postReorderAll, 280);
    }

    document.querySelectorAll('#tree-root, .child-list').forEach(ul=>{
      new Sortable(ul, {
        group: 'nodes',
        animation: 170,
        handle: '.drag',
        fallbackOnBody: true,
        swapThreshold: .65,
        ghostClass: 'sortable-ghost',
        onEnd: scheduleSave
      });
    });
  })();
  </script>

  <script>
  /* =========================
     DELETE NODE (AJAX)
     ========================= */
  document.addEventListener('click', async (e)=>{
    const btn = e.target.closest('.btn-node-delete[data-del-url]');
    if (!btn) return;

    e.preventDefault();
    if (!confirm('Supprimer ce nœud ?')) return;

    window.setSaveState?.('is-saving','Suppression…');

    try{
      const res = await fetch(btn.dataset.delUrl, {
        method: 'POST',
        headers: { 'Content-Type':'application/x-www-form-urlencoded', 'X-Requested-With':'XMLHttpRequest' },
        body: new URLSearchParams({_token: btn.dataset.csrf || ''})
      });

      if(!res.ok) throw new Error('HTTP '+res.status);

      btn.closest('li.node-item')?.remove();
      window.setSaveState?.('is-ok','OK');
      window.showToastX?.('ok', 'Suppression', 'Nœud supprimé.');
    }catch(err){
      console.error(err);
      window.setSaveState?.('is-error','Erreur');
      window.showToastX?.('err', 'Suppression', 'Erreur lors de la suppression.');
    }
  });
  </script>
{% endblock %}
