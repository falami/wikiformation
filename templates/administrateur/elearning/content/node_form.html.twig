  <script>
  /* =========================================================
     UI INJECTION (toasts + saving pill + sticky actions)
     ========================================================= */
  (function(){
    let stack = document.querySelector('.toast-stack');
    if(!stack){
      stack = document.createElement('div');
      stack.className = 'toast-stack';
      document.body.appendChild(stack);
    }

    window.showToastX = function(type, title, message, timeout=3800){
      const el = document.createElement('div');
      el.className = 'toastx ' + (type || 'ok');
      el.innerHTML = `
        <div class="top">
          <div class="ttl">${title || 'Info'}</div>
          <button class="xbtn" type="button" aria-label="Fermer">✕</button>
        </div>
        <div class="msg">${message || ''}</div>
      `;
      el.querySelector('.xbtn')?.addEventListener('click', ()=> el.remove());
      stack.appendChild(el);
      if(timeout) setTimeout(()=> el.remove(), timeout);
    };

    const header = document.querySelector('.h-title > .d-flex.gap-2');
    if(header && !document.querySelector('.save-pill')){
      const pill = document.createElement('span');
      pill.className = 'save-pill is-ok';
      pill.innerHTML = `<span class="dot"></span><span class="txt">Prêt</span>`;
      header.prepend(pill);
    }

    window.setSaveState = function(state, text){
      const pill = document.querySelector('.save-pill');
      if(!pill) return;
      pill.classList.remove('is-saving','is-ok','is-error');
      pill.classList.add(state || 'is-ok');
      pill.querySelector('.txt').textContent =
        text || (state === 'is-saving' ? 'Sauvegarde…' : state === 'is-error' ? 'Erreur' : 'OK');
    };

    if(!document.querySelector('.sticky-actions')){
      const sticky = document.createElement('div');
      sticky.className = 'sticky-actions';

      const backBtn = document.querySelector('.h-title a.btn.btn-outline-light');
      const saveBtn = document.querySelector('.h-title button.btn.btn-gradient');

      const backClone = backBtn ? backBtn.cloneNode(true) : null;
      const saveClone = saveBtn ? saveBtn.cloneNode(true) : null;

      if(backClone) sticky.appendChild(backClone);
      if(saveClone){
        saveClone.type = 'submit';
        const formId = saveBtn?.getAttribute('form');
        if(formId) saveClone.setAttribute('form', formId);
        sticky.appendChild(saveClone);
      }

      if(sticky.children.length) document.body.appendChild(sticky);
    }
  })();
  </script>

  <script>
  /* =========================
     TOMSELECT + PARENT UX
     ========================= */
  (function(){
    const typeSel     = document.getElementById('{{ form.type.vars.id }}');
    const parentSel   = document.getElementById('{{ form.parent.vars.id }}');
    const parentWrap  = document.getElementById('parent-wrapper');

    function ensureTomSelect(id){
      const el = document.getElementById(id);
      if (!el) return null;
      if (el.tomselect) return el.tomselect;
      return new TomSelect('#'+id, {
        create: false,
        allowEmptyOption: true,
        sortField: { field: "text", direction:"asc" },
        dropdownParent: 'body' // ✅ IMPORTANT
      });
    }

    ensureTomSelect('{{ form.type.vars.id }}');
    ensureTomSelect('{{ form.parent.vars.id }}');


    // ✅ Désactive "form-floating" pour les selects TomSelect (sinon ça casse)
    ['{{ form.type.vars.id }}','{{ form.parent.vars.id }}'].forEach((id)=>{
      const el = document.getElementById(id);
      const wrap = el?.closest('.form-floating');
      if (wrap) wrap.classList.add('ts-off');
    });


    function isSousChapitre(val){
      return String(val||'').toUpperCase().includes('SOUS');
    }

    const hasInitialParent = !!(parentSel && (
      (parentSel.tomselect && parentSel.tomselect.getValue()) ||
      (!parentSel.tomselect && parentSel.value)
    ));

    function syncParentVisibility(){
      const typeVal = typeSel.tomselect ? typeSel.tomselect.getValue() : typeSel.value;
      const sous = String(typeVal||'').toUpperCase().includes('SOUS');
      parentWrap.style.display = sous ? '' : 'none';
    }


    if (typeSel){
      syncParentVisibility();
      if (typeSel.tomselect) typeSel.tomselect.on('change', syncParentVisibility);
      else typeSel.addEventListener('change', syncParentVisibility);
    }
  })();
  </script>

  <script>
  /* =========================
     SLUG LIVE PROPOSAL
     ========================= */
  function slugify(str){
    return (str || '')
      .toString()
      .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
      .toLowerCase()
      .trim()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '')
      .replace(/-{2,}/g, '-');
  }

  (function(){
    const titre = document.getElementById('{{ form.titre.vars.id }}');
    const slug  = document.getElementById('{{ form.slug.vars.id }}');
    if (!titre || !slug) return;

    let manual = !!(slug.value && slug.value.trim().length);

    const wrap = slug.closest('.form-floating')?.parentElement || slug.parentElement;
    const helper = document.createElement('div');
    helper.className = 'slug-help';
    helper.innerHTML = `
      <span class="state ${manual ? 'manual' : 'auto'}">
        <span class="dot"></span>
        <span class="txt">${manual ? 'Manuel' : 'Auto'}</span>
      </span>
      <span class="hint">Proposition :</span>
      <code class="proposal">—</code>
      <button type="button" class="btn-mini btn-apply">Appliquer</button>
      <button type="button" class="btn-mini btn-auto" ${manual ? '' : 'disabled'}>Auto</button>
    `;
    wrap.appendChild(helper);

    const proposalEl = helper.querySelector('.proposal');
    const btnApply   = helper.querySelector('.btn-apply');
    const btnAuto    = helper.querySelector('.btn-auto');
    const stateEl    = helper.querySelector('.state');
    const stateTxt   = helper.querySelector('.state .txt');

    let lastProposal = '';

    function setMode(isManual){
      manual = !!isManual;
      stateEl.classList.toggle('manual', manual);
      stateEl.classList.toggle('auto', !manual);
      stateTxt.textContent = manual ? 'Manuel' : 'Auto';
      btnAuto.disabled = !manual;
    }

    function computeProposal(){
      const p = slugify(titre.value);
      lastProposal = p;
      proposalEl.textContent = p || '—';
      return p;
    }

    function flashSlug(){
      slug.classList.remove('slug-flash');
      void slug.offsetWidth;
      slug.classList.add('slug-flash');
    }

    titre.addEventListener('input', () => {
      const p = computeProposal();
      if (!manual){
        slug.value = p;
        flashSlug();
      }
    });

    slug.addEventListener('input', () => {
      setMode(true);
      computeProposal();
    });

    btnApply.addEventListener('click', () => {
      const p = computeProposal();
      if (!p) return;
      slug.value = p;
      flashSlug();
    });

    btnAuto.addEventListener('click', () => {
      setMode(false);
      const p = computeProposal();
      slug.value = p;
      flashSlug();
    });

    computeProposal();
    if (!manual && !slug.value.trim()){
      slug.value = lastProposal;
    }
  })();
  </script>

  <script>
