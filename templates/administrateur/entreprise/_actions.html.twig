{# templates/administrateur/entreprise/_actions.html.twig #}

<div class="btn-group btn-group-sm entreprise-actions" role="group">
  {# ✅ bouton principal : modifier (si locked -> on met un cadenas) #}
  <a class="btn btn-light entreprise-main"
     data-bs-toggle="tooltip" title="Modifier"
     href="{{ path('app_administrateur_entreprise_modifier', { entite: entite.id, id: entreprise.id }) }}">
    <i class="bi bi-pencil"></i>
  </a>

  {# ✅ split dropdown #}
  <button type="button"
          class="btn btn-light dropdown-toggle dropdown-toggle-split entreprise-split"
          data-bs-toggle="dropdown" aria-expanded="false">
    <span class="visually-hidden">Actions</span>
  </button>

  <ul class="dropdown-menu dropdown-menu-end entreprise-menu">

    <li>
      <a class="dropdown-item d-flex align-items-center"
         href="{{ path('app_administrateur_entreprise_modifier', { entite: entite.id, id: entreprise.id }) }}">
        <i class="bi bi-pencil me-2"></i> Modifier
      </a>
    </li>

    <li><hr class="dropdown-divider"></li>

    {% if not locked %}
      <li>
        <button type="button"
                class="dropdown-item d-flex align-items-center text-danger delete-btn"
                data-bs-toggle="modal"
                data-bs-target="#deleteModal"
                data-url="{{ path('app_administrateur_entreprise_supprimer', { entite: entite.id, id: entreprise.id }) }}">
          <i class="bi bi-trash me-2"></i> Supprimer
        </button>
      </li>
    {% else %}
      <li>
        <span class="dropdown-item d-flex align-items-center text-muted disabled"
              title="Entreprise utilisée, suppression bloquée">
          <i class="bi bi-lock me-2"></i> Suppression bloquée
        </span>
      </li>
    {% endif %}

  </ul>
</div>
