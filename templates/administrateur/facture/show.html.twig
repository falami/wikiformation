{# templates/administrateur/facture/show.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}Facture {{ f.numero ?: ('#' ~ f.id) }}{% endblock %}

{% block stylesheets %}
  {{ parent() }}

  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/style-table.css') }}">

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};

      --bg:#f6f8fb;
      --panel:#ffffff;
      --ink:#0f172a;
      --muted:rgba(15,23,42,.62);
      --stroke:rgba(15,23,42,.10);
      --shadow: 0 18px 55px rgba(0,0,0,.08);
      --r: 22px;
    }

    body{ background: var(--bg); }

    
    .hero{
      border-radius:22px;
      padding: 1.2rem 1.2rem;
      position: relative;
      overflow: hidden;
      color: #fff;

      /* Ombre douce premium */
      box-shadow: 0 18px 50px rgba(0,0,0,.14);

      /* Fond piloté par les couleurs de l'entité */
      background:
        /* halo clair (tertiaire) */
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        /* halo accent (secondaire) */
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        /* voile subtil (quaternaire) pour la profondeur */
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        /* dégradé principal (principal -> plus clair) */
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    /* léger glass highlight */
    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    /* barre accent = secondaire (et glow basé sur secondaire) */
    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }

    .chip{
      display:inline-flex; align-items:center; gap:.45rem;
      padding:.28rem .65rem; border-radius:999px; font-size:.82rem;
      background: rgba(255,255,255,.10);
      border:1px solid rgba(255,255,255,.14);
      color: rgba(255,255,255,.92);
      white-space: nowrap;
    }
    .chip i{ color: var(--theme-color-secondaire); }
    .hero .btn{
      border-radius: 14px;
      font-weight: 800;
    }
    .hero .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .hero .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }
    .btn-pill{
      border-radius:999px !important;
      font-weight:800;
      padding: .52rem .85rem;
      box-shadow: 0 10px 24px rgba(0,0,0,.18);
      border: 1px solid rgba(255,255,255,.18);
      backdrop-filter: blur(6px);
    }
    .btn-ghost{
      background: rgba(255,255,255,.10) !important;
      color:#fff !important;
    }
    .btn-ghost:hover{ background: rgba(255,255,255,.16) !important; }

    /* ===== Panels glass ===== */
    .panel{
      background: var(--panel);
      border: 1px solid var(--stroke);
      border-radius: var(--r);
      box-shadow: var(--shadow);
      overflow:hidden;
    }
    .panel-hd{
      padding: 14px 16px;
      display:flex; align-items:center; justify-content:space-between; gap:1rem;
      border-bottom: 1px solid var(--stroke);
      background: var(--panel);
    }
    .panel-title{
      display:flex; align-items:center; gap:.65rem;
      font-weight:900; color: var(--ink);
      letter-spacing: -.01em;
      margin:0;
    }
    .panel-title i{
      width: 40px; height:40px; display:grid; place-items:center;
      border-radius: 14px;
      background: rgba(15,23,42,.04);
      border: 1px solid rgba(15,23,42,.08);
    }
    .panel-bd{ padding: 16px; }

    /* ===== KPI row ===== */
    .kpi{
      display:flex; align-items:center; gap:12px;
      padding: 14px 14px;
      border-radius: 18px;
      border: 1px solid var(--stroke);
      background: var(--panel);
    }
    .kpi .ico{
      width: 46px; height:46px; border-radius: 16px;
      display:grid; place-items:center;
      background: rgba(15,23,42,.04);
      border: 1px solid rgba(15,23,42,.08);
      color: var(--ink);
    }
    .kpi .label{ color: rgba(15,23,42,.60); font-size:.86rem; }
    .kpi .val{ font-weight: 950; font-size: 1.35rem; letter-spacing:-.02em; color: var(--ink); }
    .kpi .sub{ color: rgba(15,23,42,.55); font-size:.82rem; }

    .mono{ font-variant-numeric: tabular-nums; font-feature-settings: "tnum" 1; }

    .badge-soft{
      border-radius: 999px;
      border: 1px solid rgba(15,23,42,.12);
      background: rgba(15,23,42,.04);
      padding: .3rem .55rem;
      font-weight: 800;
      white-space: nowrap;
    }
    .pill-success{ background: rgba(25,135,84,.10); border-color: rgba(25,135,84,.22); color:#146c43; }
    .pill-danger{  background: rgba(220,53,69,.10); border-color: rgba(220,53,69,.22); color:#b02a37; }
    .pill-warn{    background: rgba(255,193,7,.16); border-color: rgba(255,193,7,.30); color:#8a6a00; }
    .pill-muted{   background: rgba(108,117,125,.10); border-color: rgba(108,117,125,.20); color:#495057; }
    .pill-info{    background: rgba(13,110,253,.10); border-color: rgba(13,110,253,.22); color:#0b5ed7; }

    /* ===== Tables premium ===== */
    .table-premium thead th{
      background: #f7f8fb !important;
      text-transform: uppercase;
      letter-spacing: .06em;
      font-size: .76rem;
      color: rgba(15,23,42,.58);
      border-bottom: 1px solid rgba(15,23,42,.10) !important;
      white-space: nowrap;
    }
    .table-premium tbody td{
      border-bottom: 1px solid rgba(15,23,42,.08);
      vertical-align: middle;
      font-size: .92rem;
    }
    .table-premium tbody tr:hover > *{
      background: rgba(255,193,7,.08) !important;
    }

    /* ===== Sidebar info ===== */
    .info-grid{
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    @media (max-width: 992px){ .info-grid{ grid-template-columns: 1fr; } }

    .info{
      border:1px solid var(--stroke);
      border-radius: 18px;
      padding: 12px 12px;
      background: #fff;
    }
    .info .k{ color: rgba(15,23,42,.55); font-size:.82rem; }
    .info .v{ font-weight: 850; color: var(--ink); margin-top:.15rem; }

    pre.pretty-pre{
      background:#f8f9fa;
      border:1px solid rgba(0,0,0,.08);
      border-radius:14px;
      padding:12px 14px;
      white-space:pre-wrap;
      margin:0;
    }

    /* Mobile sticky actions */
    @media (max-width: 768px){
      .sticky-actions{
        position: sticky;
        bottom: 10px;
        z-index: 20;
        display:flex; gap:.5rem; flex-wrap:wrap;
        padding: 10px;
        border-radius: 18px;
        background: rgba(255,255,255,.86);
        border: 1px solid rgba(15,23,42,.10);
        box-shadow: 0 18px 55px rgba(0,0,0,.10);
        backdrop-filter: blur(10px);
      }
      td.action-column{
        position: sticky;
        right:0;
        background:#fff;
        z-index:5;
        box-shadow:-8px 0 12px -8px rgba(0,0,0,.08);
      }
    }

    /* Empêche "250,00" et "€" de se séparer sur 2 lignes */
    .mono{ 
      font-variant-numeric: tabular-nums;
      font-feature-settings: "tnum" 1;
      white-space: nowrap;           /* ✅ important */
    }
  </style>
{% endblock %}

{% block body %}
{% set num = f.numero ?: ('#' ~ f.id) %}
{% set st = f.status.value ?? '' %}
{% set paidEur = (paidCents|default(0) / 100) %}
{% set remainingEur = (remainingCents|default(0) / 100) %}
{% set htEur = (f.montantHtCents / 100) %}
{% set tvaEur = (f.montantTvaCents / 100) %}
{% set ttcEur = (f.montantTtcCents / 100) %}

  {# ===== HERO ===== #}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>

    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">

        <div>
          <h2 class="m-0 fw-bold">
            <i class="fa fa-file-invoice-dollar me-2" style="color:var(--theme-color-secondaire)"></i>
            Facture {{ num }}
          </h2>

          <div class="opacity-75 mt-1">
            Facturation pour
            <strong>{{ f.destinataireLabel }}</strong>
          </div>

          <div class="d-flex gap-2 flex-wrap mt-3">

            <span class="chip">
              <i class="fa fa-building"></i>
              {{ entite.nom }}
            </span>

            <span class="chip">
              <i class="fa fa-calendar"></i>
              {{ f.dateEmission ? f.dateEmission|date('d/m/Y') : '—' }}
            </span>

            {% if st == 'paid' %}
              <span class="chip">
                <i class="fa fa-check-circle"></i> Payée
              </span>
            {% elseif st == 'canceled' %}
              <span class="chip">
                <i class="fa fa-times-circle"></i> Annulée
              </span>
            {% else %}
              <span class="chip">
                <i class="fa fa-exclamation-circle"></i> À payer
              </span>
            {% endif %}

            {% if f.stripeInvoiceId %}
              <span class="chip">
                <i class="fa fa-credit-card"></i> Stripe
              </span>
            {% endif %}

          </div>
        </div>

        <div class="d-flex gap-2">

          <a href="{{ path('app_administrateur_facture_index', {entite: entite.id}) }}"
            class="btn btn-outline-light btn-sm fw-semibold">
            <i class="fa fa-arrow-left me-1"></i> Retour
          </a>

          <a href="{{ path('app_administrateur_facture_edit', {entite: entite.id, id: f.id}) }}"
            class="btn btn-outline-light btn-sm fw-semibold">
            <i class="fa fa-pen me-1"></i> Modifier
          </a>

          <a href="{{ path('app_administrateur_facture_pdf', {entite: entite.id, id: f.id}) }}"
            class="btn btn-light btn-sm fw-semibold">
            <i class="fa fa-file-pdf me-1"></i> PDF
          </a>

          {% if remainingCents > 0 and st != 'canceled' %}
            <a href="{{ path('app_administrateur_paiement_new', {entite: entite.id, facture: f.id}) }}"
              class="btn btn-light btn-sm fw-semibold">
              <i class="fa fa-plus me-1"></i> Paiement
            </a>
          {% endif %}

        </div>

      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  {# ===== KPIs ===== #}
  <div class="row g-3 mb-3">
    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi">
        <div class="ico"><i class="bi bi-cash-stack fs-4"></i></div>
        <div class="flex-grow-1">
          <div class="label">Total TTC</div>
          <div class="val mono">{{ ttcEur|number_format(2, ',', ' ') }}&nbsp;€</div>
          <div class="sub">Somme de la facture</div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi">
        <div class="ico"><i class="bi bi-receipt fs-4"></i></div>
        <div class="flex-grow-1">
          <div class="label">HT / TVA</div>
          <div class="val mono">{{ htEur|number_format(2, ',', ' ') }}&nbsp;€</div>
          <div class="sub mono">TVA : {{ tvaEur|number_format(2, ',', ' ') }}&nbsp;€</div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi">
        <div class="ico"><i class="bi bi-check2-circle fs-4"></i></div>
        <div class="flex-grow-1">
          <div class="label">Payé</div>
          <div class="val mono">{{ paidEur|number_format(2, ',', ' ') }}&nbsp;€</div>
          <div class="sub">Encaissements</div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi">
        <div class="ico"><i class="bi bi-exclamation-circle fs-4"></i></div>
        <div class="flex-grow-1">
          <div class="label">Reste</div>
          <div class="val mono">{{ remainingEur|number_format(2, ',', ' ') }}&nbsp;€</div>
          <div class="sub">TTC − payé</div>
        </div>
      </div>
    </div>
  </div>

  {# ===== Main grid ===== #}
  <div class="row g-3">
    <div class="col-lg-8">

      {# ===== LIGNES ===== #}
      <div class="panel mb-3">
        <div class="panel-hd">
          <div class="panel-title">
            <i class="bi bi-list-check"></i>
            Lignes de facture
          </div>

          <span class="badge-soft pill-muted">
            {{ f.lignes|length }} ligne{{ f.lignes|length > 1 ? 's' : '' }}
          </span>
        </div>

        <div class="table-responsive p-3">
          <table class="table table-premium align-middle mb-0">
            <thead>
              <tr>
                <th>Libellé</th>
                <th class="text-end">Qté</th>
                <th class="text-end">PU HT</th>
                <th class="text-end">HT net</th>
                <th class="text-end">TVA</th>
                <th class="text-end">TTC</th>
              </tr>
            </thead>
            <tbody>
              {% for l in f.lignes %}
                <tr {% if l.isDebours %}style="background: rgba(108,117,125,.06)"{% endif %}>
                  <td>
                    <div class="fw-semibold">{{ l.label }}</div>
                    {% if l.isDebours %}
                      <div class="small text-muted mt-1"><i class="bi bi-info-circle me-1"></i>Débours</div>
                    {% endif %}
                  </td>

                  <td class="text-end mono">{{ l.qte }}</td>
                  <td class="text-end mono">{{ (l.puHtCents/100)|number_format(2, ',', ' ') }}&nbsp;€</td>
                  <td class="text-end mono fw-semibold">{{ (l.totalHtNetCents/100)|number_format(2, ',', ' ') }}&nbsp;€</td>
                  <td class="text-end mono">{{ (l.totalTvaCents/100)|number_format(2, ',', ' ') }}&nbsp;€</td>
                  <td class="text-end mono fw-semibold">{{ (l.totalTtcCents/100)|number_format(2, ',', ' ') }}&nbsp;€</td>
                </tr>
              {% else %}
                <tr><td colspan="6" class="text-muted">Aucune ligne.</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>

      {# ===== PAIEMENTS ===== #}
      <div class="panel">
        <div class="panel-hd">
          <div class="panel-title">
            <i class="bi bi-credit-card-2-front"></i>
            Paiements
          </div>

          {% if remainingCents|default(0) > 0 and st != 'canceled' %}
            <a class="btn btn-sm btn-success btn-pill"
               href="{{ path('app_administrateur_paiement_new', {entite: entite.id, facture: f.id}) }}">
              <i class="bi bi-plus-circle"></i> Ajouter
            </a>
          {% endif %}
        </div>

        <div class="table-responsive p-3">
          <table class="table table-premium align-middle mb-0">
            <thead>
              <tr>
                <th style="width:140px">Date</th>
                <th>Mode</th>
                <th>Payeur</th>
                <th class="text-end" style="width:160px">Montant</th>
              </tr>
            </thead>
            <tbody>
              {% for p in paiements %}
                <tr>
                  <td class="mono">{{ p.datePaiement ? p.datePaiement|date('d/m/Y') : '—' }}</td>

                  <td>
                    {% set mode = p.mode %}
                    {% if mode is not null %}
                      {% set cls = mode.value == 'cb' ? 'pill-success'
                        : (mode.value == 'virement' ? 'pill-info'
                        : (mode.value == 'cheque' ? 'pill-warn'
                        : (mode.value == 'especes' ? 'pill-warn'
                        : 'pill-muted'))) %}
                      <span class="badge-soft {{ cls }}">
                        <i class="bi bi-lightning-charge me-1"></i> {{ mode.label() }}
                      </span>
                    {% else %}
                      —
                    {% endif %}
                  </td>

                  <td><span class="text-muted">{{ p.payeurLabel }}</span></td>

                  <td class="text-end mono fw-semibold">
                    {{ (p.montantCents/100)|number_format(2, ',', ' ') }}&nbsp;€
                  </td>
                </tr>
              {% else %}
                <tr><td colspan="4" class="text-muted">Aucun paiement.</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>

    </div>

    {# ===== Sidebar infos ===== #}
    <div class="col-lg-4">

      <div class="panel mb-3">
        <div class="panel-hd">
          <div class="panel-title">
            <i class="bi bi-info-circle"></i>
            Détails
          </div>
          <span class="badge-soft pill-muted">ID #{{ f.id }}</span>
        </div>

        <div class="panel-bd">
          <div class="info-grid">
            <div class="info">
              <div class="k">Destinataire</div>
              <div class="v">{{ f.destinataireLabel }}</div>
            </div>

            <div class="info">
              <div class="k">Date émission</div>
              <div class="v mono">{{ f.dateEmission ? f.dateEmission|date('d/m/Y') : '—' }}</div>
            </div>

            <div class="info">
              <div class="k">Statut</div>
              <div class="v">
                {% if st == 'paid' %}
                  <span class="badge-soft pill-success">PAYÉE</span>
                {% elseif st == 'canceled' %}
                  <span class="badge-soft pill-danger">ANNULÉE</span>
                {% else %}
                  <span class="badge-soft pill-warn">À PAYER</span>
                {% endif %}
              </div>
            </div>

            <div class="info">
              <div class="k">Devise</div>
              <div class="v mono">{{ f.devise|default('EUR') }}</div>
            </div>

            {% if f.remiseGlobalePourcent is not null or f.remiseGlobaleMontantCents is not null %}
              <div class="info" style="grid-column: 1 / -1;">
                <div class="k">Remise globale</div>
                <div class="v">
                  {% if f.remiseGlobaleMontantCents is not null and f.remiseGlobaleMontantCents > 0 %}
                    -{{ (f.remiseGlobaleMontantCents/100)|number_format(2, ',', ' ') }}&nbsp;€
                  {% elseif f.remiseGlobalePourcent is not null and f.remiseGlobalePourcent > 0 %}
                    {{ f.remiseGlobalePourcent|number_format(2, ',', ' ') }} %
                  {% else %}
                    —
                  {% endif %}
                </div>
              </div>
            {% endif %}

            {% if f.meta is not null %}
              <div class="info" style="grid-column: 1 / -1;">
                <div class="k">Meta</div>
                <div class="v">
                  <pre class="pretty-pre small mb-0">{{ f.meta|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
                </div>
              </div>
            {% endif %}

            {# Paiement en ligne : on garde la logique mais on la met "à la Inscription" (info discrète) #}
            {% set connect = entite.connect ?? null %}
            {% set canPayOnline = connect and connect.onlinePaymentEnabled and connect.isReadyForCheckout %}
            <div class="info" style="grid-column: 1 / -1;">
              <div class="k">Paiement en ligne</div>
              <div class="v">
                {% if canPayOnline %}
                  <span class="badge-soft pill-success"><i class="bi bi-check2-circle me-1"></i>Disponible</span>
                {% else %}
                  <span class="badge-soft pill-muted"><i class="bi bi-slash-circle me-1"></i>Indisponible</span>
                  <div class="small text-muted mt-1">
                    Stripe non connecté ou onboarding incomplet.
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="panel mb-3">
        <div class="panel-hd">
          <div class="panel-title">
            <i class="bi bi-shield-check"></i>
            Raccourcis
          </div>
        </div>
        <div class="panel-bd d-grid gap-2">
          <a class="btn btn-outline-secondary btn-pill"
             href="{{ path('app_administrateur_facture_edit', {entite: entite.id, id: f.id}) }}">
            <i class="bi bi-pencil-square"></i> Modifier la facture
          </a>

          <a class="btn btn-outline-danger btn-pill"
             href="{{ path('app_administrateur_facture_pdf', {entite: entite.id, id: f.id}) }}">
            <i class="bi bi-file-earmark-pdf"></i> Télécharger le PDF
          </a>

          {% if remainingCents|default(0) > 0 and st != 'canceled' %}
            <a class="btn btn-success btn-pill"
               href="{{ path('app_administrateur_paiement_new', {entite: entite.id, facture: f.id}) }}">
              <i class="bi bi-plus-circle"></i> Ajouter un paiement
            </a>
          {% endif %}
        </div>
      </div>

      {# Optionnel : petite "zone sensible" comme tes autres pages (si tu as une route delete) #}
      {# 
      <div class="panel border-danger">
        <div class="panel-hd" style="background:rgba(220,53,69,.08)">
          <div class="panel-title text-danger">
            <i class="bi bi-trash"></i> Zone sensible
          </div>
        </div>
        <div class="panel-bd">
          <form method="post"
                action="{{ path('app_administrateur_facture_delete', {entite: entite.id, id: f.id}) }}"
                onsubmit="return confirm('Supprimer définitivement cette facture ?');">
            <input type="hidden" name="_token" value="{{ csrf_token('del' ~ f.id) }}">
            <button class="btn btn-outline-danger btn-pill w-100">
              <i class="bi bi-trash me-1"></i> Supprimer la facture
            </button>
          </form>
        </div>
      </div>
      #}

    </div>
  </div>

  {# Mobile sticky actions #}
  <div class="sticky-actions mt-3 d-md-none">
    <a class="btn btn-outline-secondary btn-pill btn-sm flex-grow-1"
       href="{{ path('app_administrateur_facture_index', {entite: entite.id}) }}">
      <i class="bi bi-arrow-left"></i> Retour
    </a>

    <a class="btn btn-outline-danger btn-pill btn-sm flex-grow-1"
       href="{{ path('app_administrateur_facture_pdf', {entite: entite.id, id: f.id}) }}">
      <i class="bi bi-file-earmark-pdf"></i> PDF
    </a>

    {% if remainingCents|default(0) > 0 and st != 'canceled' %}
      <a class="btn btn-success btn-pill btn-sm flex-grow-1"
         href="{{ path('app_administrateur_paiement_new', {entite: entite.id, facture: f.id}) }}">
        <i class="bi bi-plus-circle"></i> Paiement
      </a>
    {% endif %}
  </div>
{% endblock %}