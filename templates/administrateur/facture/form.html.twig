{# templates/administrateur/facture/form.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}{{ title }}{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/formulaire.css') }}">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};

      --bg:#f5f7fb;
      --panel:#fff;
      --ink:#0f172a;
      --muted:#64748b;
      --stroke: rgba(15, 23, 42, .10);
      --shadow: 0 18px 55px rgba(15, 23, 42, .10);
      --radius:18px;
    }

    body{ background: var(--bg); }

    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;

      /* Ombre douce premium */
      box-shadow: 0 18px 50px rgba(0,0,0,.14);

      /* Fond piloté par les couleurs de l'entité */
      background:
        /* halo clair (tertiaire) */
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        /* halo accent (secondaire) */
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        /* voile subtil (quaternaire) pour la profondeur */
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        /* dégradé principal (principal -> plus clair) */
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    /* léger glass highlight */
    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    /* barre accent = secondaire (et glow basé sur secondaire) */
    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }
    /* ===== Chips HERO (comme Sessions) ===== */
    .hero .chip--hero{
      display:inline-flex;
      align-items:center;
      gap:.5rem;
      padding:.32rem .7rem;
      border-radius:999px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(255,255,255,.14);
      backdrop-filter: blur(6px);
      font-size:.82rem;
      color: rgba(255,255,255,.92);
      white-space: nowrap;
    }

    /* icônes accent */
    .hero .chip--hero i{ color: var(--theme-color-secondaire); }

    /* chip “pill” plus lumineuse */
    .hero .chip--pill{
      background: color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
      border-color: color-mix(in srgb, var(--theme-color-secondaire) 28%, rgba(255,255,255,.14));
      color:#fff;
    }

    /* boutons du hero */
    .hero .btn{
      border-radius:14px;
      font-weight:800;
    }
    .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }

    .cardx{
      background: var(--panel);
      border: 1px solid var(--stroke);
      border-radius: var(--radius);
      box-shadow: 0 10px 28px rgba(15,23,42,.08);
      overflow:visible;
    }
    .cardx-h{
      padding: .95rem 1.05rem;
      display:flex; align-items:center; justify-content:space-between; gap:1rem;
      background: linear-gradient(180deg, rgba(0,0,0,.015), transparent);
      border-bottom: 1px solid var(--stroke);
    }
    .cardx-title{
      margin:0; font-weight:800; letter-spacing:-.01em; color: var(--ink);
      display:flex; align-items:center; gap:.6rem;
    }
    .chip{
      font-size:.78rem; padding:.25rem .55rem; border-radius:999px;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, var(--stroke));
      color: var(--muted);
      white-space:nowrap;
    }

    label.form-label{ font-weight: 700; color: var(--ink); }
    .form-text, .text-muted, .small{ color: var(--muted) !important; }
    .form-control, .form-select{
      border-radius: 14px;
      border: 1px solid var(--stroke);
      padding: .65rem .85rem;
    }
    .form-control:focus, .form-select:focus{
      border-color: color-mix(in srgb, var(--theme-color-principal) 55%, var(--stroke));
      box-shadow: 0 0 0 .2rem color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
    }

    /* TomSelect */
    .ts-wrapper .ts-control{
      border-radius: 14px !important;
      padding: .55rem .75rem !important;
      border-color: var(--stroke) !important;
    }
    .ts-wrapper.focus .ts-control{
      box-shadow: 0 0 0 .2rem color-mix(in srgb, var(--theme-color-principal) 18%, transparent) !important;
      border-color: color-mix(in srgb, var(--theme-color-principal) 55%, var(--stroke)) !important;
    }
    .ts-dropdown, .ts-dropdown.form-control, .ts-dropdown .ts-dropdown-content{
      z-index: 1080 !important;
    }

    .input-euro .form-control{
      border-top-right-radius: 0 !important;
      border-bottom-right-radius: 0 !important;
    }
    .input-euro .euro-suffix{
      border-top-left-radius: 0 !important;
      border-bottom-left-radius: 0 !important;
      font-weight: 800;
      letter-spacing: .02em;
      color: var(--theme-color-principal);
      border-color: var(--stroke);
      min-width: 46px;
      justify-content: center;
      border: 1px solid var(--stroke);
    }

    .ligne-item .card{
      border-style:dashed;
      border-color: color-mix(in srgb, var(--theme-color-principal) 16%, var(--stroke));
      border-radius: 16px;
    }

    .summary-box{
      border: 1px solid var(--stroke);
      border-radius: 18px;
      background: linear-gradient(180deg, color-mix(in srgb, var(--theme-color-principal) 8%, transparent), transparent);
      padding: 1rem;
    }

    .mini-kpi{
      border:1px solid var(--stroke);
      border-radius: 16px;
      padding:.85rem 1rem;
      background: linear-gradient(180deg, color-mix(in srgb, var(--theme-color-secondaire) 10%, transparent), transparent);
    }

    @media (max-width:768px){
      .hero{ border-radius:16px; }
    }

    .ligne-item.is-debours .card{
      border-style: solid;
      border-color: color-mix(in srgb, var(--theme-color-secondaire) 55%, var(--stroke));
      background: linear-gradient(180deg, rgba(255,193,7,.10), transparent);
    }




    /* ===== LIGNES : grille plus propre ===== */
.lines-head{
  display:none;
  padding:.65rem .95rem;
  border:1px solid var(--stroke);
  border-radius: 14px;
  background: linear-gradient(180deg, color-mix(in srgb, var(--theme-color-principal) 6%, transparent), transparent);
  color: var(--muted);
  font-size:.78rem;
  font-weight: 800;
  letter-spacing:.02em;
}

@media (min-width: 768px){
  .lines-head{ display:block; }
}

.ligne-item .card{
  border-style:dashed;
  border-color: color-mix(in srgb, var(--theme-color-principal) 16%, var(--stroke));
  border-radius: 16px;
  background: var(--panel);
}

.ligne-fields{
  display:grid;
  gap:.75rem;
  grid-template-columns: 1fr 1fr 1fr 1fr 1fr auto; /* Qte / PU / TVA / Rem% / Rem€ / Actions */
  align-items:end;
}

@media (max-width: 767.98px){
  .ligne-fields{
    grid-template-columns: 1fr 1fr;
  }
  .ligne-actions{
    grid-column: 1 / -1;
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:.75rem;
  }
}

.ligne-actions{
  display:flex;
  justify-content:flex-end;
  align-items:center;
  gap:.6rem;
}

.debours-pill{
  display:inline-flex;
  align-items:center;
  gap:.45rem;
  padding:.35rem .6rem;
  border-radius:999px;
  border:1px solid var(--stroke);
  background: color-mix(in srgb, var(--theme-color-secondaire) 12%, transparent);
  font-weight: 800;
  font-size:.78rem;
  color: var(--ink);
  white-space:nowrap;
}

.btn-icon-soft{
  border:1px solid var(--stroke);
  background: color-mix(in srgb, var(--theme-color-principal) 6%, transparent);
  border-radius: 12px;
  padding:.5rem .7rem;
}

.btn-icon-soft:hover{
  background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
}

.ligne-item.is-debours .debours-pill{
  background: rgba(255,193,7,.18);
  border-color: rgba(255,193,7,.35);
}


  </style>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  <script src="https://npmcdn.com/flatpickr/dist/l10n/fr.js"></script>
{% endblock %}

{% block body %}


  {# ===== HERO (style Sessions) ===== #}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>

    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-receipt me-2" style="color:var(--theme-color-secondaire)"></i>
            {{ title }}
          </h2>

          <div class="opacity-75 mt-1">
            Références, lignes, remises et montants.
          </div>

          <div class="d-flex flex-wrap gap-2 mt-3">
            <span class="chip chip--hero">
              <i class="bi bi-receipt-cutoff"></i>
              Facture
            </span>

            <span class="chip chip--hero">
              <i class="bi bi-building"></i>
              {{ entite.nom }}
            </span>

            <span class="chip chip--hero">
              <i class="bi bi-pencil-square"></i>
              {{ title }}
            </span>

            {% if form.vars.value and form.vars.value.id %}
              <span class="chip chip--hero chip--pill">
                <i class="bi bi-file-earmark-pdf"></i>
                PDF dispo
              </span>
            {% endif %}
          </div>
        </div>

        <div class="d-flex flex-wrap gap-2">
          <a class="btn btn-outline-theme btn-sm fw-semibold"
            href="{{ path('app_administrateur_facture_index', {entite: entite.id}) }}">
            <i class="bi bi-arrow-left me-1"></i> Annuler
          </a>

          {% if form.vars.value and form.vars.value.id %}
            <a class="btn btn-light btn-sm fw-semibold"
              href="{{ path('app_administrateur_facture_pdf', {entite: entite.id, id: form.vars.value.id}) }}">
              <i class="bi bi-filetype-pdf me-1"></i> PDF
            </a>
          {% endif %}

          <button form="{{ form.vars.id }}" type="submit" class="btn btn-light btn-sm fw-semibold">
            <i class="bi bi-check2 me-1"></i> Enregistrer
          </button>
        </div>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  {{ form_start(form, { attr: { id: form.vars.id, novalidate:'novalidate', name:'facture_form' } }) }}
  {{ form_errors(form) }}

  <div class="row g-4">

    {# ===== COL LEFT ===== #}
    <div class="col-lg-8">

      {# ===== Références ===== #}
      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="fa fa-link text-warning"></i> Références</h5>
          <span class="chip">Étape 1</span>
        </div>

        <div class="p-3 p-md-4">
          <div class="row g-3">

            <div class="col-md-12">
              {{ form_label(form.formation) }}
              {{ form_widget(form.formation) }}
              {{ form_errors(form.formation) }}
              <div class="form-text">
                En rattachant une formation, <strong>une ligne</strong> peut être auto-remplie (titre + prix) et les montants recalculés.
              </div>
            </div>

            <div class="col-md-12">
              <div class="mini-kpi">
                <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
                  <div class="fw-bold"><i class="bi bi-mortarboard-fill me-2"></i>Formation sélectionnée</div>
                  <span class="badge rounded-pill" style="border:1px solid var(--stroke); background:rgba(255,193,7,.15); color:var(--ink);">
                    Auto
                  </span>
                </div>
                <div class="mt-2 small">
                  <div class="d-flex justify-content-between gap-3 py-1">
                    <span class="text-muted">Titre</span>
                    <span class="fw-semibold text-end" id="formation-title">—</span>
                  </div>
                  <div class="d-flex justify-content-between gap-3 py-1">
                    <span class="text-muted">Heures / quantité</span>
                    <span class="fw-semibold text-end" id="formation-hours">—</span>
                  </div>
                  <div class="d-flex justify-content-between gap-3 py-1">
                    <span class="text-muted">Prix (base)</span>
                    <span class="fw-semibold text-end" id="formation-price">—</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="col-md-6">
              {{ form_row(form.destinataire) }}
            </div>

            <div class="col-md-6">
              {{ form_label(form.entrepriseDestinataire) }}
              <div class="d-flex gap-2 align-items-start">
                <div class="flex-grow-1">
                  {{ form_widget(form.entrepriseDestinataire) }}
                  {{ form_errors(form.entrepriseDestinataire) }}
                </div>

                {# (optionnel) bouton modal entreprise si tu as déjà la route côté facture #}
                {# <button type="button" class="btn btn-outline-primary" id="btnAddEntreprise" title="Créer une entreprise">
                  <i class="fa fa-plus"></i>
                </button> #}
              </div>
            </div>

            <div class="col-md-12">
              <div class="form-text">Tu peux choisir une <strong>entreprise</strong> et/ou une <strong>personne</strong>.</div>
            </div>

            <div class="col-md-12">
              {{ form_row(form.inscriptions) }}
              <div class="form-text">Sélection multiple possible (TomSelect).</div>
            </div>

            <div class="col-md-4">{{ form_row(form.dateEmission) }}</div>
            <div class="col-md-4">{{ form_row(form.devise) }}</div>
            <div class="col-md-4">{{ form_row(form.status) }}</div>
            <div class="col-md-12">
              {{ form_row(form.note) }}
            </div>
          </div>
        </div>
      </div>

      {# ===== Montants + Remise globale ===== #}
      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="fa fa-receipt text-warning"></i> Montants</h5>
          <span class="chip">Auto</span>
        </div>

        <div class="p-3 p-md-4">
          <div class="row g-3">

            {# ✅ Facture = champs Symfony (une seule fois) #}
            <div class="col-md-6">
              <label>Montant HT (avec débours)</label>
              <div class="input-group input-euro">
                {{ form_widget(form.montantHtCents, {'attr': {'class':'form-control text-end', 'placeholder':'0,00'}}) }}
                <span class="input-group-text euro-suffix">€</span>
              </div>
              {{ form_errors(form.montantHtCents) }}
            </div>

            <div class="col-md-6">
              {{ form_label(form.montantTvaCents) }}
              <div class="input-group input-euro">
                {{ form_widget(form.montantTvaCents, {'attr': {'class':'form-control text-end', 'placeholder':'0,00'}}) }}
                <span class="input-group-text euro-suffix">€</span>
              </div>
              {{ form_errors(form.montantTvaCents) }}
            </div>

            {# ✅ Indicateurs internes (readonly, pas des champs Symfony) #}
            <div class="col-md-6">
              <label>Montant HT (hors débours)</label>
              <div class="input-group input-euro">
                <input type="text" class="form-control text-end" id="ht-hors-debours" value="0,00" readonly>
                <span class="input-group-text euro-suffix">€</span>
              </div>
              <div class="form-text">Indicateur interne (CA) : exclut les lignes “Débours”.</div>
            </div>

            <div class="col-md-6">
              <label>Total débours (HT)</label>
              <div class="input-group input-euro">
                <input type="text" class="form-control text-end" id="total-debours-ht" value="0,00" readonly>
                <span class="input-group-text euro-suffix">€</span>
              </div>
            </div>

            <div class="col-md-6">
              {{ form_label(form.remiseGlobalePourcent) }}
              <div class="input-group input-euro">
                {{ form_widget(form.remiseGlobalePourcent, {'attr': {'class':'form-control text-end', 'placeholder':'0,00'}}) }}
                <span class="input-group-text euro-suffix">%</span>
              </div>
              <div class="form-text">Soit % soit € (si tu mets l’un, l’autre est vidé).</div>
            </div>

            <div class="col-md-6">
              {{ form_label(form.remiseGlobaleMontantCents) }}
              <div class="input-group input-euro">
                {{ form_widget(form.remiseGlobaleMontantCents, {'attr': {'class':'form-control text-end', 'placeholder':'0,00'}}) }}
                <span class="input-group-text euro-suffix">€</span>
              </div>
            </div>

            <div class="col-md-12">
              {{ form_label(form.montantTtcCents) }}
              <div class="input-group input-euro">
                {{ form_widget(form.montantTtcCents, {'attr': {'class':'form-control text-end', 'placeholder':'0,00'}}) }}
                <span class="input-group-text euro-suffix">€</span>
              </div>
              {{ form_errors(form.montantTtcCents) }}
            </div>

          </div>

          <div class="form-text mt-2">
            Calcul : remise par ligne → sous-total HT net → remise globale (prorata lignes) → TVA par ligne → TTC.
          </div>
        </div>

      </div>

      {# ===== Lignes (prototype) ===== #}
      {% set lignePrototype %}
        <div class="ligne-row">

          {# Label pleine largeur #}
          <div class="mb-2">
            {{ form_row(form.lignes.vars.prototype.label) }}
          </div>

          {# Champs en grille #}
          <div class="ligne-fields">
            <div>{{ form_row(form.lignes.vars.prototype.qte) }}</div>
            <div>{{ form_row(form.lignes.vars.prototype.puHtCents) }}</div>
            <div>{{ form_row(form.lignes.vars.prototype.tvaBp) }}</div>
            <div>{{ form_row(form.lignes.vars.prototype.remisePourcent) }}</div>

            <div>
              {{ form_label(form.lignes.vars.prototype.remiseMontantCents) }}
              <div class="input-group input-euro">
                {{ form_widget(form.lignes.vars.prototype.remiseMontantCents, {'attr': {'class':'form-control text-end', 'placeholder':'0,00'}}) }}
                <span class="input-group-text euro-suffix">€</span>
              </div>
              {{ form_errors(form.lignes.vars.prototype.remiseMontantCents) }}
            </div>

            {# Actions #}
            <div class="ligne-actions">
              <label class="debours-pill">
                {{ form_widget(form.lignes.vars.prototype.isDebours, { attr: { class: 'form-check-input js-debours me-2' } }) }}
                <i class="bi bi-receipt-cutoff"></i> Débours
              </label>

              <button type="button" class="btn btn-outline-danger btn-icon-soft btn-remove-ligne" title="Supprimer la ligne">
                <i class="bi bi-trash"></i>
              </button>
            </div>
          </div>

        </div>
      {% endset %}


      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="fa fa-list text-warning"></i> Lignes</h5>
          <span class="chip">Étape 2</span>
        </div>

        <div class="p-3 p-md-4">
          {# Header desktop (repère colonnes) #}
          <div class="lines-head mb-3">
            <div class="d-grid" style="grid-template-columns: 1fr 1fr 1fr 1fr 1fr auto; gap:.75rem;">
              <div>Qté</div>
              <div>PU HT</div>
              <div>TVA</div>
              <div>Remise %</div>
              <div>Remise €</div>
              <div class="text-end">Actions</div>
            </div>
          </div>

          <div id="lignes-collection" data-prototype="{{ lignePrototype|e('html_attr') }}">
            {% for ligneForm in form.lignes %}
              <div class="ligne-item mb-3">
                <div class="card p-3 p-md-3">
                  <div class="ligne-row">

                    <div class="mb-2">
                      {{ form_row(ligneForm.label) }}
                    </div>

                    <div class="ligne-fields">
                      <div>{{ form_row(ligneForm.qte) }}</div>
                      <div>{{ form_row(ligneForm.puHtCents) }}</div>
                      <div>{{ form_row(ligneForm.tvaBp) }}</div>
                      <div>{{ form_row(ligneForm.remisePourcent) }}</div>

                      <div>
                        {{ form_label(ligneForm.remiseMontantCents) }}
                        <div class="input-group input-euro">
                          {{ form_widget(ligneForm.remiseMontantCents, {'attr': {'class':'form-control text-end', 'placeholder':'0,00'}}) }}
                          <span class="input-group-text euro-suffix">€</span>
                        </div>
                        {{ form_errors(ligneForm.remiseMontantCents) }}
                      </div>

                      <div class="ligne-actions">
                        <label class="debours-pill">
                          {{ form_widget(ligneForm.isDebours, { attr: { class: 'form-check-input js-debours me-2' } }) }}
                          <i class="bi bi-receipt-cutoff"></i> Débours
                        </label>

                        <button type="button" class="btn btn-outline-danger btn-icon-soft btn-remove-ligne" title="Supprimer la ligne">
                          <i class="bi bi-trash"></i>
                        </button>
                      </div>
                    </div>

                  </div>
                </div>
              </div>
            {% endfor %}
          </div>

