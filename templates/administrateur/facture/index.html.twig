    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-cash-stack fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Total TTC</div>
              <div class="kpi-value" id="kpi-ttc">—</div>
              <div class="kpi-sub">Somme des factures</div>
            </div>
          </div>
          <div class="mt-3 kpi-bar"><span id="kpi-bar-ttc"></span></div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-check2-circle fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Total payé</div>
              <div class="kpi-value" id="kpi-paid">—</div>
              <div class="kpi-sub">Somme des paiements</div>
            </div>
          </div>
          <div class="mt-3 kpi-bar"><span id="kpi-bar-paid"></span></div>
        </div>
      </div>
