    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-exclamation-circle fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Reste à payer</div>
              <div class="kpi-value" id="kpi-remaining">—</div>
              <div class="kpi-sub">TTC - payé</div>
            </div>
          </div>
          <div class="mt-3 kpi-bar"><span id="kpi-bar-remaining"></span></div>
        </div>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  {# ===== TOOLBAR ===== #}
  <div class="toolbar mb-3">
    <div class="d-flex flex-wrap gap-2 align-items-center">
      <div class="me-auto d-flex flex-wrap gap-2 align-items-center">
        


        {# Période : Année / Mois / Trimestre #}
        <span class="chip">
          <i class="bi bi-calendar3"></i>
          <select id="periodTypeFilter" class="form-select form-select-sm ms-2" style="width:auto">
            <option value="all">Toutes</option>
            <option value="year">Année</option>
            <option value="month">Mois</option>
            <option value="quarter">Trimestre</option>
          </select>

          <select id="yearFilter" class="form-select form-select-sm ms-2 d-none" style="width:auto">
            <option value="all">—</option>
            {% for y in 2024..2027 %}
              <option value="{{ y }}">{{ y }}</option>
            {% endfor %}
          </select>

          <select id="monthFilter" class="form-select form-select-sm ms-2 d-none" style="width:auto">
            <option value="all">—</option>
            {% for m in 1..12 %}
              <option value="{{ m }}">{{ "%02d"|format(m) }}</option>
            {% endfor %}
          </select>

          <select id="quarterFilter" class="form-select form-select-sm ms-2 d-none" style="width:auto">
            <option value="all">—</option>
            <option value="1">T1</option>
            <option value="2">T2</option>
            <option value="3">T3</option>
            <option value="4">T4</option>
          </select>
        </span>


        <span class="chip">
          <i class="bi bi-funnel"></i>
          <select id="factureStatusFilter" class="form-select form-select-sm ms-2" style="width:auto">
            <option value="all">Toutes</option>
            <option value="due">Dues</option>
            <option value="partial">Payées partiellement</option>
            <option value="paid">Payées</option>
            <option value="canceled">Annulées</option>
          </select>
        </span>

        {# === Destinataires particuliers === #}
        <span class="chip">
          <i class="bi bi-person"></i>
          <div class="dropdown">
            <button class="btn btn-sm btn-outline-secondary dropdown-toggle"
                    type="button" data-bs-toggle="dropdown" data-bs-auto-close="outside"
                    id="btnPayeurUsers">
              Particuliers <span class="badge bg-secondary-subtle text-secondary ms-1" id="badgePayeurUsers">0</span>
            </button>

            <div class="dropdown-menu p-2 shadow" style="min-width: 320px;">
              <div class="px-2 pb-2">
                <input type="text" class="form-control form-control-sm" placeholder="Rechercher un particulier…"
                      id="searchPayeurUsers">
              </div>

              <div class="px-2 d-flex gap-2 pb-2">
                <button type="button" class="btn btn-sm btn-light" id="usersSelectAll">Tout</button>
                <button type="button" class="btn btn-sm btn-light" id="usersSelectNone">Aucun</button>
              </div>

              <div class="px-2" style="max-height: 280px; overflow:auto;" id="listPayeurUsers">
                {% for u in payeurUsers %}
                  <label class="dropdown-item d-flex align-items-center gap-2 user-item" data-text="{{ (u.nom ~ ' ' ~ u.prenom ~ ' ' ~ u.email)|lower }}">
                    <input class="form-check-input m-0 payeur-user-check" type="checkbox" value="{{ u.id }}">
                    <span class="flex-grow-1">
                      <div class="fw-semibold">{{ u.nom }} {{ u.prenom }}</div>
                      <div class="text-muted small">{{ u.email }}</div>
                    </span>
                  </label>
                {% else %}
                  <div class="text-muted small px-2 py-1">Aucun destinataire particulier.</div>
                {% endfor %}
              </div>
            </div>
          </div>
        </span>

        {# === Destinataires entreprises === #}
        <span class="chip">
          <i class="bi bi-building"></i>
          <div class="dropdown">
            <button class="btn btn-sm btn-outline-secondary dropdown-toggle"
                    type="button" data-bs-toggle="dropdown" data-bs-auto-close="outside"
                    id="btnPayeurEntreprises">
              Entreprises <span class="badge bg-secondary-subtle text-secondary ms-1" id="badgePayeurEnt">0</span>
            </button>

            <div class="dropdown-menu p-2 shadow" style="min-width: 320px;">
              <div class="px-2 pb-2">
                <input type="text" class="form-control form-control-sm" placeholder="Rechercher une entreprise…"
                      id="searchPayeurEnt">
              </div>

              <div class="px-2 d-flex gap-2 pb-2">
                <button type="button" class="btn btn-sm btn-light" id="entSelectAll">Tout</button>
                <button type="button" class="btn btn-sm btn-light" id="entSelectNone">Aucun</button>
              </div>

              <div class="px-2" style="max-height: 280px; overflow:auto;" id="listPayeurEnt">
                {% for e in payeurEntreprises %}
                  <label class="dropdown-item d-flex align-items-center gap-2 ent-item" data-text="{{ (e.raisonSociale ~ ' ' ~ (e.email ?? ''))|lower }}">
                    <input class="form-check-input m-0 payeur-ent-check" type="checkbox" value="{{ e.id }}">
                    <span class="flex-grow-1">
                      <div class="fw-semibold">{{ e.raisonSociale }}</div>
                      <div class="text-muted small">{{ e.email ?? '—' }}</div>
                    </span>
                  </label>
                {% else %}
                  <div class="text-muted small px-2 py-1">Aucune entreprise destinataire.</div>
                {% endfor %}
              </div>
            </div>
          </div>
        </span>
      </div>

      <div class="d-flex gap-2 align-items-center">
        <button id="btnReset" class="btn btn-outline-secondary btn-sm fw-semibold" type="button">
          <i class="bi bi-arrow-counterclockwise"></i> Reset
        </button>

        {# menu export (plus clean) #}
        <div class="dropdown">
          <button class="btn btn-warning btn-sm fw-semibold dropdown-toggle" type="button"
                  data-bs-toggle="dropdown" aria-expanded="false">
            <i class="bi bi-download"></i> Export
          </button>
          <ul class="dropdown-menu dropdown-menu-end" id="exportMenu">
            {# rempli par DataTables #}
          </ul>
        </div>
      </div>
    </div>
  </div>

  {# ===== TABLE ===== #}
  <div class="table-card mb-4 p-3">
    <table id="tableauFactures" class="table table-hover align-middle mb-0" style="width:100%">
      <thead>
        <tr class="text-center align-middle">
          <th>Numéro</th>
          <th>Destinataire</th>
          <th style="width:130px">Date émission</th>

          <th>HT</th>          {# ✅ AJOUT #}
          <th>TVA</th>
          <th>Débours</th>     {# ✅ AJOUT #}
          <th>TTC</th>
          <th>Payé</th>
          <th>Reste</th>

          <th style="width:170px">Statut</th>
          <th class="action-column"></th>
        </tr>
      </thead>

      <tbody><tr><td colspan="11"></td></tr></tbody>
    </table>

  </div>


<script>
$(function () {
  (async () => {

    const $filter = $('#factureStatusFilter');
    let baseline = null; // total général entité (non filtré)

    const $periodType = $('#periodTypeFilter');
    const $yearFilter = $('#yearFilter');
    const $monthFilter = $('#monthFilter');
    const $quarterFilter = $('#quarterFilter');

    function getSelectedPayeurUserIds(){
      return $('.payeur-user-check:checked').map(function(){ return $(this).val(); }).get();
    }
    function getSelectedPayeurEntrepriseIds(){
      return $('.payeur-ent-check:checked').map(function(){ return $(this).val(); }).get();
    }
    function refreshPayeurBadges(){
      $('#badgePayeurUsers').text(getSelectedPayeurUserIds().length);
      $('#badgePayeurEnt').text(getSelectedPayeurEntrepriseIds().length);
    }
    function selectAllOnLoad(){
      $('.payeur-user-check').prop('checked', true);
      $('.payeur-ent-check').prop('checked', true);
      $('#searchPayeurUsers').val('');
      $('#searchPayeurEnt').val('');
      refreshPayeurBadges();
    }
    selectAllOnLoad();
    togglePeriodControls();

    function togglePeriodControls(){
      const t = $periodType.val() || 'all';

      // ✅ Affichage selon le type
      // all      -> rien
      // year     -> année
      // month    -> année + mois
      // quarter  -> année + trimestre
      const showYear    = (t === 'year' || t === 'month' || t === 'quarter');
      const showMonth   = (t === 'month');
      const showQuarter = (t === 'quarter');

      $yearFilter.toggleClass('d-none', !showYear);
      $monthFilter.toggleClass('d-none', !showMonth);
      $quarterFilter.toggleClass('d-none', !showQuarter);

      // ✅ Reset des contrôles non utilisés
      if (!showYear)    $yearFilter.val('all');
      if (!showMonth)   $monthFilter.val('all');
      if (!showQuarter) $quarterFilter.val('all');
    }
    


    function euro(cents){
      const v = (cents || 0) / 100;
      return v.toLocaleString('fr-FR', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €';
    }

    function nowLabel(){
      const d = new Date();
      return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
    }

    function initTooltips(){
      document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => {
        bootstrap.Tooltip.getOrCreateInstance(el);
      });
    }

    function clampPct(x){
      return Math.max(0, Math.min(100, x));
    }

    function pct(part, total){
      return total > 0 ? clampPct(Math.round((part / total) * 100)) : 0;
    }

    async function loadBaseline(){
      try {
        const res = await fetch("{{ path('app_administrateur_facture_kpis', { entite: entite.id }) }}", {
          headers: { 'X-Requested-With': 'XMLHttpRequest' }
        });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        baseline = await res.json(); // {count, ttcCents, paidCents, remainingCents}
      } catch (e) {
        baseline = null;
        console.warn('[Factures] Baseline KPIs indisponible:', e);
      }
    }

    function applyKpis(k){
      const ttc = k?.ttcCents || 0;
      const paid = k?.paidCents || 0;
      const remaining = k?.remainingCents || 0;
      const count = k?.count || 0;

      // valeurs
      $('#kpi-count').text(count);
      $('#kpi-ttc').text(euro(ttc));
      $('#kpi-paid').text(euro(paid));
      $('#kpi-remaining').text(euro(remaining));

      // baseline (fallback sur filtré si baseline KO)
      const baseTtc  = (baseline && typeof baseline.ttcCents === 'number') ? baseline.ttcCents : ttc;
      const basePaid = (baseline && typeof baseline.paidCents === 'number') ? baseline.paidCents : paid;
      const baseRem  = (baseline && typeof baseline.remainingCents === 'number') ? baseline.remainingCents : remaining;
      const baseCnt  = (baseline && typeof baseline.count === 'number') ? baseline.count : count;

      // jauges par rapport au total général
      const pctTtc   = pct(ttc, baseTtc);
      const pctPaid  = pct(paid, basePaid);
      const pctRem   = pct(remaining, baseRem);
      const pctCount = pct(count, baseCnt);

      $('#kpi-bar-count').css('width', pctCount + '%');
      $('#kpi-bar-ttc').css('width', pctTtc + '%');
      $('#kpi-bar-paid').css('width', pctPaid + '%');
      $('#kpi-bar-remaining').css('width', pctRem + '%');

      // tooltips jauges (optionnel mais cool)
      $('#kpi-bar-count').closest('.kpi-bar')
        .attr('data-bs-toggle','tooltip')
        .attr('title', `Filtré : ${pctCount}% du nombre total (${baseline ? baseline.count : count})`);
      $('#kpi-bar-ttc').closest('.kpi-bar')
        .attr('data-bs-toggle','tooltip')
        .attr('title', `Filtré : ${pctTtc}% du TTC total (${euro(baseTtc)})`);
      $('#kpi-bar-paid').closest('.kpi-bar')
        .attr('data-bs-toggle','tooltip')
        .attr('title', `Filtré : ${pctPaid}% du total payé (${euro(basePaid)})`);
      $('#kpi-bar-remaining').closest('.kpi-bar')
        .attr('data-bs-toggle','tooltip')
        .attr('title', `Filtré : ${pctRem}% du reste total (${euro(baseRem)})`);

      initTooltips();
    }

    function enableDtDropdownOutsideScroll(){
      // quand un dropdown s'ouvre
      document.addEventListener('show.bs.dropdown', function (e) {
        const toggle = e.target;
        const dd = toggle.closest('.dropdown, .btn-group');
        if (!dd) return;

        const menu = dd.querySelector('.dropdown-menu');
        if (!menu) return;

        if (!menu.__originalParent) menu.__originalParent = dd;

        document.body.appendChild(menu);
        menu.classList.add('dt-floating-dropdown');

        const rect = toggle.getBoundingClientRect();

        // ⚠️ après appendChild, le menu a un layout -> on mesure
        const menuRect = menu.getBoundingClientRect();
        const isEnd = menu.classList.contains('dropdown-menu-end');

        const top = rect.bottom + window.scrollY + 6;
        let left = isEnd
          ? rect.right + window.scrollX - menuRect.width
          : rect.left + window.scrollX;

        left = Math.max(8, Math.min(left, window.scrollX + window.innerWidth - menuRect.width - 8));

        menu.style.position = 'absolute';
        menu.style.top = `${top}px`;
        menu.style.left = `${left}px`;
        menu.style.zIndex = '9999';
      });

      // quand un dropdown se ferme -> on remet le menu dans son parent
      document.addEventListener('hidden.bs.dropdown', function (e) {
        const toggle = e.target;
        const dd = toggle.closest('.dropdown, .btn-group');
        if (!dd) return;

        const menus = document.querySelectorAll('body .dt-floating-dropdown');
        menus.forEach(m => {
          if (m.__originalParent === dd) {
            dd.appendChild(m);
            m.classList.remove('dt-floating-dropdown');
            m.style.position = '';
            m.style.top = '';
            m.style.left = '';
            m.style.zIndex = '';
          }
        });
      });

      // si on scroll/resize pendant que le menu est ouvert -> on ferme
      window.addEventListener('scroll', () => {
        document.querySelectorAll('[aria-expanded="true"][data-bs-toggle="dropdown"]').forEach(btn => btn.click());
      }, true);

      window.addEventListener('resize', () => {
        document.querySelectorAll('[aria-expanded="true"][data-bs-toggle="dropdown"]').forEach(btn => btn.click());
      });
    }

    // ✅ baseline (total général) une seule fois au démarrage
    await loadBaseline();

    const table = $('#tableauFactures').DataTable({
      serverSide:true,
      processing:true,
      autoWidth:false,
      scrollX:true,
      scrollCollapse:true,
      responsive:false,

      ajax:{
        url: "{{ path('app_administrateur_facture_ajax', { entite: entite.id }) }}",
        type:"POST",
        data: function(d){
          d.statusFilter = $filter.val() || 'all';

          d.periodType = $periodType.val() || 'all';
          d.yearFilter = $yearFilter.val() || 'all';
          d.monthFilter = $monthFilter.val() || 'all';
          d.quarterFilter = $quarterFilter.val() || 'all';

          d.payeurUserIds = getSelectedPayeurUserIds();
          d.payeurEntrepriseIds = getSelectedPayeurEntrepriseIds();
        }

      },

      dom:
        '<"dt-top d-flex flex-wrap gap-2 align-items-center justify-content-between"'
          + '<"dt-actions d-flex gap-2 align-items-center"B>'
          + '<"dt-search"f>'
        + '>'
        + 'rt'
        + '<"dt-bottom-internal d-flex flex-wrap gap-2 align-items-center justify-content-between"lip>',

      buttons:[
        { extend:'copy',  title:'Factures', text:'Copier' },
        { extend:'csv',   title:'Factures', text:'CSV' },
        { extend:'excel', title:'Factures', text:'Excel' },
        { extend:'pdf',   title:'Factures', text:'PDF' },
        { extend:'print', title:'Factures', text:'Imprimer' },
      ],

      lengthMenu:[[10,25,50,100,500],[10,25,50,100,500]],

      columns:[
        { data:'numero' },
        { data:'dest' },
        { data:'dateEmission' },

        { data:'ht' },
        { data:'tva' },
        { data:'debours' },
        { data:'ttc' },
        { data:'paid' },
        { data:'remaining' },

        { data:'status' },
        { data:'actions' }
      ],

      columnDefs: [
      // ✅ centre TOUS les headers
      { targets: '_all', className: 'dt-head-center' },

      // ✅ puis tes règles existantes
      { targets:[3,4,5,6,7,8,10], className:'text-end' },
      { targets:10, className:'action-column text-end', orderable:false, searchable:false, width:'0px' },
      { targets:[3,4,5,6,7,8,9,10], searchable:false },
      { targets:[2,9,10], render: function(data){ return data; } },
    ],


      order:[[2,'desc']],
      language:{ url:'https://cdn.datatables.net/plug-ins/2.2.2/i18n/fr-FR.json' },
      deferRender:true,

      initComplete:function(){
        // export buttons -> dropdown menu
        const api = this.api();
        const container = api.buttons().container();
        const $btns = $(container).find('button');

        $('#exportMenu').empty();
        $btns.each(function(){
          const $b = $(this);
          const label = $b.text().trim();

          const icon = label === 'Excel' ? 'bi-file-earmark-excel' :
                       label === 'PDF' ? 'bi-file-earmark-pdf' :
                       label === 'CSV' ? 'bi-filetype-csv' :
                       label === 'Imprimer' ? 'bi-printer' :
                       label === 'Copier' ? 'bi-clipboard' : 'bi-download';

          const $item = $(`
            <li>
              <a class="dropdown-item d-flex align-items-center gap-2" href="#">
                <i class="bi ${icon}"></i> <span>${label}</span>
              </a>
            </li>
          `);

          $item.on('click', function(e){
            e.preventDefault();
            $b.trigger('click');
          });

          $('#exportMenu').append($item);
        });

        $(container).hide();
      }
    });


    // ✅ Dropdown actions factures : on "flotte" le menu hors du scroll DataTables (sinon il est clippé)
    (function enableFactureActionsFloatingDropdown(){
      document.addEventListener('show.bs.dropdown', function(e){
        const toggle = e.target;
        if (!toggle.closest('.facture-actions')) return;

        const dd = toggle.closest('.dropdown, .btn-group');
        if (!dd) return;

        const menu = dd.querySelector('.dropdown-menu');
        if (!menu) return;

        if (!menu.__originalParent) menu.__originalParent = dd;

        document.body.appendChild(menu);
        menu.classList.add('facture-floating-dropdown');

        const rect = toggle.getBoundingClientRect();

        menu.style.position = 'absolute';
        menu.style.top = '0px';
        menu.style.left = '0px';
        menu.style.display = 'block';

        const menuRect = menu.getBoundingClientRect();
        const isEnd = menu.classList.contains('dropdown-menu-end');

        const top = rect.bottom + window.scrollY + 6;

        let left = isEnd
          ? (rect.right + window.scrollX - menuRect.width)
          : (rect.left + window.scrollX);

        left = Math.max(8, Math.min(left, window.scrollX + window.innerWidth - menuRect.width - 8));

        menu.style.top = `${top}px`;
        menu.style.left = `${left}px`;
      }, true);

      document.addEventListener('hidden.bs.dropdown', function(e){
        const toggle = e.target;
        if (!toggle.closest('.facture-actions')) return;

        const dd = toggle.closest('.dropdown, .btn-group');
        if (!dd) return;

        document.querySelectorAll('body .facture-floating-dropdown').forEach(menu => {
          if (menu.__originalParent === dd) {
            dd.appendChild(menu);
            menu.classList.remove('facture-floating-dropdown');
            menu.style.position = '';
            menu.style.top = '';
            menu.style.left = '';
            menu.style.display = '';
          }
        });
      }, true);

      // ✅ si scroll/resize : ferme les menus ouverts
      window.addEventListener('scroll', () => {
        document.querySelectorAll('.facture-actions [aria-expanded="true"][data-bs-toggle="dropdown"]')
          .forEach(btn => btn.click());
      }, true);

      window.addEventListener('resize', () => {
        document.querySelectorAll('.facture-actions [aria-expanded="true"][data-bs-toggle="dropdown"]')
          .forEach(btn => btn.click());
      }, true);
    })();




    function reloadAll(){
      table.ajax.reload(null, true);
    }

    // ✅ handlers propres (namespaces) : on ne casse pas les autres
    $filter.off('change.fact').on('change.fact', reloadAll);

    // ✅ période : on toggle + on reload (dans le bon ordre)
    $periodType.off('change.fact').on('change.fact', function(){
      togglePeriodControls();

      // ✅ garde-fou : si month/quarter et year=all => on force une année (sinon back filtre mal/retourne tout)
      const t = $periodType.val() || 'all';
      if ((t === 'month' || t === 'quarter') && ($yearFilter.val() === 'all')) {
        $yearFilter.val(String(new Date().getFullYear()));
      }

      reloadAll();
    });

    $yearFilter.off('change.fact').on('change.fact', reloadAll);
    $monthFilter.off('change.fact').on('change.fact', reloadAll);
    $quarterFilter.off('change.fact').on('change.fact', reloadAll);

    $(document).on('change', '.payeur-user-check, .payeur-ent-check', function(){
      refreshPayeurBadges();
      reloadAll();
    });

    $('#searchPayeurUsers').on('input', function(){
      const q = ($(this).val() || '').toLowerCase();
      $('#listPayeurUsers .user-item').each(function(){
        $(this).toggle(($(this).data('text') || '').includes(q));
      });
    });

    $('#searchPayeurEnt').on('input', function(){
      const q = ($(this).val() || '').toLowerCase();
      $('#listPayeurEnt .ent-item').each(function(){
        $(this).toggle(($(this).data('text') || '').includes(q));
      });
    });

    $('#usersSelectAll').on('click', function(){
      $('.payeur-user-check').prop('checked', true);
      refreshPayeurBadges();
      reloadAll();
    });
    $('#usersSelectNone').on('click', function(){
      $('.payeur-user-check').prop('checked', false);
      refreshPayeurBadges();
      reloadAll();
    });

    $('#entSelectAll').on('click', function(){
      $('.payeur-ent-check').prop('checked', true);
      refreshPayeurBadges();
      reloadAll();
    });
    $('#entSelectNone').on('click', function(){
      $('.payeur-ent-check').prop('checked', false);
      refreshPayeurBadges();
      reloadAll();
    });


    // ✅ KPIs filtrés à chaque réponse serveur (/ajax)
    table.on('xhr.dt', function(e, settings, json){
      if(json && json.kpis){
        applyKpis(json.kpis);
      }
    });

    // ✅ tooltips + refresh label
    initTooltips();
    table.on('draw.dt', function(){
      initTooltips();
      $('#hero-last-refresh').text('Maj : ' + nowLabel());
    });



    // ✅ reset
    $('#btnReset').off('click').on('click', function(){
      $filter.val('all');

      $periodType.val('all');
      $yearFilter.val('all');
      $monthFilter.val('all');
      $quarterFilter.val('all');

      $('.payeur-user-check, .payeur-ent-check').prop('checked', false);
      $('#searchPayeurUsers').val('');
      $('#searchPayeurEnt').val('');
      refreshPayeurBadges();

      togglePeriodControls();

      table.search('');
      table.order([[3,'desc']]); // date_emission
      table.ajax.reload(null, true);
    });


    // ✅ dropdown anti-clipping
    enableDtDropdownOutsideScroll();

    // (optionnel) init KPIs à blanc (si tu veux éviter "—" jusqu’au 1er xhr)
    // applyKpis({count:0, ttcCents:0, paidCents:0, remainingCents:0});

  })();
});
</script>

{% endblock %}
