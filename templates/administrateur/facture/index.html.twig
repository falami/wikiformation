{# templates/administrateur/facture/index.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}Factures{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }


    /* ====== HERO (glass + accent) ====== */
    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;

      /* Ombre douce premium */
      box-shadow: 0 18px 50px rgba(0,0,0,.14);

      /* Fond piloté par les couleurs de l'entité */
      background:
        /* halo clair (tertiaire) */
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        /* halo accent (secondaire) */
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        /* voile subtil (quaternaire) pour la profondeur */
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        /* dégradé principal (principal -> plus clair) */
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    /* léger glass highlight */
    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    /* barre accent = secondaire (et glow basé sur secondaire) */
    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }
    /* ===== Chips HERO (comme Sessions) ===== */
    .hero .chip{
      display:inline-flex;
      align-items:center;
      gap:.5rem;
      padding:.32rem .7rem;
      border-radius:999px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(255,255,255,.14);
      backdrop-filter: blur(6px);
      font-size:.82rem;
      color: rgba(255,255,255,.92);
      white-space: nowrap;
    }
    .hero .chip i{ color: var(--theme-color-secondaire); }

    .hero .chip--pill{
      background: color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
      border-color: color-mix(in srgb, var(--theme-color-secondaire) 28%, rgba(255,255,255,.14));
      color:#fff;
    }

    .hero .subtitle{ opacity:.86; }

    /* boutons du hero (cohérent + “premium”) */
    .hero .btn{
      border-radius:14px;
      font-weight:800;
    }

    /* ton btn outline “theme” déjà présent ? sinon ajoute-le */
    .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }

    /* ====== KPI CARDS ====== */
    .kpi-card{
      border: 1px solid rgba(0,0,0,.06);
      box-shadow: 0 10px 26px rgba(0,0,0,.06);
      border-radius: 18px;
      overflow:hidden;
      background: #fff;
      position:relative;
    }
    .kpi-card:before{
      content:"";
      position:absolute; inset:0;
      background: radial-gradient(700px 120px at 20% 0%, rgba(255,193,7,.12), transparent 55%);
      pointer-events:none;
    }
    .kpi-ico{
      width:44px; height:44px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }

    .filter-icon{
      width:38px; height:38px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }
    .kpi-label{ color: rgba(0,0,0,.55); font-size:.85rem }
    .kpi-value{ font-weight: 800; font-size: 1.6rem; letter-spacing:-.02em }
    .kpi-sub{ color: rgba(0,0,0,.50); font-size:.82rem }
    .kpi-bar{
      height: 6px; border-radius: 999px;
      background: rgba(0,0,0,.06);
      overflow:hidden;
    }
    .kpi-bar > span{
      display:block; height:100%;
      width: 0%;
      background: var(--theme-color-secondaire);
      border-radius: 999px;
      transition: width .35s ease;
    }

    /* ====== TOOLBAR ====== */
    .toolbar{
      border-radius: 16px;
      background: #fff;
      border: 1px solid rgba(0,0,0,.06);
      box-shadow: 0 10px 24px rgba(0,0,0,.05);
      padding: .85rem;
    }
    .toolbar .hint{
      font-size:.85rem;
      color: rgba(0,0,0,.55);
    }
    .chip{
      display:inline-flex; align-items:center; gap:.5rem;
      padding:.35rem .7rem;
      border-radius:999px;
      background: rgba(0,0,0,.03);
      border: 1px solid rgba(0,0,0,.06);
      font-size:.85rem;
      color: rgba(0,0,0,.65);
    }

    /* ====== DATATABLE CARD ====== */
    .table-card{
      border-radius: 18px;
      background: #fff;
      border: 1px solid rgba(0,0,0,.06);
      box-shadow: 0 12px 30px rgba(0,0,0,.06);
      overflow:hidden;
    }
    table.dataTable{ margin:0 !important; }
    table.dataTable thead th{
      position: sticky; top: 0; z-index: 2;
      background: #f7f8fa !important;
      border-bottom: 1px solid rgba(0,0,0,.08) !important;
      text-transform: uppercase;
      font-size: .78rem;
      letter-spacing:.06em;
      color: rgba(0,0,0,.55);
 
    }
    #tableauFactures tbody tr:hover{
      background: rgba(255,193,7,.06) !important;
    }

    /* DataTables UI polish */
    .dataTables_wrapper .dataTables_filter input{
      border-radius: 999px !important;
      padding: .45rem .85rem !important;
      border: 1px solid rgba(0,0,0,.12) !important;
      outline: none !important;
      box-shadow: none !important;
    }
    .dataTables_wrapper .dataTables_length select{
      border-radius: 999px !important;
      border: 1px solid rgba(0,0,0,.12) !important;
      padding: .35rem .7rem !important;
    }
    .dt-top{
      padding: .75rem .85rem;
      border-bottom: 1px solid rgba(0,0,0,.06);
      background: #fff;
    }
    .dt-bottom{
      padding: .75rem .85rem;
      border-top: 1px solid rgba(0,0,0,.06);
      background: #fff;
    }
    .dt-actions .btn{
      border-radius: 999px;
      font-weight: 700;
      padding: .40rem .75rem;
    }

    /* mobile sticky action col */
    @media (max-width: 768px){
      table.dataTable td.action-column{
        position: sticky; right:0; background:#fff; z-index:5;
        box-shadow: -12px 0 18px -14px rgba(0,0,0,.22);
      }
      .hero{ border-radius: 16px; }
    }


    /* ✅ Zebra propre (1 ligne sur 2) — on colore les cellules pour battre Bootstrap */
    #tableauFactures tbody tr:nth-child(odd) > *{
      background-color: #fff !important;
    }
    #tableauFactures tbody tr:nth-child(even) > *{
      background-color: rgba(35,51,66,.035) !important;
    }

    /* Hover au dessus de tout */
    #tableauFactures tbody tr:hover > *{
      background-color: rgba(255,193,7,.08) !important;
    }

    /* Un peu plus d'air vertical */
    #tableauFactures tbody td{
      padding-top: .75rem !important;
      padding-bottom: .75rem !important;
    }

    /* ✅ Espace VISUEL entre le tableau et la pagination/info (le point clé) */
    .dataTables_wrapper .dt-bottom-internal{
      margin-top: .75rem !important;        /* <-- c'est ça qui "décolle" */
      padding: 1rem .85rem !important;
      border-top: 1px solid rgba(0,0,0,.06);
      background: #fff;
    }




    /* ✅ 1) Crée un vrai espace entre le tableau et le bas DataTables */
    #tableauFactures.dataTable{
      margin-bottom: .85rem !important; /* bat ton margin:0!important */
    }

    /* ✅ 2) Style + respiration de la barre du bas (info + pagination) */
    #tableauFactures_wrapper .dt-bottom-internal{
      padding: 1rem .85rem !important;
      background: #fff;
      border-top: 1px solid rgba(0,0,0,.06);
    }

    /* ✅ 3) Optionnel : on “décolle” encore un peu les éléments internes */
    #tableauFactures_wrapper .dataTables_info,
    #tableauFactures_wrapper .dataTables_paginate,
    #tableauFactures_wrapper .dataTables_length{
      margin-top: .25rem !important;
    }



    #tableauFactures tbody tr:nth-child(even) td{
      background-color: rgba(35,51,66,.035) !important;
    }
    #tableauFactures tbody tr:nth-child(odd) td{
      background-color: #fff !important;
    }
    #tableauFactures tbody tr:hover td{
      background-color: rgba(255,193,7,.08) !important;
    }


    /* Empêche le retour à la ligne dans la colonne actions */
    #tableauFactures td.action-column{
      white-space: nowrap;
    }

    /* Le dropdown doit passer au-dessus de la barre du bas */
    body .dt-floating-dropdown{
      z-index: 9999 !important;
    }

    /* ✅ Montants : ne jamais casser entre le nombre et le € */
    #tableauFactures td:nth-child(4),
    #tableauFactures td:nth-child(5),
    #tableauFactures td:nth-child(6),
    #tableauFactures td:nth-child(7),
    #tableauFactures td:nth-child(8){
      white-space: nowrap;
    }


    /* ✅ Colonne actions plus compacte */
    #tableauFactures th:last-child,
    #tableauFactures td:last-child{
      width: 190px !important;
      min-width: 190px !important;
      white-space: nowrap;
    }

    /* Optionnel : réduire un peu le padding des actions pour gagner encore */
    #tableauFactures td.action-column{
      padding-left: .35rem !important;
      padding-right: .35rem !important;
    }


    /* ===== Actions : largeur MINIMALE ABSOLUE ===== */
    #tableauFactures th.action-column,
    #tableauFactures td.action-column{
      width: 1% !important;
      min-width: 1% !important;
      max-width: 1% !important;
      white-space: nowrap !important;
      padding-left: .25rem !important;
      padding-right: .25rem !important;
      text-align: right;
    }




    /* Colonne Numéro : un peu plus large + autorise le retour à la ligne */
    #tableauFactures th:nth-child(1),
    #tableauFactures td:nth-child(1){
      min-width: 220px;
      white-space: normal !important;
    }

    /* Bloc numéro + note */
    .fact-num-wrap{ line-height: 1.15; }
    .fact-num{
      font-weight: 800;
      letter-spacing: .02em;
    }

    /* Note façon "chip" discrète */
    .fact-note{
      margin-top: .35rem;
      display: inline-flex;
      align-items: flex-start;
      gap: .35rem;
      padding: .25rem .5rem;
      border-radius: 12px;
      background-color: var(--bs-info-bg-subtle);
      border: 1px solid rgba(0,0,0,.06);
      color: black;
      font-size: .80rem;
      max-width: 100%;
    }

    /* Tronquer à 2 lignes */
    .fact-note-text{
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      word-break: break-word;
    }








    /* =========================
      ✅ Dropdown "premium" (même design que Paiements)
      ========================= */

    /* Le bouton toggle (dans la chip) */
    .chip .dropdown-toggle{
      border-radius: 999px;
      border: 1px solid rgba(0,0,0,.10);
      background: rgba(255,255,255,.75);
      box-shadow: 0 8px 18px rgba(0,0,0,.06);
      color: rgba(0,0,0,.72);
      font-weight: 700;
      padding: .38rem .70rem;
      line-height: 1.1;
      transition: transform .08s ease, box-shadow .18s ease, border-color .18s ease;
    }
    .chip .dropdown-toggle:hover{
      border-color: rgba(0,0,0,.16);
      box-shadow: 0 12px 22px rgba(0,0,0,.08);
    }
    .chip .dropdown-toggle:active{
      transform: translateY(1px);
    }

    /* Badge compteur dans le bouton */
    .chip .dropdown-toggle .badge{
      border-radius: 999px;
      font-weight: 800;
      letter-spacing: .02em;
    }

    /* Le menu */
    .toolbar .dropdown-menu{
      border-radius: 16px;
      border: 1px solid rgba(0,0,0,.10);
      box-shadow: 0 18px 46px rgba(0,0,0,.18);
      padding: .65rem;
      background:
        radial-gradient(900px 220px at 10% 0%, rgba(255,193,7,.10), transparent 55%),
        #fff;
      overflow: hidden;
    }

    /* Petit "header" du menu : zone recherche */
    .toolbar .dropdown-menu .form-control{
      border-radius: 999px;
      border: 1px solid rgba(0,0,0,.12);
      background: rgba(255,255,255,.95);
      padding: .42rem .85rem;
      box-shadow: none !important;
    }
    .toolbar .dropdown-menu .form-control:focus{
      border-color: rgba(255,193,7,.55);
      box-shadow: 0 0 0 .2rem rgba(255,193,7,.18) !important;
    }

    /* Boutons Tout / Aucun */
    .toolbar .dropdown-menu .btn{
      border-radius: 999px;
      border: 1px solid rgba(0,0,0,.10);
      background: rgba(0,0,0,.03);
      font-weight: 700;
      padding: .35rem .7rem;
    }
    .toolbar .dropdown-menu .btn:hover{
      background: rgba(255,193,7,.12);
      border-color: rgba(255,193,7,.35);
    }

    /* Liste scrollable (comme Paiements) */
    .toolbar .dropdown-menu [id^="list"], /* si tu gardes les ids list... */
    .toolbar .dropdown-menu .dropdown-list{
      border-radius: 12px;
      border: 1px solid rgba(0,0,0,.06);
      background: rgba(255,255,255,.92);
      padding: .25rem;
      max-height: 280px;
      overflow: auto;
    }

    /* Item ligne */
    .toolbar .dropdown-menu .dropdown-item{
      border-radius: 12px;
      padding: .45rem .55rem;
      margin: .10rem 0;
      border: 1px solid transparent;
      background: transparent;
    }
    .toolbar .dropdown-menu .dropdown-item:hover{
      background: rgba(255,193,7,.10);
      border-color: rgba(255,193,7,.20);
    }

    /* Checkbox */
    .toolbar .dropdown-menu .form-check-input{
      width: 1.05rem;
      height: 1.05rem;
      border-radius: .35rem;
      border: 1px solid rgba(0,0,0,.18);
      margin-top: 0;
    }
    .toolbar .dropdown-menu .form-check-input:checked{
      background-color: var(--theme-color-secondaire);
      border-color: rgba(0,0,0,.10);
    }

    /* Texte secondaire */
    .toolbar .dropdown-menu .text-muted{
      color: rgba(0,0,0,.52) !important;
    }

    /* Scrollbar clean */
    .toolbar .dropdown-menu *::-webkit-scrollbar{ width: 10px; }
    .toolbar .dropdown-menu *::-webkit-scrollbar-track{ background: rgba(0,0,0,.04); border-radius: 999px; }
    .toolbar .dropdown-menu *::-webkit-scrollbar-thumb{ background: rgba(0,0,0,.18); border-radius: 999px; }
    .toolbar .dropdown-menu *::-webkit-scrollbar-thumb:hover{ background: rgba(0,0,0,.26); }







/* =========================
   ✅ Actions factures (même design que Devis)
   ========================= */

/* largeur mini colonne actions */
#tableauFactures th:last-child,
#tableauFactures td:last-child{
  width: 1% !important;
  min-width: 0 !important;
  white-space: nowrap;
}

/* boutons compacts */
.facture-actions .btn{
  padding: .32rem .55rem;
}

/* bouton principal */
.facture-actions .facture-main{
  background: rgba(255,255,255,.85);
  border-color: rgba(0,0,0,.12);
  box-shadow: 0 10px 22px rgba(0,0,0,.06);
}
.facture-actions .facture-main:hover{
  box-shadow: 0 14px 28px rgba(0,0,0,.10);
  border-color: rgba(0,0,0,.18);
}

/* split */
.facture-actions .facture-split{
  padding-left: .55rem;
  padding-right: .55rem;
  border-color: rgba(0,0,0,.12);
  background: rgba(255,255,255,.85);
}

/* menu dropdown */
.facture-actions .facture-menu{
  border-radius: 16px;
  border: 1px solid rgba(0,0,0,.10);
  box-shadow: 0 18px 46px rgba(0,0,0,.18);
  padding: .55rem;
  background:
    radial-gradient(900px 220px at 10% 0%, rgba(255,193,7,.10), transparent 55%),
    #fff;
  overflow: hidden;
}
.facture-actions .facture-menu .dropdown-item{
  border-radius: 12px;
  padding: .50rem .60rem;
  margin: .10rem 0;
  border: 1px solid transparent;
}
.facture-actions .facture-menu .dropdown-item:hover{
  background: rgba(255,193,7,.10);
  border-color: rgba(255,193,7,.22);
}

/* fusion pill (main + split) */
.facture-actions.btn-group .facture-main{
  border-top-right-radius: 0 !important;
  border-bottom-right-radius: 0 !important;
}
.facture-actions.btn-group .facture-split{
  border-top-left-radius: 0 !important;
  border-bottom-left-radius: 0 !important;
  margin-left: -1px;
  position: relative;
}
.facture-actions.btn-group .facture-split:before{
  content:"";
  position:absolute;
  left:0;
  top:20%;
  bottom:20%;
  width:1px;
  background: rgba(0,0,0,.10);
}

/* ne jamais masquer quand dropdown ouvert */
#tableauFactures td.action-column .facture-actions{
  opacity: 1 !important;
  visibility: visible !important;
}
#tableauFactures td.action-column .facture-actions:focus-within{
  opacity: 1 !important;
  visibility: visible !important;
}

/* alignement colonne */
#tableauFactures td.action-column{
  padding-left: 0 !important;
  padding-right: .15rem !important;
  text-align: right;
}

/* ✅ Menu floaté au-dessus de tout */
body .facture-floating-dropdown{
  z-index: 20000 !important;
}

    
#tableauFactures thead th{
  text-align: center !important;
}




/* ✅ centre verticalement les titres (thead) */
#tableauFactures thead th{
  vertical-align: middle !important;
}

/* (optionnel) si tu veux aussi le body */
#tableauFactures tbody td{
  vertical-align: middle;
}



  </style>

  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/style-table.css') }}">
  <link rel="stylesheet" href="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/datatables.min.css"/>
  <link rel="stylesheet" href="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.css"/>
{% endblock %}

{% block javascripts %}
  {{ parent() }}

  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

  <script src="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.js"></script>
{% endblock %}

{% block body %}


  {# ===== HERO (style Sessions / site/index) ===== #}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>

    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-receipt-cutoff me-2" style="color:var(--theme-color-secondaire)"></i>
            Factures
          </h2>

          <div class="subtitle mt-1">
            Pilotage : total TTC, payé, reste, exports & impression.
          </div>

          <div class="d-flex flex-wrap gap-2 mt-3">
            <span class="chip">
              <i class="bi bi-clipboard-check"></i>
              Finance
            </span>

            <span class="chip">
              <i class="bi bi-building"></i>
              {{ entite.nom }}
            </span>

            <span class="chip chip--pill">
              <i class="bi bi-clock-history"></i>
              <span id="hero-last-refresh">—</span>
            </span>
          </div>
        </div>

        <div class="d-flex flex-wrap gap-2">
          <a class="btn btn-light btn-sm fw-semibold"
            href="{{ path('app_administrateur_facture_new', {'entite': entite.id}) }}">
            <i class="bi bi-file-earmark-plus me-1"></i> Nouvelle facture
          </a>

          <a class="btn btn-outline-theme btn-sm fw-semibold"
            href="{{ path('app_administrateur_paiement_index', {'entite': entite.id}) }}">
            <i class="bi bi-credit-card-2-front me-1"></i> Paiements
          </a>

          <a class="btn btn-outline-theme btn-sm fw-semibold"
            href="{{ path('app_administrateur_avoir_index', {'entite': entite.id}) }}">
            <i class="bi bi-arrow-counterclockwise me-1"></i> Avoirs
          </a>
        </div>
      </div>
    </div>
  </div>

  {# ===== KPI ===== #}
  <div class="row g-3 mb-3">
    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-files fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Factures</div>
              <div class="kpi-value" id="kpi-count">—</div>
              <div class="kpi-sub" id="kpi-range">Nombre de factures</div>
            </div>
          </div>
          <div class="mt-3 kpi-bar"><span id="kpi-bar-count"></span></div>
        </div>
      </div>
