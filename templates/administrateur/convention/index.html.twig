{# templates/administrateur/convention/index.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}Conventions / Contrats{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }

    /* ===== HERO (exactement comme session/index) ===== */
    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;

      box-shadow: 0 18px 50px rgba(0,0,0,.14);

      background:
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }

    /* Chips HERO (comme session/index) */
    .hero .chip{
      display:inline-flex;
      align-items:center;
      gap:.5rem;
      padding:.32rem .7rem;
      border-radius: 999px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(255,255,255,.14);
      font-size:.82rem;
      color: rgba(255,255,255,.92);
      backdrop-filter: blur(6px);
      white-space: nowrap;
    }
    .hero .chip i{
      color: var(--theme-color-secondaire);
    }
    .hero .chip--pill{
      background: color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
      border-color: color-mix(in srgb, var(--theme-color-secondaire) 28%, rgba(255,255,255,.14));
      color:#fff;
    }

    /* Boutons HERO (comme session/index) */
    .hero .btn{
      border-radius: 14px;
      font-weight: 800;
    }
    .hero .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .hero .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }

    /* ✅ Optionnel : si tu veux garder ton HTML actuel en meta-chip, on l'aligne sur chip */
    .hero .meta-chip{ /* alias */
      display:inline-flex;
      align-items:center;
      gap:.5rem;
      padding:.32rem .7rem;
      border-radius: 999px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(255,255,255,.14);
      font-size:.82rem;
      color: rgba(255,255,255,.92);
      backdrop-filter: blur(6px);
      white-space: nowrap;
    }
    .hero .meta-chip i{ color: var(--theme-color-secondaire); }

    @media (max-width: 768px){
      .hero{ border-radius: 16px; }
    }

    /* ===== KPI CARDS (simple) ===== */
    .kpi-card{
      border: 1px solid rgba(0,0,0,.06);
      box-shadow: 0 10px 26px rgba(0,0,0,.06);
      border-radius: 18px;
      overflow:hidden;
      background: #fff;
      position:relative;
    }
    .kpi-card:before{
      content:"";
      position:absolute; inset:0;
      background: radial-gradient(700px 120px at 20% 0%, rgba(255,193,7,.12), transparent 55%);
      pointer-events:none;
    }
    .kpi-ico{
      width:44px; height:44px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }

    .filter-icon{
      width:38px; height:38px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }
    .kpi-label{ color: rgba(0,0,0,.55); font-size:.85rem }
    .kpi-value{ font-weight: 800; font-size: 1.6rem; letter-spacing:-.02em }
    .kpi-sub{ color: rgba(0,0,0,.50); font-size:.82rem }
    .kpi-bar{
      height: 6px; border-radius: 999px;
      background: rgba(0,0,0,.06);
      overflow:hidden;
    }
    .kpi-bar > span{
      display:block; height:100%;
      width: 0%;
      background: var(--theme-color-secondaire);
      border-radius: 999px;
      transition: width .35s ease;
    }

    /* ===== TOOLBAR ===== */
    .toolbar{
      border-radius: 16px;
      background: #fff;
      border: 1px solid rgba(0,0,0,.06);
      box-shadow: 0 10px 24px rgba(0,0,0,.05);
      padding: .85rem;
    }
    .toolbar .hint{
      font-size:.85rem;
      color: rgba(0,0,0,.55);
    }
    .chip{
      display:inline-flex; align-items:center; gap:.5rem;
      padding:.35rem .7rem;
      border-radius:999px;
      background: rgba(0,0,0,.03);
      border: 1px solid rgba(0,0,0,.06);
      font-size:.85rem;
      color: rgba(0,0,0,.65);
    }

    /* ===== DATATABLE CARD ===== */
    .table-card{
      border-radius: 18px;
      background: #fff;
      border: 1px solid rgba(0,0,0,.06);
      box-shadow: 0 12px 30px rgba(0,0,0,.06);
      overflow:hidden;
    }
    table.dataTable{ margin:0 !important; }
    table.dataTable thead th{
      position: sticky; top: 0; z-index: 2;
      background: #f7f8fa !important;
      border-bottom: 1px solid rgba(0,0,0,.08) !important;
      text-transform: uppercase;
      font-size: .78rem;
      letter-spacing:.06em;
      color: rgba(0,0,0,.55);
    }

    /* DataTables UI polish */
    .dataTables_wrapper .dataTables_filter input{
      border-radius: 999px !important;
      padding: .45rem .85rem !important;
      border: 1px solid rgba(0,0,0,.12) !important;
      outline: none !important;
      box-shadow: none !important;
    }
    .dataTables_wrapper .dataTables_length select{
      border-radius: 999px !important;
      border: 1px solid rgba(0,0,0,.12) !important;
      padding: .35rem .7rem !important;
    }
    .dt-top{
      padding: .75rem .85rem;
      border-bottom: 1px solid rgba(0,0,0,.06);
      background: #fff;
    }
    .dt-bottom-internal{
      padding: 1rem .85rem !important;
      border-top: 1px solid rgba(0,0,0,.06);
      background: #fff;
    }
    .dt-actions .btn{
      border-radius: 999px;
      font-weight: 700;
      padding: .40rem .75rem;
    }

    /* Zebra + hover (on colore les cellules pour battre Bootstrap) */
    #tableauConventions tbody tr:nth-child(odd) > *{ background-color:#fff !important; }
    #tableauConventions tbody tr:nth-child(even) > *{ background-color: rgba(35,51,66,.035) !important; }
    #tableauConventions tbody tr:hover > *{ background-color: rgba(255,193,7,.08) !important; }
    #tableauConventions tbody td{ padding-top:.75rem !important; padding-bottom:.75rem !important; }

    /* Mobile sticky action col */
    @media (max-width: 768px){
      table.dataTable td.action-column{
        position: sticky; right:0; background:#fff; z-index:5;
        box-shadow: -12px 0 18px -14px rgba(0,0,0,.22);
      }
      .hero{ border-radius: 16px; }
    }
  </style>

  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/style-table.css') }}">
  <link rel="stylesheet" href="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/datatables.min.css"/>
  <link rel="stylesheet" href="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.css"/>
{% endblock %}

{% block javascripts %}
  {{ parent() }}

  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

  <script src="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.js"></script>
{% endblock %}

{% block body %}

  {# ===== HERO (même structure que session/index) ===== #}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>

    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-file-earmark-text me-2" style="color:var(--theme-color-secondaire)"></i>
            Conventions / Contrats
          </h2>
          <div class="opacity-75 mt-1">
            Liste centralisée : entreprise, session, formation, PDF & actions.
          </div>

          <div class="d-flex flex-wrap gap-2 mt-3">
            <span class="chip"><i class="bi bi-patch-check"></i> Qualiopi</span>
            <span class="chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
            <span class="chip chip--pill"><i class="bi bi-clock-history"></i> <span id="hero-last-refresh">—</span></span>
          </div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
          <a class="btn btn-light btn-sm fw-semibold"
            href="{{ path('app_administrateur_inscription_index', {'entite': entite.id}) }}">
            <i class="bi bi-people me-1"></i> Inscriptions
          </a>
        </div>
      </div>
    </div>
  </div>

  {# ===== KPI (simple, sans endpoint) ===== #}
  <div class="row g-3 mb-3">
    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-files fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Conventions affichées</div>
              <div class="kpi-value" id="kpi-count">—</div>
              <div class="kpi-sub">Filtrées / page courante</div>
            </div>
          </div>
          <div class="mt-3 kpi-bar"><span id="kpi-bar-count"></span></div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-search fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Recherche</div>
              <div class="kpi-value" id="kpi-search">—</div>
              <div class="kpi-sub">Texte saisi</div>
            </div>
          </div>
          <div class="mt-3 kpi-bar"><span id="kpi-bar-search"></span></div>
        </div>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  {# ===== TOOLBAR ===== #}
  <div class="toolbar mb-3">
    <div class="d-flex flex-wrap gap-2 align-items-center">
      <div class="me-auto d-flex flex-wrap gap-2 align-items-center">
        <span class="chip">
          <i class="bi bi-info-circle"></i>
          Recherche : entreprise, formation, session, ID
        </span>

        <span class="hint d-none d-lg-inline">
          Tu peux exporter (CSV/Excel/PDF/Print) depuis le menu Export.
        </span>
      </div>

      <div class="d-flex gap-2 align-items-center">
        <button id="btnReset" class="btn btn-outline-secondary btn-sm fw-semibold" type="button">
          <i class="bi bi-arrow-counterclockwise"></i> Reset
        </button>

        <div class="dropdown">
          <button class="btn btn-warning btn-sm fw-semibold dropdown-toggle" type="button"
                  data-bs-toggle="dropdown" aria-expanded="false">
            <i class="bi bi-download"></i> Export
          </button>
          <ul class="dropdown-menu dropdown-menu-end" id="exportMenu">
            {# rempli par DataTables #}
          </ul>
        </div>
      </div>
    </div>
  </div>

  {# ===== TABLE ===== #}
  <div class="table-card p-3">
    <table id="tableauConventions" class="table table-hover align-middle mb-0" style="width:100%">
      <thead>
        <tr>
          <th style="width:170px">N°</th>
          <th>Entreprise</th>
          <th>Formation</th>
          <th style="width:170px">Session</th>
          <th style="width:120px">PDF</th>
          <th class="text-end" style="width:260px">Actions</th>
        </tr>
      </thead>
      <tbody><tr><td colspan="6"></td></tr></tbody>

    </table>
  </div>

<script>
$(function () {
  function nowLabel(){
    const d = new Date();
    return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
  }

  const table = $('#tableauConventions').DataTable({
    autoWidth: false,
    scrollX: true,
    scrollCollapse: true,
    responsive: false,

    processing: true,
    serverSide: true,

    ajax: {
      url: "{{ path('app_administrateur_convention_ajax', { entite: entite.id }) }}",
      type: "POST"
    },

    dom:
      '<"dt-top d-flex flex-wrap gap-2 align-items-center justify-content-between"'
        + '<"dt-actions d-flex gap-2 align-items-center"B>'
        + '<"dt-search"f>'
      + '>'
      + 'rt'
      + '<"dt-bottom-internal d-flex flex-wrap gap-2 align-items-center justify-content-between"lip>',

    buttons: [
      { extend: 'copy',  title: 'Conventions', text: 'Copier' },
      { extend: 'csv',   title: 'Conventions', text: 'CSV' },
      { extend: 'excel', title: 'Conventions', text: 'Excel' },
      { extend: 'pdf',   title: 'Conventions', text: 'PDF' },
      { extend: 'print', title: 'Conventions', text: 'Imprimer' },
    ],

    lengthMenu: [[10,25,50,100,500],[10,25,50,100,500]],

    columns: [
      { data:'numero' },
      { data:'entreprise' },
      { data:'formation' },
      { data:'session' },
      { data:'pdf' },
      { data:'actions' }
    ],

    columnDefs: [
      { targets:[4,5], render: function(data){ return data; } },
      { targets:5, className:'action-column text-end', orderable:false, searchable:false },
      { targets:4, orderable:false, searchable:false },
      { targets:0, type:'string' },
    ],

    order: [[0,'desc']],
    language: { url:'https://cdn.datatables.net/plug-ins/2.2.2/i18n/fr-FR.json' },
    deferRender: true,

    initComplete: function(){
      const api = this.api();
      const container = api.buttons().container();
      const $btns = $(container).find('button');

      $('#exportMenu').empty();
      $btns.each(function(){
        const $b = $(this);
        const label = $b.text().trim();

        const icon = label === 'Excel' ? 'bi-file-earmark-excel' :
                     label === 'PDF' ? 'bi-file-earmark-pdf' :
                     label === 'CSV' ? 'bi-filetype-csv' :
                     label === 'Imprimer' ? 'bi-printer' :
                     label === 'Copier' ? 'bi-clipboard' : 'bi-download';

        const $item = $(`
          <li>
            <a class="dropdown-item d-flex align-items-center gap-2" href="#">
              <i class="bi ${icon}"></i> <span>${label}</span>
            </a>
          </li>
        `);

        $item.on('click', function(e){
          e.preventDefault();
          $b.trigger('click');
        });

        $('#exportMenu').append($item);
      });

      $(container).hide();
      $('#hero-last-refresh').text('Maj : ' + nowLabel());
    }
  });

  function refreshKpis(){
    const info = table.page.info();
    const count = info ? info.recordsDisplay : 0;
    const search = (table.search() || '').trim();

    $('#kpi-count').text(count);
    $('#kpi-search').text(search ? 'Oui' : 'Non');

    $('#kpi-bar-count').css('width', count > 0 ? '100%' : '0%');
    $('#kpi-bar-search').css('width', search ? '100%' : '0%');
    $('#hero-last-refresh').text('Maj : ' + nowLabel());
  }

  table.on('draw.dt', refreshKpis);

  $('#btnReset').on('click', function(){
    table.search('').draw();
  });

  refreshKpis();
});
</script>

{% endblock %}
