<div class="btn-group btn-group-sm convention-actions" role="group">

  {# ✅ Bouton principal = éditer #}
  <a class="btn btn-light convention-main"
     data-bs-toggle="tooltip" title="Éditer"
     href="{{ path('app_administrateur_convention_edit', { entite: entite.id, id: c.id }) }}">
    <i class="bi bi-pencil"></i>
  </a>

  {# ✅ Split dropdown #}
  <button type="button"
          class="btn btn-light dropdown-toggle dropdown-toggle-split convention-split"
          data-bs-toggle="dropdown" aria-expanded="false">
    <span class="visually-hidden">Actions</span>
  </button>

  <ul class="dropdown-menu dropdown-menu-end convention-menu">
    <li>
      <a class="dropdown-item d-flex align-items-center"
         href="{{ path('app_administrateur_convention_edit', { entite: entite.id, id: c.id }) }}">
        <i class="bi bi-pencil me-2"></i> Modifier
      </a>
    </li>

    <li>
      <a class="dropdown-item d-flex align-items-center"
         href="{{ path('app_administrateur_convention_show', { entite: entite.id, id: c.id }) }}">
        <i class="bi bi-eye me-2"></i> Ouvrir
      </a>
    </li>


    <li>
      <a class="dropdown-item d-flex align-items-center"
         href="{{ path('app_administrateur_convention_pdf', { entite: entite.id, id: c.id }) }}"
         target="_blank">
        <i class="bi bi-file-earmark-pdf me-2"></i> PDF
      </a>
    </li>
  </ul>
</div>