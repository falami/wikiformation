{% extends 'base_admin.html.twig' %}
{% block title %}Positionnements — Session #{{ session.id }}{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
    }
    .hero{
      border-radius:22px;
      background: linear-gradient(135deg, rgba(35,51,66,.98), rgba(35,51,66,.78));
      color:#fff;
      box-shadow:0 18px 50px rgba(0,0,0,.14);
      overflow:hidden;
    }
    .cardx{
      background:#fff;
      border-radius:18px;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 12px 30px rgba(0,0,0,.06);
      overflow:hidden;
    }
    .badge-soft{
      border:1px solid rgba(0,0,0,.10);
      background: rgba(0,0,0,.03);
      border-radius:999px;
      padding:.25rem .55rem;
      font-weight:800;
      font-size:.8rem;
    }
  </style>
{% endblock %}

{% block body %}
<div class="container-fluid px-3">

  <div class="hero p-4 mb-4">
    <div class="d-flex flex-wrap gap-2 mb-2">
      <span class="meta-chip"><i class="bi bi-ui-checks"></i> Positionnements</span>
      <span class="meta-chip"><i class="bi bi-easel2"></i> Session #{{ session.id }}</span>
      <span class="meta-chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
    </div>
    <h2 class="fw-bold mb-1">Questionnaires attribués à la session</h2>
    <div class="opacity-75">
      Quand tu ajoutes un nouveau stagiaire à la session, il aura automatiquement accès aux questionnaires attribués.
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  <div class="row g-3">
    <div class="col-12 col-xl-4">
      <div class="cardx">
        <div class="p-3 border-bottom fw-bold">
          <i class="bi bi-plus-circle"></i> Ajouter un questionnaire
        </div>

        <div class="p-3">
          {{ form_start(form) }}

            <div class="mb-3">
              <label class="form-label fw-bold">Questionnaire</label>
              {{ form_widget(form.questionnaire, { attr: { class: 'form-select' } }) }}
              {{ form_errors(form.questionnaire) }}
            </div>

            <div class="row g-2">
              <div class="col-6">
                <div class="form-check">
                  {{ form_widget(form.isRequired, { attr: { class: 'form-check-input' } }) }}
                  <label class="form-check-label fw-semibold">{{ form_label(form.isRequired) }}</label>
                </div>
              </div>
              <div class="col-6">
                <label class="form-label fw-bold">Ordre</label>
                {{ form_widget(form.position, { attr: { class: 'form-control' } }) }}
              </div>
            </div>

            <div class="form-check mt-3">
              {{ form_widget(form.generateForExisting, { attr: { class: 'form-check-input' } }) }}
              <label class="form-check-label fw-semibold">
                {{ form_label(form.generateForExisting) }}
              </label>
              <div class="text-muted small">
                Si des stagiaires sont déjà inscrits à cette session, leurs tentatives seront créées tout de suite.
              </div>
            </div>

            <div class="d-grid mt-3">
              <button class="btn btn-warning fw-semibold" type="submit">
                <i class="bi bi-check2-circle"></i> Ajouter
              </button>
            </div>

          {{ form_end(form) }}
        </div>
      </div>
    </div>

    <div class="col-12 col-xl-8">
      <div class="cardx">
        <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
          <div class="fw-bold"><i class="bi bi-list-check"></i> Attributions</div>
          <span class="text-muted small">{{ sessionPositionings|length }} questionnaire(s)</span>
        </div>

        <div class="table-responsive">
          <table class="table align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Ordre</th>
                <th>Questionnaire</th>
                <th>Obligatoire</th>
                <th class="text-end"></th>
              </tr>
            </thead>
            <tbody>
              {% for sp in sessionPositionings %}
                <tr>
                  <td class="fw-bold">{{ sp.position }}</td>
                  <td class="fw-semibold">{{ sp.questionnaire.title }}</td>
                  <td>
                    {% if sp.required %}
                      <span class="badge-soft"><i class="bi bi-star-fill"></i> Oui</span>
                    {% else %}
                      <span class="badge-soft"><i class="bi bi-star"></i> Non</span>
                    {% endif %}
                  </td>
                  <td class="text-end">
                    <form method="post"
                          action="{{ path('app_administrateur_session_positioning_delete', {entite: entite.id, session: session.id, sp: sp.id}) }}"
                          class="d-inline"
                          onsubmit="return confirm('Supprimer cette attribution ?');">
                      <input type="hidden" name="_token" value="{{ csrf_token('del_sp_' ~ sp.id) }}">
                      <button class="btn btn-sm btn-outline-danger fw-semibold">
                        <i class="bi bi-trash"></i>
                      </button>
                    </form>
                  </td>
                </tr>
              {% else %}
                <tr><td colspan="4" class="text-center text-muted py-4">Aucun questionnaire attribué.</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>

      </div>
    </div>
  </div>

</div>
{% endblock %}
