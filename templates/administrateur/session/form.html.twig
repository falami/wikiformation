<script>
document.addEventListener('DOMContentLoaded', function () {
  // … ton code existant …

  // ================== MODALE : NOUVEAU SITE ==================
  const formNewSite = document.getElementById('form-new-site');
  const siteSelect  = document.getElementById('{{ form.site.vars.id }}');
  const siteError   = document.getElementById('new-site-error');

  // URL Symfony (POST)
  const newSiteUrl = "{{ path('app_administrateur_session_site_new', { entite: entite.id }) }}";

  if (formNewSite && siteSelect) {
    formNewSite.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (siteError) {
        siteError.classList.add('d-none');
        siteError.textContent = '';
      }

      const fd = new FormData(formNewSite);

      try {
        const resp = await fetch(newSiteUrl, {
          method: 'POST',
          body: fd,
          headers: { 'X-Requested-With': 'XMLHttpRequest' }
        });

        const data = await resp.json().catch(() => null);

        if (!resp.ok || !data || data.success === false) {
          const msg = data?.message || `Erreur serveur (${resp.status}).`;
          if (siteError) {
            siteError.textContent = msg;
            siteError.classList.remove('d-none');
          }
          return;
        }

        // ✅ Ajoute l’option au select + sélectionne
        const opt = new Option(data.label, String(data.id), true, true);
        siteSelect.add(opt);

        // ✅ Si TomSelect est actif, il faut aussi l’informer
        if (siteSelect.tomselect) {
          siteSelect.tomselect.addOption({ value: String(data.id), text: data.label });
          siteSelect.tomselect.addItem(String(data.id), true);
        } else {
          siteSelect.value = String(data.id);
          siteSelect.dispatchEvent(new Event('change', { bubbles: true }));
        }

        // ✅ Ferme la modale
        const modalEl = document.getElementById('modal-new-site');
        if (modalEl) {
          const modal = bootstrap.Modal.getInstance(modalEl) || new bootstrap.Modal(modalEl);
          modal.hide();
        }

        // ✅ Reset form
        formNewSite.reset();

      } catch (err) {
        if (siteError) {
          siteError.textContent = "Erreur réseau / JS : " + (err?.message || err);
          siteError.classList.remove('d-none');
        }
      }
    });
  }
});
</script>




<script>
document.addEventListener('DOMContentLoaded', function () {

  // ================== MODALE : NOUVEAU STAGIAIRE ==================
  const formNewStagiaire = document.getElementById('form-new-stagiaire');
  const errEl = document.getElementById('new-stagiaire-error');

  const newStagiaireUrl = "{{ path('app_administrateur_session_stagiaire_new', { entite: entite.id }) }}";

  // Collection inscriptions (déjà utilisée dans ton code)
  const wrapIns = document.getElementById('inscriptions-collection');
  const protoIns = wrapIns ? wrapIns.dataset.prototype : null;

  // ⚠️ indexIns existe déjà dans ton script principal, mais ici on le recalcule “safe”
  let localIndexIns = wrapIns ? wrapIns.querySelectorAll('.inscription-item').length : 0;

  function showErr(msg){
    if (!errEl) return;
    errEl.textContent = msg || 'Erreur.';
    errEl.classList.remove('d-none');
  }

  function clearErr(){
    if (!errEl) return;
    errEl.textContent = '';
    errEl.classList.add('d-none');
  }

  // Heuristique : dans une inscription-item, le 1er <select> = stagiaire, le 2e = status
  function getStagiaireSelectFromRow(row){
    if (!row) return null;
    const selects = row.querySelectorAll('select');
    return selects.length ? selects[0] : null;
  }

  function addOptionAndSelect(selectEl, id, label){
    if (!selectEl) return;

    const value = String(id);

    // TomSelect
    if (selectEl.tomselect) {
      selectEl.tomselect.addOption({ value, text: label });
      selectEl.tomselect.addItem(value, true);
      return;
    }

    // Select natif
    const opt = new Option(label, value, true, true);
    selectEl.add(opt);
    selectEl.value = value;
    selectEl.dispatchEvent(new Event('change', { bubbles:true }));
  }

  // Ajoute l’option dans TOUS les selects stagiaire déjà présents
  function addOptionToAllStagiaireSelects(id, label){
    if (!wrapIns) return;

    wrapIns.querySelectorAll('.inscription-item').forEach(row => {
      const s = getStagiaireSelectFromRow(row);
      if (!s) return;

      // évite doublon
      const exists = Array.from(s.options || []).some(o => String(o.value) === String(id));
      if (!exists) {
        if (s.tomselect) s.tomselect.addOption({ value: String(id), text: label });
        else s.add(new Option(label, String(id)));
      }
    });
  }

  function addInscriptionRow(){
    if (!wrapIns || !protoIns) return null;

    const html = protoIns.replace(/__name__/g, localIndexIns++);
    const div = document.createElement('div');
    div.innerHTML = html;
    const row = div.firstElementChild;
    wrapIns.appendChild(row);

    // Important : ton initTomSelectOn/initTomSelectInscriptions existe déjà dans ton gros script.
    // Ici on “ré-initialise” proprement sans casser :
    row.querySelectorAll('select').forEach(el => {
      if (window.TomSelect && el && !el.tomselect) {
        new TomSelect(el, {
          dropdownParent: 'body',
          create: false,
          allowEmptyOption: true,
          sortField: { field: 'text', direction: 'asc' },
          plugins: ['remove_button'],
        });
      }
    });

    // Mets à jour chips/résumé si tes fonctions existent
    if (typeof updateChipIns === 'function') updateChipIns();
    if (typeof refreshResume === 'function') refreshResume();

    return row;
  }

  if (formNewStagiaire) {
    formNewStagiaire.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearErr();

      const fd = new FormData(formNewStagiaire);

      try {
        const resp = await fetch(newStagiaireUrl, {
          method: 'POST',
          body: fd,
          headers: { 'X-Requested-With': 'XMLHttpRequest' }
        });

        const data = await resp.json().catch(() => null);

        if (!resp.ok || !data || data.success === false) {
          showErr(data?.message || `Erreur serveur (${resp.status}).`);
          return;
        }

        // ✅ 1) Ajoute l’option partout (pour les selects déjà existants)
        addOptionToAllStagiaireSelects(data.id, data.label);

        // ✅ 2) Ajoute une ligne “inscription” et sélectionne automatiquement le nouveau stagiaire
        const row = addInscriptionRow();
        if (row) {
          const stagSel = getStagiaireSelectFromRow(row);
          addOptionAndSelect(stagSel, data.id, data.label);

          // status: si tu veux forcer un status par défaut, tu peux le faire ici
          // ex: row.querySelectorAll('select')[1]?.tomselect?.setValue('preinscrit', true);
        }

        // ✅ 3) Ferme modale + reset
        const modalEl = document.getElementById('modal-new-stagiaire');
        if (modalEl) {
          const modal = bootstrap.Modal.getInstance(modalEl) || new bootstrap.Modal(modalEl);
          modal.hide();
        }

        formNewStagiaire.reset();
        clearErr();

      } catch (err) {
        showErr("Erreur réseau / JS : " + (err?.message || err));
      }
    });
  }
});
</script>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const modalEl = document.getElementById('modal-new-site');
  if (!modalEl) return;

  // --- DOM
  const acEl   = document.getElementById('new-site-autocomplete');
  const addrEl = document.getElementById('new-site-adresse');
  const cpEl   = document.getElementById('new-site-cp');
  const villeEl= document.getElementById('new-site-ville');
  const deptEl = document.getElementById('new-site-dept');
  const regEl  = document.getElementById('new-site-region');
  const paysEl = document.getElementById('new-site-pays');

  const latEl  = document.getElementById('new-site-lat');
  const lngEl  = document.getElementById('new-site-lng');
  const placeEl= document.getElementById('new-site-placeId');
  const fmtEl  = document.getElementById('new-site-formatted');
  const dispEl = document.getElementById('new-site-latlng-display');

  const mapDiv = document.getElementById('new-site-map');

  // --- Leaflet state
  let map = null;
  let marker = null;
  let geocodeTimer = null;
  let lastQueryKey = null;
  let lastLatLngSource = 'auto'; // auto|manual
  let pendingLatLng = null;

  function pad6(n){ return Number(n).toFixed(6); }
  function normalize(s){ return (s || '').toString().trim(); }

  function setLatLng(lat, lng, { pan=true, source='manual' } = {}){
    lastLatLngSource = source;

    const latF = pad6(lat), lngF = pad6(lng);
    if (latEl) latEl.value = latF;
    if (lngEl) lngEl.value = lngF;
    if (dispEl) dispEl.textContent = `${latF} / ${lngF}`;

    if (!map) {
      pendingLatLng = { lat, lng, source, pan };
      return;
    }

    if (!marker){
      marker = L.marker([lat, lng], { draggable:true }).addTo(map);
      marker.on('dragend', () => {
        const p = marker.getLatLng();
        setLatLng(p.lat, p.lng, { pan:false, source:'manual' });
      });
    } else {
      marker.setLatLng([lat, lng]);
    }

    if (pan) {
      const targetZoom = Math.max(map.getZoom(), 16);
      map.setView([lat, lng], targetZoom, { animate:true });
    }
  }

  function initMapIfNeeded(){
    if (map || !mapDiv) return;

    map = L.map('new-site-map', { scrollWheelZoom: true }).setView([46.603354, 1.888334], 6);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 19 }).addTo(map);

    map.on('click', (e) => setLatLng(e.latlng.lat, e.latlng.lng, { source:'manual' }));

    if (pendingLatLng) {
      const { lat, lng, source, pan } = pendingLatLng;
      pendingLatLng = null;
      setLatLng(lat, lng, { source, pan });
    }
  }

  function clearLatLng(){
    lastLatLngSource = 'auto';
    if (latEl) latEl.value = '';
    if (lngEl) lngEl.value = '';
    if (placeEl) placeEl.value = '';
    if (fmtEl) fmtEl.value = '';
    if (dispEl) dispEl.textContent = '-';
    if (map && marker){
      map.removeLayer(marker);
      marker = null;
    }
  }

  function buildQuery(){
    const a  = normalize(addrEl?.value);
    const cp = normalize(cpEl?.value);
    const v  = normalize(villeEl?.value);
    const p  = normalize(paysEl?.value);
    const d  = normalize(deptEl?.value);

    if (!a || !cp || !v) return null;
    return [a, cp, v, d, p].filter(Boolean).join(', ');
  }

  async function geocodeAndPlace(){
    const latFilled = !!normalize(latEl?.value);
    const lngFilled = !!normalize(lngEl?.value);
    if (lastLatLngSource === 'manual' && latFilled && lngFilled) return;
    if ((placeEl?.value || '').trim()) return;

    const q = buildQuery();
    if (!q) return;

    const key = q.toLowerCase();
    if (key === lastQueryKey) return;
    lastQueryKey = key;

    try{
      const url = new URL('https://nominatim.openstreetmap.org/search');
      url.searchParams.set('format', 'json');
      url.searchParams.set('limit', '1');
      url.searchParams.set('q', q);

      const res = await fetch(url.toString(), { headers: { 'Accept':'application/json' }});
      if (!res.ok) return;

      const data = await res.json();
      if (!Array.isArray(data) || !data.length) return;

      const lat = parseFloat(data[0].lat);
      const lon = parseFloat(data[0].lon);
      if (!Number.isFinite(lat) || !Number.isFinite(lon)) return;

      setLatLng(lat, lon, { source:'auto', pan:true });
    } catch(e){}
  }

  function scheduleGeocode(){
    clearTimeout(geocodeTimer);
    geocodeTimer = setTimeout(geocodeAndPlace, 650);
  }

  // ✅ Bootstrap modal hooks
  modalEl.addEventListener('shown.bs.modal', () => {
    initMapIfNeeded();
    setTimeout(() => map && map.invalidateSize(true), 180);
    scheduleGeocode();
  });

  document.getElementById('btn-newsite-clear')?.addEventListener('click', clearLatLng);

  const btnGeoloc = document.getElementById('btn-newsite-geoloc');
  btnGeoloc?.addEventListener('click', () => {
    if (!navigator.geolocation){
      alert("La géolocalisation n'est pas disponible sur ce navigateur.");
      return;
    }
    btnGeoloc.disabled = true;
    navigator.geolocation.getCurrentPosition(
      (pos) => {
        setLatLng(pos.coords.latitude, pos.coords.longitude, { source:'manual', pan:true });
        btnGeoloc.disabled = false;
      },
      () => { alert("Impossible de récupérer ta position."); btnGeoloc.disabled = false; },
      { enableHighAccuracy:true, timeout:8000 }
    );
  });

  [addrEl, cpEl, villeEl].forEach(el=>{
    el?.addEventListener('input', scheduleGeocode);
    el?.addEventListener('change', scheduleGeocode);
  });
  [paysEl, deptEl].forEach(el=> el?.addEventListener('change', scheduleGeocode));

  // =================== GOOGLE PLACES (gmp-place-autocomplete) ===================
  function comp(components, type){
    const c = (components || []).find(x => (x.types || []).includes(type));
    return (c?.longText || c?.long_name || c?.text || '') || '';
  }

  function waitForGoogle(cb){
    const t = setInterval(()=>{
      if (window.google?.maps?.places?.PlaceAutocompleteElement){
        clearInterval(t); cb();
      }
    }, 50);
    setTimeout(()=>clearInterval(t), 8000);
  }

  function initPlaces(){
    if (!acEl || !window.google?.maps?.places?.PlaceAutocompleteElement) return;

    acEl.addEventListener('gmp-select', async ({ placePrediction }) => {
      try{
        const place = placePrediction.toPlace();
        await place.fetchFields({ fields: ['id','formattedAddress','location','addressComponents'] });

        const comps = place.addressComponents || [];
        const streetNumber = comp(comps, 'street_number');
        const route        = comp(comps, 'route');
        const postalCode   = comp(comps, 'postal_code');
        const locality     = comp(comps, 'locality') || comp(comps, 'postal_town');
        const region       = comp(comps, 'administrative_area_level_1');
        const departement  = comp(comps, 'administrative_area_level_2');
        const country      = comp(comps, 'country');

        const adresse = [streetNumber, route].filter(Boolean).join(' ').trim();

        if (addrEl) addrEl.value = adresse || '';
        if (cpEl && postalCode) cpEl.value = postalCode;
        if (villeEl && locality) villeEl.value = locality;
        if (regEl && region) regEl.value = region;
        if (deptEl && departement) deptEl.value = departement;
        if (paysEl && country) paysEl.value = country;

        if (placeEl) placeEl.value = place.id || '';
        if (fmtEl) fmtEl.value = place.formattedAddress || '';

        const loc = place.location;
        if (loc) {
          const lat = loc.lat();
          const lng = loc.lng();
          if (latEl) latEl.value = String(lat);
          if (lngEl) lngEl.value = String(lng);

          // ✅ si la modale n'est pas ouverte, on mémorise, sinon on place direct
          setLatLng(lat, lng, { source:'auto', pan:true });
        }
      } catch(e){
        console.warn('PlaceAutocompleteElement error:', e);
      }
    });
  }

  waitForGoogle(initPlaces);
});
</script>





