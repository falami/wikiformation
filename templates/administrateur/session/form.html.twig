<script>
function pad2(n){ return String(n).padStart(2,'0'); }

// Parse "d/m/Y H:i" -> Date (local)
function parseFRDateTime(str){
  const m = (str || '').trim().match(/^(\d{2})\/(\d{2})\/(\d{4})\s+(\d{2}):(\d{2})$/);
  if (!m) return null;
  const dd = parseInt(m[1], 10);
  const mm = parseInt(m[2], 10) - 1;
  const yyyy = parseInt(m[3], 10);
  const HH = parseInt(m[4], 10);
  const ii = parseInt(m[5], 10);
  const d = new Date(yyyy, mm, dd, HH, ii, 0, 0);
  return isNaN(d.getTime()) ? null : d;
}

function setTime(dateObj, hh, mm){
  const d = new Date(dateObj);
  d.setHours(hh, mm, 0, 0);
  return d;
}

function bindFlatpickr(scope) {
  const root = scope || document;
  if (!window.flatpickr) return;

  // Locale FR
  if (window.flatpickr?.l10ns?.fr) {
    flatpickr.localize(flatpickr.l10ns.fr);
  }

  const isDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;

  // Marque les champs que l'utilisateur a modifiés manuellement
  root.querySelectorAll('.flatpickr-datetime').forEach((el) => {
    if (!el.dataset) return;
    if (!el.dataset.userTouched) {
      el.dataset.userTouched = "0";
      el.addEventListener('input', () => el.dataset.userTouched = "1");
      el.addEventListener('change', () => el.dataset.userTouched = "1");
    }
  });

  root.querySelectorAll('.flatpickr-datetime').forEach((el) => {
    if (el._flatpickr) return;

    flatpickr(el, {
      enableTime: true,
      time_24hr: true,
      dateFormat: "d/m/Y H:i",
      allowInput: true,
      minuteIncrement: 5,

      onOpen: function(selectedDates, dateStr, instance) {
        if (isDark) instance.calendarContainer.classList.add('flatpickr-dark');
      },

      onChange: function(selectedDates, dateStr, instance) {
        if (instance.__autoApplying) return;

        const current = selectedDates && selectedDates[0] ? selectedDates[0] : parseFRDateTime(el.value);
        if (!current) return;

        const row = el.closest('.jour-item') || el.closest('.row') || el.parentElement;
        if (!row) return;

        const inputs = Array.from(row.querySelectorAll('.flatpickr-datetime'));
        if (inputs.length < 2) return;

        const startInput = inputs[0];
        const endInput   = inputs[1];
        const isStartField = (el === startInput);

        const startFp = startInput?._flatpickr || null;
        const endFp   = endInput?._flatpickr || null;

        function safeSet(fp, dateObj) {
          if (!fp) return;
          fp.__autoApplying = true;
          try { fp.setDate(dateObj, false); } finally { fp.__autoApplying = false; }
        }

        // --- init flags
        if (endInput.dataset.endLinked == null) endInput.dataset.endLinked = "1";

        // Si l'utilisateur modifie la FIN -> on "délie" (endLinked=0)
        if (!isStartField) {
          endInput.dataset.endLinked = "0";
        }

        // ----- DEBUT
        if (isStartField) {
          const startTouched = startInput.dataset.userTouched === "1";
          const hh = current.getHours(), mi = current.getMinutes();

          // Début à 08:30 si pas touché OU si click date (00:00)
          const newStart = setTime(current, 8, 30);
          const shouldForceStartTime = (!startTouched) || (hh === 0 && mi === 0);

          if (shouldForceStartTime && startFp) {
            safeSet(startFp, newStart);
            startInput.dataset.userTouched = "0";
          }

          // 🔥 ICI : fin suit la date de début
          const existingEnd = parseFRDateTime(endInput.value);
          const endTouched  = endInput.dataset.userTouched === "1";
          const endLinked   = endInput.dataset.endLinked === "1";

          // heure de fin à conserver si déjà existante, sinon 17:00
          const endHour = existingEnd ? existingEnd.getHours() : 17;
          const endMin  = existingEnd ? existingEnd.getMinutes() : 0;

          // nouvelle fin = même jour que début (newStart), heure = conservée
          const desiredEnd = setTime(newStart, endHour, endMin);

          // On met à jour la fin si :
          // - elle est "liée" (endLinked=1)  ✅ (cas normal)
          // OU
          // - elle n'a pas été touchée par l'utilisateur
          // OU
          // - elle est vide
          const endEmpty = !endInput.value || !existingEnd;

          if ((endLinked || !endTouched || endEmpty)) {
            if (endFp) safeSet(endFp, desiredEnd);
            else {
              endInput.value =
                `${pad2(desiredEnd.getDate())}/${pad2(desiredEnd.getMonth()+1)}/${desiredEnd.getFullYear()} ` +
                `${pad2(desiredEnd.getHours())}:${pad2(desiredEnd.getMinutes())}`;
            }
            endInput.dataset.userTouched = "0";
            endInput.dataset.endLinked = "1"; // reste lié
          }

          // Sécurité : fin >= début
          const endVal = parseFRDateTime(endInput.value);
          if (endVal && endVal.getTime() < newStart.getTime()) {
            const corrected = setTime(newStart, 17, 0);
            if (endFp) safeSet(endFp, corrected);
            else endInput.value =
              `${pad2(corrected.getDate())}/${pad2(corrected.getMonth()+1)}/${corrected.getFullYear()} ` +
              `${pad2(corrected.getHours())}:${pad2(corrected.getMinutes())}`;
            endInput.dataset.endLinked = "1";
            endInput.dataset.userTouched = "0";
          }
        }

        // ----- FIN : sécurité fin >= début (si l'utilisateur met une fin avant)
        if (!isStartField) {
          const startVal = parseFRDateTime(startInput.value);
          const endVal   = parseFRDateTime(endInput.value);

          if (startVal && endVal && endVal.getTime() < startVal.getTime()) {
            const corrected = setTime(startVal, 17, 0);
            if (endFp) safeSet(endFp, corrected);
            else endInput.value =
              `${pad2(corrected.getDate())}/${pad2(corrected.getMonth()+1)}/${corrected.getFullYear()} ` +
              `${pad2(corrected.getHours())}:${pad2(corrected.getMinutes())}`;

            // Comme on corrige automatiquement, on peut relier à nouveau
            endInput.dataset.endLinked = "1";
            endInput.dataset.userTouched = "0";
          }
        }
      }
    });
  });
}

document.addEventListener('DOMContentLoaded', function () {

  const idFormation = '#{{ form.formation.vars.id }}';
  const idSite      = '#{{ form.site.vars.id }}';
  const idEngin     = '#{{ form.engin.vars.id }}';
  const idTypeFinancement = '#{{ form.typeFinancement.vars.id }}';
  const idFormateur = '#{{ form.formateur.vars.id }}';
  const idStatus    = '#{{ form.status.vars.id }}';
  const idCode      = '#{{ form.code.vars.id }}';
  const idCapacite  = '#{{ form.capacite.vars.id }}';
  const idMontant   = '#{{ form.montantCents.vars.id }}';

  const $formation = document.querySelector(idFormation);
  const $site      = document.querySelector(idSite);
  const $engin     = document.querySelector(idEngin);
  const $typeFinancement = document.querySelector(idTypeFinancement);
  const $formateur = document.querySelector(idFormateur);
  const $status    = document.querySelector(idStatus);
  const $code      = document.querySelector(idCode);
  const $capacite  = document.querySelector(idCapacite);
  const $montant   = document.querySelector(idMontant);

  const idFormationLibre = '#{{ form.formationIntituleLibre.vars.id }}';
  const $formationLibre = document.querySelector(idFormationLibre);

  const idOrganisme = '#{{ form.organismeFormation.vars.id }}';
  const $organisme = document.querySelector(idOrganisme);
  const wrapOrganisme = document.getElementById('wrap-organisme-formation');


  const wrapFormation = document.getElementById('wrap-formation');
  const wrapFormationLibre = document.getElementById('wrap-formation-libre');

  // valeur Enum Symfony -> adapte si ta value n'est pas "OF"
  const OF_VALUE = $typeFinancement?.dataset?.ofValue || '';




  // Résumé DOM
  const $r = {
    formation: document.getElementById('resume-formation'),
    site: document.getElementById('resume-site'),
    engin: document.getElementById('resume-engin'),
    typeFinancement: document.getElementById('resume-type-financement'),
    formateur: document.getElementById('resume-formateur'),
    code: document.getElementById('resume-code'),
    statut: document.getElementById('resume-statut'),
    capacite: document.getElementById('resume-capacite'),
    montant: document.getElementById('resume-montant'),
    jours: document.getElementById('resume-jours'),
    stagiaires: document.getElementById('resume-stagiaires'),
    pill: document.getElementById('resume-valid-pill')
  };

  const chipJours = document.getElementById('chip-jours');
  const chipIns   = document.getElementById('chip-ins');

  const formMain = document.querySelector('form[name="session_administrateur"]');
  const submitButtons = formMain ? [...formMain.querySelectorAll('button[type="submit"]')] : [];

  function selectedText(selectEl){
    if (!selectEl || !selectEl.value) return '';
    const opt = selectEl.selectedOptions && selectEl.selectedOptions[0];
    return (opt ? opt.textContent : '').trim();
  }

  function initTomSelectOn(el) {
    if (el && !el.tomselect) {
      new TomSelect(el, {
        dropdownParent: 'body',   // ✅ FIX overflow/z-index
        create: false,
        allowEmptyOption: true,
        sortField: { field: 'text', direction: 'asc' },
        plugins: ['remove_button'],
        onChange: refreshResume
      });
    } else if (el?.tomselect) {
      el.tomselect.on('change', refreshResume);
    }
  }

  // ✅ OF helper
  function isOFSelected(){
    return ($typeFinancement?.value || '') === OF_VALUE;
  }

  // ✅ Toggle formation/intitulé + required (pour ton initFormValidation inchangé)
  function syncFormationMode(){
    const isOF = isOFSelected();

    if (wrapFormation) wrapFormation.classList.toggle('d-none', isOF);
    if (wrapFormationLibre) wrapFormationLibre.classList.toggle('d-none', !isOF);

    // ✅ organismeFormation visible en même temps que formationIntituleLibre
    if (wrapOrganisme) wrapOrganisme.classList.toggle('d-none', !isOF);

    // formation (interne)
    if ($formation) {
      $formation.disabled = isOF;
      if (isOF) $formation.removeAttribute('required');
      else $formation.setAttribute('required', 'required');

      if (isOF) {
        if ($formation.tomselect) $formation.tomselect.clear(true);
        else $formation.value = '';
      }
    }

    // intitulé libre (OF)
    if ($formationLibre) {
      $formationLibre.disabled = !isOF;
      if (isOF) $formationLibre.setAttribute('required', 'required');
      else $formationLibre.removeAttribute('required');
      if (!isOF) $formationLibre.value = '';
    }

    // ✅ organismeFormation (OF)
    if ($organisme) {
      $organisme.disabled = !isOF;

      // Si tu veux obliger le choix d’une entreprise quand OF :
      if (isOF) $organisme.setAttribute('required', 'required');
      else $organisme.removeAttribute('required');

      if (!isOF) {
        if ($organisme.tomselect) $organisme.tomselect.clear(true);
        else $organisme.value = '';
      }
    }

    refreshResume();
  }


  // TomSelect champs principaux
  [$formation, $site, $engin, $formateur, $status, $typeFinancement, $organisme].forEach(el => el && initTomSelectOn(el));


  // Flatpickr FR
  if (window.flatpickr && window.flatpickr.l10ns && window.flatpickr.l10ns.fr) {
    flatpickr.localize(flatpickr.l10ns.fr);
  }
  bindFlatpickr(document);

  // ========== Validation (ton code) ==========
  initFormValidation({
    formName: 'session_administrateur',
    tomSelectFields: [
      { id: '{{ form.formation.vars.id }}', label: '*Formation' },
      { id: '{{ form.site.vars.id }}',      label: '*Site' },
      { id: '{{ form.organismeFormation.vars.id }}', label: '*Organisme de formation' },
    ]
  });


  // ================== JOURNÉES ==================
  const wrapJours = document.getElementById('jours-collection');
  const protoJours = wrapJours ? wrapJours.dataset.prototype : null;
  let indexJour = {{ form.jours|length }};

  function countJours(){
    return wrapJours ? wrapJours.querySelectorAll('.jour-item').length : 0;
  }
  function updateChipJours(){
    const n = countJours();
    if (chipJours) chipJours.textContent = `${n} jour${n>1?'s':''}`;
    if ($r.jours) $r.jours.textContent = String(n);
  }

  if (wrapJours && protoJours) {
    document.getElementById('btn-add-jour').addEventListener('click', () => {
      const html = protoJours.replace(/__name__/g, indexJour++);
      const div  = document.createElement('div');
      div.innerHTML = html;
      const item = div.firstElementChild;
      wrapJours.appendChild(item);
      bindFlatpickr(item);

      item.querySelectorAll('.formateur-jour-select, select').forEach(el => {
        if (el.tagName === 'SELECT') initTomSelectOn(el);
      });

      updateChipJours();
      refreshResume();
    });

    wrapJours.addEventListener('click', (e) => {
      if (e.target.closest('.btn-remove-jour')) {
        e.preventDefault();
        e.target.closest('.jour-item').remove();
        updateChipJours();
        refreshResume();
      }
    });

    bindFlatpickr(wrapJours);
    updateChipJours();
  }

  // ================== INSCRIPTIONS ==================
  const wrapIns = document.getElementById('inscriptions-collection');
  const protoIns = wrapIns ? wrapIns.dataset.prototype : null;
  let indexIns = {{ form.inscriptions|length }};

  function countIns(){
    return wrapIns ? wrapIns.querySelectorAll('.inscription-item').length : 0;
  }
  function updateChipIns(){
    const n = countIns();
    if (chipIns) chipIns.textContent = `${n} inscrit${n>1?'s':''}`;
    if ($r.stagiaires) $r.stagiaires.textContent = String(n);
  }

  function initTomSelectInscriptions(scope) {
    (scope || document).querySelectorAll('select.tom-select-inscription, #inscriptions-collection select').forEach(el => {
      initTomSelectOn(el);
    });
  }
  initTomSelectInscriptions(document);
  updateChipIns();

  if (wrapIns && protoIns) {
    document.getElementById('btn-add-inscription').addEventListener('click', ()=>{
      const html = protoIns.replace(/__name__/g, indexIns++);
      const div = document.createElement('div');
      div.innerHTML = html;
      const row = div.firstElementChild;
      wrapIns.appendChild(row);
      initTomSelectInscriptions(row);
      updateChipIns();
      refreshResume();
    });

    wrapIns.addEventListener('click', (e)=>{
      if (e.target.closest('.btn-remove-inscription')) {
        e.preventDefault();
        e.target.closest('.inscription-item').remove();
        updateChipIns();
        refreshResume();
      }
    });
  }

  // ================== MODALES AJAX ==================
  // (tout ton code inchangé ici - je ne touche à rien)

  // ================== PRECHECK FULL ==================
  // (tout ton code inchangé ici - je ne touche à rien)

  // ================== RÉSUMÉ LIVE + complétude ==================
  const parseEuros = v => {
    if (typeof v !== 'string') v = String(v ?? '');
    v = v.replace(/\s/g,'').replace(',', '.').replace(/[^\d.]/g,'');
    const n = parseFloat(v);
    return isNaN(n) ? 0 : n;
  };
  const formatMoney = n => new Intl.NumberFormat('fr-FR', { style:'currency', currency:'EUR' }).format(n);

  function refreshResume(){
    // ✅ Formation dans résumé : select OU intitulé libre si OF
    const isOF = isOFSelected();
    if ($r.formation) {
      $r.formation.textContent = isOF
        ? (($formationLibre?.value || '').trim() || '-')
        : (selectedText($formation) || '-');
    }

    if ($r.site)      $r.site.textContent      = selectedText($site) || '-';
    if ($r.engin)     $r.engin.textContent     = selectedText($engin) || '-';
    if ($r.formateur) $r.formateur.textContent = selectedText($formateur) || '-';
    if ($r.typeFinancement) $r.typeFinancement.textContent = selectedText($typeFinancement) || '-';
    if ($r.statut)    $r.statut.textContent    = selectedText($status) || '-';
    if ($r.code)      $r.code.textContent      = ($code?.value || '').trim() || '-';

    const cap = ($capacite?.value || '').toString().trim();
    if ($r.capacite) $r.capacite.textContent = cap ? cap : '-';

    const m = parseEuros($montant?.value || '');
    if ($r.montant) $r.montant.textContent = m ? formatMoney(m) : '-';

    updateChipJours();
    updateChipIns();

    // ✅ complétude formation selon OF
    const hasFormation = isOF
      ? !!(($formationLibre?.value || '').trim())
      : !!($formation?.value && $formation.value.trim());

    const hasSite      = !!($site?.value && $site.value.trim());
    const hasJour      = countJours() >= 1;
    const hasIns       = countIns() >= 1;

    const ok = hasFormation && hasSite && hasJour && hasIns && (formMain ? formMain.checkValidity() : true);

    submitButtons.forEach(b => b.disabled = !ok);

    if ($r.pill) {
      if (ok) {
        $r.pill.textContent = '✅ Complet';
        $r.pill.style.background = 'rgba(25,135,84,.15)';
        $r.pill.style.borderColor = 'rgba(25,135,84,.35)';
        $r.pill.style.color = 'var(--ink)';
      } else {
        $r.pill.textContent = '⚠️ Incomplet';
        $r.pill.style.background = 'rgba(255,193,7,.15)';
        $r.pill.style.borderColor = 'rgba(255,193,7,.35)';
        $r.pill.style.color = 'var(--ink)';
      }
    }
  }

  [$code,$capacite,$montant].forEach(el => el && el.addEventListener('input', refreshResume));
  [$code,$capacite,$montant].forEach(el => el && el.addEventListener('change', refreshResume));

  // ✅ rafraîchit résumé si l’intitulé libre change
  $formationLibre?.addEventListener('input', refreshResume);
  $formationLibre?.addEventListener('change', refreshResume);

  // ✅ toggle OF au changement + init
  $typeFinancement?.addEventListener('change', syncFormationMode);
  syncFormationMode();

  refreshResume();
});
</script>


{# ========== Validation formulaire principal (ton code, inchangé) ========== #}
<script>
function initFormValidation({ formName, tomSelectFields=[] }){
  const form = document.querySelector(`form[name="${formName}"]`);
  if (!form) return;
  const submitButton = form.querySelector('button[type="submit"]');
  if (!submitButton) return;

  let errorAlert = document.getElementById('form-error-alert');
  if (!errorAlert) {
    errorAlert = document.createElement('div');
    errorAlert.className = 'alert alert-danger d-none';
    errorAlert.id = 'form-error-alert';
    submitButton.parentElement.prepend(errorAlert);
  }

  form.addEventListener('submit', e=>{
    const messages = new Set();
    let first = null;

    tomSelectFields.forEach(({id,label})=>{
      const f = document.getElementById(id);
      if (f && f.hasAttribute('required') && (!f.value || !f.value.trim())) {
        f.classList.add('is-invalid');
        messages.add(`- ${label}`);
        if(!first) first=f;
      }
    });

    const items = form.querySelectorAll('#jours-collection .jour-item');
    if (items.length === 0) {
      messages.add('- Ajouter au moins une journée');
    } else {
      items.forEach((row, i) => {
        const inputs = row.querySelectorAll('.flatpickr-datetime');
        const debut  = inputs[0]?.value?.trim();
        const fin    = inputs[1]?.value?.trim();
        if (!debut || !fin) {
          messages.add(`- Journée #${i+1}: début et fin obligatoires`);
          if (!first) first = inputs[0] || inputs[1];
        }
      });
    }

    form.querySelectorAll(':invalid').forEach(el=>{
      el.classList.add('is-invalid');
      if(!first) first=el;
      const l = form.querySelector(`label[for="${el.id}"]`);
      if (l) messages.add(`- ${l.textContent.trim()}`);
    });

    if (messages.size) {
      e.preventDefault();
      errorAlert.innerHTML = `<strong>Champs requis manquants :</strong><br>${[...messages].join('<br>')}`;
      errorAlert.classList.remove('d-none');
      if (first && first.scrollIntoView) first.scrollIntoView({behavior:'smooth', block:'center'});
      setTimeout(()=>errorAlert.classList.add('d-none'), 6000);
    }
  });
}
</script>


