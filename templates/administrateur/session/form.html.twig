                  <div class="form-check form-switch">
                    {{ form_widget(form.salleTablesChaisesErgo, { attr: { class:'form-check-input', 'data-logistique-switch':'1' } }) }}
                  </div>
                </div>
                {{ form_errors(form.salleTablesChaisesErgo) }}

                <div class="switch-row">
