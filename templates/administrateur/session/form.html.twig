{# templates/administrateur/session/form.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}{{ modeEdition ? 'Modification' : 'Ajout' }} d'une session{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/formulaire.css') }}">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin=""/>

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};

      --bg: #f5f7fb;
      --panel: #ffffff;
      --ink: #0f172a;
      --muted:#64748b;
      --stroke: rgba(15, 23, 42, .10);
      --shadow: 0 18px 55px rgba(15, 23, 42, .10);
      --radius: 18px;
      --modal-radius: 22px;
      --modal-stroke: color-mix(in srgb, var(--theme-color-principal) 14%, rgba(15,23,42,.12));
      --modal-shadow: 0 30px 90px rgba(2, 6, 23, .25);
    }


    body{ background: var(--bg); }

    /* ===== HERO (copié de session/index) ===== */
    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;

      /* Ombre douce premium */
      box-shadow: 0 18px 50px rgba(0,0,0,.14);

      /* Fond piloté par les couleurs de l'entité */
      background:
        /* halo clair (tertiaire) */
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        /* halo accent (secondaire) */
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        /* voile subtil (quaternaire) pour la profondeur */
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        /* dégradé principal (principal -> plus clair) */
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    /* léger glass highlight */
    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    /* barre accent = secondaire (et glow basé sur secondaire) */
    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }

    /* ===== Chips HERO (comme facture) ===== */
    .hero .chip{
      display:inline-flex;
      align-items:center;
      gap:.5rem;
      padding:.32rem .7rem;
      border-radius: 999px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(255,255,255,.14);
      font-size:.82rem;
      color: rgba(255,255,255,.92);
      backdrop-filter: blur(6px);
      white-space: nowrap;
    }
    .hero .chip i{
      color: var(--theme-color-secondaire);
    }

    /* chip highlight (optionnel) */
    .hero .chip--pill{
      background: color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
      border-color: color-mix(in srgb, var(--theme-color-secondaire) 28%, rgba(255,255,255,.14));
      color:#fff;
    }

    .hero .btn{
      border-radius: 14px;
      font-weight: 800;
    }
    .hero .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .hero .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }

    @media (max-width:768px){
      .hero{ border-radius:16px; }
    }
    .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }

    /* ===== Cards premium ===== */
    .cardx{
      background: var(--panel);
      border: 1px solid var(--stroke);
      border-radius: var(--radius);
      box-shadow: 0 10px 28px rgba(15,23,42,.08);
      overflow:hidden;
    }
    .cardx-h{
      padding: .95rem 1.05rem;
      display:flex; align-items:center; justify-content:space-between; gap:1rem;
      background: linear-gradient(180deg, rgba(0,0,0,.015), transparent);
      border-bottom: 1px solid var(--stroke);
    }
    .cardx-title{
      margin:0; font-weight:800; letter-spacing:-.01em; color: var(--ink);
      display:flex; align-items:center; gap:.6rem;
    }
    .chip{
      font-size:.78rem; padding:.25rem .55rem; border-radius:999px;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, var(--stroke));
      color: var(--muted);
      white-space:nowrap;
    }

    /* ===== Form polish ===== */
    label.form-label{ font-weight: 700; color: var(--ink); }
    .form-text, .text-muted, .small{ color: var(--muted) !important; }
    .form-control, .form-select{
      border-radius: 14px;
      border: 1px solid var(--stroke);
      padding: .65rem .85rem;
    }
    .form-control:focus, .form-select:focus{
      border-color: color-mix(in srgb, var(--theme-color-principal) 55%, var(--stroke));
      box-shadow: 0 0 0 .2rem color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
    }

    /* TomSelect polish + FIX dropdown */
    .ts-wrapper .ts-control{
      border-radius: 14px !important;
      padding: .55rem .75rem !important;
      border-color: var(--stroke) !important;
    }
    .ts-wrapper.focus .ts-control{
      box-shadow: 0 0 0 .2rem color-mix(in srgb, var(--theme-color-principal) 18%, transparent) !important;
      border-color: color-mix(in srgb, var(--theme-color-principal) 55%, var(--stroke)) !important;
    }
    .ts-dropdown{ z-index: 9999 !important; }
    .ts-wrapper.focus, .ts-wrapper.dropdown-active{ z-index: 9999; }
    .card, .card-body, .container, .container-fluid, .cardx, .cardx *{ overflow: visible; }

    /* ===== Sticky actions ===== */
    .sticky-actions{
      position: sticky; bottom: 14px; z-index: 5;
      background: color-mix(in srgb, var(--panel) 82%, transparent);
      backdrop-filter: blur(10px);
      border: 1px solid var(--stroke);
      border-radius: var(--radius);
      padding: .75rem;
      box-shadow: var(--shadow);
    }

    /* ===== Sections / items ===== */
    .jour-item{
      border:1px dashed color-mix(in srgb, var(--theme-color-principal) 16%, var(--stroke));
      background: linear-gradient(180deg, rgba(0,0,0,.01), transparent);
      margin: 10px 0;
      padding: 12px;
      border-radius: 16px;
    }
    .inscription-item{
      border:1px dashed color-mix(in srgb, var(--theme-color-principal) 16%, var(--stroke));
      background: linear-gradient(180deg, rgba(0,0,0,.01), transparent);
      padding: 12px;
      border-radius: 16px;
    }

    /* ===== Pièces obligatoires (tes cartes) ===== */
    .pieces-obligatoires-group{ margin-top:.5rem; }
    .pieces-obligatoires-grid{
      display:grid;
      grid-template-columns:repeat(auto-fit, minmax(220px, 1fr));
      gap:.75rem;
    }
    .piece-check-card{
      position:relative;
      padding:.65rem .75rem .65rem 2.4rem;
      border-radius:.75rem;
      border:1px solid #e2e8f0;
      background:#f8fafc;
      cursor:pointer;
      transition:all .15s ease-in-out;
      display:flex;
      flex-direction:column;
      justify-content:center;
      min-height:56px;
    }
    .piece-check-card:hover{
      border-color:var(--theme-color-secondaire);
      box-shadow:0 0 0 2px rgba(255,193,7,.15);
      background:#ffffff;
    }
    .piece-check-card .form-check-input{
      position:absolute;
      left:.8rem;
      top:50%;
      transform:translateY(-50%);
      width:1.1rem;
      height:1.1rem;
    }
    .piece-check-card .form-check-label{ margin-left:0; font-size:.85rem; line-height:1.3; }
    .piece-check-card-title{ font-weight:600; display:block; }
    .piece-check-card-sub{ font-size:.75rem; color:#6b7280; }
    .piece-check-card .form-check-input:checked{
      background-color:var(--theme-color-secondaire);
      border-color:var(--theme-color-secondaire);
    }
    .piece-check-card.checked{
      border-color:var(--theme-color-secondaire);
      background:rgba(255,193,7,.05);
    }

    /* ====== NE PAS CHANGER : switches boolean (on garde EXACTEMENT ton look) ====== */
    .soft-box{
      border-radius: 16px;
      border: 1px dashed rgba(15,35,54,.18);
      background: rgba(248,251,254,.75);
      padding: 1rem;
    }
    .switch-row{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap: 1rem;
      padding:.8rem .9rem;
      border-radius:14px;
      border:1px solid rgba(15,35,54,.08);
      background:#fff;
    }
    .switch-row + .switch-row{ margin-top:.65rem; }
    .switch-row .title{ font-weight:700; line-height:1.15; }
    .switch-row .desc{
      margin-top:.25rem;
      font-size:.85rem;
      color:#6b7280;
    }
    .switch-row .form-check.form-switch{ margin:0; }
    .switch-row .form-check-input{ width:2.6em; height:1.35em; }
    .switch-row .form-check-input:checked{
      background-color: var(--theme-color-secondaire);
      border-color: var(--theme-color-secondaire);
    }

    @media (max-width:768px){
      .hero{ border-radius:16px; }
    }

    /* Google Places dropdown MUST be above Bootstrap modal */
    .pac-container{
      z-index: 20000 !important;
    }



    /* Backdrop un peu + “ciné” */
    .modal-backdrop.show{ opacity:.55; }

    .modal.modal-ultra .modal-dialog{ max-width: 560px; }
    .modal.modal-ultra .modal-content{
      border-radius: var(--modal-radius);
      border: 1px solid var(--modal-stroke);
      box-shadow: var(--modal-shadow);
      overflow:hidden;
      background:
        radial-gradient(900px 420px at 10% 0%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 60%),
        radial-gradient(700px 360px at 92% 10%,
          color-mix(in srgb, var(--theme-color-secondaire) 25%, transparent),
          transparent 60%),
        linear-gradient(180deg, #ffffff, #fbfdff);
    }

    /* Header glass + accent */
    .modal.modal-ultra .modal-header{
      position:relative;
      border-bottom: 1px solid color-mix(in srgb, var(--modal-stroke) 70%, transparent);
      padding: 1.05rem 1.15rem;
      background: linear-gradient(180deg, rgba(255,255,255,.88), rgba(255,255,255,.72));
      backdrop-filter: blur(10px);
    }
    .modal.modal-ultra .modal-header::before{
      content:"";
      position:absolute; left:0; top:0; bottom:0;
      width: 10px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }
    .modal.modal-ultra .modal-title{
      font-weight: 900;
      letter-spacing: -.02em;
      color: var(--ink);
      display:flex; align-items:center; gap:.65rem;
      margin-left:.4rem;
    }
    .modal.modal-ultra .modal-title .ico{
      width: 38px; height: 38px;
      border-radius: 14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, var(--stroke));
      color: var(--theme-color-principal);
    }

    .modal.modal-ultra .btn-close{ opacity:.75; }
    .modal.modal-ultra .btn-close:hover{ opacity:1; }

    .modal.modal-ultra .modal-body{ padding: 1rem 1.15rem 1.1rem; }
    .modal.modal-ultra .modal-footer{
      padding: .85rem 1.15rem 1.05rem;
      border-top: 1px solid color-mix(in srgb, var(--modal-stroke) 70%, transparent);
      background: linear-gradient(180deg, rgba(255,255,255,.65), rgba(255,255,255,.92));
    }

    /* Petite “carte” interne pour le formulaire */
    .ultra-panel{
      border-radius: 18px;
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 12%, var(--stroke));
      background: rgba(255,255,255,.78);
      box-shadow: 0 10px 26px rgba(15,23,42,.06);
      padding: .95rem;
    }

    /* Inputs with icon */
    .ultra-field{
      position:relative;
    }
    .ultra-field .fi{
      position:absolute;
      left:.85rem; top:50%;
      transform: translateY(-50%);
      width: 34px; height: 34px;
      border-radius: 12px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-secondaire) 14%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-secondaire) 22%, var(--stroke));
      color: color-mix(in srgb, var(--theme-color-secondaire) 85%, #000 15%);
      pointer-events:none;
    }
    .ultra-field .form-control,
    .ultra-field .form-select,
    .ultra-field textarea{
      padding-left: 3.2rem !important;
    }

    /* Hint / helper */
    .ultra-hint{
      display:flex; gap:.6rem; align-items:flex-start;
      padding:.65rem .75rem;
      border-radius: 16px;
      background: linear-gradient(180deg,
        color-mix(in srgb, var(--theme-color-principal) 7%, transparent),
        rgba(255,255,255,.65));
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 12%, var(--stroke));
      color: var(--muted);
      font-size: .86rem;
    }
    .ultra-hint i{ color: var(--theme-color-secondaire); margin-top:.1rem; }

    /* Footer buttons */
    .modal.modal-ultra .btn{
      border-radius: 14px;
      font-weight: 800;
    }
    .modal.modal-ultra .btn-ultra-cancel{
      border: 1px solid var(--stroke);
      background: rgba(255,255,255,.75);
    }
    .modal.modal-ultra .btn-ultra-cancel:hover{
      background: #fff;
    }

    /* CTA glass gradient (si tu utilises déjà .btn-gradient tu peux garder) */
    .modal.modal-ultra .btn-ultra-primary{
      color:#fff;
      border: 0;
      background:
        radial-gradient(900px 220px at 10% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 45%, transparent),
          transparent 60%),
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%));
      box-shadow: 0 14px 34px color-mix(in srgb, var(--theme-color-principal) 20%, transparent);
    }
    .modal.modal-ultra .btn-ultra-primary:hover{
      filter: brightness(1.03);
      transform: translateY(-1px);
    }
    .modal.modal-ultra .btn-ultra-primary:active{
      transform: translateY(0);
    }

    /* Error alert un peu plus chic */
    .modal.modal-ultra .alert{
      border-radius: 16px;
      border: 1px solid rgba(220,53,69,.25);
      background: rgba(220,53,69,.08);
    }

  </style>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

  {# Flatpickr local #}
  <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.js"></script>
  <script src="https://npmcdn.com/flatpickr/dist/l10n/fr.js"></script>

  <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
  <script>
  window.initGmpPlaces = function(){ /* vide : on initialise dans le JS plus bas */ };
</script>

<script
  src="https://maps.googleapis.com/maps/api/js?key={{ googleMapsBrowserKey }}&libraries=places&language=fr&region=FR&loading=async&callback=initGmpPlaces"
  async>
</script>



{% endblock %}

{% block body %}

  {# ===== HERO (même style que session/index) ===== #}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>

    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-calendar-event me-2" style="color:var(--theme-color-secondaire)"></i>
            {{ modeEdition ? 'Modifier une session' : 'Ajouter une session' }}
          </h2>
          <div class="opacity-75 mt-1">Références, journées, stagiaires, pièces et logistique.</div>

          <div class="d-flex flex-wrap gap-2 mt-3">
            <span class="chip"><i class="bi bi-calendar-event"></i> Session</span>
            <span class="chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
            <span class="chip chip--pill"><i class="bi bi-pencil-square"></i> {{ modeEdition ? 'Modification' : 'Création' }}</span>
            {% if form.vars.value and form.vars.value.id %}
              <span class="chip"><i class="bi bi-hash"></i> #{{ form.vars.value.id }}</span>
            {% endif %}
          </div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
          <a class="btn btn-outline-theme btn-sm fw-semibold" href="javascript:history.back()">
            <i class="bi bi-arrow-left"></i> Retour
          </a>
          <button form="{{ form.vars.id }}" type="submit" class="btn btn-light btn-sm fw-semibold" id="btnHeroSubmit">
            <i class="bi bi-check2"></i> Enregistrer
          </button>
        </div>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  {{ form_start(form, { attr: { id: form.vars.id, novalidate: 'novalidate', name: 'session_administrateur' } }) }}
  {{ form_errors(form) }}

  <div class="row g-4">
    {# ====================== COL LEFT ====================== #}
    <div class="col-lg-8">

      {# ===== Liens & Références ===== #}
      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-link-45deg text-warning"></i> Liens & Références</h5>
          <span class="chip">Étape 1</span>
        </div>
        <div class="p-3 p-md-4">
          <div class="row g-3">
            {# Formation (interne) + Intitulé (OF) #}
            <div class="col-md-12">{{ form_row(form.typeFinancement) }}</div>
            <div class="col-md-6">
              
              
              <div id="wrap-formation">
                {{ form_row(form.formation) }}
              </div>

              <div id="wrap-formation-libre" class="d-none mt-2">
                {{ form_row(form.formationIntituleLibre) }}
              </div>


            </div>


            <div class="col-md-6">
              

              <div id="wrap-organisme-formation" class="d-none mt-2">
                {{ form_row(form.organismeFormation) }}
              </div>

            </div>


            <div class="col-md-6">
              <div class="d-flex align-items-end gap-2">
                <div class="flex-grow-1">{{ form_row(form.site) }}</div>
                <button type="button" class="btn btn-outline-secondary"
                        data-bs-toggle="modal" data-bs-target="#modal-new-site" title="Créer un site">
                  <i class="fa fa-plus"></i>
                </button>
              </div>
            </div>

            

            <div class="col-md-6">
              <div class="d-flex align-items-end gap-2">
                <div class="flex-grow-1">{{ form_row(form.formateur) }}</div>
                <button type="button" class="btn btn-outline-secondary"
                        data-bs-toggle="modal" data-bs-target="#modal-new-formateur" title="Créer un formateur">
                  <i class="fa fa-user-plus"></i>
                </button>
              </div>
            </div>

            <div class="col-md-6">{{ form_row(form.status) }}</div>
            <div class="col-md-6">{{ form_row(form.engin) }}</div>
            <div class="col-md-6">{{ form_row(form.code) }}</div>
          </div>

          <div class="form-text mt-2">
            Formation / site / engin / formateur + code et statut.
          </div>
        </div>
      </div>

      {# ===== Capacité ===== #}
      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-people text-warning"></i> Capacité & Tarif</h5>
          <span class="chip">Paramètres</span>
        </div>
        <div class="p-3 p-md-4">
          <div class="row g-3">
            <div class="col-md-6">{{ form_row(form.capacite) }}</div>
            <div class="col-md-6">{{ form_row(form.montantCents) }}</div>
          </div>
          <div class="form-text mt-2">
            Le tarif effectif = montant personnalisé, sinon le prix de base de la formation.
          </div>
        </div>
      </div>

      {# ===== Pièces obligatoires ===== #}
      {% if form.piecesObligatoires is defined %}
        <div class="cardx mb-4">
          <div class="cardx-h">
            <h5 class="cardx-title"><i class="bi bi-file-earmark-check text-warning"></i> Pièces obligatoires</h5>
            <span class="chip">Dossier</span>
          </div>
          <div class="p-3 p-md-4">
            <p class="small text-muted mb-3">
              Coche les pièces qui doivent être présentes <strong>et validées</strong> pour considérer un stagiaire
              comme « dossier complet ».
            </p>

            <div class="pieces-obligatoires-group">
              {{ form_label(form.piecesObligatoires, null, { label_attr: {'class': 'form-label fw-semibold'} }) }}
              {{ form_errors(form.piecesObligatoires) }}

              <div class="pieces-obligatoires-grid">
                {% for child in form.piecesObligatoires %}
                  <div class="form-check piece-check-card">
                    {{ form_widget(child, {'attr': {'class': 'form-check-input'}}) }}
                    <label class="form-check-label" for="{{ child.vars.id }}">
                      <span class="piece-check-card-title">{{ child.vars.label }}</span>
                      {% set val = child.vars.value %}
                      <span class="piece-check-card-sub">
                        {% if val == 'cni_recto' %}
                          Carte nationale d’identité (recto) ou passeport en cours de validité.
                        {% elseif val == 'cni_verso' %}
                          Carte nationale d’identité (verso) ou passeport en cours de validité.
                        {% elseif val == 'convocation_signee' %}
                          Convocation signée par le stagiaire.
                        {% elseif val == 'reglement_interieur_signee' %}
                          Règlement intérieur daté et signé.
                        {% elseif val == 'opco_prise_en_charge' %}
                          Justificatif de prise en charge OPCO.
                        {% elseif val == 'justificatif_domicile' %}
                          Justificatif de domicile de moins de 3 mois.
                        {% else %}
                          Pièce justificative obligatoire pour ce dossier.
                        {% endif %}
                      </span>
                    </label>
                  </div>
                {% endfor %}
              </div>
            </div>
          </div>
        </div>
      {% endif %}

      {# ===== Journées ===== #}
      {% set jourPrototype %}
        <div class='row g-3 mb-2 jour-item'>
          <div class='col-md-4'>
            {{ form_row(form.jours.vars.prototype.dateDebut) }}
          </div>
          <div class='col-md-4'>
            {{ form_row(form.jours.vars.prototype.dateFin) }}
          </div>
          <div class='col-md-3'>
            {{ form_row(form.jours.vars.prototype.formateur) }}
          </div>
          <div class='col-md-1 d-flex align-items-end justify-content-end'>
            <button type='button' class='btn btn-outline-danger btn-remove-jour'>
              <i class='fa fa-trash'></i>
            </button>
          </div>
        </div>
      {% endset %}

      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-calendar-week text-warning"></i> Journées</h5>
          <span class="chip" id="chip-jours">{{ form.jours|length }} jour{{ form.jours|length > 1 ? 's' : '' }}</span>
        </div>
        <div class="p-3 p-md-4">
          <div id="jours-collection" data-prototype="{{ jourPrototype|e('html_attr') }}">
            {% for jour in form.jours %}
              <div class="row g-3 mb-2 jour-item">
                <div class="col-md-4">{{ form_row(jour.dateDebut) }}</div>
                <div class="col-md-4">{{ form_row(jour.dateFin) }}</div>
                <div class="col-md-3">{{ form_row(jour.formateur) }}</div>
                <div class="col-md-1 d-flex align-items-end justify-content-end">
                  <button type="button" class="btn btn-outline-danger btn-remove-jour">
                    <i class="fa fa-trash"></i>
                  </button>
                </div>
              </div>
            {% endfor %}
          </div>

          <button type="button" class="btn btn-outline-primary mt-2" id="btn-add-jour">
            <i class="fa fa-plus"></i> Ajouter une journée
          </button>
        </div>
      </div>

      {# ===== Stagiaires ===== #}
      {% set insPrototype %}
        <div class='row g-3 mb-4 inscription-item align-items-end'>
          <div class='col-md-5'>
            {{ form_row(form.inscriptions.vars.prototype.stagiaire) }}
          </div>
          <div class='col-md-5'>
            {{ form_row(form.inscriptions.vars.prototype.status) }}
          </div>
          <div class='col-md-2 d-flex align-items-end justify-content-end'>
            <button type='button' class='btn btn-outline-danger btn-remove-inscription'>
              <i class='fa fa-trash'></i>
            </button>
          </div>
        </div>
      {% endset %}

      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-people-fill text-warning"></i> Stagiaires</h5>
          <span class="chip" id="chip-ins">{{ form.inscriptions|length }} inscrit{{ form.inscriptions|length > 1 ? 's' : '' }}</span>
        </div>
