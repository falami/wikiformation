{% include 'partials/_modales_index_generiques.html.twig' %}

<script>
$(function(){
  const $status    = $('#sessionStatusFilter');
  const $formation = $('#sessionFormationFilter');
  const $dossier   = $('#dossierFilter');
  const $dateFrom  = $('#dateFrom');
  const $dateTo    = $('#dateTo');
  const $formateur = $('#formateurFilter');

  function nowLabel(){
    const d = new Date();
    return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
  }

  let tsStatus = null, tsFormation = null, tsDossier = null;
  function initTomSelect(){
    const common = {
      create: false,
      allowEmptyOption: true,
      maxItems: 1,
      plugins: ['clear_button'],
      render: { no_results: () => 'Aucun résultat' } // ✅ évite les tokens bizarres dans HTML inline
    };

    tsStatus?.destroy(); tsFormation?.destroy(); tsDossier?.destroy();
    tsStatus    = new TomSelect('#sessionStatusFilter',    {...common, placeholder:'Tous'});
    tsFormation = new TomSelect('#sessionFormationFilter', {...common, placeholder:'Toutes'});
    tsDossier   = new TomSelect('#dossierFilter',          {...common, placeholder:'Tous'});

    tsStatus.on('change',    () => refreshAll(true));
    tsFormation.on('change', () => refreshAll(true));
    tsDossier.on('change',   () => refreshAll(true));
  }


  let fpRange = null;
  function initFlatpickr(){
    fpRange?.destroy?.();
    fpRange = flatpickr("#dateRange", {
      locale: "fr",
      mode: "range",
      dateFormat: "d/m/Y",
      allowInput: true,
      disableMobile: true,
      onClose: function(selectedDates){
        const from = selectedDates[0] ? selectedDates[0].toISOString().slice(0,10) : '';
        const to   = selectedDates[1] ? selectedDates[1].toISOString().slice(0,10) : '';
        $dateFrom.val(from);
        $dateTo.val(to);
        refreshAll(true);
      }
    });
  }

  async function loadMeta(){
    const url = "{{ path('app_administrateur_session_kpis_meta', { entite: entite.id }) }}";
    const res = await fetch(url, { headers: { 'Accept':'application/json' }});
    if(!res.ok) return;
    const json = await res.json();

    tsFormation.clearOptions();
    tsFormation.addOption({ value: 'all', text: 'Toutes' });
    (json.formations || []).forEach(f => tsFormation.addOption({ value: String(f.id), text: f.label }));
    tsFormation.refreshOptions(false);
    tsFormation.setValue('all', true);
  }

  async function loadKpis(){
    const params = new URLSearchParams();
    params.set('status', $status.val() || 'all');
    params.set('formation', $formation.val() || 'all');

    const url = "{{ path('app_administrateur_session_kpis', { entite: entite.id }) }}?" + params.toString();
    const res = await fetch(url, { headers: { 'Accept':'application/json' }});
    if(!res.ok) return;

    const k = await res.json();
    $('#kpi-count').text(k.count ?? '—');
    $('#kpi-upcoming').text(k.upcoming ?? '—');
    $('#kpi-running').text(k.running ?? '—');
    $('#kpi-done').text(k.done ?? '—');
    $('#kpi-range').text('{{ entite.nom }}');
    $('#hero-last-refresh').text('Maj : ' + nowLabel());
  }

  function updateResetUi(count){
    const btn = document.getElementById('btnReset');
    const badge = document.getElementById('resetCount');
    if(!btn || !badge) return;

    if(count > 0){
      btn.disabled = false;
      btn.classList.add('is-active');
      badge.style.display = 'inline-flex';
      badge.textContent = String(count);
    } else {
      btn.disabled = true;
      btn.classList.remove('is-active');
      badge.style.display = 'none';
      badge.textContent = '0';
    }
  }

  function buildActiveFilters(){
    const items = [];

    const st = $status.val();
    if(st && st !== 'all') items.push({ key:'status', label:'Statut', value: $('#sessionStatusFilter option:selected').text() });

    const fo = $formation.val();
    if(fo && fo !== 'all') items.push({ key:'formation', label:'Formation', value: $('#sessionFormationFilter option:selected').text() });

    const ds = $dossier.val();
    if(ds && ds !== 'all') items.push({ key:'dossier', label:'Dossier', value: $('#dossierFilter option:selected').text() });

    const df = ($dateFrom.val() || '').trim();
    const dt = ($dateTo.val() || '').trim();
    if(df || dt) items.push({ key:'periode', label:'Période', value: `${df || '…'} → ${dt || '…'}` });

    const fu = ($formateur.val() || '').trim();
    if(fu) items.push({ key:'formateur', label:'Formateur', value: fu });

    const $wrap = $('#activeFilters');
    $wrap.find('.af-badge').remove();

    if(items.length === 0){
      $('#activeFiltersEmpty').show();
      updateResetUi(0);
      return;
    }

    $('#activeFiltersEmpty').hide();
    updateResetUi(items.length);

    items.forEach(it=>{
      const $b = $(`<span class="af-badge" data-key="${it.key}">
        <strong>${it.label} :</strong> ${it.value} <i class="bi bi-x-lg ms-1"></i>
      </span>`);

      $b.on('click', ()=>{
        switch(it.key){
          case 'status':    tsStatus.setValue('all', true); break;
          case 'formation': tsFormation.setValue('all', true); break;
          case 'dossier':   tsDossier.setValue('all', true); break;
          case 'periode':
            $dateFrom.val(''); $dateTo.val('');
            fpRange?.clear();
            $('#dateRange').val('');
            break;
          case 'formateur':
            $formateur.val('');
            break;
        }
        refreshAll(true);
      });

      $wrap.append($b);
    });
  }

  const table = $('#tableauSession').DataTable({
    serverSide: true,
    processing: true,
    autoWidth: false,
    scrollX: true,
    scrollCollapse: true,
    responsive: false,

    ajax:{
      url:"{{ path('app_administrateur_session_ajax', { entite: entite.id }) }}",
      type:"POST",
      data: d => {
        d.statusFilter    = $status.val() || 'all';
        d.formationFilter = $formation.val() || 'all';
        d.dossierFilter   = $dossier.val() || 'all';
        d.dateFrom        = $dateFrom.val() || '';
        d.dateTo          = $dateTo.val() || '';
        d.formateurFilter = $formateur.val() || '';
      }
    },

    dom:
      '<"dt-top d-flex flex-wrap gap-2 align-items-center justify-content-between"'
        + '<"dt-actions d-flex gap-2 align-items-center"B>'
        + '<"dt-search"f>'
      + '>'
      + 'rt'
      + '<"dt-bottom-internal d-flex flex-wrap gap-2 align-items-center justify-content-between"lip>',

    buttons:['copy','csv','excel','pdf','print'],
    lengthMenu:[[10,25,50,500],[10,25,50,500]],

    columns:[
      {data:'dossier', name:'dossier', orderable:true, searchable:false},
      {
        data:'dates',
        name:'dates',
        render: function(data, type, row){
          if(type === 'sort' || type === 'type') return row.dateStartSort || '';
          return data;
        }
      },
      {data:'infos', name:'infos', orderable:false, searchable:true},
      {data:'participants', name:'participants', orderable:false, searchable:false},
      {data:'capacite', name:'capacite', orderable:false, searchable:false},
      {data:'tarif', name:'tarif'},
      {data:'satisfaction', name:'satisfaction', orderable:false, searchable:false}, // ✅ NEW
      {data:'status', name:'status', orderable:true, searchable:false},
      {data:'actions', name:'actions', orderable:false, searchable:false}

    ],

    columnDefs:[
      {targets: 8, className:'action-column text-end', orderable:false, searchable:false}, // ✅ actions = 8 maintenant
      {targets: [0,1,2,3,4,5,6,7], className:'text-center'},
      {targets: 6, width: '360px'} // ✅ satisfaction = index 6 maintenant (0-based)
    ],

    order:[[1,'desc']],
    language:{ url:'https://cdn.datatables.net/plug-ins/2.2.2/i18n/fr-FR.json' },

    initComplete:function(){
      const api = this.api();
      const $btns = $(api.buttons().container()).find('button');

      $('#exportMenu').empty();
      $btns.each(function(){
        const $b=$(this);
        $('<li><a class="dropdown-item" href="#">'+$b.text()+'</a></li>')
          .on('click',e=>{e.preventDefault();$b.click();})
          .appendTo('#exportMenu');
      });
      $(api.buttons().container()).hide();
      api.columns.adjust();
    }
  });



  // ✅ Dropdown actions sessions : flotte le menu hors du scroll DataTables (anti-clipping)
  (function enableSessionActionsFloatingDropdown(){
    document.addEventListener('show.bs.dropdown', function(e){
      const toggle = e.target;
      if (!toggle.closest('.session-actions')) return;

      const dd = toggle.closest('.dropdown, .btn-group');
      if (!dd) return;

      const menu = dd.querySelector('.dropdown-menu');
      if (!menu) return;

      if (!menu.__originalParent) menu.__originalParent = dd;

      document.body.appendChild(menu);
      menu.classList.add('session-floating-dropdown');

      const rect = toggle.getBoundingClientRect();

      menu.style.position = 'absolute';
      menu.style.top = '0px';
      menu.style.left = '0px';
      menu.style.display = 'block';

      const menuRect = menu.getBoundingClientRect();
      const top = rect.bottom + window.scrollY + 6;

      let left = (rect.right + window.scrollX - menuRect.width);
      left = Math.max(8, Math.min(left, window.scrollX + window.innerWidth - menuRect.width - 8));

      menu.style.top = `${top}px`;
      menu.style.left = `${left}px`;
    }, true);

    document.addEventListener('hidden.bs.dropdown', function(e){
      const toggle = e.target;
      if (!toggle.closest('.session-actions')) return;

      const dd = toggle.closest('.dropdown, .btn-group');
      if (!dd) return;

      document.querySelectorAll('body .session-floating-dropdown').forEach(menu => {
        if (menu.__originalParent === dd) {
          dd.appendChild(menu);
          menu.classList.remove('session-floating-dropdown');
          menu.style.position = '';
          menu.style.top = '';
          menu.style.left = '';
          menu.style.display = '';
        }
      });
    }, true);

    // ✅ ferme les menus ouverts si scroll/resize (anti menus “perdus”)
    window.addEventListener('scroll', () => {
      document.querySelectorAll('.session-actions [aria-expanded="true"][data-bs-toggle="dropdown"]')
        .forEach(btn => btn.click());
    }, true);

    window.addEventListener('resize', () => {
      document.querySelectorAll('.session-actions [aria-expanded="true"][data-bs-toggle="dropdown"]')
        .forEach(btn => btn.click());
    }, true);
  })();



  function refreshAll(resetPaging=false){
    table.ajax.reload(null, resetPaging);
    loadKpis();
    buildActiveFilters();
  }



  // Ajustements colonnes (simple, sans doublons)
  function dtAdjust(){ table.columns.adjust(); }
  table.on('init.dt', () => setTimeout(dtAdjust, 60));
  table.on('draw.dt', () => dtAdjust());
  window.addEventListener('resize', () => setTimeout(dtAdjust, 150));

  // formateur debounce
  let tFormateur = null;
  $formateur.on('input', ()=>{
    clearTimeout(tFormateur);
    tFormateur = setTimeout(()=>refreshAll(true), 300);
  });

  // Reset
  $('#btnReset').on('click', function(){
    tsStatus.setValue('all', true);
    tsFormation.setValue('all', true);
    tsDossier.setValue('all', true);

    fpRange?.clear();
    $('#dateRange').val('');
    $dateFrom.val(''); $dateTo.val('');
    $formateur.val('');

    table.search('');
    refreshAll(true);
  });

  // Tooltips bootstrap (dossier)
  function initTooltips(){
    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el=>{
      if(!bootstrap.Tooltip.getInstance(el)) new bootstrap.Tooltip(el);
    });
  }
  table.on('draw.dt', initTooltips);

  // Init
  initTomSelect();
  initFlatpickr();

  loadMeta().then(()=>{
    loadKpis();
    buildActiveFilters();
  });

  $('#hero-last-refresh').text('Maj : ' + nowLabel());



  // ✅ Modale delete : injecte l'URL + CSRF token
  const deleteModalEl = document.getElementById('deleteModal');
  if (deleteModalEl) {
    const deleteForm  = document.getElementById('deleteForm');
    const tokenInput  = document.getElementById('deleteToken');
    const itemNameEl  = document.getElementById('deleteItemName');

    deleteModalEl.addEventListener('show.bs.modal', (event) => {
      const btn = event.relatedTarget;
      if (!btn) return;

      const url   = btn.getAttribute('data-url') || '';
      const token = btn.getAttribute('data-token') || '';
      const label = btn.getAttribute('data-label') || 'cet élément';

      if (deleteForm) deleteForm.action = url;
      if (tokenInput) tokenInput.value = token;
      if (itemNameEl) itemNameEl.textContent = label;
    });
  }


});
</script>
