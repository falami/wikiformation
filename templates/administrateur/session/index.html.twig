{# templates/administrateur/session/index.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}Sessions{% endblock %}

{% block stylesheets %}
  {{ parent() }}

  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/style-table.css') }}">
  <link rel="stylesheet" href="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.css"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css">

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }

    /* ===== HERO ===== */
    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;

      /* Ombre douce premium */
      box-shadow: 0 18px 50px rgba(0,0,0,.14);

      /* Fond piloté par les couleurs de l'entité */
      background:
        /* halo clair (tertiaire) */
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        /* halo accent (secondaire) */
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        /* voile subtil (quaternaire) pour la profondeur */
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        /* dégradé principal (principal -> plus clair) */
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    /* léger glass highlight */
    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    /* barre accent = secondaire (et glow basé sur secondaire) */
    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }
    /* ===== Chips HERO (comme facture) ===== */
    .hero .chip{
      display:inline-flex;
      align-items:center;
      gap:.5rem;
      padding:.32rem .7rem;
      border-radius: 999px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(255,255,255,.14);
      font-size:.82rem;
      color: rgba(255,255,255,.92);
      backdrop-filter: blur(6px);
      white-space: nowrap;
    }
    .hero .chip i{
      color: var(--theme-color-secondaire);
    }

    /* chip highlight (optionnel) */
    .hero .chip--pill{
      background: color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
      border-color: color-mix(in srgb, var(--theme-color-secondaire) 28%, rgba(255,255,255,.14));
      color:#fff;
    }

    .hero .btn{
      border-radius: 14px;
      font-weight: 800;
    }
    .hero .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .hero .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }

    /* ===== KPI ===== */
    .kpi-card{
      border: 1px solid rgba(0,0,0,.06);
      box-shadow: 0 10px 26px rgba(0,0,0,.06);
      border-radius: 18px;
      overflow:hidden;
      background:#fff;
    }
    .kpi-label{ color: rgba(0,0,0,.55); font-size:.85rem }
    .kpi-value{ font-weight:800; font-size:1.6rem; letter-spacing:-.02em }
    .kpi-sub{ color: rgba(0,0,0,.50); font-size:.82rem }

    /* ===== Filterbar ===== */
    .filterbar{
      background:#fff;
      border-radius:18px;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 10px 24px rgba(0,0,0,.05);
      overflow: visible; /* important pour TomSelect dropdown */
    }
    .filterbar__top{
      padding: .9rem 1rem;
      border-bottom:1px solid rgba(0,0,0,.06);
      background: linear-gradient(180deg, rgba(0,0,0,.015), transparent);
      display:flex;
      align-items:center;
      gap:.75rem;
    }
    .filterbar__title{ font-weight:800; letter-spacing:-.01em; margin:0; font-size:1rem; }
    .filterbar__hint{ color: rgba(0,0,0,.55); font-size:.85rem; margin-left:.25rem; }
    .filterbar__body{ padding: 1rem; }

    .filtergrid{
      display:grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: .75rem;
      align-items:end;
    }
    .fcol-status{ grid-column: span 2; }
    .fcol-formation{ grid-column: span 2; }
    .fcol-dossier{ grid-column: span 2; }
    .fcol-period{ grid-column: span 3; }
    .fcol-formateur{ grid-column: span 2; }
    .fcol-actions{ grid-column: span 1; }

    @media (max-width: 1200px){
      .fcol-status{ grid-column: span 3; }
      .fcol-formation{ grid-column: span 4; }
      .fcol-dossier{ grid-column: span 5; }
      .fcol-period{ grid-column: span 6; }
      .fcol-formateur{ grid-column: span 6; }
      .fcol-actions{ grid-column: span 12; }
    }
    @media (max-width: 768px){
      .filterbar__body{ padding:.85rem; }
      .fcol-status, .fcol-formation, .fcol-dossier, .fcol-period, .fcol-formateur, .fcol-actions{ grid-column: span 12; }
      .hero{ border-radius:16px; }
    }

    .filter-control .form-label{
      font-size:.78rem;
      font-weight:700;
      color: rgba(0,0,0,.55);
      text-transform:uppercase;
      letter-spacing:.06em;
      margin-bottom:.25rem;
    }
    .filterbox{
      border:1px solid rgba(0,0,0,.08);
      border-radius:14px;
      padding:.55rem .6rem;
      background:#fff;
      box-shadow: 0 8px 18px rgba(0,0,0,.04);
    }
    .filterbox:focus-within{
      border-color: rgba(255,193,7,.55);
      box-shadow: 0 0 0 .2rem rgba(255,193,7,.18), 0 10px 18px rgba(0,0,0,.06);
    }
    .filterrow{ display:flex; gap:.6rem; align-items:center; }
    .kpi-ico{
      width:44px; height:44px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }

    .filter-icon{
      width:38px; height:38px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }
    .filterbox .form-select,
    .filterbox .form-control{
      border:0 !important;
      box-shadow:none !important;
      padding-left:0 !important;
      padding-right:0 !important;
      background:transparent !important;
    }

    /* Reset (même look que filterbox) */
    .resetbox{
      border:1px solid rgba(0,0,0,.08);
      border-radius:14px;
      padding:.55rem .6rem;
      background:#fff;
      box-shadow:0 8px 18px rgba(0,0,0,.04);
      cursor:pointer;
      user-select:none;
      transition: all .16s ease;
      width: 100%;
      display:flex;
      align-items:center;
      justify-content:center;
    }
    .resetbox:hover{
      border-color: rgba(0,0,0,.14);
      box-shadow: 0 10px 20px rgba(0,0,0,.06);
      transform: translateY(-1px);
    }
    .resetbox:focus,
    .resetbox:focus-visible{
      outline: none;
      border-color: rgba(255,193,7,.55);
      box-shadow: 0 0 0 .2rem rgba(255,193,7,.18), 0 10px 18px rgba(0,0,0,.06);
    }
    .resetbox.is-active{
      border-color: rgba(255,193,7,.35);
      background: rgba(255,193,7,.06);
    }
    .resetbox:disabled{ cursor: default; opacity: .55; transform:none; }
    .resetbox__text{ font-size:.9rem; font-weight:800; color: rgba(0,0,0,.65); }
    .resetbox__badge{
      min-width: 28px;
      height: 22px;
      padding: 0 .5rem;
      border-radius: 999px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      font-size:.78rem;
      font-weight:800;
      background: rgba(0,0,0,.06);
      color: rgba(0,0,0,.65);
      border: 1px solid rgba(0,0,0,.08);
      margin-left:.5rem;
    }
    .resetbox.is-active .resetbox__badge{
      background: rgba(255,193,7,.22);
      border-color: rgba(255,193,7,.30);
      color: rgba(0,0,0,.75);
    }

    .active-filters{
      padding: .65rem 1rem;
      border-top:1px solid rgba(0,0,0,.06);
      background:#fff;
      display:flex;
      align-items:center;
      gap:.5rem;
      flex-wrap:wrap;
    }
    .active-filters .label{
      font-size:.8rem;
      color: rgba(0,0,0,.55);
      font-weight:800;
      margin-right:.25rem;
    }
    .af-badge{
      display:inline-flex;
      align-items:center;
      gap:.35rem;
      border-radius:999px;
      padding:.35rem .6rem;
      border:1px solid rgba(0,0,0,.08);
      background: rgba(0,0,0,.03);
      font-size:.82rem;
      cursor:pointer;
      user-select:none;
    }
    .af-badge:hover{ background: rgba(255,193,7,.12); border-color: rgba(255,193,7,.25); }
    .af-badge i{ opacity:.7; }

    /* ===== Table card + DataTables ===== */
    .table-card{
      background:#fff;
      border-radius:18px;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 12px 30px rgba(0,0,0,.06);
      overflow: visible; /* ne pas couper le scroll interne DT */
    }
    table.dataTable{ margin:0 !important; }
    table.dataTable thead th{
      background:#f7f8fa!important;
      border-bottom:1px solid rgba(0,0,0,.08)!important;
      font-size:.78rem;
      text-transform:uppercase;
      letter-spacing:.05em;
      color: rgba(0,0,0,.55);
      text-align:center !important;
      vertical-align: middle;
    }
    #tableauSession tbody td{
      padding-top:.65rem!important;
      padding-bottom:.65rem!important;
      vertical-align: middle;
      text-align:center !important;
    }

    /* Zebra + hover */
    #tableauSession tbody tr:nth-child(even) > *{ background:rgba(35,51,66,.035)!important; }
    #tableauSession tbody tr:hover > *{ background:rgba(255,193,7,.08)!important; }

    /* ScrollX container */
    #tableauSession_wrapper .dataTables_scrollBody{
      overflow-x:auto !important;
      -webkit-overflow-scrolling: touch;
      scrollbar-gutter: stable both-edges;
    }

    /* Colonnes : permettre wrap sur Infos (4) */
    #tableauSession td:nth-child(2){
      white-space: normal !important;
      width:150px !important;
    }

    /* Actions : ne pas clipper + alignement */
    #tableauSession td.action-column{
      overflow: visible !important;
      white-space: nowrap !important;
      text-align: right !important;
    }

    /* ✅ Sticky mobile (TH + TD) + scope sur #tableauSession */
    @media (max-width: 768px){
      #tableauSession td.action-column,
      #tableauSession th.action-column{
        position: sticky;
        right: 0;
        z-index: 5;
        background: #fff;
        box-shadow: -12px 0 18px -14px rgba(0,0,0,.22);
      }

      /* padding compact */
      #tableauSession td.action-column{
        padding-left: .25rem !important;
        padding-right: .15rem !important;
      }

      /* ✅ Zebra/hover cohérents sur la cellule sticky */
      #tableauSession tbody tr:nth-child(even) > td.action-column{
        background: rgba(35,51,66,.035) !important;
      }
      #tableauSession tbody tr:hover > td.action-column{
        background: rgba(255,193,7,.08) !important;
      }
    }


    /* Hover actions (si tu utilises .hover-actions absolute dans ton partial) */
    #tableauSession td.action-column .hover-actions{ z-index:50; }

    /* TomSelect dropdown au-dessus */
    .filterbar .ts-dropdown{ z-index: 2000 !important; }

    /* Flatpickr style */
    .flatpickr-calendar{
      border-radius: 16px;
      box-shadow: 0 18px 40px rgba(0,0,0,.12);
      border: 1px solid rgba(0,0,0,.08);
    }
    .flatpickr-day.selected,
    .flatpickr-day.startRange,
    .flatpickr-day.endRange{
      background: var(--theme-color-secondaire) !important;
      border-color: var(--theme-color-secondaire) !important;
      color:#111 !important;
    }
    .flatpickr-day.inRange{
      background: rgba(255,193,7,.18) !important;
      border-color: rgba(255,193,7,.08) !important;
    }


    .note-chip{
      display:inline-flex;
      align-items:center;
      gap:.35rem;
      border-radius:999px;
      padding:.22rem .50rem;
      font-weight:800;
      font-size:.78rem;
      border:1px solid rgba(0,0,0,.10);
      background: rgba(0,0,0,.03);
      white-space: nowrap;
    }
    .note-chip b{ font-weight:900; }
    .note-chip .muted{ font-weight:800; opacity:.55; }
    .note-chip.good{ background: rgba(25,135,84,.10); border-color: rgba(25,135,84,.25); color:#146c43; }
    .note-chip.mid{ background: rgba(255,193,7,.14); border-color: rgba(255,193,7,.28); color: rgba(0,0,0,.75); }
    .note-chip.bad{ background: rgba(220,53,69,.10); border-color: rgba(220,53,69,.25); color:#b02a37; }



    /* Empêche que l'icône se retrouve seule sur une ligne */
    #tableauSession td i.bi { white-space: nowrap; }

    /* Empêche le retour à la ligne entre icône + libellé
      (fonctionne avec ton HTML actuel: <div class="text-start"> ... </div>) */
    #tableauSession td .text-start { white-space: nowrap; }


    /* Animation douce des progress-bars */
    .progress-bar.smooth-bar{
      transition: width .55s ease;
    }

    /* Barre dégradée rouge->orange->vert */
    .progress-bar.gradient-bar{
      background: linear-gradient(90deg, #dc3545 0%, #ffc107 50%, #198754 100%);
      transition: width .55s ease;
    }



    /* Bloc satisfaction (dans cellule DataTable) */
    .sat-card{
      border: 1px solid rgba(0,0,0,.08);
      border-left: 4px solid var(--theme-color-secondaire);
      border-radius: 12px;
      padding: .65rem .75rem;
      background: color-mix(in srgb, var(--theme-color-tertiaire) 60%, #fff 40%);
    }

    .sat-title{
      color: var(--theme-color-principal);
      font-weight: 700;
      letter-spacing: .06em;
    }

    .sat-muted{
      color: color-mix(in srgb, var(--theme-color-quaternaire) 55%, transparent);
    }

    .sat-divider{
      height: 1px;
      background: color-mix(in srgb, var(--theme-color-quaternaire) 12%, transparent);
      margin: .25rem 0 .35rem;
    }

    /* Optionnel : rendre les progress bars cohérentes avec la charte */
    .sat-card .progress{
      background: color-mix(in srgb, var(--theme-color-quaternaire) 12%, transparent);
    }



    /* ===== Colonne Tarif : ne jamais couper le montant / € ===== */
  #tableauSession th:nth-child(6),
  #tableauSession td:nth-child(6){
    white-space: nowrap !important;
  }




  /* =========================
   ✅ Actions Sessions (pill + split, style Dépenses/Devis)
   ========================= */

/* largeur mini colonne actions */
#tableauSession th.action-column,
#tableauSession td.action-column{
  width: 1% !important;
  min-width: 0 !important;
  white-space: nowrap !important;
}


/* boutons compacts */
.session-actions .btn{
  padding: .32rem .55rem;
}

/* bouton principal */
.session-actions .session-main{
  background: rgba(255,255,255,.85);
  border-color: rgba(0,0,0,.12);
  box-shadow: 0 10px 22px rgba(0,0,0,.06);
}
.session-actions .session-main:hover{
  box-shadow: 0 14px 28px rgba(0,0,0,.10);
  border-color: rgba(0,0,0,.18);
}

/* split */
.session-actions .session-split{
  padding-left: .55rem;
  padding-right: .55rem;
  border-color: rgba(0,0,0,.12);
  background: rgba(255,255,255,.85);
}

/* fusion pill (main + split) */
.session-actions.btn-group .session-main{
  border-top-right-radius: 0 !important;
  border-bottom-right-radius: 0 !important;
}
.session-actions.btn-group .session-split{
  border-top-left-radius: 0 !important;
  border-bottom-left-radius: 0 !important;
  margin-left: -1px;
  position: relative;
}
.session-actions.btn-group .session-split:before{
  content:"";
  position:absolute;
  left:0;
  top:20%;
  bottom:20%;
  width:1px;
  background: rgba(0,0,0,.10);
}

/* menu dropdown */
.session-actions .session-menu{
  border-radius: 16px;
  border: 1px solid rgba(0,0,0,.10);
  box-shadow: 0 18px 46px rgba(0,0,0,.18);
  padding: .55rem;
  background:
    radial-gradient(900px 220px at 10% 0%, rgba(255,193,7,.10), transparent 55%),
    #fff;
  overflow: hidden;
}
.session-actions .session-menu .dropdown-item{
  border-radius: 12px;
  padding: .50rem .60rem;
  margin: .10rem 0;
  border: 1px solid transparent;
}
.session-actions .session-menu .dropdown-item:hover{
  background: rgba(255,193,7,.10);
  border-color: rgba(255,193,7,.22);
}

/* ✅ menu au-dessus du scroll DataTables (si clipping) */
body .session-floating-dropdown{
  z-index: 20000 !important;
}



  
/* ✅ Colonne actions : ultra compacte */
#tableauSession th:last-child,
#tableauSession td.action-column{
  width: 1% !important;
  min-width: 0 !important;           /* 👈 enlève toute largeur mini */
  padding-left: .15rem !important;   /* 👈 réduit le padding */
  padding-right: .15rem !important;
  white-space: nowrap !important;
  text-align: right !important;
}

/* ⚠️ IMPORTANT : annule ton ancien min-width:140px */
#tableauSession td.action-column{
  min-width: 0 !important;
}


/* ✅ Icônes plus petites */
.session-actions .btn i{
  font-size: .95rem;
}

/* ✅ Split encore plus fin */
.session-actions .session-split{
  padding-left: .32rem !important;
  padding-right: .32rem !important;
}

/* ✅ Menu compact (optionnel) */
.session-actions .session-menu{
  padding: .40rem !important;
}
.session-actions .session-menu .dropdown-item{
  padding: .40rem .50rem !important;
}


/* Participants : cell plus lisible */
#tableauSession td:nth-child(4){
  white-space: normal !important;
  min-width: 180px;
}




/* ✅ Colonne Participants : centré + vertical */
.participants-cell{
  display: flex;
  flex-direction: column;
  align-items: center;     /* centre horizontalement */
  justify-content: center;
  gap: .4rem;
  text-align: center;      /* centre le texte */
}

/* liste en colonne */
.participants-list{
  display: flex;
  flex-direction: column;  /* ✅ 1 par ligne */
  align-items: center;
  gap: .25rem;
  width: 100%;
}

/* badges participants */
.participant-badge{
  display: inline-block;
  max-width: 100%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  border: 1px solid rgba(0,0,0,.08);
  background: #f8f9fa;
  color: #111;
  padding: .25rem .55rem;
  border-radius: 999px;
}

/* badge +X */
.participant-more{
  border: 1px solid rgba(255,193,7,.35);
  background: rgba(255,193,7,.16);
  color: rgba(0,0,0,.78);
  padding: .25rem .55rem;
  border-radius: 999px;
  font-weight: 800;
}

/* total */
.participants-total{
  font-size: .82rem;
  color: rgba(0,0,0,.55);
}

  </style>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
  <script src="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/fr.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
{% endblock %}

{% block body %}

  {# ===== HERO (comme facture) ===== #}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>

    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-easel2 me-2" style="color:var(--theme-color-secondaire)"></i>
            Sessions
          </h2>
          <div class="opacity-75 mt-1">Pilotage, planification et suivi.</div>

          <div class="d-flex flex-wrap gap-2 mt-3">
            <span class="chip"><i class="bi bi-easel2"></i> Sessions</span>
            <span class="chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
            <span class="chip chip--pill"><i class="bi bi-clock-history"></i> <span id="hero-last-refresh">—</span></span>
