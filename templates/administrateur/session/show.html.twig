    if (!btn) return;

    current = {
      pieceId: btn.dataset.pieceId,
      insId: btn.dataset.inscriptionId,
      viewUrl: btn.dataset.viewUrl,
      updateUrl: btn.dataset.updateUrl,
      csrf: btn.dataset.csrf,
      downloadUrl: btn.dataset.downloadUrl,
