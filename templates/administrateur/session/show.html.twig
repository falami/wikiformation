  }
});
</script>




<script>
document.addEventListener('DOMContentLoaded', () => {
  const bulkAll = document.getElementById('bulkAll');
  if (!bulkAll) return;

  const getBoxes = () => Array.from(document.querySelectorAll('input.bulk-one'));

  const refreshBulkAllState = () => {
    const boxes = getBoxes();
    const enabled = boxes.filter(b => !b.disabled);
    const checked = enabled.filter(b => b.checked);

    if (enabled.length === 0) {
      bulkAll.checked = false;
      bulkAll.indeterminate = false;
      bulkAll.disabled = true;
      return;
    }

    bulkAll.disabled = false;
    bulkAll.checked = checked.length === enabled.length;
    bulkAll.indeterminate = checked.length > 0 && checked.length < enabled.length;
  };

  // ✅ Click sur "tout"
  bulkAll.addEventListener('change', () => {
    const boxes = getBoxes();
    boxes.forEach(b => {
      if (!b.disabled) b.checked = bulkAll.checked;
    });
    refreshBulkAllState();
  });

  // ✅ Click sur une ligne
  document.addEventListener('change', (e) => {
    if (!e.target.matches('input.bulk-one')) return;
    refreshBulkAllState();
  });

  // init
  refreshBulkAllState();








  // Tout cocher / décocher par entreprise
  document.querySelectorAll('.js-select-all').forEach(btn => {
    btn.addEventListener('click', () => {
      const scope = btn.dataset.scope;
      document.querySelectorAll('.js-insc[data-scope="'+scope+'"]').forEach(cb => cb.checked = true);
    });
  });

  document.querySelectorAll('.js-unselect-all').forEach(btn => {
    btn.addEventListener('click', () => {
      const scope = btn.dataset.scope;
      document.querySelectorAll('.js-insc[data-scope="'+scope+'"]').forEach(cb => cb.checked = false);
    });
  });

  // Avant submit : ajouter des inputs inscriptionIds[]
  document.querySelectorAll('.js-bulk-form').forEach(form => {
    form.addEventListener('submit', (e) => {
      const scope = form.dataset.scope;

      // nettoyer les anciens inputs
      form.querySelectorAll('input[name="inscriptionIds[]"]').forEach(n => n.remove());

      const checked = Array.from(document.querySelectorAll('.js-insc[data-scope="'+scope+'"]:checked'))
        .map(cb => cb.value);

      if (checked.length === 0) {
        e.preventDefault();
        alert("Aucune inscription sélectionnée.");
        return;
      }

      checked.forEach(id => {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'inscriptionIds[]';
        input.value = id;
        form.appendChild(input);
      });
    });
  });
});
</script>





