<script>
document.addEventListener('DOMContentLoaded', () => {
  function nowLabel(){
    const d = new Date();
    return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
  }
  $('#hero-last-refresh').text('Maj : ' + nowLabel());

  const modalEl = document.getElementById('pieceModal');
  if (!modalEl) return;

  const modal = bootstrap.Modal.getOrCreateInstance(modalEl);

  const titleEl = document.getElementById('pieceModalTitle');
  const subEl   = document.getElementById('pieceModalSub');
  const pillEl  = document.getElementById('pieceModalPill');
  const previewEl = document.getElementById('pieceModalPreview');

  const selValide = document.getElementById('pieceModalValide');
  const taComment = document.getElementById('pieceModalComment');
  const btnSave   = document.getElementById('pieceModalSave');
  const msgEl     = document.getElementById('pieceModalMsg');

  const aDownload = document.getElementById('pieceModalDownload');
  const aOpenNew  = document.getElementById('pieceModalOpenNew');

  let current = null;

  function setPill(valide){
    if (!pillEl) return;
    pillEl.textContent = valide ? '✅ Validé' : '⏳ À valider';
  }

  function renderPreview(url){
    if (!previewEl) return;
    previewEl.innerHTML = '';

    const u = (url || '').toLowerCase();
    const isImage = u.match(/\.(jpg|jpeg|png|webp)(\?|$)/);

    if (isImage){
      const img = document.createElement('img');
      img.src = url;
      img.alt = 'Aperçu';
      img.style.width = '100%';
      img.style.height = '520px';
      img.style.objectFit = 'contain';
      img.style.background = '#0b1621';
      previewEl.appendChild(img);
      return;
    }

    const iframe = document.createElement('iframe');
    iframe.src = url;
    iframe.style.width = '100%';
    iframe.style.height = '520px';
    iframe.style.border = '0';
    previewEl.appendChild(iframe);
  }

  document.addEventListener('click', (e) => {
    const btn = e.target.closest('.js-piece-open');
    if (!btn) return;

    current = {
      id: btn.dataset.pieceId,
      viewUrl: btn.dataset.viewUrl,
      updateUrl: btn.dataset.updateUrl,
      csrf: btn.dataset.csrf,
      downloadUrl: btn.dataset.downloadUrl,
      cardEl: btn.closest('.doc-mini'),
      openBtn: btn
    };

    const type = btn.dataset.pieceType || 'Document';
    const date = btn.dataset.pieceDate || '';
    const valide = btn.dataset.pieceValide === '1';
    const comment = btn.dataset.pieceComment || '';

    titleEl.textContent = type;
    subEl.textContent = `Déposé le ${date}`;
    selValide.value = valide ? '1' : '0';
    taComment.value = comment;
    setPill(valide);

    msgEl.textContent = '';
    btnSave.disabled = false;

    aOpenNew.href = current.viewUrl;
    aDownload.href = current.downloadUrl || current.viewUrl;

    renderPreview(current.viewUrl);
    modal.show();
  });

  btnSave.addEventListener('click', async () => {
    if (!current) return;

    btnSave.disabled = true;
    msgEl.textContent = 'Enregistrement…';

    try{
      const body = new URLSearchParams();
      body.set('_token', current.csrf);
      body.set('valide', selValide.value);
      body.set('commentaire', taComment.value || '');

      const res = await fetch(current.updateUrl, {
        method: 'POST',
        headers: {
          'X-Requested-With':'XMLHttpRequest',
          'Content-Type':'application/x-www-form-urlencoded; charset=UTF-8'
        },
        body: body.toString()
      });

      const json = await res.json().catch(()=>null);
      if (!res.ok || !json || !json.ok){
        throw new Error(json?.message || ('HTTP ' + res.status));
      }

      msgEl.textContent = '✅ Enregistré';
      setPill(!!json.valide);

      /* MAJ visuelle dans la mini-card */
      if (current.cardEl){
        // update badge validé / à valider
        const title = current.cardEl.querySelector('.doc-title');
        if (title){
          const pills = title.querySelectorAll('.badge.rounded-pill');
          pills.forEach(b => b.remove());

          const status = document.createElement('span');
          status.className = json.valide
            ? 'badge rounded-pill bg-success-subtle text-success'
            : 'badge rounded-pill bg-warning-subtle text-warning';
          status.innerHTML = json.valide
            ? '<i class="fa fa-check me-1"></i>Validé'
            : '<i class="fa fa-hourglass me-1"></i>À valider';
          title.appendChild(status);
        }

        // update icône
        const ico = current.cardEl.querySelector('.doc-ico i');
        if (ico){
          ico.className = json.valide ? 'fa fa-check' : 'fa fa-hourglass-half';
        }

        // update commentaire meta
        const meta = current.cardEl.querySelector('.doc-meta');
        if (meta){
          let commentSpan = meta.querySelector('.js-comment-span');
          if (!commentSpan){
            commentSpan = document.createElement('span');
            commentSpan.className = 'text-muted js-comment-span';
            meta.appendChild(commentSpan);
          }
          if (json.commentaire){
            commentSpan.innerHTML = `<i class="fa fa-comment-dots me-1"></i>${json.commentaire}`;
          } else {
            commentSpan.remove();
          }
        }

        // update dataset pour prochaine ouverture
        if (current.openBtn){
          current.openBtn.dataset.pieceValide = json.valide ? '1' : '0';
          current.openBtn.dataset.pieceComment = json.commentaire || '';
        }
      }

      setTimeout(()=> { msgEl.textContent = ''; }, 1200);
    } catch(err){
      console.error(err);
      msgEl.textContent = '❌ ' + (err?.message || 'Erreur');
    } finally {
      btnSave.disabled = false;
    }
  });

});
</script>





<script>
document.addEventListener('DOMContentLoaded', () => {

  // ✅ tooltips bootstrap (sur tout le document)
  const initTooltips = () => {
    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach((el) => {
      if (!bootstrap.Tooltip.getInstance(el)) new bootstrap.Tooltip(el);
    });
  };

  initTooltips();

  // ✅ Event delegation : marche même après redraw DataTables
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('.js-delete-session');
    if (!btn) return;

    const url   = btn.getAttribute('data-url') || '';
    const token = btn.getAttribute('data-token') || '';
    const label = btn.getAttribute('data-label') || 'cette session';

    const form  = document.getElementById('deleteSessionForm');
    const tok   = document.getElementById('deleteSessionToken');
    const labEl = document.getElementById('deleteSessionLabel');

    if (form) form.setAttribute('action', url);
    if (tok) tok.value = token;
    if (labEl) labEl.textContent = label;
  });

