{# templates/administrateur/session/show.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}Session {{ session.code }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
      crossorigin=""/>
<link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
<link rel="stylesheet" href="https://cdn.datatables.net/2.2.2/css/dataTables.dataTables.css"/>
<link rel="stylesheet" href="{{ asset('dist/css/style-table.css') }}">
<style>
:root{
  --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
  --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
  --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
  --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};

  --bg:#f5f7fb;
  --panel:#ffffff;
  --ink:#0f172a;
  --muted:#64748b;
  --stroke: rgba(15, 23, 42, .10);
  --shadow: 0 18px 55px rgba(15, 23, 42, .10);
  --radius: 18px;
}


.hero{
  border-radius: 22px;
  position: relative;
  overflow: hidden;
  color: #fff;
  box-shadow: 0 18px 50px rgba(0,0,0,.14);
  background:
    radial-gradient(1200px 420px at 12% -10%,
      color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
      transparent 58%
    ),
    radial-gradient(900px 380px at 92% 0%,
      color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
      transparent 60%
    ),
    radial-gradient(700px 260px at 55% 115%,
      color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
      transparent 62%
    ),
    linear-gradient(135deg,
      color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
      color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
    );
}
.hero::after{
  content:"";
  position:absolute;
  inset:0;
  pointer-events:none;
  background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
  opacity:.85;
}
.hero .accent{
  width: 12px;
  border-radius: 999px;
  background: var(--theme-color-secondaire);
  box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
}
.hero .chip{
  display:inline-flex;
  align-items:center;
  gap:.5rem;
  padding:.32rem .7rem;
  border-radius:999px;
  background: rgba(255,255,255,.10);
  border: 1px solid rgba(255,255,255,.14);
  font-size:.82rem;
  color: rgba(255,255,255,.92);
  backdrop-filter: blur(6px);
  white-space: nowrap;
}
.hero .chip i{ color: var(--theme-color-secondaire); }
.hero .chip--pill{
  background: color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
  border-color: color-mix(in srgb, var(--theme-color-secondaire) 28%, rgba(255,255,255,.14));
  color:#fff;
}
.hero .btn{ border-radius: 14px; font-weight: 800; }
.hero .btn-outline-theme{
  border-color: rgba(255,255,255,.35);
  color:#fff;
}
.hero .btn-outline-theme:hover{
  background: rgba(255,255,255,.10);
  border-color: rgba(255,255,255,.55);
  color:#fff;
}

body{ overflow-x:hidden; }
.cardx, .doc-mini, .accordion, .accordion-item{ min-width:0; }

/* ===== Premium Card ===== */
.cardx{
  background: var(--panel);
  border: 1px solid var(--stroke);
  border-radius: var(--radius);
  box-shadow: 0 10px 28px rgba(15,23,42,.08);
  overflow:hidden;
}
.cardx-h{
  padding: .95rem 1.05rem;
  display:flex; align-items:center; justify-content:space-between; gap:1rem;
  background: linear-gradient(180deg, rgba(0,0,0,.015), transparent);
  border-bottom: 1px solid var(--stroke);
}
.cardx-title{
  margin:0; font-weight:800; letter-spacing:-.01em; color: var(--ink);
  display:flex; align-items:center; gap:.6rem;
}
.cardx-sub{
  margin:.15rem 0 0;
  color: var(--muted);
  font-size:.9rem;
}

/* chips / badges premium */
.chip{
  font-size:.78rem; padding:.3rem .6rem; border-radius:999px;
  border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, var(--stroke));
  background: color-mix(in srgb, var(--theme-color-principal) 9%, transparent);
  color: var(--ink);
  white-space:nowrap;
}
.badge-soft{
  border-radius:999px;
  padding:.35rem .65rem;
  border:1px solid var(--stroke);
  background: rgba(255,255,255,.65);
  color: var(--ink);
}

/* ===== Accordion premium ===== */
.premium-accordion .premium-item{
  border:1px solid var(--stroke);
  border-radius: 20px;
  overflow:hidden;
  margin-bottom:.85rem;
  background: rgba(255,255,255,.86);
  box-shadow: 0 10px 28px rgba(15,23,42,.06);
  transition: transform .15s ease, box-shadow .15s ease, border-color .15s ease;
}
.premium-accordion .premium-item:hover{
  transform: translateY(-1px);
  box-shadow: 0 18px 46px rgba(15,23,42,.10);
  border-color: color-mix(in srgb, var(--theme-color-principal) 20%, var(--stroke));
}
.premium-accordion .accordion-button{
  padding: 1rem 1.1rem;
  background: transparent;
  box-shadow:none !important;
}
.premium-accordion .accordion-button::after{
  opacity:.65;
  transform: scale(.92);
}
.premium-accordion .accordion-button:not(.collapsed){
  background:
    linear-gradient(180deg, rgba(0,0,0,.012), transparent),
    radial-gradient(800px 240px at 20% 0%, color-mix(in srgb, var(--theme-color-secondaire) 14%, transparent), transparent 60%);
}

/* header stagiaire */
.stag-head{
  display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap;
  width:100%;
}
.stag-left{
  display:flex; align-items:center; gap:.85rem;
}
.stag-avatar{
  width:44px;height:44px;border-radius:16px;
  display:flex;align-items:center;justify-content:center;
  border:1px solid var(--stroke);
  background: color-mix(in srgb, var(--theme-color-secondaire) 14%, transparent);
  color: color-mix(in srgb, var(--theme-color-secondaire) 95%, #000);
  flex:0 0 auto;
}
.stag-name{
  font-weight: 900;
  line-height:1.1;
}
.stag-meta{
  color: var(--muted);
  font-size: .88rem;
}

/* pills stats */
.pill{
  border-radius:999px;
  padding:.45rem .75rem;
  border:1px solid var(--stroke);
  display:inline-flex;
  align-items:center;
  gap:.4rem;
  background: rgba(255,255,255,.7);
  font-weight:700;
  font-size:.82rem;
}
.pill-ok{
  background: rgba(16,185,129,.10);
}
.pill-wait{
  background: rgba(245,158,11,.12);
}
.pill-danger{
  background: rgba(239,68,68,.10);
}

/* actions header */
.stag-actions{
  display:flex; align-items:center; gap:.5rem; flex-wrap:wrap; justify-content:flex-end;
}
.btn-soft{
  border-radius: 14px;
  border: 1px solid var(--stroke);
  background: rgba(255,255,255,.75);
}
.btn-soft:hover{ background: rgba(255,255,255,.95); }

/* ===== Grid pièces ===== */
.docs-mini-grid{
  display:grid;
  grid-template-columns: 1fr;
  gap: .85rem;
}
@media (min-width: 992px){
  .docs-mini-grid{ grid-template-columns: 1fr 1fr; }
}
.doc-mini{
  border:1px solid var(--stroke);
  border-radius: 18px;
  background:
    linear-gradient(180deg, rgba(0,0,0,.012), transparent);
  padding: .95rem;
  display:flex;
  gap:.9rem;
  align-items:flex-start;
  transition: transform .15s ease, box-shadow .15s ease, border-color .15s ease;
}
.doc-mini:hover{
  transform: translateY(-1px);
  box-shadow: 0 16px 40px rgba(15,23,42,.10);
  border-color: color-mix(in srgb, var(--theme-color-principal) 22%, var(--stroke));
}
.doc-ico{
  width: 44px; height: 44px;
  border-radius: 16px;
  display:flex; align-items:center; justify-content:center;
  border: 1px solid color-mix(in srgb, var(--theme-color-secondaire) 26%, var(--stroke));
  background: color-mix(in srgb, var(--theme-color-secondaire) 14%, transparent);
  flex: 0 0 auto;
}
.doc-main{ flex:1 1 auto; min-width:0; }
.doc-title{
  font-weight: 900;
  margin: 0;
  color: var(--ink);
  display:flex;
  align-items:center;
  gap:.5rem;
  flex-wrap:wrap;
}
.doc-meta{
  margin-top: .3rem;
  color: var(--muted);
  font-size: .9rem;
  display:flex;
  gap:.85rem;
  flex-wrap:wrap;
}
.doc-actions{
  flex: 0 0 auto;
  display:flex;
  gap:.45rem;
  align-items:center;
}
.doc-actions .btn{ border-radius: 14px; }

/* empty */
.empty-docs{
  display:flex;
  align-items:center;
  gap: .9rem;
  padding: 1.05rem;
  border-radius: 18px;
  border: 1px dashed var(--stroke);
  background:
    radial-gradient(900px 240px at 15% 0%, color-mix(in srgb, var(--theme-color-principal) 10%, transparent), transparent 55%),
    linear-gradient(180deg, rgba(255,255,255,.7), rgba(255,255,255,.55));
}
.empty-ico{
  width: 46px; height: 46px;
  border-radius: 16px;
  display:flex; align-items:center; justify-content:center;
  background: color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
  border: 1px solid color-mix(in srgb, var(--theme-color-secondaire) 28%, var(--stroke));
  flex: 0 0 auto;
}







.badge-status{
  font-size: .75rem;
  border-radius: 999px;
  padding: .25rem .6rem;
}
.card-session{
  border-radius: 1rem;
  border: 1px solid #e2e8f0;
}
.card-session .card-header{
  border-bottom: 1px solid #e2e8f0;
}
.avatar{
  width:48px;height:48px;border-radius:999px;object-fit:cover;
}
.table-sm td, .table-sm th{
  padding:.35rem .5rem;
}
#session-map{
  width:100%;height:260px;border-radius:12px;
}
.timeline{
  border-left:2px solid #e2e8f0;
  padding-left:1rem;
}
.timeline-item{
  position:relative;
  margin-bottom:.75rem;
}
.timeline-item::before{
  content:'';
  position:absolute;
  left:-11px;
  top:3px;
  width:10px;height:10px;
  background:var(--theme-color-secondaire);
  border-radius:999px;
}

.session-meta{
  display:grid;
  grid-template-columns:minmax(0,1fr);
  gap:.75rem;
}
@media (min-width: 768px){
  .session-meta{
    grid-template-columns:repeat(2,minmax(0,1fr));
  }
}
.session-meta-item{
  padding:.6rem .8rem;
  border-radius:.75rem;
  background: #f8fafc;
  border:1px solid #e2e8f0;
}
.session-meta-label{
  font-size:.75rem;
  text-transform:uppercase;
  letter-spacing:.04em;
  color:#64748b;
  display:flex;
  align-items:center;
  gap:.4rem;
  margin-bottom:.15rem;
}
.session-meta-value{
  font-weight:500;
  color:#0f172a;
}

/* timeline plus lisible */
.timeline-header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:.1rem;
}
.timeline-badge{
  font-size:.7rem;
  border-radius:999px;
  padding:.1rem .5rem;
  background:#e2e8f0;
  color:#475569;
}
.timeline-date{
  font-size:.8rem;
  font-weight:500;
}

/* carte formateur */
.trainer-card{
  align-items:center;
}
.trainer-meta{
  font-size:.85rem;
}
.trainer-meta .badge{
  font-size:.7rem;
}

/* lieu de formation */
.site-header-line{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:.5rem;
}
.site-name{
  font-weight:600;
}
.site-address{
  font-size:.85rem;
  color:#475569;
}

.map-frame{
  border-radius: 1rem;
  overflow: hidden;
  border: 1px solid #e2e8f0;
  background: #f8fafc;
}
.map-frame iframe{
  display:block;
  width:100%;
  height:240px;
  border:0;
}
@media (max-width: 576px){
  .map-frame iframe{ height: 220px; }
}
.travel-badges .badge{ border-radius:999px; }




.docs-pill-ok{
  border:1px solid var(--stroke);
  background: rgba(16,185,129,.12);
  color: var(--ink);
}
.docs-pill-wait{
  border:1px solid var(--stroke);
  background: rgba(245,158,11,.14);
  color: var(--ink);
}

.empty-docs{
  display:flex;
  align-items:center;
  gap: .9rem;
  padding: 1rem;
  border-radius: 16px;
  border: 1px dashed var(--stroke);
  background: linear-gradient(180deg, color-mix(in srgb, var(--theme-color-principal) 7%, transparent), transparent);
}
.empty-ico{
  width: 44px; height: 44px;
  border-radius: 14px;
  display:flex; align-items:center; justify-content:center;
  background: color-mix(in srgb, var(--theme-color-secondaire) 16%, transparent);
  border: 1px solid color-mix(in srgb, var(--theme-color-secondaire) 28%, var(--stroke));
  flex: 0 0 auto;
}
.empty-ico i{ color: color-mix(in srgb, var(--theme-color-secondaire) 95%, #000); font-size: 1.15rem; }

.docs-mini-grid{
  display:grid;
  grid-template-columns: 1fr;
  gap: .75rem;
}

.doc-mini{
  border:1px solid var(--stroke);
  border-radius: 16px;
  background: linear-gradient(180deg, rgba(0,0,0,.012), transparent);
  padding: .85rem;
  display:flex;
  gap:.85rem;
  align-items:flex-start;
}

.doc-mini .doc-ico{
  width: 42px; height: 42px;
  border-radius: 14px;
  display:flex; align-items:center; justify-content:center;
  background: color-mix(in srgb, var(--theme-color-secondaire) 14%, transparent);
  border: 1px solid color-mix(in srgb, var(--theme-color-secondaire) 26%, var(--stroke));
  flex: 0 0 auto;
}
.doc-mini .doc-ico i{
  color: color-mix(in srgb, var(--theme-color-secondaire) 95%, #000);
}

.doc-mini .doc-main{ flex:1 1 auto; min-width:0; }
.doc-mini .doc-title{
  font-weight: 900;
  margin: 0;
  color: var(--ink);
  display:flex;
  align-items:center;
  gap:.5rem;
  flex-wrap:wrap;
}
.doc-mini .doc-meta{
  margin-top: .25rem;
  color: var(--muted);
  font-size: .9rem;
  display:flex;
  gap:.75rem;
  flex-wrap:wrap;
}

.doc-mini .doc-actions{
  flex: 0 0 auto;
  display:flex;
  gap:.35rem;
  align-items:center;
}
.doc-mini .doc-actions .btn{
  border-radius: 12px;
}

@media (min-width: 992px){
  .docs-mini-grid{
    grid-template-columns: 1fr 1fr; /* 2 colonnes desktop */
  }
}


.doc-mini{
  transition: transform .15s ease, box-shadow .15s ease, border-color .15s ease;
}
.doc-mini:hover{
  transform: translateY(-1px);
  box-shadow: 0 14px 35px rgba(15,23,42,.10);
  border-color: color-mix(in srgb, var(--theme-color-principal) 22%, var(--stroke));
}




.premium-accordion .premium-item{
  border:1px solid var(--stroke);
  border-radius: 18px;
  overflow:hidden;
  margin-bottom:.8rem;
  box-shadow: 0 10px 28px rgba(15,23,42,.06);
}
.premium-accordion .premium-btn{
  background:
    radial-gradient(900px 220px at 10% 0%, rgba(255,193,7,.14), transparent 60%),
    linear-gradient(180deg, rgba(0,0,0,.010), transparent);
}
.stag-avatar{
  width:42px;height:42px;border-radius:14px;
  display:flex;align-items:center;justify-content:center;
  border:1px solid var(--stroke);
  background: color-mix(in srgb, var(--theme-color-secondaire) 14%, transparent);
}



/* ===== Confirm modal (premium) ===== */
.confirmx{
  border: 1px solid var(--stroke);
  border-radius: 22px;
  overflow: hidden;
  box-shadow: 0 28px 80px rgba(15,23,42,.20);
  background:
    radial-gradient(900px 220px at 10% 0%,
      color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent),
      transparent 55%
    ),
    linear-gradient(180deg, rgba(255,255,255,.92), rgba(255,255,255,.86));
  backdrop-filter: blur(10px);
}

.confirmx-ico{
  width: 46px; height: 46px;
  border-radius: 16px;
  display:flex; align-items:center; justify-content:center;
  background: rgba(239,68,68,.10);
  border: 1px solid rgba(239,68,68,.18);
  color: rgba(239,68,68,.95);
  flex: 0 0 auto;
}

.confirmx-title{
  font-weight: 950;
  letter-spacing: -.02em;
  color: var(--ink);
  line-height: 1.1;
}

.confirmx-sub{
  color: var(--muted);
  font-size: .92rem;
  margin-top: .15rem;
}

.confirmx-card{
  border: 1px solid var(--stroke);
  border-radius: 18px;
  padding: 1rem;
  background:
    linear-gradient(180deg, rgba(0,0,0,.012), transparent);
}

.confirmx-pill{
  border: 1px solid var(--stroke);
  background: rgba(255,255,255,.65);
  color: var(--ink);
  padding: .38rem .65rem;
}

.modal-backdrop.show{ opacity:.55; }





</style>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.datatables.net/2.2.2/js/dataTables.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.6/dist/umd/popper.min.js"></script>
<script type="text/javascript" src="https://cdn.datatables.net/v/bs5/jszip-2.5.0/dt-1.10.25/b-1.7.1/b-html5-1.7.1/b-print-1.7.1/date-1.1.1/fh-3.1.9/r-2.2.9/rg-1.1.3/sc-2.0.4/sp-1.3.0/datatables.min.js"></script>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
        crossorigin=""></script>
