<script>
document.addEventListener('DOMContentLoaded', () => {
  const modalEl = document.getElementById('confirmDeleteModal');
  if (!modalEl) return;

  const modal = bootstrap.Modal.getOrCreateInstance(modalEl);

  const form = document.getElementById('confirmDeleteForm');
  const tok  = document.getElementById('confirmDeleteToken');
  const lab  = document.getElementById('confirmDeleteLabel');
  const sub  = document.getElementById('confirmDeleteSub');
  const meta = document.getElementById('confirmDeleteMeta');

  // Event delegation (fonctionne même si redraw DataTables)
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('.js-confirm-delete');
    if (!btn) return;

    const url   = btn.getAttribute('data-url') || '';
    const token = btn.getAttribute('data-token') || '';
    const label = btn.getAttribute('data-label') || 'Document';
    const subTxt = btn.getAttribute('data-sub') || 'Ce document sera supprimé.';

    if (form) form.setAttribute('action', url);
    if (tok) tok.value = token;

    if (lab) lab.textContent = label;
    if (sub) sub.textContent = subTxt;

    if (meta) meta.textContent = 'Cette action est irréversible.';
    modal.show();
  });

  // petit confort : focus bouton danger à l’ouverture
  modalEl.addEventListener('shown.bs.modal', () => {
    modalEl.querySelector('button.btn-danger')?.focus();
  });
});
</script>



