                </a>
              </div>
            </div>

            {# 3) Pièces stagiaires (ancre vers ton accordéon premium) #}
            <div class="doc-mini">
              <div class="doc-ico"><i class="fa fa-id-card"></i></div>
              <div class="doc-main">
                <div class="doc-title">
                  Documents stagiaires (dossiers)
                  <span class="badge badge-soft">{{ inscriptionsAll|length }} inscription(s)</span>
                </div>
                <div class="doc-meta">
                  <span class="text-muted">CNI, justificatif, OPCO, règlement, etc.</span>
                </div>
              </div>
              <div class="doc-actions">
                <a class="btn btn-outline-secondary btn-sm"
                  href="#"
                  onclick="event.preventDefault(); document.getElementById('accStagPieces')?.scrollIntoView({behavior:'smooth', block:'start'});"
                  title="Voir">
                  <i class="fa fa-eye"></i>
                </a>
              </div>
            </div>

            {# 4) QCM (PDF questionnaire + résultats) #}
            {% set pre = assignmentsByPhase.pre|default([]) %}
            {% set post = assignmentsByPhase.post|default([]) %}
            {% set nQcm = pre|length + post|length %}
            <div class="doc-mini">
              <div class="doc-ico"><i class="fa fa-clipboard-list"></i></div>
              <div class="doc-main">
                <div class="doc-title">
                  QCM (Pré / Post)
                  <span class="badge badge-soft">{{ nQcm }} assignment(s)</span>
                </div>
                <div class="doc-meta">
                  <span class="text-muted">Accès aux questionnaires PDF + résultats si soumis</span>
                </div>
              </div>
              <div class="doc-actions">
                <a class="btn btn-outline-secondary btn-sm"
                  href="#"
                  onclick="event.preventDefault(); document.querySelector('.fa-clipboard-list')?.closest('.cardx')?.scrollIntoView({behavior:'smooth', block:'start'});"
                  title="Voir">
                  <i class="fa fa-eye"></i>
                </a>
              </div>
            </div>

            {# 5) Factures (lien vers index factures) #}
            <div class="doc-mini">
              <div class="doc-ico"><i class="fa fa-file-invoice-dollar"></i></div>
              <div class="doc-main">
                <div class="doc-title">
                  Factures & avoirs
                  <span class="badge badge-soft">Finance</span>
                </div>
                <div class="doc-meta">
                  <span class="text-muted">Liste des factures / avoirs liés aux inscriptions</span>
                </div>
              </div>
              <div class="doc-actions">
                <a class="btn btn-outline-secondary btn-sm"
                  href="{{ path('app_administrateur_facture_index', {entite: entite.id}) }}"
                  title="Ouvrir la liste">
                  <i class="fa fa-eye"></i>
                </a>
              </div>
            </div>

            {# 6) Conventions (scroll vers bloc bulk conventions) #}
            <div class="doc-mini">
              <div class="doc-ico"><i class="fa fa-file-signature"></i></div>
              <div class="doc-main">
                <div class="doc-title">
                  Conventions / contrats
                  <span class="badge badge-soft">Stagiaires / Entreprises</span>
                </div>
                <div class="doc-meta">
                  <span class="text-muted">Génération / signature / PDF depuis les participants</span>
                </div>
              </div>
              <div class="doc-actions">
                <a class="btn btn-outline-secondary btn-sm"
                  href="#"
                  onclick="event.preventDefault(); document.getElementById('accConvEntreprise')?.scrollIntoView({behavior:'smooth', block:'start'});"
                  title="Voir">
                  <i class="fa fa-eye"></i>
                </a>
              </div>
            </div>

          </div>

            {# ================== SUPPORTS (Assets) ================== #}
            {% set sas = supportAssignSessions|default([]) %}
            {% set sauByUser = supportAssignUsersByUserId|default({}) %}

            <hr class="my-4">

            <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
              <h6 class="mb-0">
                <i class="fa fa-paperclip text-theme-secondaire me-1"></i>
                Supports de cours (assets)
              </h6>

              <span class="chip">
                {{ sas|length }} pour la session •
                {{ sauByUser|length }} stagiaire(s) avec supports dédiés
              </span>
            </div>

            {# -------- A) Supports assignés à la session (tout le monde) -------- #}
            <div class="mb-3">
              <div class="fw-bold mb-2">Pour tous les stagiaires (assignés à la session)</div>

              {% if sas|length > 0 %}
                <div class="docs-mini-grid">
                  {% for assign in sas %}
                    {% set a = assign.asset %}

                    <div class="doc-mini">
                      <div class="doc-ico"><i class="fa fa-paperclip"></i></div>

                      <div class="doc-main">
                        <div class="doc-title">
                          {{ a ? (a.titre ?? ('Asset #' ~ a.id)) : 'Asset supprimé' }}

                          {% if a and a.mimeType %}
                            <span class="badge badge-soft">{{ a.mimeType }}</span>
                          {% endif %}

                          {% if assign.isVisibleToTrainee %}
                            <span class="badge rounded-pill bg-success-subtle text-success">Visible stagiaire</span>
                          {% else %}
                            <span class="badge rounded-pill bg-secondary-subtle text-secondary">Masqué</span>
                          {% endif %}
                        </div>

                        <div class="doc-meta">
                          <span class="text-muted">
                            Ajouté le {{ (assign.createdAt ?? assign.dateCreation)|date('d/m/Y H:i') }}
                          </span>

                          {% if assign.visibleFrom or assign.visibleUntil %}
                            <span class="text-muted">
                              <i class="fa fa-calendar me-1"></i>
                              {% if assign.visibleFrom %}du {{ assign.visibleFrom|date('d/m/Y H:i') }}{% endif %}
                              {% if assign.visibleUntil %} au {{ assign.visibleUntil|date('d/m/Y H:i') }}{% endif %}
                            </span>
                          {% endif %}
                        </div>
                      </div>

                      <div class="doc-actions">
                        {% if a and a.filename %}
                          {# ✅ ADAPTE LE DOSSIER SELON TON SupportAsset (ex: uploads/support_assets/) #}
                          {% set url = asset('uploads/supports/library/' ~ a.filename) %}

                          <a class="btn btn-outline-secondary btn-sm" target="_blank" href="{{ url }}" title="Ouvrir">
                            <i class="fa fa-eye"></i>
                          </a>
                          <a class="btn btn-outline-primary btn-sm" href="{{ url }}" download title="Télécharger">
                            <i class="fa fa-download"></i>
                          </a>
                        {% else %}
                          <span class="text-muted small">Fichier indisponible</span>
                        {% endif %}
                      </div>
                    </div>

                  {% endfor %}
                </div>
              {% else %}
                <div class="empty-docs">
                  <div class="empty-ico"><i class="fa fa-file-circle-xmark"></i></div>
                  <div>
                    <div class="fw-bold">Aucun support assigné à la session</div>
                    <div class="text-muted small">Assigne des assets à la session pour les rendre accessibles à tous.</div>
                  </div>
                </div>
              {% endif %}
            </div>

            {# -------- B) Supports assignés par stagiaire -------- #}
            <div class="mt-4">
              <div class="fw-bold mb-2">Supports dédiés par stagiaire (assignés à l’utilisateur)</div>

              {% if inscriptionsAll is empty %}
                <div class="text-muted small">Aucun stagiaire.</div>
              {% else %}
                <div class="accordion" id="accSupportUser">
                  {% for ins in inscriptionsAll %}
                    {% set u = ins.stagiaire %}
                    {% set list = (u and sauByUser[u.id] is defined) ? sauByUser[u.id] : [] %}
                    {% set blockId = 'su_' ~ ins.id %}

                    <div class="accordion-item">
                      <h2 class="accordion-header" id="h_{{ blockId }}">
                        <button class="accordion-button collapsed" type="button"
                                data-bs-toggle="collapse" data-bs-target="#c_{{ blockId }}"
                                aria-expanded="false" aria-controls="c_{{ blockId }}">
                          <div class="w-100 d-flex align-items-center justify-content-between">
                            <div class="d-flex flex-column">
                              <span class="fw-semibold">
                                {{ u ? (u.prenom ~ ' ' ~ u.nom) : ('Inscription #' ~ ins.id) }}
                              </span>
                              <span class="text-muted small">{{ u and u.email ? u.email : '-' }}</span>
                            </div>
                            <span class="badge bg-secondary ms-3">{{ list|length }}</span>
                          </div>
                        </button>
                      </h2>

                      <div id="c_{{ blockId }}" class="accordion-collapse collapse" aria-labelledby="h_{{ blockId }}"
                          data-bs-parent="#accSupportUser">
                        <div class="accordion-body">

                          {% if list|length == 0 %}
                            <div class="text-muted small">Aucun support dédié.</div>
                          {% else %}
                            <div class="docs-mini-grid">
                              {% for assign in list %}
                                {% set a = assign.asset %}

                                <div class="doc-mini">
                                  <div class="doc-ico"><i class="fa fa-user-tag"></i></div>

                                  <div class="doc-main">
                                    <div class="doc-title">
                                      {{ a ? (a.titre ?? ('Asset #' ~ a.id)) : 'Asset supprimé' }}

                                      {% if a and a.mimeType %}
                                        <span class="badge badge-soft">{{ a.mimeType }}</span>
                                      {% endif %}

                                      {% if assign.isVisibleToTrainee %}
                                        <span class="badge rounded-pill bg-success-subtle text-success">Visible</span>
                                      {% else %}
                                        <span class="badge rounded-pill bg-secondary-subtle text-secondary">Masqué</span>
                                      {% endif %}
                                    </div>

                                    <div class="doc-meta">
                                      <span class="text-muted">
                                        Ajouté le {{ (assign.createdAt ?? assign.dateCreation)|date('d/m/Y H:i') }}
                                      </span>

                                      {% if assign.visibleFrom or assign.visibleUntil %}
                                        <span class="text-muted">
                                          <i class="fa fa-calendar me-1"></i>
                                          {% if assign.visibleFrom %}du {{ assign.visibleFrom|date('d/m/Y H:i') }}{% endif %}
                                          {% if assign.visibleUntil %} au {{ assign.visibleUntil|date('d/m/Y H:i') }}{% endif %}
                                        </span>
                                      {% endif %}
                                    </div>
                                  </div>

                                  <div class="doc-actions">
                                    {% if a and a.filename %}
                                      {% set url = asset('uploads/supports/' ~ a.filename) %}

                                      <a class="btn btn-outline-secondary btn-sm" target="_blank" href="{{ url }}" title="Ouvrir">
                                        <i class="fa fa-eye"></i>
                                      </a>
                                      <a class="btn btn-outline-primary btn-sm" href="{{ url }}" download title="Télécharger">
                                        <i class="fa fa-download"></i>
                                      </a>
                                    {% else %}
                                      <span class="text-muted small">Fichier indisponible</span>
                                    {% endif %}
                                  </div>
                                </div>

                              {% endfor %}
                            </div>
                          {% endif %}

                        </div>
                      </div>
                    </div>
                  {% endfor %}
                </div>
              {% endif %}
            </div>


        </div>
      </div>
    </div>
  </div>



 {# ================== ACTIONS & PDF DE LA SESSION ================== #}
  <div class="row g-3 mb-4">
    <div class="col-lg-12">
      <div class="cardx card-session">
        <div class="cardx-h">
          <span><i class="fa fa-gears text-theme-secondaire me-2"></i> Actions & PDF pour cette session</span>
        </div>
        <div class="p-3 p-md-4">
          <div class="row g-3">
            <div class="col-md-4">
              <h6 class="mb-2"><i class="fa fa-file-pen me-1 text-theme-secondaire"></i> Émargements</h6>
              <p class="small text-muted mb-2">
                Feuilles d’émargement à faire signer par les stagiaires et le formateur.
              </p>
              <div class="d-grid gap-2">
                <a href="{{ path('app_formateur_emargement_pdf', {entite: entite.id}) ~ '?session=' ~ session.id }}"
                  class="btn btn-outline-primary btn-sm"
                  target="_blank">
                  <i class="fa fa-file-pdf"></i> Feuille d’émargement (synthèse)
                </a>
              </div>
            </div>

            <div class="col-md-4">
              <h6 class="mb-2"><i class="fa fa-file-signature me-1 text-theme-secondaire"></i> Convention & contrats</h6>
              <p class="small text-muted mb-2">
                Génération / gestion des conventions individuelles par stagiaire.
              </p>
              <ul class="small mb-0">
                <li>
                  Depuis le tableau des participants, clique sur
                  <i class="fa fa-file-contract text-primary"></i>
                  pour générer ou visualiser la convention PDF d’un stagiaire.
                </li>
                <li>
                  Tu peux aussi accéder aux formulaires depuis l’inscription :
                  <code>Inscription &gt; Convention / contrat</code>.
                </li>
              </ul>
            </div>

            <div class="col-md-4">
              <h6 class="mb-2"><i class="fa fa-file-invoice-dollar me-1 text-theme-secondaire"></i> Factures & finances</h6>
              <p class="small text-muted mb-2">
                Création / consultation des factures et avoirs liés aux inscriptions de la session.
              </p>
              <ul class="small mb-0">
                <li>
                  Depuis chaque fiche inscription, tu peux créer et visualiser les
                  factures / avoirs associés.
                </li>
                <li class="mt-1">
                  <a href="{{ path('app_administrateur_facture_index', {entite: entite.id}) }}"
                    class="link-secondary">
                    <i class="fa fa-list-ul"></i> Aller à la liste des factures
                  </a>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>





  {# ================== ÉQUIPEMENTS (LOGISTIQUE) ================== #}
  <div class="row g-3 mb-4">
    <div class="col-lg-12">
      <div class="cardx card-session">
        <div class="cardx-h">
          <span>
            <i class="fa fa-chalkboard-teacher text-theme-secondaire me-2"></i>
            Équipements & logistique
          </span>

          {# petit résumé #}
          {% set equipList = [
            ['equipOrdinateurFormateur', 'Ordinateur (formateur)', 'bi-laptop'],
            ['equipVideoprojecteurEcran', 'Vidéoprojecteur / écran', 'bi-projector'],
            ['equipInternetStable', 'Connexion Internet stable', 'bi-wifi'],
            ['equipTableauPaperboard', 'Tableau blanc / paperboard', 'bi-easel2'],
            ['equipMarqueursSupportsImprimes', 'Marqueurs / supports imprimés', 'bi-journal-text'],
            ['salleAdapteeTailleGroupe', 'Salle adaptée (taille du groupe)', 'bi-people'],
            ['salleTablesChaisesErgo', 'Tables / chaises ergonomiques', 'bi-grid-3x3-gap'],
            ['salleLumiereChauffageClim', 'Lumière / chauffage / clim', 'bi-sun'],
            ['salleEauCafe', 'Eau / café', 'bi-cup-hot'],
          ] %}

          {% set okCount = 0 %}
          {% set totalCount = 0 %}
          {% for it in equipList %}
            {% set prop = it[0] %}
            {% if attribute(session, prop) is defined %}
              {% set totalCount = totalCount + 1 %}
              {% if attribute(session, prop) %}
                {% set okCount = okCount + 1 %}
              {% endif %}
            {% endif %}
          {% endfor %}

          <span class="badge bg-light text-dark">
            {{ okCount }}/{{ totalCount }} validé{{ totalCount > 1 ? 's' : '' }}
          </span>
        </div>

        <div class="p-3 p-md-4">
          <div class="row g-3">
            {% for it in equipList %}
              {% set prop  = it[0] %}
              {% set label = it[1] %}
              {% set icon  = it[2] %}

              {% if attribute(session, prop) is defined %}
                {% set val = attribute(session, prop) %}
                <div class="col-12 col-md-6 col-lg-4">
                  <div class="session-meta-item d-flex align-items-start justify-content-between gap-2">
                    <div>
                      <div class="session-meta-label">
                        <i class="bi {{ icon }} text-theme-secondaire"></i>
                        {{ label }}
                      </div>
                      <div class="small text-muted">
                        {{ val ? 'Présent' : 'Non' }}
                      </div>
                    </div>

                    <span class="badge {{ val ? 'bg-success' : 'bg-secondary' }}">
                      <i class="bi {{ val ? 'bi-check2' : 'bi-x' }}"></i>
                    </span>
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>

          {# fallback si rien n'existe #}
          {% if totalCount == 0 %}
            <p class="text-muted mb-0">Aucun champ “logistique” n’est disponible sur cette session.</p>
          {% endif %}
        </div>
      </div>
    </div>
  </div>





  























