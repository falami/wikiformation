  {# ====== Conventions entreprise (bulk) ====== #}
 <div class="row g-3 mb-4">
    <div class="col-lg-12">
      <div class="cardx card-session">
        <div class="cardx-h">
          <div>
            <div class="fw-semibold">Conventions - financement entreprise</div>
            <div class="text-muted small">Tout est coché par défaut. Tu peux décocher avant de générer.</div>
          </div>
        </div>

        <div class="card-body">
          {% if byEntreprise is empty %}
            <div class="alert alert-info mb-0">
              Aucun stagiaire “financement entreprise” sur cette session.
            </div>
          {% else %}

            <div class="accordion" id="accConvEntreprise">
              {% for group in byEntreprise %}
                {% set entreprise = group.entreprise %}
                {% set inscs = group.inscriptions|default([]) %}
                {% set blockId = 'ent_' ~ entreprise.id %}

                <div class="accordion-item">
                  <h2 class="accordion-header" id="h_{{ blockId }}">
                    <button class="accordion-button collapsed" type="button"
                            data-bs-toggle="collapse" data-bs-target="#c_{{ blockId }}"
                            aria-expanded="false" aria-controls="c_{{ blockId }}">
                      <div class="w-100 d-flex align-items-center justify-content-between">
                        <div class="d-flex flex-column">
                          <span class="fw-semibold">{{ entreprise.raisonSociale }}</span>
                          <span class="text-muted small">{{ inscs|length }} stagiaire(s)</span>
                        </div>
                        <span class="badge bg-secondary ms-3">{{ inscs|length }}</span>
                      </div>
                    </button>
                  </h2>

                  <div id="c_{{ blockId }}" class="accordion-collapse collapse" aria-labelledby="h_{{ blockId }}"
                      data-bs-parent="#accConvEntreprise">
                    <div class="accordion-body">

                      {# Actions (select all + generate) #}
                      <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
                        <button type="button"
                                class="btn btn-outline-secondary btn-sm js-select-all"
                                data-scope="{{ blockId }}">
                          <i class="bi bi-check2-square me-1"></i>Tout cocher
                        </button>

                        <button type="button"
                                class="btn btn-outline-secondary btn-sm js-unselect-all"
                                data-scope="{{ blockId }}">
                          <i class="bi bi-square me-1"></i>Tout décocher
                        </button>

                        <form method="post"
                              action="{{ path('app_administrateur_convention_from_session_entreprise', { entite: entite.id }) }}"
                              class="ms-auto js-bulk-form"
                              data-scope="{{ blockId }}">
                          <input type="hidden" name="_token" value="{{ csrf_token('conv_bulk_' ~ entite.id) }}">
                          <input type="hidden" name="sessionId" value="{{ session.id }}">
                          <input type="hidden" name="entrepriseId" value="{{ entreprise.id }}">

                          {# On injecte les ids cochés via JS avant submit #}
                          <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary btn-sm">
                              <i class="bi bi-file-earmark-text me-1"></i>Générer / mettre à jour la convention
                            </button>
                          </div>
                        </form>
                      </div>

                      {# Liste stagiaires #}
                      <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                          <thead>
                            <tr>
                              <th style="width:38px;"></th>
                              <th>Stagiaire</th>
                              <th class="text-muted">Email</th>
                              <th class="text-muted">Inscription</th>
                            </tr>
                          </thead>
                          <tbody>
                            {% for i in inscs %}
                              {% set u = i.stagiaire %}
                              <tr>
                                <td>
                                  <input class="form-check-input js-insc"
                                        type="checkbox"
                                        data-scope="{{ blockId }}"
                                        value="{{ i.id }}"
                                        checked>
                                </td>
                                <td class="fw-semibold">
                                  {{ (u.prenom ~ ' ' ~ u.nom)|trim ?: '-' }}
                                </td>
                                <td class="text-muted small">
                                  {{ u.email ?? '-' }}
                                </td>
                                <td class="text-muted small">
                                  #{{ i.id }}
                                </td>
                              </tr>
                            {% endfor %}
                          </tbody>
                        </table>
                      </div>

                      <div class="text-muted small mt-2">
                        Astuce : ce bouton met à jour la convention entreprise de cette session (il remplace la liste des stagiaires rattachés).
                      </div>

                    </div>
                  </div>
                </div>
              {% endfor %}
            </div>

          {% endif %}
        </div>
      </div>
    </div>
  </div>








{# ================== DOCUMENTS / SUPPORTS (ICÔNES) ================== #}
  <div class="row g-3 mb-4">
