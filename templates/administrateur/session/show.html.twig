{% block body %}


<div class="hero p-3 mb-4 d-flex gap-3">
  <div class="accent"></div>

  <div class="flex-grow-1">
    <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
      <div>
        <h2 class="m-0 fw-bold">
          <i class="fa fa-calendar text-theme-secondaire me-2"></i>
          {{ session.formation ? session.formation.titre : session.formationIntituleLibre }}
        </h2>

          <div class="opacity-75 mt-1">ID Session : {{ session.code }} - Site : {{ session.site ? session.site.nom : '-' }}</div>

        <div class="d-flex flex-wrap gap-2 mt-3">
          <span class="chip"><i class="bi bi-easel2"></i> Sessions</span>
          <span class="chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
          <span class="chip chip--pill"><i class="bi bi-clock-history"></i> <span id="hero-last-refresh">-</span></span>
        </div>
      </div>

        <div class="d-flex gap-2 flex-wrap">
          <a href="{{ path('app_administrateur_session_index', {entite: entite.id}) }}" class="btn btn-outline-light btn-sm fw-semibold">
            <i class="fa fa-arrow-left"></i> Retour
          </a>
          <a href="{{ path('app_administrateur_session_modifier', {entite: entite.id, id: session.id}) }}"
            class="btn btn-light btn-sm fw-semibold">
            <i class="fa fa-pen"></i> Modifier
          </a>
        </div>
    </div>
  </div>
</div>



  {% include 'flagMessage.html.twig' %}

  {# ================== LIGNE DE RÉSUMÉ ================== #}
  <div class="row g-3 mb-4">
    {# INFOS SESSION #}
    <div class="col-md-4">
      <div class="cardx mb-3">
        <div class="cardx-h">
          <span>
            <i class="fa fa-info-circle text-theme-secondaire me-2"></i> Infos session
          </span>
          <span class="badge badge-status bg-light text-dark">
            {{ session.status ? session.status.label : '-' }}
          </span>
        </div>
        <div class="p-3 p-md-3">

          {# calcul min/max #}
          {% set min = null %}
          {% set max = null %}
          {% for j in session.jours %}
            {% if min is null or j.dateDebut < min %}{% set min = j.dateDebut %}{% endif %}
            {% if max is null or j.dateFin > max %}{% set max = j.dateFin %}{% endif %}
          {% endfor %}

          <div class="session-meta">
            <div class="session-meta-item">
              <div class="session-meta-label">
                <i class="fa fa-graduation-cap text-theme-secondaire"></i>
                Formation
              </div>
              <div class="session-meta-value">
                {{ session.formation ? session.formation.titre : session.formationIntituleLibre }}
              </div>
            </div>

            <div class="session-meta-item">
              <div class="session-meta-label">
                <i class="fa fa-users text-theme-secondaire"></i>
                Capacité
              </div>
              <div class="session-meta-value">
                {{ session.capacite }} place{{ session.capacite > 1 ? 's' : '' }}
              </div>
            </div>

            <div class="session-meta-item">
              <div class="session-meta-label">
                <i class="fa fa-calendar-day text-theme-secondaire"></i>
                Période
              </div>
              <div class="session-meta-value">
                {% if min and max %}
                  {{ min|date('d/m/Y H:i') }} <br />au<br /> {{ max|date('d/m/Y H:i') }}<br>
                  <span class="text-muted small">
                    {{ session.jours|length }} jour{{ session.jours|length > 1 ? 's' : '' }} planifié{{ session.jours|length > 1 ? 's' : '' }}
                  </span>
                {% else %}
                  <span class="text-muted">Non planifiée</span>
                {% endif %}
              </div>
            </div>

            <div class="session-meta-item">
              <div class="session-meta-label">
                <i class="fa fa-euro-sign text-theme-secondaire"></i>
                Tarif
              </div>
              <div class="session-meta-value">
                {% set tarif = session.tarifEffectifCents() %}
                {% if tarif %}
                  {{ (tarif/100)|number_format(2, ',', ' ') }} € TTC
                  <div class="small text-muted">par stagiaire</div>
                {% else %}
                  <span class="text-muted small">Utilise le prix de base de la formation</span>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="cardx">
        <div class="cardx-h">
        <span>
          <i class="fa fa-location-dot text-theme-secondaire me-2"></i> Lieu de formation
        </span>
        </div>
        <div class="p-3 p-md-4">
          {% if session.site %}
            <div class="site-header-line mb-2">
              <div class="site-name">{{ session.site.nom }}</div>
              {% if session.site.ville %}
                <span class="badge bg-light text-dark">{{ session.site.ville }}</span>
              {% endif %}
            </div>

            <div class="site-address mb-3">
              {% if session.site.adresse %}{{ session.site.adresse }}<br>{% endif %}
              {% if session.site.codePostal or session.site.ville %}
                {{ session.site.codePostal }} {{ session.site.ville }}<br>
              {% endif %}
              {% if session.site.region or session.site.pays %}
                {{ session.site.region }} {{ session.site.pays }}
              {% endif %}
            </div>

            <div id="session-map"></div>
          {% else %}
            <p class="text-muted mb-0">Aucun site associé.</p>
          {% endif %}
        </div>
      </div>
    </div>
    

    {# PLANNING / EMARGEMENTS #}
    <div class="col-lg-4">
      <div class="cardx mb-3">
        <div class="cardx-h">
          <span>
            <i class="fa fa-clock text-theme-secondaire me-2"></i> Planning & émargements
          </span>
          
        </div>
        <div class="p-3 p-md-4">
          {% if session.jours|length > 0 %}
            <div class="timeline">
              {% for j in session.jours %}
                {% set totalEmarg = 0 %}
                  {% set signedEmarg = 0 %}
                  {% set dayKey = j.dateDebut|date('Y-m-d') %}

                  {% for e in session.emargements %}
                    {% if e.dateJour and e.dateJour|date('Y-m-d') == dayKey %}
                      {% set totalEmarg = totalEmarg + 1 %}

                      {% set isSigned =
                        (e.signedAt is not null)
                        or (e.signatureDataUrl is defined and e.signatureDataUrl)
                        or (e.signaturePath is defined and e.signaturePath)
                      %}

                      {% if isSigned %}
                        {% set signedEmarg = signedEmarg + 1 %}
                      {% endif %}
                    {% endif %}
                  {% endfor %}


                <div class="timeline-item">
                  <div class="timeline-header">
                    <span class="timeline-badge">Jour {{ loop.index }}</span>
                    <span class="small text-muted">{{ j.dateDebut|date('d/m/Y') }}</span>
                  </div>
                  <div class="timeline-date">
                    <i class="fa fa-clock me-1 text-theme-secondaire"></i>
                    {{ j.dateDebut|date('H:i') }} → {{ j.dateFin|date('H:i') }}
                  </div>
                  <div class="small text-muted mt-1">
                    Émargements :
                    {% if totalEmarg > 0 %}
                      {% if signedEmarg == totalEmarg %}
                        <span class="text-success">
                          <i class="fa fa-check-circle me-1"></i>{{ signedEmarg }}/{{ totalEmarg }} signé(s)
                        </span>
                      {% else %}
                        <span class="text-warning">
                          <i class="fa fa-pen-nib me-1"></i>{{ signedEmarg }}/{{ totalEmarg }} signé(s)
                        </span>
                      {% endif %}
                    {% else %}
                      <span class="text-muted">-</span>
                    {% endif %}
                  </div>

                </div>
              {% endfor %}
            </div>
          {% else %}
            <p class="text-muted mb-0">Aucune journée planifiée pour le moment.</p>
          {% endif %}
        </div>
      </div>
    </div>

    {# FORMATEUR + LIEU #}
    <div class="col-md-4">
      <div class="cardx mb-3">
        <div class="cardx-h">
          <span><i class="fa fa-user-tie text-theme-secondaire me-2"></i> Formateur(s)</span>
          {% if session.formateur %}
            <span class="badge bg-light text-dark">Référent :
              {{ session.formateur.utilisateur ? session.formateur.utilisateur.prenom ~ ' ' ~ session.formateur.utilisateur.nom : '-' }}
            </span>
          {% endif %}
        </div>

        <div class="p-3 p-md-2">
          {% if formateursSession is defined and formateursSession|length > 0 %}
            <ul class="list-group list-group-flush">
              {% for f in formateursSession %}
                {% set u = f.utilisateur %}
                {% set contrat = contratsByFormateur[f.id] ?? null %}
                {% set travel = travelByFormateurId[f.id] ?? null %}


                <li class="list-group-item">
                  <div class="d-flex align-items-center justify-content-between trainer-card">
                    <div class="d-flex align-items-center">
                      <img class="avatar me-3"
                          src="{{ u and u.photo ? asset('uploads/photos/utilisateur/' ~ u.photo) : 'https://via.placeholder.com/96x96?text=F' }}"
                          alt="Photo formateur">

                      <div class="trainer-meta">
                        <h6 class="mb-1">
                          {{ u ? u.prenom ~ ' ' ~ u.nom : 'Formateur #' ~ f.id }}
                          {% if session.formateur and f.id == session.formateur.id %}
                            <span class="badge bg-theme-tertiaire text-dark ms-2">Référent</span>
                          {% endif %}
                        </h6>

                        {% if u %}
                          <div class="text-muted mb-1">
                            {{ u.email }}<br>
                            {{ u.telephone ?: '' }}
                          </div>
                        {% endif %}

                        {% if f.certifications %}
                          <div class="small mb-1">
                            <span class="fw-semibold d-block mb-1">Certifications</span>
                            <span>{{ f.certifications }}</span>
                          </div>
                        {% endif %}

                        <div class="small text-muted mt-1">
                          {{ session.getNombreJoursPourFormateur(f) }} jour(s) d’intervention -
                          {{ session.getNombreHeuresPourFormateur(f)|number_format(1, ',', ' ') }} h
                        </div>
                        

                      </div>
                    </div>
                  </div>

                  <div class="text-center mt-2">
                    <div class="btn-group btn-group-sm" role="group">
                      <a href="{{ path('app_administrateur_session_contrat_formateur', { entite: entite.id, id: session.id, formateur: f.id }) }}"
                        class="btn btn-outline-primary"
                        title="{{ contrat ? 'Regénérer le contrat formateur (PDF mis à jour)' : 'Créer un nouveau contrat pré-rempli' }}">
                        <i class="fa fa-file-signature"></i>
                        {{ contrat ? 'Regénérer le contrat' : 'Préparer un contrat' }}
                      </a>

                      {% if contrat %}
                        <a href="{{ path('app_administrateur_formateurs_contrats_edit', { entite: entite.id, id: contrat.id }) }}"
                          class="btn btn-outline-secondary"
                          title="Modifier les informations du contrat">
                          <i class="fa fa-pen"></i>
                        </a>
                      {% endif %}

                      {% if contrat and contrat.pdfPath %}
                        <a href="{{ asset(contrat.pdfPath) }}"
                          class="btn btn-outline-success"
                          target="_blank"
                          title="Voir le contrat PDF">
                          <i class="fa fa-file-pdf"></i>
                        </a>
                      {% endif %}
                    </div>

                    {% if contrat %}
                      <div class="small text-muted mt-1">
                        Contrat n° {{ contrat.numero }}<br>
                        {{ contrat.status.label }}
                      </div>
                    {% endif %}
                  </div>

                {% if travel %}
                    <div class="mt-3 p-3 rounded-4 border" style="background:#f8fafc; border-color:#e2e8f0!important;">
                      <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                        <div>
                          <div class="fw-semibold">
                            <i class="fa fa-route text-theme-secondaire me-1"></i>
                            Itinéraire formateur → site
                          </div>
                          <div class="small text-muted">
                            {{ travel.originAddress ?: 'Adresse formateur non renseignée' }}
                            <br>
                            → {{ travel.destAddress ?: 'Adresse site non renseignée' }}
                          </div>

                          <div class="travel-badges mt-2 d-flex gap-2 flex-wrap">
                            {% if travel.distanceText %}
                              <span class="badge text-bg-light">{{ travel.distanceText }}</span>
                            {% endif %}
                            {% if travel.durationText %}
                              <span class="badge text-bg-light">{{ travel.durationText }}</span>
                            {% endif %}
                            {% if travel.costText %}
                              <span class="badge text-bg-light">
                                Frais estimés : <strong>{{ travel.costText }}</strong>
                                <span class="text-muted">({{ kmRate|number_format(2, ',', ' ') }} €/km)</span>
                              </span>
                            {% endif %}
                          </div>

                          {% if travel.gmapsError %}
                            <div class="small text-muted mt-2">
                              <i class="fa fa-triangle-exclamation me-1"></i>
                              {{ travel.gmapsError }}
                            </div>
                          {% endif %}
                        </div>
                      </div>

                      <div class="mt-3 map-frame">
                        {% if travel.gmapsEmbedUrl %}
                          <iframe src="{{ travel.gmapsEmbedUrl }}"
                                  loading="lazy"
                                  referrerpolicy="no-referrer-when-downgrade"
                                  allowfullscreen></iframe>
                        {% else %}
                          <div class="text-muted small p-3">
                            <i class="fa fa-info-circle me-1"></i>
                            Carte indisponible (clé navigateur manquante ou adresses incomplètes).
                          </div>
                        {% endif %}
                      </div>
                    </div>
                  {% endif %}
                </li>
              {% endfor %}
            </ul>
          {% else %}
            <p class="text-muted mb-0">Aucun formateur associé à cette session.</p>
          {% endif %}
        </div>
      </div>

      
    </div>
  </div>

  {# --- Statistiques globales dossiers / pièces obligatoires --- #}
  {% set piecesObligGlobal = session.piecesObligatoires|default([]) %}
  {% set totalIns = session.inscriptions|length %}
  {% set dossiersNonRequis = 0 %}
  {% set dossiersNonCrees = 0 %}
  {% set dossiersComplets = 0 %}
  {% set dossiersIncomplets = 0 %}

  {% for ins in session.inscriptions %}
    {% if piecesObligGlobal is empty %}
      {% set dossiersNonRequis = dossiersNonRequis + 1 %}
    {% else %}
      {% if ins.dossier is null %}
        {% set dossiersNonCrees = dossiersNonCrees + 1 %}
      {% else %}
        {% set manquantes = ins.piecesManquantes is defined ? ins.piecesManquantes : ins.dossier.getPiecesManquantesPourSession(session) %}
        {% if manquantes is empty %}
          {% set dossiersComplets = dossiersComplets + 1 %}
        {% else %}
          {% set dossiersIncomplets = dossiersIncomplets + 1 %}
        {% endif %}
      {% endif %}
    {% endif %}
  {% endfor %}

  {% set inscriptionsAvecPieces = totalIns - dossiersNonRequis %}
  {% set pourcentageComplets = inscriptionsAvecPieces > 0 ? (dossiersComplets / inscriptionsAvecPieces * 100) : 0 %}

  {# ================== PARTICIPANTS / DOSSIERS ================== #}
  <div class="row g-3 mb-4">
    <div class="col-12">
      <div class="cardx mb-3">
        <div class="cardx-h">
          <span><i class="fa fa-users text-theme-secondaire me-2"></i> Participants</span>
          <div class="text-end small">
            <div>{{ totalIns }} inscrit(s) / {{ session.capacite }} places</div>

            {% if piecesObligGlobal is not empty and inscriptionsAvecPieces > 0 %}
              <div class="mt-1">
                <div class="d-flex justify-content-between mb-1">
                  <span class="text-muted">Dossiers complets</span>
                  <span class="fw-semibold">{{ dossiersComplets }}/{{ inscriptionsAvecPieces }}</span>
                </div>
                <div class="progress" style="height:6px;">
                  <div class="progress-bar bg-success"
                      role="progressbar"
                      style="width: {{ pourcentageComplets|round(0, 'floor') }}%;"
                      aria-valuenow="{{ pourcentageComplets|round(0, 'floor') }}"
                      aria-valuemin="0" aria-valuemax="100"></div>
                </div>
                <div class="text-muted mt-1">
                  <span class="me-2">{{ dossiersIncomplets }} dossier(s) incomplet(s)</span>
                  <span class="me-2">{{ dossiersNonCrees }} dossier(s) non créé(s)</span>
                </div>
              </div>
            {% else %}
              <div class="text-muted mt-1">Aucune pièce obligatoire définie pour cette session.</div>
            {% endif %}
          </div>
        </div>

        <div class="card-body p-0">
          {% if session.inscriptions|length > 0 %}
            <div class="table-responsive">
              <table class="table table-sm mb-0 align-middle">
                <thead class="table-light">
                  <tr>
                    <th style="width:36px">
                      <input class="form-check-input" type="checkbox" id="bulkAll">
                    </th>
                    <th>Stagiaire</th>
                    <th>Entreprise</th>
                    <th>Statut</th>
                    <th>Assiduité</th>
                    <th>Convention</th>
                    <th class="text-end">Actions</th>
                  </tr>
                </thead>


                <tbody>
                  {% for ins in session.inscriptions %}
                    {% set s = ins.stagiaire %}
                    {% set mode = ins.modeFinancement ?? ins.mode ?? null %}
                    {% set entreprise = ins.entreprise ?? null %}

                    {# IMPORTANT : Inscription n'a PAS "convention". On la retrouve via session.conventionContrats + entreprise #}
                    {% set conv = (entreprise and conventionsByEntrepriseId[entreprise.id] is defined) ? conventionsByEntrepriseId[entreprise.id] : null %}



                    <tr>
                      <td>
                        <input class="form-check-input bulk-one"
                              type="checkbox"
                              value="{{ ins.id }}"
                              data-entreprise-id="{{ ins.entreprise ? ins.entreprise.id : '' }}">
                      </td>

                      <td>
                        {% if s %}
                          <strong>{{ s.prenom }} {{ s.nom }}</strong><br>
                          <span class="text-muted small">{{ s.email }}</span>
                          {% if entreprise and entreprise.raisonSociale %}
                            <div class="small text-muted mt-1">
                              <i class="fa fa-building me-1"></i>{{ entreprise.raisonSociale }}
                            </div>
                          {% endif %}
                        {% else %}
                          -
                        {% endif %}
                      </td>
                      <td>
                        {% if entreprise %}
                          <div class="fw-semibold">{{ entreprise.raisonSociale ?: '-' }}</div>
                          <div class="small text-muted">
                            {% if entreprise.siret %}SIRET : {{ entreprise.siret }}{% endif %}
                          </div>
                        {% else %}
                          <span class="text-muted">-</span>
                        {% endif %}
                      </td>

                      <td>
                        <span class="badge bg-light text-dark">
                          {{ ins.status ? ins.status.label : '-' }}
                        </span>
                      </td>

                      <td>
                        {% if ins.tauxAssiduite is not null %}
                          {{ ins.tauxAssiduite|number_format(0, ',', ' ') }}%
                        {% else %}
                          -
                        {% endif %}
                      </td>

                      <td>
                        {% set entreprise = ins.entreprise ?? null %}
                        {% set stagiaire  = ins.stagiaire ?? null %}
                        {% set mode       = ins.modeFinancement ?? ins.mode ?? null %}

                        {# retrouver la convention (entreprise OU stagiaire) #}
                        {% set conv = null %}
                        {% if entreprise and conventionsByEntrepriseId[entreprise.id] is defined %}
                          {% set conv = conventionsByEntrepriseId[entreprise.id] %}
                        {% elseif stagiaire and conventionsByStagiaireId[stagiaire.id] is defined %}
                          {% set conv = conventionsByStagiaireId[stagiaire.id] %}
                        {% endif %}

                        {# si mode non renseigné #}
                        {% if mode is null %}
                          <span class="text-muted small">-</span>

                        {# cas convention entreprise requise #}
                        {% elseif mode.requiresConvention() %}
                          {% if entreprise is null %}
                            <span class="badge bg-warning-subtle text-warning" title="Le mode de financement nécessite une entreprise.">
                              <i class="fa fa-building me-1"></i> Entreprise requise
                            </span>
                          {% else %}
                            {% if conv %}
                              {% set isSigned =
                                (conv.signatureDataUrlStagiaire is defined and conv.signatureDataUrlStagiaire)
                                or (conv.signatureDataUrlEntreprise is defined and conv.signatureDataUrlEntreprise)
                                or (conv.dateSignatureOf is defined and conv.dateSignatureOf)
                              %}

                              <div class="btn-group btn-group-sm" role="group">
                                <a href="{{ path('app_administrateur_convention_show', { entite: entite.id, id: conv.id }) }}"
                                  class="btn {{ isSigned ? 'btn-outline-success' : 'btn-outline-warning' }}"
                                  title="{{ isSigned ? 'Convention signée' : 'Convention à signer' }}">
                                  <i class="fa {{ isSigned ? 'fa-check-circle' : 'fa-pen-nib' }}"></i>
                                  {{ isSigned ? 'Signée' : 'À signer' }}
                                </a>

                                <a href="{{ path('app_administrateur_convention_show', { entite: entite.id, id: conv.id }) }}"
                                  class="btn btn-outline-secondary" title="Ouvrir">
                                  <i class="fa fa-eye"></i>
                                </a>

                                {% if conv.pdfPath %}
                                  <a href="{{ path('app_administrateur_convention_pdf', { entite: entite.id, id: conv.id }) }}"
                                    class="btn btn-outline-primary" target="_blank" title="PDF">
                                    <i class="fa fa-file-pdf"></i>
                                  </a>
                                {% else %}
                                  <form method="post"
                                        action="{{ path('app_administrateur_convention_generate_pdf', { entite: entite.id, id: conv.id }) }}"
                                        class="d-inline"
                                        onsubmit="return confirm('Générer le PDF de cette convention ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('genpdf' ~ conv.id) }}">
                                    <button class="btn btn-outline-primary" type="submit" title="Générer PDF">
                                      <i class="fa fa-gears"></i>
                                    </button>
                                  </form>
                                {% endif %}
                              </div>
                            {% else %}
                              <a href="{{ path('app_administrateur_convention_from_inscription', { entite: entite.id, id: ins.id }) }}"
                                class="btn btn-outline-primary btn-sm">
                                <i class="fa fa-file-contract"></i> Préparer
                              </a>
                            {% endif %}
                          {% endif %}

                        {# cas contrat stagiaire (financement individuel) #}
                        {% elseif mode.requiresContratStagiaire() %}
                          {% if conv %}
                            {% set isSigned =
                              (conv.signatureDataUrlStagiaire is defined and conv.signatureDataUrlStagiaire)
                              or (conv.dateSignatureOf is defined and conv.dateSignatureOf)
                            %}

                            <div class="btn-group btn-group-sm" role="group">
                              <a href="{{ path('app_administrateur_convention_show', { entite: entite.id, id: conv.id }) }}"
                                class="btn {{ isSigned ? 'btn-outline-success' : 'btn-outline-warning' }}">
                                <i class="fa {{ isSigned ? 'fa-check-circle' : 'fa-pen-nib' }}"></i>
                                {{ isSigned ? 'Signé' : 'À signer' }}
                              </a>

                              <a href="{{ path('app_administrateur_convention_show', { entite: entite.id, id: conv.id }) }}"
                                class="btn btn-outline-secondary" title="Ouvrir">
                                <i class="fa fa-eye"></i>
                              </a>
                            </div>
                          {% else %}
                            <a href="{{ path('app_administrateur_convention_from_inscription', { entite: entite.id, id: ins.id }) }}"
                              class="btn btn-outline-primary btn-sm">
                              <i class="fa fa-file-contract"></i> Préparer
                            </a>
                          {% endif %}

                        {% else %}
                          <span class="text-muted small">-</span>
                        {% endif %}
                      </td>





                      <td class="text-end">
                        <div class="btn-group btn-group-sm" role="group">
                          <a href="{{ path('app_administrateur_inscription_show', {entite: entite.id, id: ins.id}) }}"
                             class="btn btn-outline-secondary"
                             title="Voir l’inscription">
                            <i class="fa fa-eye"></i>
                          </a>
                          <a href="{{ path('app_administrateur_inscription_edit', {entite: entite.id, id: ins.id}) }}"
                             class="btn btn-outline-secondary"
                             title="Modifier l’inscription">
                            <i class="fa fa-pen"></i>
                          </a>

                          <a href="{{ path('app_administrateur_pdf_convocation', {entite: entite.id, id: ins.id}) }}"
                             class="btn btn-outline-primary"
                             title="Convocation PDF"
                             target="_blank">
                            <i class="fa fa-file-lines"></i>
                          </a>

                          {% if ins.attestation is defined and ins.attestation and ins.attestation.id is defined %}
                            <a href="{{ path('app_administrateur_pdf_attestation', {entite: entite.id, id: ins.id}) }}"
                               class="btn btn-outline-success"
                               title="Attestation PDF"
                               target="_blank">
                              <i class="fa fa-file-circle-check"></i>
                            </a>
                          {% endif %}

                          {% set statusValue = ins.status.value %}
                          {% if statusValue not in ['termine', 'annule', 'absent'] %}
                            <form id="close-ins-{{ ins.id }}"
                                  method="post"
                                  action="{{ path('app_administrateur_inscription_close', { entite: entite.id, id: ins.id }) }}"
                                  class="d-none">
                              <input type="hidden" name="_token" value="{{ csrf_token('close' ~ ins.id) }}">
                            </form>

                            <a href="#"
                              class="btn btn-outline-success"
                              title="Clôturer l’inscription (calculer l’assiduité)"
                              onclick="event.preventDefault();
                                        if (confirm('Clôturer cette inscription ? Le taux d’assiduité sera calculé et la réussite mise à jour.')) {
                                          document.getElementById('close-ins-{{ ins.id }}').submit();
                                        }">
                              <i class="fa fa-flag-checkered"></i>
                            </a>
                          {% endif %}

                        </div>
                      </td>
                    </tr>
                  {% endfor %}
                </tbody>

              </table>
            </div>
          {% else %}
            <p class="text-muted m-3">Aucun participant pour cette session.</p>
          {% endif %}
        </div>
      </div>
    </div>
  </div>





{# ================== DOCUMENTS STAGIAIRES (PREMIUM) ================== #}
{% set requiredPiecesGlobal = session.piecesObligatoires|default([]) %}
{% set uploadCsrf = csrf_token('stagiaire_piece_upload_' ~ session.id) %}
<div class="row g-3 mb-4">
  <div class="col-12">
    <div class="cardx">
      <div class="cardx-h">
        <div>
          <h5 class="cardx-title">
            <i class="fa fa-id-card text-warning"></i>
            Documents stagiaires
          </h5>
          <div class="cardx-sub">Contrôle des pièces déposées et complétude du dossier par inscription.</div>
        </div>

        <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
          <span class="chip">
            <i class="fa fa-users me-1"></i> {{ inscriptionsAll|length }} inscription(s)
          </span>
          <span class="badge-soft">
            <i class="fa fa-list-check me-1"></i> Pièces obligatoires : <strong>{{ requiredPiecesGlobal|length ?: '-' }}</strong>
          </span>
        </div>
      </div>

      <div class="p-3 p-md-4">
        {% if inscriptionsAll is empty %}
          <div class="empty-docs">
            <div class="empty-ico"><i class="fa fa-users-slash"></i></div>
            <div>
              <div class="fw-bold">Aucun stagiaire</div>
              <div class="text-muted small">Ajoute des inscriptions pour commencer.</div>
            </div>
          </div>
        {% else %}

          <div class="accordion premium-accordion" id="accStagPieces">
            {% for ins in inscriptionsAll %}
              {% set s = ins.stagiaire %}
              {% set dossier = ins.dossier %}
              {% set pieces = dossier ? dossier.pieces : [] %}

              {% set nTotal = pieces|length %}
              {% set nOk = pieces|filter(p => p.valide)|length %}
              {% set nWait = nTotal - nOk %}

              {% set missing = ins.piecesManquantes|default([]) %}
              {% set dossierComplet = ins.dossierComplet|default(false) %}
              {% set blockId = 'ins_' ~ ins.id %}

              <div class="accordion-item premium-item">
                <h2 class="accordion-header" id="h_{{ blockId }}">
                  <button class="accordion-button collapsed" type="button"
                          data-bs-toggle="collapse" data-bs-target="#c_{{ blockId }}"
                          aria-expanded="false" aria-controls="c_{{ blockId }}">

                    <span class="stag-head w-100">
                      <span class="stag-left">
                        <span class="stag-avatar"><i class="fa fa-user"></i></span>

                        <span class="d-flex flex-column">
                          <span class="stag-name">
                            {{ s ? (s.prenom ~ ' ' ~ s.nom) : ('Stagiaire #' ~ ins.id) }}
                          </span>
                          <span class="stag-meta">
                            <span class="me-2">Inscription n°{{ ins.id }} • {{ s and s.email ? s.email : '-' }}</span>
                          </span>
                        </span>
                      </span>

                      <span class="stag-actions">
                        <span class="pill pill-ok js-ins-ok" data-ins="{{ ins.id }}">
                          <i class="fa fa-check"></i> <span class="js-nok">{{ nOk }}</span> validé(s)
                        </span>
                        <span class="pill pill-wait js-ins-wait" data-ins="{{ ins.id }}">
                          <i class="fa fa-hourglass"></i> <span class="js-nwait">{{ nWait }}</span> à valider
                        </span>

                        {% if requiredPiecesGlobal is not empty %}
                          {% if dossierComplet %}
                            <span class="pill pill-ok">
                              <i class="fa fa-shield-check"></i> Dossier complet
                            </span>
                          {% else %}
                            <span class="pill pill-danger"
                                  title="{% if missing is not empty %}Manquantes : {{ missing|map(m => m.label)|join(', ') }}{% endif %}">
                              <i class="fa fa-triangle-exclamation"></i> À compléter
                            </span>
                          {% endif %}
                        {% endif %}

                        <span class="btn btn-primary btn-sm fw-semibold js-upload-open"
                              role="button" tabindex="0"
                              data-inscription-id="{{ ins.id }}"
                              data-stagiaire-label="{{ s ? (s.prenom ~ ' ' ~ s.nom)|e('html_attr') : ('Inscription #' ~ ins.id) }}"
                              title="Ajouter une pièce">
                          <i class="fa fa-plus me-1"></i> Ajouter
                        </span>

                        <a class="btn btn-soft btn-sm"
                          href="{{ path('app_administrateur_inscription_show', {entite: entite.id, id: ins.id}) }}"
                          title="Ouvrir la fiche inscription">
                          <i class="fa fa-up-right-from-square"></i>
                        </a>
                      </span>
                    </span>

                  </button>
                </h2>


                <div id="c_{{ blockId }}" class="accordion-collapse collapse"
                    aria-labelledby="h_{{ blockId }}" data-bs-parent="#accStagPieces">
                  <div class="accordion-body">

                    {% if pieces is empty %}
                      <div class="empty-docs">
                        <div class="empty-ico"><i class="fa fa-file-circle-xmark"></i></div>
                        <div>
                          <div class="fw-bold">Aucune pièce déposée</div>
                          <div class="text-muted small">Le stagiaire peut déposer, ou tu peux ajouter via “Ajouter”.</div>
                        </div>
                      </div>
                    {% else %}
                      <div class="docs-mini-grid js-piece-grid" data-ins="{{ ins.id }}">
                        {% for p in pieces %}
                          <div class="doc-mini js-piece-card" data-piece-id="{{ p.id }}">
                            <div class="doc-ico">
                              {% if p.valide %}<i class="fa fa-check"></i>{% else %}<i class="fa fa-hourglass-half"></i>{% endif %}
                            </div>

                            <div class="doc-main">
                              <div class="doc-title">
                                <span class="badge badge-soft">{{ p.type.label() }}</span>

                                {% if p.valide %}
                                  <span class="badge rounded-pill bg-success-subtle text-success">
                                    <i class="fa fa-check me-1"></i>Validé
                                  </span>
                                {% else %}
                                  <span class="badge rounded-pill bg-warning-subtle text-warning">
                                    <i class="fa fa-hourglass me-1"></i>À valider
                                  </span>
                                {% endif %}
                              </div>

                              <div class="doc-meta">
                                <span><i class="fa fa-clock me-1"></i>{{ p.uploadedAt|date('d/m/Y H:i') }}</span>
                                {% if p.commentaireControle %}
                                  <span class="text-muted js-comment-span">
                                    <i class="fa fa-comment-dots me-1"></i>{{ p.commentaireControle }}
                                  </span>
                                {% endif %}
                              </div>
                            </div>

                            <div class="doc-actions">
                              <button type="button"
                                      class="btn btn-soft btn-sm js-stag-piece-open"
                                      title="Voir / Contrôler"
                                      data-piece-id="{{ p.id }}"
                                      data-inscription-id="{{ ins.id }}"
                                      data-piece-type="{{ p.type.label() }}"
                                      data-piece-date="{{ p.uploadedAt|date('d/m/Y H:i') }}"
                                      data-piece-valide="{{ p.valide ? '1' : '0' }}"
                                      data-piece-comment="{{ p.commentaireControle|default('')|e('html_attr') }}"
                                      data-view-url="{{ path('app_administrateur_session_stagiaire_piece_view', {entite: entite.id, session: session.id, piece: p.id}) }}"
                                      data-update-url="{{ path('app_administrateur_session_stagiaire_piece_update', {entite: entite.id, session: session.id, piece: p.id}) }}"
                                      data-download-url="{{ path('app_administrateur_session_stagiaire_piece_download', {entite: entite.id, session: session.id, piece: p.id}) }}"
                                      data-csrf="{{ csrf_token('upd_piece_' ~ p.id) }}">
                                <i class="fa fa-eye"></i>
                              </button>

                              <a class="btn btn-outline-primary btn-sm"
                                title="Télécharger"
                                href="{{ path('app_administrateur_session_stagiaire_piece_download', {entite: entite.id, session: session.id, piece: p.id}) }}">
                                <i class="fa fa-download"></i>
                              </a>
                            </div>
                          </div>
                        {% endfor %}
                      </div>
                    {% endif %}
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>








{# ================== DOCUMENTS SESSION (premium + modal) ================== #}
{% set sessionPieces = session.pieces ?? [] %}
{% set nTotal = sessionPieces|length %}
{% set nOk = sessionPieces|filter(p => p.valide)|length %}
{% set nWait = nTotal - nOk %}
<div class="row g-3 mb-4">
  <div class="col-12">
    <div class="cardx">
      <div class="cardx-h">
        <h5 class="cardx-title">
          <i class="fa fa-folder-open text-warning"></i>
          Documents session
          {% if nTotal > 0 %}
            <span class="chip ms-2">{{ nTotal }} doc(s)</span>
          {% endif %}
        </h5>

        <div class="d-flex align-items-center gap-2 flex-wrap">
          {% if nTotal > 0 %}
            <span class="badge rounded-pill px-3 py-2 docs-pill-ok">
              <i class="fa fa-check me-1"></i>{{ nOk }} validé(s)
            </span>
            <span class="badge rounded-pill px-3 py-2 docs-pill-wait">
              <i class="fa fa-hourglass me-1"></i>{{ nWait }} à valider
            </span>
          {% endif %}

          <a class="btn btn-outline-primary btn-sm fw-semibold"
            href="{{ path('app_administrateur_session_pieces_index', {entite: entite.id, session: session.id}) }}">
            <i class="fa fa-gear me-1"></i> Gérer
          </a>
        </div>
      </div>

      <div class="p-3 p-md-4">

        {% if nTotal == 0 %}
          <div class="empty-docs">
            <div class="empty-ico"><i class="fa fa-file-circle-xmark"></i></div>
            <div class="empty-txt">
              <div class="fw-bold">Aucun document déposé</div>
              <div class="text-muted small">Ajoute des pièces depuis “Gérer” (upload + contrôle).</div>
            </div>
          </div>
        {% else %}

          <div class="docs-mini-grid">
            {% for p in sessionPieces %}
              <div class="doc-mini">
                <div class="doc-ico">
                  {% if p.valide %}
                    <i class="fa fa-check"></i>
                  {% else %}
                    <i class="fa fa-hourglass-half"></i>
                  {% endif %}
                </div>

                <div class="doc-main">
                  <div class="doc-title">
                    <span class="badge badge-soft">{{ p.type.label }}</span>

                    {% if p.valide %}
                      <span class="badge rounded-pill bg-success-subtle text-success">
                        <i class="fa fa-check me-1"></i>Validé
                      </span>
                    {% else %}
                      <span class="badge rounded-pill bg-warning-subtle text-warning">
                        <i class="fa fa-hourglass me-1"></i>À valider
                      </span>
                    {% endif %}
                  </div>

                  <div class="doc-meta">
                    <span><i class="fa fa-clock me-1"></i>{{ p.uploadedAt|date('d/m/Y H:i') }}</span>
                    {% if p.commentaireControle %}
                      <span class="text-muted">
                        <i class="fa fa-comment-dots me-1"></i>{{ p.commentaireControle }}
                      </span>
                    {% endif %}
                  </div>
                </div>

                <div class="doc-actions">
                  <button type="button"
                          class="btn btn-outline-secondary btn-sm js-piece-open"
                          title="Voir / Contrôler"
                          data-piece-id="{{ p.id }}"
                          data-piece-type="{{ p.type.label }}"
                          data-piece-date="{{ p.uploadedAt|date('d/m/Y H:i') }}"
                          data-piece-valide="{{ p.valide ? '1' : '0' }}"
                          data-piece-comment="{{ p.commentaireControle|default('')|e('html_attr') }}"
                          data-view-url="{{ path('app_administrateur_session_pieces_view', {entite: entite.id, session: session.id, piece: p.id}) }}"
                          data-update-url="{{ path('app_administrateur_session_pieces_update', {entite: entite.id, session: session.id, piece: p.id}) }}"
                          data-download-url="{{ path('app_administrateur_session_pieces_download', {entite: entite.id, session: session.id, piece: p.id}) }}"
                          data-csrf="{{ csrf_token('upd_session_piece_' ~ p.id) }}">
                    <i class="fa fa-eye"></i>
                  </button>

                  <a class="btn btn-outline-primary btn-sm"
                    title="Télécharger"
                    href="{{ path('app_administrateur_session_pieces_download', {entite: entite.id, session: session.id, piece: p.id}) }}">
                    <i class="fa fa-download"></i>
                  </a>
                  <button type="button"
                          class="btn btn-outline-danger btn-sm js-confirm-delete"
                          title="Supprimer"
                          data-bs-toggle="tooltip"
                          data-url="{{ path('app_administrateur_session_pieces_delete', { entite: entite.id, session: session.id, piece: p.id }) }}"
                          data-token="{{ csrf_token('del_session_piece_' ~ p.id) }}"
                          data-label="{{ (p.type.label ?? p.type.label() ?? 'Document')|e('html_attr') }}"
                          data-sub="{{ ('Déposé le ' ~ (p.uploadedAt ? p.uploadedAt|date('d/m/Y H:i') : ''))|e('html_attr') }}">
                    <i class="fa fa-trash"></i>
                  </button>
                </div>
              </div>
            {% endfor %}
          </div>

          <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
            <div class="text-muted small">Affichage des {{ nTotal }} document(s).</div>

            <a class="btn btn-light btn-sm fw-semibold"
              href="{{ path('app_administrateur_session_pieces_index', {entite: entite.id, session: session.id}) }}">
              <i class="fa fa-folder-open me-1"></i> Gérer / Voir tout
            </a>
          </div>


        {% endif %}
      </div>
    </div>
  </div>
</div>





