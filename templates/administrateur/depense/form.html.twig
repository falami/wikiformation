{# templates/administrateur/depense/form.html.twig #}
{% extends 'base_admin.html.twig' %}

{% block title %}{{ title|default('Dépense') }}{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/formulaire.css') }}">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};

      --bg:#f5f7fb;
      --panel:#fff;
      --ink:#0f172a;
      --muted:#64748b;
      --stroke: rgba(15, 23, 42, .10);
      --shadow: 0 18px 55px rgba(15, 23, 42, .10);
      --radius:18px;
    }
    

    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;

      /* Ombre douce premium */
      box-shadow: 0 18px 50px rgba(0,0,0,.14);

      /* Fond piloté par les couleurs de l'entité */
      background:
        /* halo clair (tertiaire) */
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        /* halo accent (secondaire) */
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        /* voile subtil (quaternaire) pour la profondeur */
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        /* dégradé principal (principal -> plus clair) */
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    /* léger glass highlight */
    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    /* barre accent = secondaire (et glow basé sur secondaire) */
    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }
    /* ===== HERO Chips (comme site/index) ===== */
    .hero .chip{
      display:inline-flex;
      align-items:center;
      gap:.5rem;
      padding:.32rem .7rem;
      border-radius: 999px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(255,255,255,.14);
      font-size:.82rem;
      color: rgba(255,255,255,.92);
      backdrop-filter: blur(6px);
      white-space: nowrap;
    }
    .hero .chip i{ color: var(--theme-color-secondaire); }

    .hero .chip--pill{
      background: color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
      border-color: color-mix(in srgb, var(--theme-color-secondaire) 28%, rgba(255,255,255,.14));
      color:#fff;
    }

    /* boutons hero (cohérents site/index) */
    .hero .btn{
      border-radius: 14px;
      font-weight: 800;
    }
    .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }

    /* ===== CARDS ===== */
    .cardx{
      background: var(--panel);
      border: 1px solid var(--stroke);
      border-radius: var(--radius);
      box-shadow: 0 10px 28px rgba(15,23,42,.08);
      overflow:visible;
    }
    .cardx-h{
      padding: .95rem 1.05rem;
      display:flex; align-items:center; justify-content:space-between; gap:1rem;
      background: linear-gradient(180deg, rgba(0,0,0,.015), transparent);
      border-bottom: 1px solid var(--stroke);
    }
    .cardx-title{
      margin:0; font-weight:800; letter-spacing:-.01em; color: var(--ink);
      display:flex; align-items:center; gap:.6rem;
    }
    .chip{
      font-size:.78rem; padding:.25rem .55rem; border-radius:999px;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, var(--stroke));
      color: var(--muted);
      white-space:nowrap;
    }

    /* ===== FORM POLISH ===== */
    label.form-label{ font-weight: 700; color: var(--ink); }
    .form-text, .text-muted, .small{ color: var(--muted) !important; }
    .form-control, .form-select{
      border-radius: 14px;
      border: 1px solid var(--stroke);
      padding: .65rem .85rem;
    }
    .form-control:focus, .form-select:focus{
      border-color: color-mix(in srgb, var(--theme-color-principal) 55%, var(--stroke));
      box-shadow: 0 0 0 .2rem color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
    }

    /* TomSelect */
    .ts-wrapper .ts-control{
      border-radius: 14px !important;
      padding: .55rem .75rem !important;
      border-color: var(--stroke) !important;
    }
    .ts-wrapper.focus .ts-control{
      box-shadow: 0 0 0 .2rem color-mix(in srgb, var(--theme-color-principal) 18%, transparent) !important;
      border-color: color-mix(in srgb, var(--theme-color-principal) 55%, var(--stroke)) !important;
    }
    .ts-dropdown, .ts-dropdown.form-control, .ts-dropdown .ts-dropdown-content{
      z-index: 1080 !important;
    }

    /* input suffix */
    .input-euro .form-control{
      border-top-right-radius: 0 !important;
      border-bottom-right-radius: 0 !important;
    }
    .input-euro .euro-suffix{
      border-top-left-radius: 0 !important;
      border-bottom-left-radius: 0 !important;
      font-weight: 800;
      letter-spacing: .02em;
      color: var(--theme-color-principal);
      border-color: var(--stroke);
      min-width: 46px;
      justify-content: center;
      border: 1px solid var(--stroke);
    }

    .mini-kpi{
      border:1px solid var(--stroke);
      border-radius: 16px;
      padding:.85rem 1rem;
      background: linear-gradient(180deg, color-mix(in srgb, var(--theme-color-secondaire) 10%, transparent), transparent);
    }
    .summary-box{
      border: 1px solid var(--stroke);
      border-radius: 18px;
      background: linear-gradient(180deg, color-mix(in srgb, var(--theme-color-principal) 8%, transparent), transparent);
      padding: 1rem;
    }

    /* Upload */
    .upload-drop{
      border: 1.5px dashed color-mix(in srgb, var(--theme-color-principal) 22%, var(--stroke));
      border-radius: 16px;
      padding: 1rem;
      background: color-mix(in srgb, var(--panel) 92%, transparent);
      transition: .15s ease;
    }
    .upload-drop.is-dragover{
      background: color-mix(in srgb, var(--theme-color-secondaire) 16%, var(--panel));
      border-color: color-mix(in srgb, var(--theme-color-secondaire) 40%, var(--stroke));
    }

    @media (max-width:768px){
      .hero{ border-radius:16px; }
    }



    .proof-card{
      border:1px solid var(--stroke);
      border-radius: 18px;
      overflow:hidden;
      background: linear-gradient(180deg, color-mix(in srgb, var(--theme-color-principal) 6%, transparent), transparent);
      box-shadow: 0 10px 28px rgba(15,23,42,.08);
    }
    .proof-card-h{
      padding:.8rem 1rem;
      display:flex; align-items:center; justify-content:space-between; gap:.75rem;
      border-bottom:1px solid var(--stroke);
      background: linear-gradient(180deg, rgba(0,0,0,.02), transparent);
    }
    .proof-meta{
      display:flex; flex-direction:column; gap:.15rem;
    }
    .proof-name{
      font-weight: 800; color: var(--ink); line-height:1.1;
    }
    .proof-sub{
      color: var(--muted); font-size:.85rem;
    }
    .proof-body{
      background: color-mix(in srgb, var(--panel) 92%, transparent);
    }
    .proof-frame{
      width:100%;
      height: 360px;
      border:0;
      display:block;
      background: #fff;
    }
    @media (max-width: 768px){
      .proof-frame{ height: 260px; }
    }

    .scan-thumb{
      border:1px solid var(--stroke);
      border-radius:14px;
      overflow:hidden;
      background:#fff;
    }
    .scan-thumb img{
      width:100%;
      height:auto;
      display:block;
    }
    .scan-thumb iframe{
      width:100%;
      height:260px;
      border:0;
      display:block;
    }
    @media (max-width:768px){
      .scan-thumb iframe{ height:220px; }
    }



    /* ===== Scan preview : taille réduite ===== */
    #scanPreview .scan-thumb img,
    #scanPreview .scan-thumb iframe {
      max-height: 300px;       /* 👈 taille réduite */
      width: 100%;
      object-fit: contain;
      border-radius: 12px;
      background: #fff;
    }

    @media (max-width: 768px) {
      #scanPreview .scan-thumb img,
      #scanPreview .scan-thumb iframe {
        max-height: 140px;
      }
    }



  </style>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  <script src="https://npmcdn.com/flatpickr/dist/l10n/fr.js"></script>
{% endblock %}

{% block body %}


  {# ===== HERO (comme site/index) ===== #}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>

    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-wallet2 me-2" style="color:var(--theme-color-secondaire)"></i>
            {{ title|default('Dépense') }}
          </h2>
          <div class="opacity-75 mt-1">Saisie rapide, TVA, montants.</div>

          <div class="d-flex flex-wrap gap-2 mt-3">
            <span class="chip"><i class="bi bi-wallet2"></i> Dépenses</span>
            <span class="chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
            <span class="chip chip--pill">
              <i class="bi bi-pencil-square"></i>
              {% if form.vars.value and form.vars.value.id %}Modification{% else %}Création{% endif %}
            </span>
          </div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
          <a class="btn btn-outline-theme btn-sm fw-semibold"
            href="{{ path('app_administrateur_depense_index', { entite: entite.id }) }}">
            <i class="bi bi-arrow-left me-1"></i> Retour
          </a>

          <button form="{{ form.vars.id }}" type="submit" class="btn btn-light btn-sm fw-semibold">
            <i class="bi bi-check2 me-1"></i> Enregistrer
          </button>
        </div>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  {{ form_start(form, { attr: { id: form.vars.id, novalidate:'novalidate', name:'depense_form' } }) }}
  {{ form_errors(form) }}

  <div class="row g-4">

    {# ===== COL LEFT ===== #}
    <div class="col-lg-8">






      <div class="card border-0 shadow-sm mb-3" style="border-radius:18px;">
        <div class="card-body">

          <div class="d-flex flex-wrap gap-2 align-items-center justify-content-between">
            <div>
              <div class="fw-bold">Scanner un reçu</div>
              <div class="text-muted small">Glisse une photo / PDF, ou prends une photo : on te propose HT / TVA / TTC + date.</div>
            </div>

            <div class="d-flex gap-2 align-items-center flex-wrap">
              {# input principal : fichiers #}
              <input id="scanFile" type="file"
                    accept="image/*,application/pdf"
                    class="d-none">

              {# input camera dédié (mobile) : photo directe #}
              <input id="scanCamera" type="file"
                    accept="image/*"
                    capture="environment"
                    class="d-none">

              <button type="button" class="btn btn-light btn-sm" id="btnScanPick" style="border-color:var(--stroke);">
                <i class="bi bi-folder2-open me-1"></i> Choisir
              </button>

              <button type="button" class="btn btn-light btn-sm" id="btnScanCamera" style="border-color:var(--stroke);">
                <i class="bi bi-camera me-1"></i> Photo
              </button>

              <button type="button" class="btn btn-light btn-sm" id="btnScanClear" style="border-color:var(--stroke);" disabled>
                <i class="bi bi-x-circle me-1"></i> Supprimer
              </button>

              <button id="btnScan" class="btn btn-warning btn-sm fw-semibold" type="button" disabled>
                <i class="bi bi-magic"></i> Analyser
              </button>
            </div>
          </div>

          {# Dropzone + aperçu #}
          <div class="upload-drop mt-3" id="scanDropzone" style="cursor:pointer;">
            <div class="d-flex align-items-start gap-3">
              <div class="fs-3"><i class="bi bi-receipt-cutoff"></i></div>

              <div class="flex-grow-1">
                <div class="fw-bold" style="color:var(--ink)">Glisse ton reçu ici</div>
                <div class="small text-muted">JPG/PNG/WebP ou PDF</div>

                <div class="d-flex flex-wrap gap-2 mt-2 align-items-center">
                  <span class="badge rounded-pill text-bg-light border" id="scanFileBadge">
                    <i class="bi bi-dot me-1"></i> Aucun fichier
                  </span>
                  <span class="small text-muted" id="scanFileMeta"></span>
                </div>
              </div>

              <div class="text-end">
                <div class="small text-muted">Clique pour choisir</div>
                <i class="bi bi-cloud-arrow-up fs-4"></i>
              </div>
            </div>

            <div id="scanPreview" class="mt-3" style="display:none;"></div>
          </div>

          <div id="scanStatus" class="small mt-2 text-muted"></div>

          <div id="scanProposal" class="mt-3" style="display:none;">
            <div class="p-3 border rounded-3" style="background:rgba(255,193,7,.08); border-color:rgba(255,193,7,.25) !important;">
              <div class="d-flex flex-wrap gap-2 align-items-center justify-content-between">
                <div>
                  <div class="fw-bold">Proposition</div>
                  <div class="small text-muted" id="scanConfidence">—</div>
                </div>
                <button id="btnApplyProposal" class="btn btn-dark btn-sm fw-semibold" type="button">
                  <i class="bi bi-check2"></i> Appliquer au formulaire
                </button>
              </div>

              <div class="row g-2 mt-2 small">
                <div class="col-md-3"><div class="text-muted">Date</div><div class="fw-semibold" id="pDate">—</div></div>
                <div class="col-md-3"><div class="text-muted">TTC</div><div class="fw-semibold" id="pTtc">—</div></div>
                <div class="col-md-3"><div class="text-muted">TVA (Taux)</div><div class="fw-semibold" id="pTva">—</div></div>
                <div class="col-md-3"><div class="text-muted">HT</div><div class="fw-semibold" id="pHt">—</div></div>
              </div>
            </div>
          </div>

        </div>
      </div>

      {# ===== Infos ===== #}
      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-info-circle-fill text-warning"></i> Informations</h5>
          <span class="chip">Étape 1</span>
        </div>

        <div class="p-3 p-md-4">
          <div class="row g-3">
            <div class="col-12">
              {{ form_label(form.libelle) }}
              {{ form_widget(form.libelle, {
                attr: {
                  class: 'form-control',
                  rows: 3,
                  placeholder: "Ex : Achat fournitures (facture #1234) • Licence logiciel • Déplacement…"
                }
              }) }}
              {{ form_errors(form.libelle) }}
              <div class="form-text">
                <i class="bi bi-journal-text me-1"></i>
                Décris la dépense (référence, contexte, refacturation, n° facture…). Max 2000 caractères.
              </div>

            </div>


            <div class="col-md-6">
              {{ form_label(form.categorie) }}
              <div class="input-group">
                {{ form_widget(form.categorie) }}
                <button type="button"
                        class="btn btn-light"
                        style="border-color: var(--stroke);"
                        data-bs-toggle="modal" data-bs-target="#modalAddCategorie">
                  <i class="bi bi-plus-lg"></i>
                </button>
                <button type="button"
                        class="btn btn-light"
                        style="border-color: var(--stroke);"
                        id="btnEditCategorieOpen"
                        title="Éditer la catégorie sélectionnée">
                  <i class="bi bi-pencil"></i>
                </button>
              </div>


              {{ form_errors(form.categorie) }}
              <div class="form-text"><i class="bi bi-tags me-1"></i>Catégorie normalisée pour des stats propres.</div>
            </div>

            <div class="col-md-6">
              {{ form_label(form.fournisseur) }}
              <div class="input-group">
                {{ form_widget(form.fournisseur) }}
                <button type="button"
                        class="btn btn-light"
                        style="border-color: var(--stroke);"
                        data-bs-toggle="modal" data-bs-target="#modalAddFournisseur">
                  <i class="bi bi-plus-lg"></i>
                </button>
                <button type="button"
                        class="btn btn-light"
                        style="border-color: var(--stroke);"
                        id="btnEditFournisseurOpen"
                        title="Éditer le fournisseur sélectionné">
                  <i class="bi bi-pencil"></i>
                </button>
              </div>


              {{ form_errors(form.fournisseur) }}
              <div class="form-text"><i class="bi bi-truck me-1"></i>Fournisseur normalisé (évite les doublons).</div>
            </div>

            <div class="col-md-6">
              {{ form_label(form.payeur) }}
              {{ form_widget(form.payeur) }}
              {{ form_errors(form.payeur) }}
              <div class="form-text"><i class="bi bi-person-check me-1"></i>Qui a réellement payé (optionnel).</div>
            </div>

            <div class="col-md-3">
              {{ form_row(form.dateDepense) }}
            </div>
            <div class="col-md-3">
              {{ form_row(form.devise) }}
            </div>
          </div>
        </div>
      </div>



      



      {# ===== TVA + Montants ===== #}
      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-calculator-fill text-warning"></i> TVA & Montants</h5>
          <span class="chip">Auto</span>
        </div>

        <div class="p-3 p-md-4">
          <div class="row g-3 align-items-end">

            <div class="col-md-4">
              {{ form_row(form.tauxTva) }}
            </div>

            <div class="col-md-4">
              <div class="form-check form-switch mt-2">
                {{ form_widget(form.tvaDeductible) }}
                {{ form_label(form.tvaDeductible) }}
              </div>
              <div class="form-text"><i class="bi bi-percent me-1"></i>Décoche si la TVA n’est pas récupérable.</div>
            </div>

            


            <div class="col-md-4">
              <div class="mini-kpi">
                <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
                  <div class="fw-bold"><i class="bi bi-lightning-charge-fill me-2"></i>Calcul assisté</div>
                  <span class="badge rounded-pill"
                        style="border:1px solid var(--stroke); background:rgba(255,193,7,.15); color:var(--ink);">
                    Live
                  </span>
                </div>
                <div class="mt-2 small">
                  <div class="d-flex justify-content-between gap-3 py-1">
                    <span class="text-muted">Saisie TTC</span>
                    <span class="fw-semibold text-end">→ calc HT + TVA</span>
                  </div>
                  <div class="d-flex justify-content-between gap-3 py-1">
                    <span class="text-muted">Saisie HT</span>
                    <span class="fw-semibold text-end">→ calc TVA + TTC</span>
                  </div>
                </div>
              </div>
            </div>

            

            <div class="col-md-6">
              {{ form_label(form.montantHtCents) }}
              <div class="input-group input-euro">
                {{ form_widget(form.montantHtCents, {'attr': {'class':'form-control text-end', 'placeholder':'0,00'}}) }}
                <span class="input-group-text euro-suffix">€</span>
              </div>

              <div class="form-text"><i class="bi bi-sliders me-1"></i>Montant HT, le TTC sera automatiquement calculé.</div>
              {{ form_errors(form.montantHtCents) }}
            </div>

            


            <div class="col-md-6">
              {{ form_row(form.tvaDeductiblePct) }}
              <div class="form-text"><i class="bi bi-sliders me-1"></i>Ex : 80% si usage mixte (perso + pro).</div>
            </div>


            <div class="col-md-6">
              {{ form_label(form.montantTvaCents) }}
              <div class="input-group input-euro">
                {{ form_widget(form.montantTvaCents, {'attr': {'class':'form-control text-end', 'placeholder':'0,00'}}) }}
                <span class="input-group-text euro-suffix">€</span>
              </div>
              {{ form_errors(form.montantTvaCents) }}
            </div>

            <div class="col-md-6">
              {{ form_label(form.montantTtcCents) }}
              <div class="input-group input-euro">
                {{ form_widget(form.montantTtcCents, {'attr': {'class':'form-control text-end', 'placeholder':'0,00'}}) }}
                <span class="input-group-text euro-suffix">€</span>
              </div>
              {{ form_errors(form.montantTtcCents) }}
            </div>

          </div>

          <div class="form-text mt-2">
            Astuce : saisis <strong>TTC</strong> (reçu) pour obtenir automatiquement <strong>HT</strong> et <strong>TVA</strong>.
          </div>
        </div>
      </div>

      {# ===== Justificatif ===== #}
      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-paperclip text-warning"></i> Justificatif</h5>
          <span class="chip">Optionnel</span>
        </div>

        <div class="p-3 p-md-4">
          <div class="upload-drop" id="dropzone">
            <div class="d-flex align-items-start gap-3">
              <div class="fs-3"><i class="bi bi-cloud-arrow-up"></i></div>
              <div class="flex-grow-1">
                <div class="fw-bold" style="color:var(--ink)">Glisse-dépose ton fichier ici</div>
