<script>
/* =========================================================
   HELPERS (format FR)
========================================================= */
function parseNumberFR(v){
  if (v === null || v === undefined) return 0;
  v = String(v).trim().replace(/\s/g,'').replace('\u202F','').replace(',', '.');
  v = v.replace(/[^\d.\-]/g,'');
  const n = parseFloat(v);
  return isNaN(n) ? 0 : n;
}
function formatMoneyFR(n){
  if (!isFinite(n)) n = 0;
  try {
    return new Intl.NumberFormat('fr-FR', { minimumFractionDigits:2, maximumFractionDigits:2 }).format(n);
  } catch(e){
    return (Number(n).toFixed(2)).replace('.', ',');
  }
}
function getSelectedText(selectEl){
  if (!selectEl) return '';
  if (selectEl.tomselect){
    const v = selectEl.tomselect.getValue();
    if (!v) return '';
    const opt = selectEl.querySelector(`option[value="${CSS.escape(v)}"]`);
    return (opt ? opt.textContent : '').trim();
  }
  const opt = selectEl.selectedOptions && selectEl.selectedOptions[0];
  return (opt ? opt.textContent : '').trim();
}

/* =========================================================
   INIT
========================================================= */
document.addEventListener('DOMContentLoaded', function(){

  // TomSelect
  function initTomSelect(selector, opts = {}){
    const el = document.querySelector(selector);
    if (!el || el.tomselect) return el;
    new TomSelect(el, Object.assign({
      create:false,
      plugins: el.multiple ? ['remove_button'] : [],
      sortField: { field:'text', direction:'asc' }
    }, opts));
    return el;
  }

  initTomSelect('#{{ form.payeur.vars.id }}', { allowEmptyOption:true });
  initTomSelect('#{{ form.devise.vars.id }}');
  initTomSelect('#{{ form.categorie.vars.id }}', { allowEmptyOption:true });
  initTomSelect('#{{ form.fournisseur.vars.id }}', { allowEmptyOption:true });



  function postForm(url, data){
    return fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
      body: new URLSearchParams(data)
    }).then(async r => {
      const json = await r.json().catch(()=>null);
      if (!r.ok) throw (json || {message:'Erreur serveur'});
      return json;
    });
  }

  const categorieSelect = document.getElementById('{{ form.categorie.vars.id }}');
  const fournisseurSelect = document.getElementById('{{ form.fournisseur.vars.id }}');

  const modalCatEl = document.getElementById('modalAddCategorie');
  const modalFourEl = document.getElementById('modalAddFournisseur');

  const catModal = modalCatEl ? bootstrap.Modal.getOrCreateInstance(modalCatEl) : null;
  const fourModal = modalFourEl ? bootstrap.Modal.getOrCreateInstance(modalFourEl) : null;
  const $pct = document.getElementById('{{ form.tvaDeductiblePct.vars.id }}');


  function showErr(id, msg){
    const el = document.getElementById(id);
    if (!el) return;
    el.textContent = msg || '';
    el.classList.toggle('d-none', !msg);
  }

  document.getElementById('btnCreateCategorie')?.addEventListener('click', async () => {
    showErr('catErr', '');
    const libelle = (document.getElementById('newCategorieLibelle')?.value || '').trim();
    if (!libelle) { showErr('catErr', 'Le libellé est requis.'); return; }

    try {
      const url = "{{ path('app_administrateur_depense_ajax_categorie_create', { entite: entite.id }) }}";
      const type = (document.getElementById('newCategorieType')?.value || 'operating').trim();
      const actif = document.getElementById('newCategorieActif')?.checked ? 1 : 0;
      const includeInFinanceCharts = document.getElementById('newCategorieIncludeCharts')?.checked ? 1 : 0;

      const res = await postForm(url, { libelle, type, actif, includeInFinanceCharts });


      // inject dans TomSelect (ou select natif)
      if (categorieSelect?.tomselect){
        categorieSelect.tomselect.addOption({ value: String(res.id), text: res.text });
        const opt = categorieSelect.querySelector(`option[value="${CSS.escape(String(res.id))}"]`);
        if (opt){
          opt.dataset.type = res.type || type;
          opt.dataset.actif = String(res.actif ?? actif);
          opt.dataset.includeCharts = String(res.includeInFinanceCharts ?? includeInFinanceCharts);
        }

        categorieSelect.tomselect.addItem(String(res.id));
        categorieSelect.tomselect.refreshOptions(false);
      } else if (categorieSelect) {
        const opt = new Option(res.text, String(res.id), true, true);
        opt.dataset.type = res.type || type;
        opt.dataset.actif = String(res.actif ?? actif);
        opt.dataset.includeCharts = String(res.includeInFinanceCharts ?? includeInFinanceCharts);

        categorieSelect.add(opt);
        categorieSelect.value = String(res.id);
      }

      // clean + close
      document.getElementById('newCategorieLibelle').value = '';
      document.getElementById('newCategorieLibelle').value = '';
      document.getElementById('newCategorieType').value = 'operating';
      document.getElementById('newCategorieActif').checked = true;
      document.getElementById('newCategorieIncludeCharts').checked = true;

      catModal?.hide();

      // ton refreshResume existant
      if (typeof refreshResume === 'function') refreshResume();

    } catch(e){
      showErr('catErr', e?.message || 'Impossible de créer la catégorie.');
    }
  });


  const $fourColor = document.getElementById('newFournisseurColor');
  const $fourColorText = document.getElementById('newFournisseurColorText');

  function normalizeHex(v){
    v = String(v || '').trim();
    if (!v) return '';
    if (v[0] !== '#') v = '#'+v;
    v = v.toUpperCase();
    return /^#([0-9A-F]{6})$/.test(v) ? v : '';
  }

  if ($fourColor && $fourColorText){
    $fourColor.addEventListener('input', () => {
      $fourColorText.value = $fourColor.value.toUpperCase();
    });
    $fourColorText.addEventListener('input', () => {
      const hex = normalizeHex($fourColorText.value);
      if (hex) $fourColor.value = hex;
    });
  }


  document.getElementById('btnCreateFournisseur')?.addEventListener('click', async () => {
    showErr('fourErr', '');
    const nom = (document.getElementById('newFournisseurNom')?.value || '').trim();
    const siret = (document.getElementById('newFournisseurSiret')?.value || '').trim();
    const couleurHex = normalizeHex(document.getElementById('newFournisseurColorText')?.value || '');

    if (!nom) { showErr('fourErr', 'Le nom est requis.'); return; }
    if (document.getElementById('newFournisseurColorText')?.value && !couleurHex){
      showErr('fourErr', 'Couleur invalide (format attendu: #RRGGBB).');
      return;
    }

    try {
      const url = "{{ path('app_administrateur_depense_ajax_fournisseur_create', { entite: entite.id }) }}";
      const res = await postForm(url, { nom, siret, couleurHex });

      if (fournisseurSelect?.tomselect){
        fournisseurSelect.tomselect.addOption({ value: String(res.id), text: res.text });
        // après res reçu
        const opt = fournisseurSelect.querySelector(`option[value="${CSS.escape(String(res.id))}"]`);
        if (opt){
          opt.dataset.color = res.color || '';
          opt.dataset.siret = siret || '';
        }

        fournisseurSelect.tomselect.addItem(String(res.id));
        fournisseurSelect.tomselect.refreshOptions(false);
      } else if (fournisseurSelect) {
        const opt = new Option(res.text, String(res.id), true, true);
        fournisseurSelect.add(opt);
        fournisseurSelect.value = String(res.id);
      }

      document.getElementById('newFournisseurNom').value = '';
      document.getElementById('newFournisseurSiret').value = '';
      document.getElementById('newFournisseurColor').value = '#2563eb';
      document.getElementById('newFournisseurColorText').value = '#2563eb';
      fourModal?.hide();

      if (typeof refreshResume === 'function') refreshResume();

    } catch(e){
      showErr('fourErr', e?.message || 'Impossible de créer le fournisseur.');
    }
  });




  // Modals bootstrap
  const editCatEl  = document.getElementById('modalEditCategorie');
  const editFourEl = document.getElementById('modalEditFournisseur');
  const editCatModal  = editCatEl  ? bootstrap.Modal.getOrCreateInstance(editCatEl)  : null;
  const editFourModal = editFourEl ? bootstrap.Modal.getOrCreateInstance(editFourEl) : null;

  // Helpers: valeur sélectionnée TomSelect ou select natif
  function getSelectedId(selectEl){
    if (!selectEl) return '';
    if (selectEl.tomselect) return selectEl.tomselect.getValue() || '';
    return selectEl.value || '';
  }
  function getOptionEl(selectEl, id){
    if (!selectEl || !id) return null;
    return selectEl.querySelector(`option[value="${CSS.escape(id)}"]`);
  }

  /* ===================== OUVRIR MODALE EDIT CATEGORIE ===================== */
  document.getElementById('btnEditCategorieOpen')?.addEventListener('click', () => {
    showErr('catEditErr', '');
    const id = getSelectedId(categorieSelect);
    if (!id) { showErr('catEditErr', 'Sélectionne une catégorie à éditer.'); return; }

    const opt = getOptionEl(categorieSelect, id);
    document.getElementById('editCategorieId').value = id;
    document.getElementById('editCategorieLibelle').value = (opt?.textContent || '').trim();
    const type = (opt?.dataset?.type || 'operating').trim();
    const actif = (opt?.dataset?.actif ?? '1') === '1';
    const inc = (opt?.dataset?.includeCharts ?? '1') === '1';

    document.getElementById('editCategorieType').value = type;
    document.getElementById('editCategorieActif').checked = actif;
    document.getElementById('editCategorieIncludeCharts').checked = inc;


    editCatModal?.show();
  });

  document.getElementById('btnUpdateCategorie')?.addEventListener('click', async () => {
    showErr('catEditErr', '');
    const id = (document.getElementById('editCategorieId')?.value || '').trim();
    const libelle = (document.getElementById('editCategorieLibelle')?.value || '').trim();
    if (!id) { showErr('catEditErr', 'Catégorie invalide.'); return; }
    if (!libelle) { showErr('catEditErr', 'Le libellé est requis.'); return; }

    try {
      const url = "{{ path('app_administrateur_depense_ajax_categorie_update', { entite: entite.id, id: 0 }) }}".replace('/0/', `/${id}/`);
      const type = (document.getElementById('editCategorieType')?.value || 'operating').trim();
      const actif = document.getElementById('editCategorieActif')?.checked ? 1 : 0;
      const includeInFinanceCharts = document.getElementById('editCategorieIncludeCharts')?.checked ? 1 : 0;

      const res = await postForm(url, { libelle, type, actif, includeInFinanceCharts });


      // Update option text
      if (categorieSelect?.tomselect){
        categorieSelect.tomselect.updateOption(String(res.id), { value: String(res.id), text: res.text });
        const opt = categorieSelect.querySelector(`option[value="${CSS.escape(String(res.id))}"]`);
        if (opt){
          opt.dataset.type = res.type || type;
          opt.dataset.actif = String(res.actif ?? actif);
          opt.dataset.includeCharts = String(res.includeInFinanceCharts ?? includeInFinanceCharts);
        }

        categorieSelect.tomselect.refreshOptions(false);
        categorieSelect.tomselect.setValue(String(res.id), true);
      } else {
        const opt = getOptionEl(categorieSelect, String(res.id));
        if (opt) opt.textContent = res.text;
        categorieSelect.value = String(res.id);
      }

      editCatModal?.hide();
      if (typeof refreshResume === 'function') refreshResume();
    } catch(e){
      showErr('catEditErr', e?.message || 'Impossible de mettre à jour la catégorie.');
    }
  });

  /* ===================== OUVRIR MODALE EDIT FOURNISSEUR ===================== */
  function syncColorInputs(colorInput, textInput){
    if (!colorInput || !textInput) return;
    colorInput.addEventListener('input', () => { textInput.value = String(colorInput.value).toUpperCase(); });
    textInput.addEventListener('input', () => {
      const hex = normalizeHex(textInput.value);
      if (hex) colorInput.value = hex;
    });
  }

  syncColorInputs(
    document.getElementById('editFournisseurColor'),
    document.getElementById('editFournisseurColorText')
  );

  document.getElementById('btnEditFournisseurOpen')?.addEventListener('click', () => {
    showErr('fourEditErr', '');
    const id = getSelectedId(fournisseurSelect);
    if (!id) { showErr('fourEditErr', 'Sélectionne un fournisseur à éditer.'); return; }

    const opt = getOptionEl(fournisseurSelect, id);

    document.getElementById('editFournisseurId').value = id;
    document.getElementById('editFournisseurNom').value = (opt?.textContent || '').trim();
    document.getElementById('editFournisseurSiret').value = (opt?.dataset?.siret || '').trim();

    const hex = normalizeHex(opt?.dataset?.color || '') || '#2563EB';
    document.getElementById('editFournisseurColor').value = hex;
    document.getElementById('editFournisseurColorText').value = hex;

    editFourModal?.show();
  });

  document.getElementById('btnUpdateFournisseur')?.addEventListener('click', async () => {
    showErr('fourEditErr', '');
    const id = (document.getElementById('editFournisseurId')?.value || '').trim();
    const nom = (document.getElementById('editFournisseurNom')?.value || '').trim();
    const siret = (document.getElementById('editFournisseurSiret')?.value || '').trim();
    const couleurHex = normalizeHex(document.getElementById('editFournisseurColorText')?.value || '');

    if (!id) { showErr('fourEditErr', 'Fournisseur invalide.'); return; }
    if (!nom) { showErr('fourEditErr', 'Le nom est requis.'); return; }
    if (document.getElementById('editFournisseurColorText')?.value && !couleurHex){
      showErr('fourEditErr', 'Couleur invalide (format attendu: #RRGGBB).'); return;
    }

    try {
      const url = "{{ path('app_administrateur_depense_ajax_fournisseur_update', { entite: entite.id, id: 0 }) }}".replace('/0/', `/${id}/`);
      const res = await postForm(url, { nom, siret, couleurHex });

      // Update option
      if (fournisseurSelect?.tomselect){
        fournisseurSelect.tomselect.updateOption(String(res.id), { value: String(res.id), text: res.text });
        fournisseurSelect.tomselect.refreshOptions(false);
        fournisseurSelect.tomselect.setValue(String(res.id), true);
      } else {
        const opt = getOptionEl(fournisseurSelect, String(res.id));
        if (opt) opt.textContent = res.text;
        fournisseurSelect.value = String(res.id);
      }

      // Update dataset (important pour ré-ouvrir la modale avec les bonnes infos)
      const opt = getOptionEl(fournisseurSelect, String(res.id));
      if (opt){
        opt.dataset.color = res.color || '';
        opt.dataset.siret = siret || '';
      }

      editFourModal?.hide();
      if (typeof refreshResume === 'function') refreshResume();
    } catch(e){
      showErr('fourEditErr', e?.message || 'Impossible de mettre à jour le fournisseur.');
    }
  });




  // Flatpickr
  if (window.flatpickr && window.flatpickr.l10ns?.fr) flatpickr.localize(flatpickr.l10ns.fr);
  document.querySelectorAll('.flatpickr-date').forEach(el => {
    if (!el._fp) flatpickr(el, { dateFormat:'d/m/Y', allowInput:true });
  });

  // Elements
  const $libelle = document.getElementById('{{ form.libelle.vars.id }}');
  const $cat     = document.getElementById('{{ form.categorie.vars.id }}');
  const $four    = document.getElementById('{{ form.fournisseur.vars.id }}');
  const $payeur  = document.getElementById('{{ form.payeur.vars.id }}');
  const $date    = document.getElementById('{{ form.dateDepense.vars.id }}');
  const $devise  = document.getElementById('{{ form.devise.vars.id }}');

  const $taux    = document.getElementById('{{ form.tauxTva.vars.id }}');
  const $ded     = document.getElementById('{{ form.tvaDeductible.vars.id }}');

  const $ht      = document.getElementById('{{ form.montantHtCents.vars.id }}');
  const $tva     = document.getElementById('{{ form.montantTvaCents.vars.id }}');
  const $ttc     = document.getElementById('{{ form.montantTtcCents.vars.id }}');

  const $file    = document.getElementById('{{ form.justificatifFile.vars.id }}');
  const $proofInfo = document.getElementById('proofInfo');

  const $resume = {
    pill: document.getElementById('resume-valid-pill'),
    libelle: document.getElementById('resume-libelle'),
    categorie: document.getElementById('resume-categorie'),
    fournisseur: document.getElementById('resume-fournisseur'),
    payeur: document.getElementById('resume-payeur'),
    date: document.getElementById('resume-date'),
    devise: document.getElementById('resume-devise'),
    taux: document.getElementById('resume-taux'),
    deductible: document.getElementById('resume-deductible'),
    ht: document.getElementById('resume-ht'),
    tva: document.getElementById('resume-tva'),
    ttc: document.getElementById('resume-ttc'),
    proof: document.getElementById('resume-proof'),
    pct: document.getElementById('resume-pct'),
    tvaded: document.getElementById('resume-tvaded'),

  };

  // Live calc
  function recalcFromTtc(){
    const taux = parseFloat($taux?.value || '0') || 0;
    const ttc  = parseNumberFR($ttc?.value || 0);
    if (!($ht && $tva && $ttc)) return;
    if (ttc <= 0) return;

    if (taux <= 0.0001){
      $ht.value  = formatMoneyFR(ttc);
      $tva.value = formatMoneyFR(0);
      return;
    }
    const ht  = ttc / (1 + (taux/100));
    const tv  = ttc - ht;

    $ht.value  = formatMoneyFR(ht);
    $tva.value = formatMoneyFR(tv);
  }

  function recalcFromHt(){
    const taux = parseFloat($taux?.value || '0') || 0;
    const ht   = parseNumberFR($ht?.value || 0);
    if (!($ht && $tva && $ttc)) return;
    if (ht <= 0) return;

    const tv  = ht * (taux/100);
    const ttc = ht + tv;

    $tva.value = formatMoneyFR(tv);
    $ttc.value = formatMoneyFR(ttc);
  }

  // Resume + validation
  function isFilled(v){ return !!String(v || '').trim(); }

  function refreshResume(){
    const ht  = parseNumberFR($ht?.value || 0);
    const tv  = parseNumberFR($tva?.value || 0);
    const ttc = parseNumberFR($ttc?.value || 0);

    if ($resume.libelle){
      const v = ($libelle?.value || '').trim();
      $resume.libelle.textContent = v ? (v.length > 42 ? (v.slice(0, 42) + '…') : v) : '—';
    }

    if ($resume.categorie)  $resume.categorie.textContent = getSelectedText($cat) || '—';
    if ($resume.fournisseur)$resume.fournisseur.textContent = getSelectedText($four) || '—';
    if ($resume.payeur)     $resume.payeur.textContent = getSelectedText($payeur) || '—';
    if ($resume.date)       $resume.date.textContent = isFilled($date?.value) ? $date.value.trim() : '—';
    if ($resume.devise)     $resume.devise.textContent = getSelectedText($devise) || '—';

    if ($resume.taux)       $resume.taux.textContent = (parseFloat($taux?.value || '0') || 0).toString().replace('.', ',') + ' %';
    if ($resume.deductible) $resume.deductible.textContent = ($ded && $ded.checked) ? 'Oui' : 'Non';

    if ($resume.ht)  $resume.ht.textContent  = (ht  > 0) ? (formatMoneyFR(ht)  + ' €') : '—';
    if ($resume.tva) $resume.tva.textContent = (tv  > 0) ? (formatMoneyFR(tv)  + ' €') : '—';
    if ($resume.ttc) $resume.ttc.textContent = (ttc > 0) ? (formatMoneyFR(ttc) + ' €') : '—';

    


    const pct = parseNumberFR($pct?.value || 100);
    const pctClamped = Math.max(0, Math.min(100, pct));
    const isDed = ($ded && $ded.checked);

    const tvaded = isDed ? (tv * (pctClamped / 100)) : 0;

    if ($resume.pct) $resume.pct.textContent = isDed ? (formatMoneyFR(pctClamped).replace(',00','') + ' %') : '—';
    if ($resume.tvaded) $resume.tvaded.textContent = (tvaded > 0) ? (formatMoneyFR(tvaded) + ' €') : '—';


    if ($resume.proof){
      const f = $file?.files && $file.files[0] ? $file.files[0] : null;
      $resume.proof.textContent = f ? 'Sélectionné' : '—';
    }

    if ($pct) {
      $pct.disabled = !isDed;
    }

    const ok =
      isFilled($libelle?.value) &&
      isFilled($date?.value) &&
      isFilled($devise?.value) &&
      (ttc > 0 || ht > 0);


    if ($resume.pill){
      if (ok){
        $resume.pill.textContent = '✅ Complet';
        $resume.pill.style.background = 'rgba(25,135,84,.15)';
        $resume.pill.style.borderColor = 'rgba(25,135,84,.35)';
        $resume.pill.style.color = 'var(--ink)';
      } else {
        $resume.pill.textContent = '⚠️ Incomplet';
        $resume.pill.style.background = 'rgba(255,193,7,.15)';
        $resume.pill.style.borderColor = 'rgba(255,193,7,.35)';
        $resume.pill.style.color = 'var(--ink)';
      }
    }

    // disable submit buttons if incomplete
    document.querySelectorAll('form[name="depense_form"] button[type="submit"]').forEach(b => b.disabled = !ok);
  }

  // Listeners
  [$libelle,$cat,$four,$payeur,$date,$devise,$taux,$ded,$pct,$ht,$tva,$ttc].forEach(el=>{
    if (!el) return;
    el.addEventListener('input', refreshResume);
    el.addEventListener('change', refreshResume);
  });

  if ($ttc) $ttc.addEventListener('input', () => { recalcFromTtc(); refreshResume(); });
  if ($ht)  $ht.addEventListener('input',  () => { recalcFromHt();  refreshResume(); });
  if ($taux) $taux.addEventListener('change', () => {
    const ttc = parseNumberFR($ttc?.value || 0);
    if (ttc > 0) recalcFromTtc(); else recalcFromHt();
    refreshResume();
  });

  if ($ded) $ded.addEventListener('change', () => {
    if (!$ded.checked && $pct) $pct.value = '0';
    if ($ded.checked && $pct && (!String($pct.value).trim() || parseNumberFR($pct.value) === 0)) $pct.value = '100';
    refreshResume();
  });


    // File info + dropzone + preview (premium)
  let currentObjectUrl = null;

  function humanSize(bytes){
    const mb = bytes / 1024 / 1024;
    if (mb >= 1) return mb.toFixed(2) + ' Mo';
    const kb = bytes / 1024;
    return kb.toFixed(0) + ' Ko';
  }

  function isPdf(fileOrName){
    const name = typeof fileOrName === 'string' ? fileOrName : (fileOrName?.name || '');
    const type = typeof fileOrName === 'object' ? (fileOrName?.type || '') : '';
    return (type === 'application/pdf') || name.toLowerCase().endsWith('.pdf');
  }
  function isImage(fileOrName){
    const name = typeof fileOrName === 'string' ? fileOrName : (fileOrName?.name || '');
    const type = typeof fileOrName === 'object' ? (fileOrName?.type || '') : '';
    return (type.startsWith('image/')) || /\.(png|jpe?g|gif|webp)$/i.test(name);
  }

  function setProofInfoText(text){
    if (!$proofInfo) return;
    $proofInfo.textContent = text || '';
  }

  function renderProofCard({ title, subtitle, contentHtml, actionsHtml }){
    return `
      <div class="proof-card">
        <div class="proof-card-h">
          <div class="proof-meta">
            <div class="proof-name">${title}</div>
            <div class="proof-sub">${subtitle || ''}</div>
          </div>
          <div class="d-flex flex-wrap gap-2 justify-content-end">
            ${actionsHtml || ''}
          </div>
        </div>
        <div class="proof-body">
          ${contentHtml || ''}
        </div>
      </div>
    `;
  }

  function clearSelectedFile(){
    if (!$file) return;
    $file.value = ''; // clear input
    if (currentObjectUrl){
      URL.revokeObjectURL(currentObjectUrl);
      currentObjectUrl = null;
    }
    setProofInfoText('');
    refreshResume();
    renderProofPreview(); // re-render (retombe sur l’existant si présent)
  }

  document.getElementById('btnClearSelectedProof')?.addEventListener('click', clearSelectedFile);

  async function deleteExistingProof(){
    const wrap = document.getElementById('proofPreviewWrap');
    if (!wrap) return;

    const deleteUrl = wrap.dataset.deleteUrl || '';
    const token = wrap.dataset.deleteToken || '';
    if (!deleteUrl || !token) return;

    // confirm premium (simple et clair)
    if (!confirm('Supprimer définitivement le justificatif ?')) return;

    const r = await fetch(deleteUrl, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
      body: new URLSearchParams({ _token: token })
    });

    const json = await r.json().catch(()=>null);
    if (!r.ok || !json?.ok){
      alert(json?.message || 'Impossible de supprimer le justificatif.');
      return;
    }

    // UI: plus d’existant
    wrap.dataset.existing = '0';
    wrap.dataset.existingUrl = '';
    wrap.dataset.existingName = '';
    wrap.dataset.deleteUrl = '';
    wrap.dataset.deleteToken = '';

    renderProofPreview();
    refreshResume();
  }

  function renderProofPreview(){
    const wrap = document.getElementById('proofPreviewWrap');
    if (!wrap) return;

    // 1) priorité: fichier sélectionné
    const selected = $file?.files && $file.files[0] ? $file.files[0] : null;
    if (selected){
      if (currentObjectUrl) URL.revokeObjectURL(currentObjectUrl);
      currentObjectUrl = URL.createObjectURL(selected);

      const title = selected.name;
      const subtitle = `${humanSize(selected.size)} • ${selected.type || 'fichier'}`;

      let contentHtml = `
        <div class="p-3">
          <div class="text-muted small">
            <i class="bi bi-info-circle me-1"></i>
            Aperçu local (avant enregistrement).
          </div>
        </div>
      `;

      if (isPdf(selected)){
        contentHtml += `<iframe class="proof-frame" src="${currentObjectUrl}"></iframe>`;
      } else if (isImage(selected)){
        contentHtml += `
          <div class="p-3">
            <img src="${currentObjectUrl}" alt="" style="max-width:100%; border-radius:14px; border:1px solid var(--stroke);">
          </div>
        `;
      } else {
        contentHtml += `
          <div class="p-3">
            <div class="alert alert-light border mb-0">
              <i class="bi bi-file-earmark me-2"></i>
              Aperçu non disponible pour ce type de fichier. Il sera enregistré tel quel.
            </div>
          </div>
        `;
      }

      const actionsHtml = `
        <span class="badge rounded-pill text-bg-warning border" style="background: rgba(255,193,7,.15)!important; color: var(--ink);">
          Sélectionné
        </span>
      `;

      wrap.innerHTML = renderProofCard({ title, subtitle, contentHtml, actionsHtml });
      setProofInfoText(`Fichier : ${selected.name} (${humanSize(selected.size)})`);
      return;
    }

    // 2) sinon: justificatif existant
    const hasExisting = (wrap.dataset.existing === '1');
    const url = wrap.dataset.existingUrl || '';
    const name = wrap.dataset.existingName || 'Justificatif';

    if (hasExisting && url){
      const title = name;
      const subtitle = `Justificatif enregistré • affichage inline`;

      const actionsHtml = `
        <a class="btn btn-light btn-sm" style="border-color:var(--stroke);" target="_blank" href="${url}">
          <i class="bi bi-box-arrow-up-right me-1"></i> Voir
        </a>
        <button type="button" class="btn btn-danger btn-sm" id="btnDeleteExistingProof">
          <i class="bi bi-trash3 me-1"></i> Supprimer
        </button>
      `;

      let contentHtml = '';
      if (isPdf(name)){
        contentHtml = `<iframe class="proof-frame" src="${url}"></iframe>`;
      } else if (isImage(name)){
        contentHtml = `
          <div class="p-3">
            <img src="${url}" alt="" style="max-width:100%; border-radius:14px; border:1px solid var(--stroke);">
          </div>
        `;
      } else {
        contentHtml = `
          <div class="p-3">
            <div class="alert alert-light border mb-0">
              <i class="bi bi-file-earmark me-2"></i>
              Aperçu non disponible. Utilise “Voir” pour l’ouvrir.
            </div>
          </div>
        `;
      }

      wrap.innerHTML = renderProofCard({ title, subtitle, contentHtml, actionsHtml });
      document.getElementById('btnDeleteExistingProof')?.addEventListener('click', deleteExistingProof);
      setProofInfoText('');
      return;
    }

    // 3) rien
    wrap.innerHTML = '';
    setProofInfoText('');
  }

  if ($file){
    $file.addEventListener('change', () => {
      renderProofPreview();
      refreshResume();
    });
  }

  const dz = document.getElementById('dropzone');
  if (dz && $file){
    ['dragenter','dragover'].forEach(ev => dz.addEventListener(ev, (e)=>{
      e.preventDefault(); e.stopPropagation();
      dz.classList.add('is-dragover');
    }));
    ['dragleave','drop'].forEach(ev => dz.addEventListener(ev, (e)=>{
      e.preventDefault(); e.stopPropagation();
      dz.classList.remove('is-dragover');
    }));
    dz.addEventListener('drop', (e)=>{
      const files = e.dataTransfer?.files;
      if (!files || !files.length) return;
      $file.files = files;
      renderProofPreview();
      refreshResume();
    });
  }

  // IMPORTANT: résumé justificatif -> tient compte aussi de l’existant
  const _refreshResumeProof = refreshResume;
  refreshResume = function(){
    _refreshResumeProof();

    const wrap = document.getElementById('proofPreviewWrap');
    if ($resume.proof && wrap){
      const selected = $file?.files && $file.files[0] ? $file.files[0] : null;
      const hasExisting = (wrap.dataset.existing === '1');
      $resume.proof.textContent = selected ? 'Sélectionné' : (hasExisting ? 'Présent' : '—');
    }
  };

  // init
  renderProofPreview();


  // init
  refreshResume();
});
</script>



<script>
(function(){
  const $file      = document.getElementById('scanFile');
  const $camera    = document.getElementById('scanCamera');
  const $btnPick   = document.getElementById('btnScanPick');
  const $btnCam    = document.getElementById('btnScanCamera');
  const $btnClear  = document.getElementById('btnScanClear');
  const $btnScan   = document.getElementById('btnScan');
  const $status    = document.getElementById('scanStatus');
  const $box       = document.getElementById('scanProposal');

  const $dz        = document.getElementById('scanDropzone');
  const $preview   = document.getElementById('scanPreview');
  const $badge     = document.getElementById('scanFileBadge');
  const $meta      = document.getElementById('scanFileMeta');

  let lastProposal = null;
  let objectUrl = null;

  function euro(cents){
    const v = (cents||0)/100;
    return v.toLocaleString('fr-FR',{minimumFractionDigits:2,maximumFractionDigits:2}) + ' €';
  }
  function humanSize(bytes){
    const mb = bytes / 1024 / 1024;
    if (mb >= 1) return mb.toFixed(2) + ' Mo';
    const kb = bytes / 1024;
    return kb.toFixed(0) + ' Ko';
  }
  function isPdf(f){
    const name = (f?.name || '').toLowerCase();
    return f?.type === 'application/pdf' || name.endsWith('.pdf');
  }
  function isImage(f){
    return (f?.type || '').startsWith('image/');
  }

  function setFile(f){
    if (!f) return;
    const dt = new DataTransfer();
    dt.items.add(f);
    $file.files = dt.files;
    render();
  }


  function formatPctFR(x){
    const n = Number(x);
    if (!isFinite(n)) return '—';
    const s = n.toLocaleString('fr-FR', { maximumFractionDigits: 2 });
    return s + ' %';
  }

  /**
   * Renvoie un taux TVA "fiable" :
   * - priorité à un taux fourni par l’API si présent
   * - sinon calcule brut depuis HT/TTC (plus robuste que TVA/HT)
   * - puis snap vers un taux légal si proche (20/10/5.5/2.1/0)
   * - sinon conserve le brut (mais on pourra l’afficher "à vérifier")
   */
  function computeVatRatePct(proposal){
    // 1) si l’API te renvoie déjà un taux : on le prend
    const direct =
      proposal?.tauxTva ??
      proposal?.tauxTvaPct ??
      proposal?.vatRate ??
      proposal?.vatRatePct ??
      null;

    if (direct !== null && direct !== undefined && direct !== '') {
      const d = Number(String(direct).replace(',', '.'));
      if (isFinite(d) && d >= 0) return { pct: d, snapped: true, source: 'api' };
    }

    // 2) sinon on calcule depuis HT/TTC (évite dépendre d’une TVA OCR)
    const ht  = Number(proposal?.montantHtCents || 0);
    const ttc = Number(proposal?.montantTtcCents || 0);

    if (!(ht > 0) || !(ttc > 0) || ttc <= ht) {
      return { pct: 0, snapped: true, source: 'none' };
    }

    const raw = ((ttc - ht) / ht) * 100;

    // 3) snap vers taux légaux si proche
    const legal = [20, 10, 5.5, 2.1, 0];
    let best = legal[0];
    let bestDiff = Math.abs(raw - best);

    for (const r of legal) {
      const diff = Math.abs(raw - r);
      if (diff < bestDiff) { bestDiff = diff; best = r; }
    }

    // tolérance : si on est à +/- 1 point, on considère que c’est une erreur OCR
    const TOL = 1.0;
    if (bestDiff <= TOL) {
      return { pct: best, snapped: true, source: 'snapped' };
    }

    // sinon on garde le brut, mais on signalera qu’il est douteux
    return { pct: raw, snapped: false, source: 'raw' };
  }



  function clear(){
    lastProposal = null;
    $box.style.display = 'none';
    $status.textContent = '';
    if (objectUrl){ URL.revokeObjectURL(objectUrl); objectUrl = null; }
    $file.value = '';
    if ($camera) $camera.value = '';
    render();
  }

  function render(){
    const f = $file.files?.[0] || null;

    $btnClear.disabled = !f;
    $btnScan.disabled  = !f;

    if (!f){
      $badge.innerHTML = `<i class="bi bi-dot me-1"></i> Aucun fichier`;
      $meta.textContent = '';
      $preview.style.display = 'none';
      $preview.innerHTML = '';
      return;
    }

    $badge.innerHTML = `<i class="bi bi-check2-circle me-1"></i> ${f.name}`;
    $meta.textContent = `${humanSize(f.size)} • ${f.type || 'fichier'}`;

    if (objectUrl){ URL.revokeObjectURL(objectUrl); }
    objectUrl = URL.createObjectURL(f);

    let html = `<div class="scan-thumb">`;

    if (isPdf(f)){
      html += `<iframe src="${objectUrl}"></iframe>`;
    } else if (isImage(f)){
      html += `<img src="${objectUrl}" alt="Aperçu reçu">`;
    } else {
      html += `<div class="p-3 small text-muted">
                <i class="bi bi-file-earmark me-2"></i>
                Aperçu non disponible pour ce type de fichier.
              </div>`;
    }

    html += `</div>`;
    $preview.innerHTML = html;
    $preview.style.display = '';
  }

  // Buttons
  $btnPick?.addEventListener('click', () => $file?.click());
  $btnCam?.addEventListener('click', () => $camera?.click());
  $btnClear?.addEventListener('click', clear);

  // Click on dropzone => open picker
  $dz?.addEventListener('click', (e) => {
    // évite de déclencher si on sélectionne du texte
    if ((window.getSelection?.().toString() || '').length) return;
    $file?.click();
  });

  // Input changes
  $file?.addEventListener('change', () => render());
  $camera?.addEventListener('change', () => {
    const f = $camera.files?.[0];
    if (f) setFile(f);
  });

  // Drag & drop
  if ($dz){
    ['dragenter','dragover'].forEach(ev => $dz.addEventListener(ev, (e)=>{
      e.preventDefault(); e.stopPropagation();
      $dz.classList.add('is-dragover');
    }));
    ['dragleave','drop'].forEach(ev => $dz.addEventListener(ev, (e)=>{
      e.preventDefault(); e.stopPropagation();
      $dz.classList.remove('is-dragover');
    }));
    $dz.addEventListener('drop', (e)=>{
      const f = e.dataTransfer?.files?.[0];
      if (f) setFile(f);
    });
  }

  // Analyse
  $btnScan?.addEventListener('click', async () => {
    lastProposal = null;
    $box.style.display = 'none';

    const f = $file.files?.[0];
    if(!f){
      $status.textContent = "Choisis un fichier (photo/PDF) d’abord.";
      return;
    }

    $status.textContent = "Analyse en cours…";
    $btnScan.disabled = true;

    try{
      const fd = new FormData();
      fd.append('file', f);

      const res = await fetch("{{ path('app_administrateur_depense_scan_receipt', { entite: entite.id }) }}", {
        method: 'POST',
        body: fd,
        headers: { 'Accept': 'application/json' }
      });

      const json = await res.json();
      if(!res.ok || !json.ok){
        throw new Error(json.message || "Erreur d’analyse");
      }

      lastProposal = json.proposal;

      document.getElementById('scanConfidence').textContent =
        `Confiance : ${lastProposal.confidence || 0}% (à valider)`;

      document.getElementById('pDate').textContent = lastProposal.date || '—';
      document.getElementById('pTtc').textContent = euro(lastProposal.montantTtcCents);
      const rate = computeVatRatePct(lastProposal);

      document.getElementById('pTva').textContent =
        rate.snapped
          ? formatPctFR(rate.pct)
          : (formatPctFR(rate.pct) + ' (à vérifier)');

      document.getElementById('pHt').textContent  = euro(lastProposal.montantHtCents);

      $box.style.display = '';
      $status.textContent = "Proposition prête. Vérifie puis applique.";
    }catch(e){
      $status.textContent = "❌ " + (e.message || "Erreur");
    }finally{
      $btnScan.disabled = !($file.files?.[0]);
    }
  });



    const $btnApply = document.getElementById('btnApplyProposal');

  // Champs du formulaire Symfony
  const $fDate = document.getElementById('{{ form.dateDepense.vars.id }}');
  const $fTtc  = document.getElementById('{{ form.montantTtcCents.vars.id }}');
  const $fTva  = document.getElementById('{{ form.montantTvaCents.vars.id }}');
  const $fHt   = document.getElementById('{{ form.montantHtCents.vars.id }}');
  const $fTaux = document.getElementById('{{ form.tauxTva.vars.id }}');


  // Input justificatif Symfony
  const $justif = document.getElementById('{{ form.justificatifFile.vars.id }}');

  function centsToInputMoney(cents){
    const v = (Number(cents || 0) / 100);
    // On retourne une valeur "champ" (sans symbole €)
    return v.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  function isoToFrDate(iso){
    // Supporte "YYYY-MM-DD" ou "YYYY-MM-DDTHH:mm:ss"
    const m = String(iso || '').match(/^(\d{4})-(\d{2})-(\d{2})/);
    if (!m) return String(iso || '').trim();
    return `${m[3]}/${m[2]}/${m[1]}`;
  }

  function setFilesOnInput(input, file){
    if (!input || !file) return;
    const dt = new DataTransfer();
    dt.items.add(file);
    input.files = dt.files;
    // trigger change (pour ton preview + résumé)
    input.dispatchEvent(new Event('change', { bubbles: true }));
  }

  function applyProposalToForm(){
    if (!lastProposal) return;

    // 1) Remplissage champs
    if ($fDate && lastProposal.date) {
      $fDate.value = isoToFrDate(lastProposal.date);
      $fDate.dispatchEvent(new Event('input', { bubbles: true }));
      $fDate.dispatchEvent(new Event('change', { bubbles: true }));
    }

    if ($fTtc) {
      $fTtc.value = centsToInputMoney(lastProposal.montantTtcCents);
      $fTtc.dispatchEvent(new Event('input', { bubbles: true }));
      $fTtc.dispatchEvent(new Event('change', { bubbles: true }));
    }
    if ($fTva) {
      $fTva.value = centsToInputMoney(lastProposal.montantTvaCents);
      $fTva.dispatchEvent(new Event('input', { bubbles: true }));
      $fTva.dispatchEvent(new Event('change', { bubbles: true }));
    }
    if ($fHt) {
      $fHt.value = centsToInputMoney(lastProposal.montantHtCents);
      $fHt.dispatchEvent(new Event('input', { bubbles: true }));
      $fHt.dispatchEvent(new Event('change', { bubbles: true }));
    }

    // 2) Mettre automatiquement la photo/PDF scanné comme justificatif Symfony
    const f = $file?.files?.[0] || null;
    if (f && $justif) {
      setFilesOnInput($justif, f);
    }


    // 1bis) appliquer le taux TVA (snap/legal si possible)
    if ($fTaux) {
      const rate = computeVatRatePct(lastProposal);
      const pctRounded = Math.round(Number(rate.pct) * 100) / 100;

      if ($fTaux.tagName === 'SELECT') {
        const opts = Array.from($fTaux.options || []);
        let best = null;
        let bestDiff = Infinity;

        for (const o of opts) {
          const v = parseFloat(String(o.value).replace(',', '.'));
          if (!isFinite(v)) continue;
          const diff = Math.abs(v - pctRounded);
          if (diff < bestDiff) { bestDiff = diff; best = o.value; }
        }
        if (best !== null) $fTaux.value = best;
      } else {
        $fTaux.value = String(pctRounded).replace('.', ',');
      }

      $fTaux.dispatchEvent(new Event('change', { bubbles: true }));
      $fTaux.dispatchEvent(new Event('input', { bubbles: true }));
    }



    // 3) Petit feedback
    $status.textContent = "✅ Proposition appliquée au formulaire (et justificatif attaché).";
  }

  $btnApply?.addEventListener('click', applyProposalToForm);


  // init
  render();
})();
</script>


{% endblock %}
