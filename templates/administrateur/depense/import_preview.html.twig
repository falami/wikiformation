{% block javascripts %}
  {{ parent() }}
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/fr.js"></script>

<script>
/* =============================
  Helpers FR
============================= */
function parseNumberFR(v){
  if (v === null || v === undefined) return 0;
  v = String(v).trim().replace(/\s/g,'').replace('\u202F','').replace(',', '.');
  v = v.replace(/[^\d.\-]/g,'');
  const n = parseFloat(v);
  return isNaN(n) ? 0 : n;
}
function formatMoneyFR(n){
  if (!isFinite(n)) n = 0;
  try {
    return new Intl.NumberFormat('fr-FR', { minimumFractionDigits:2, maximumFractionDigits:2 }).format(n);
  } catch(e){
    return (Number(n).toFixed(2)).replace('.', ',');
  }
}
function eurosToCents(euros){
  return Math.max(0, Math.round((parseNumberFR(euros) || 0) * 100));
}
function centsToEuros(cents){
  return (parseInt(cents || 0, 10) || 0) / 100;
}
function recalcFromTtcCents(ttcCents, taux){
  ttcCents = parseInt(ttcCents || 0, 10) || 0;
  taux = parseFloat(taux || 0) || 0;
  if (ttcCents <= 0) return { ht: 0, tva: 0 };
  if (taux <= 0.0001) return { ht: ttcCents, tva: 0 };
  const ht = Math.round(ttcCents / (1 + (taux/100)));
  const tva = Math.max(0, ttcCents - ht);
  return { ht, tva };
}
function getTsText(selectEl){
  if (!selectEl) return '';
  if (selectEl.tomselect){
    const v = selectEl.tomselect.getValue();
    if (!v) return '';
    const opt = selectEl.querySelector(`option[value="${CSS.escape(v)}"]`);
    return (opt ? opt.textContent : '').trim();
  }
  const opt = selectEl.selectedOptions && selectEl.selectedOptions[0];
  return (opt ? opt.textContent : '').trim();
}

/* =============================
  Ajax helper
============================= */
function postForm(url, data){
  return fetch(url, {
    method:'POST',
    headers:{ 'Content-Type':'application/x-www-form-urlencoded; charset=UTF-8' },
    body:new URLSearchParams(data)
  }).then(async r => {
    const json = await r.json().catch(()=>null);
    if (!r.ok) throw (json || {message:'Erreur serveur'});
    return json;
  });
}

/* =============================
  UI helpers
============================= */
function refreshSelectedCount(){
  const n = document.querySelectorAll('.accept-switch:checked').length;
  const el = document.getElementById('selectedCount');
  if (el) el.textContent = n;
}

function refreshCardPreview(card){
  const htEuro = card.querySelector('.htEuro');
  const tvaEuro = card.querySelector('.tvaEuro');
  const ttcEuro = card.querySelector('.ttcEuro');

  const catSel = card.querySelector('select.ts-cat');
  const fourSel = card.querySelector('select.ts-four');

  const dedSwitch = card.querySelector('.dedSwitch');
  const pct = card.querySelector('.pct');

  const pvHt = card.querySelector('.pv-ht');
  const pvTva = card.querySelector('.pv-tva');
  const pvTtc = card.querySelector('.pv-ttc');
  const pvCat = card.querySelector('.pv-cat');
  const pvFour = card.querySelector('.pv-four');
  const pvDed = card.querySelector('.pv-ded');
  const pvTvaDed = card.querySelector('.pv-tvaded');

  const ht = parseNumberFR(htEuro?.value || 0);
  const tv = parseNumberFR(tvaEuro?.value || 0);
  const ttc = parseNumberFR(ttcEuro?.value || 0);

  if (pvHt) pvHt.textContent = ht > 0 ? (formatMoneyFR(ht) + ' €') : '—';
  if (pvTva) pvTva.textContent = tv > 0 ? (formatMoneyFR(tv) + ' €') : '—';
  if (pvTtc) pvTtc.textContent = ttc > 0 ? (formatMoneyFR(ttc) + ' €') : '—';

  if (pvCat) pvCat.textContent = getTsText(catSel) || '—';
  if (pvFour) pvFour.textContent = getTsText(fourSel) || '—';

  const isDed = !!(dedSwitch && dedSwitch.checked);
  const pctVal = Math.max(0, Math.min(100, parseNumberFR(pct?.value || 0)));
  const tvaDed = isDed ? (tv * (pctVal/100)) : 0;

  if (pvDed) pvDed.textContent = isDed ? 'Oui' : 'Non';
  if (pvTvaDed) pvTvaDed.textContent = (tvaDed > 0) ? (formatMoneyFR(tvaDed) + ' €') : '—';
}


/* =============================
  Main
============================= */
document.addEventListener('DOMContentLoaded', function(){




  const DUP_CHECK_URL = "{{ path('app_administrateur_depense_import_dup_check', { entite: entite.id }) }}";

  function debounce(fn, delay=250){
    let t = null;
    return (...args) => {
      clearTimeout(t);
      t = setTimeout(() => fn(...args), delay);
    };
  }

  async function checkDuplicateForCard(card){
    const dateEl = card.querySelector('input.js-date');
    const ttcCentsEl = card.querySelector('.ttcCents');
    if (!dateEl || !ttcCentsEl) return;

    const date = (dateEl.value || '').trim();            // Y-m-d (value flatpickr)
    const ttcCents = parseInt(ttcCentsEl.value || '0', 10) || 0;

    // pas de check si incomplet
    if (!date || ttcCents <= 0) {
      applyDupUI(card, { exists:false, depenseId:null });
      return;
    }

    try{
      const res = await postForm(DUP_CHECK_URL, { date, ttcCents });
      applyDupUI(card, res);
    } catch(e){
      // en cas d'erreur serveur: on ne casse pas l'UI
    }
  }

  function applyDupUI(card, res){
    const exists = !!res?.exists;
    const depenseId = res?.depenseId ? String(res.depenseId) : null;

    card.classList.toggle('dup', exists);
    card.setAttribute('data-dup', exists ? '1' : '0');

    const zone = card.querySelector('.dup-zone');
    const link = card.querySelector('.dup-link');

    if (zone) zone.classList.toggle('d-none', !exists);

    if (link){
      if (exists && depenseId){
        link.setAttribute('data-existing-id', depenseId);  // ✅ IMPORTANT
        link.classList.remove('disabled');
        link.setAttribute('aria-disabled', 'false');
        link.href = '#';                                   // ✅ on garde le mode modal
      } else {
        link.removeAttribute('data-existing-id');
        link.href = '#';
        link.classList.add('disabled');
        link.setAttribute('aria-disabled', 'true');
      }
    }
  }




  // mémorise la card qui a ouvert une modale (+ ou crayon)
  let lastOpenCard = null;

  // Quand on ouvre la modale "ajout catégorie"
  document.getElementById('modalAddCategorie')?.addEventListener('show.bs.modal', (ev) => {
    lastOpenCard = ev.relatedTarget?.closest('.imp-card') || null;
  });

  // Quand on ouvre la modale "ajout fournisseur"
  document.getElementById('modalAddFournisseur')?.addEventListener('show.bs.modal', (ev) => {
    lastOpenCard = ev.relatedTarget?.closest('.imp-card') || null;
  });



  function initTomSelect(root=document){
    root.querySelectorAll('select.ts').forEach(el => {
      if (el.tomselect) return;

      new TomSelect(el, {
        create: false,
        persist: false,
        plugins: ['dropdown_input'],
        sortField: [{ field: 'text', direction: 'asc' }],
        placeholder: el.getAttribute('placeholder') || '—',
      });
    });
  }

  function initDatepickers(root=document){
    root.querySelectorAll('input.js-date').forEach(el => {
      if (el._flatpickr) return;

      const def = el.dataset.defaultDate || el.value || null;

      flatpickr(el, {
        locale: 'fr',
        dateFormat: 'Y-m-d',      // valeur envoyée au backend (ton importCommit attend Y-m-d)
        altInput: true,
        altFormat: 'd/m/Y',       // affichage utilisateur
        defaultDate: def,
        allowInput: true,
        disableMobile: true,
        onChange: () => {
          // optionnel : si tu veux rafraîchir la preview quand on change la date
          const card = el.closest('.imp-card');
          if (card) refreshCardPreview(card);
        }
      });
    });
  }

  // init global
  initTomSelect(document);
  initDatepickers(document);









  const EXISTING_URL_TPL = "{{ path('app_administrateur_depense_import_existing', { entite: entite.id, id: 999999 }) }}";
  const cmpModalEl = document.getElementById('modalDupCompare');
  const cmpModal = cmpModalEl ? bootstrap.Modal.getOrCreateInstance(cmpModalEl) : null;

  function setCmpErr(msg){
    const el = document.getElementById('dupCompareErr');
    if (!el) return;
    el.textContent = msg || '';
    el.classList.toggle('d-none', !msg);
  }

  function moneyFromCents(c){ return formatMoneyFR(centsToEuros(c || 0)) + ' €'; }

  function fillImportFromCard(card){
    const dateAlt = card.querySelector('input.js-date')?._flatpickr?.altInput?.value || '';
    const dateRaw = card.querySelector('input.js-date')?.value || '';

    const lib = (card.querySelector('textarea.libelle')?.value || '').trim();
    const paySel = card.querySelector('select.ts[name*="[payeurId]"]') || card.querySelector('select.ts');
    const catSel = card.querySelector('select.ts-cat');
    const fourSel = card.querySelector('select.ts-four');

    const htC = parseInt(card.querySelector('.htCents')?.value || '0', 10) || 0;
    const tvC = parseInt(card.querySelector('.tvaCents')?.value || '0', 10) || 0;
    const ttcC = parseInt(card.querySelector('.ttcCents')?.value || '0', 10) || 0;

    const taux = card.querySelector('.taux')?.value || '—';
    const ded = !!card.querySelector('.dedSwitch')?.checked;
    const dedPct = card.querySelector('.pct')?.value || '0';

    document.getElementById('cmpImportMeta').textContent = `#${card.getAttribute('data-idx') ?? '—'}`;
    document.getElementById('cmpImportLibelle').textContent = lib || '—';
    document.getElementById('cmpImportDate').textContent = dateAlt || dateRaw || '—';
    document.getElementById('cmpImportPayeur').textContent = getTsText(paySel) || '—';
    document.getElementById('cmpImportCat').textContent = getTsText(catSel) || '—';
    document.getElementById('cmpImportFour').textContent = getTsText(fourSel) || '—';

    document.getElementById('cmpImportHT').textContent = htC ? moneyFromCents(htC) : '—';
    document.getElementById('cmpImportTVA').textContent = tvC ? moneyFromCents(tvC) : '—';
    document.getElementById('cmpImportTTC').textContent = ttcC ? moneyFromCents(ttcC) : '—';

    document.getElementById('cmpImportTaux').textContent = (taux !== '—') ? (String(taux).replace('.', ',') + ' %') : '—';
    document.getElementById('cmpImportDed').textContent = ded ? 'Oui' : 'Non';
    document.getElementById('cmpImportDedPct').textContent = ded ? (String(dedPct).replace('.', ',') + ' %') : '0 %';
  }

  function fillExisting(data){
    document.getElementById('cmpExistLibelle').textContent = (data.libelle || '—');
    document.getElementById('cmpExistDate').textContent = (data.dateFr || data.date || '—');
    document.getElementById('cmpExistPayeur').textContent = (data.payeur || '—');
    document.getElementById('cmpExistCat').textContent = (data.categorie || '—');
    document.getElementById('cmpExistFour').textContent = (data.fournisseur || '—');

    document.getElementById('cmpExistHT').textContent = data.montantHtCents ? moneyFromCents(data.montantHtCents) : '—';
    document.getElementById('cmpExistTVA').textContent = data.montantTvaCents ? moneyFromCents(data.montantTvaCents) : '—';
    document.getElementById('cmpExistTTC').textContent = data.montantTtcCents ? moneyFromCents(data.montantTtcCents) : '—';

    document.getElementById('cmpExistTaux').textContent = (data.tauxTva ?? null) !== null ? (String(data.tauxTva).replace('.', ',') + ' %') : '—';
    document.getElementById('cmpExistDed').textContent = data.tvaDeductible ? 'Oui' : 'Non';
    document.getElementById('cmpExistDedPct').textContent = data.tvaDeductible ? (String(data.tvaDeductiblePct || 0).replace('.', ',') + ' %') : '0 %';

    const open = document.getElementById('cmpExistingOpen');
    if (open && data.showUrl){
      open.href = data.showUrl;
      open.classList.remove('d-none');
    } else if (open){
      open.classList.add('d-none');
    }

    const proof = document.getElementById('cmpExistingProof');
    if (proof && data.proofUrl){
      proof.href = data.proofUrl;
      proof.classList.remove('d-none');
    } else if (proof){
      proof.classList.add('d-none');
    }
  }

  // Delegation click sur "Voir existant"
  document.addEventListener('click', async (e) => {
    const a = e.target.closest('.dup-link');
    if (!a) return;

    e.preventDefault();
    setCmpErr('');

    const card = a.closest('.imp-card');
    const existingId = a.getAttribute('data-existing-id');
    if (!card || !existingId) return;

    fillImportFromCard(card);

    try{
      const url = EXISTING_URL_TPL.replace('999999', encodeURIComponent(existingId));
      const r = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' }});
      const json = await r.json().catch(()=>null);
      if (!r.ok || !json) throw new Error(json?.message || 'Impossible de charger la dépense existante.');
      fillExisting(json);
      cmpModal?.show();
    } catch(err){
      setCmpErr(err?.message || 'Erreur lors du chargement.');
      cmpModal?.show();
    }
  });





  // remove card
  document.querySelectorAll('.btnRemoveCard').forEach(btn => {
    btn.addEventListener('click', () => {
      const col = btn.closest('.col-12');
      if (col) col.remove();
      refreshSelectedCount();
    });
  });

  // compteur sélection
  document.querySelectorAll('.accept-switch').forEach(chk => {
    chk.addEventListener('change', refreshSelectedCount);
  });
  refreshSelectedCount();

  // bouton “select non doublons”
  document.getElementById('btnSelectNonDup')?.addEventListener('click', () => {
    document.querySelectorAll('.imp-card').forEach(card => {
      const isDup = card.getAttribute('data-dup') === '1';
      const chk = card.querySelector('.accept-switch');
      if (chk) chk.checked = !isDup;
    });
    refreshSelectedCount();
  });


  // par card : euros -> cents + recalcul + preview
  document.querySelectorAll('.imp-card').forEach(card => {
    const htEuro = card.querySelector('.htEuro');
    const tvaEuro = card.querySelector('.tvaEuro');
    const ttcEuro = card.querySelector('.ttcEuro');

    const htCents = card.querySelector('.htCents');
    const tvaCents = card.querySelector('.tvaCents');
    const ttcCents = card.querySelector('.ttcCents');

    const taux = card.querySelector('.taux');

    const dedSwitch = card.querySelector('.dedSwitch');
    const dedLabel = card.querySelector('.ded-label');
    const dedVal = card.querySelector('.dedVal');
    const pct = card.querySelector('.pct');

    const catSel = card.querySelector('select.ts-cat');
    const fourSel = card.querySelector('select.ts-four');

    function syncCentsFromEuros(){
      if (htCents) htCents.value = String(eurosToCents(htEuro?.value || 0));
      if (tvaCents) tvaCents.value = String(eurosToCents(tvaEuro?.value || 0));
      if (ttcCents) ttcCents.value = String(eurosToCents(ttcEuro?.value || 0));
    }

    function doRecalcFromTtcEuro(){
      const ttc = eurosToCents(ttcEuro?.value || 0);
      const r = recalcFromTtcCents(ttc, taux?.value || 0);

      // update € fields
      if (htEuro) htEuro.value = formatMoneyFR(centsToEuros(r.ht));
      if (tvaEuro) tvaEuro.value = formatMoneyFR(centsToEuros(r.tva));

      // update hidden cents
      if (ttcCents) ttcCents.value = String(ttc);
      if (htCents) htCents.value = String(r.ht);
      if (tvaCents) tvaCents.value = String(r.tva);
    }

    // init hidden from initial
    syncCentsFromEuros();
    refreshCardPreview(card);

    // listeners money
    ttcEuro?.addEventListener('input', () => {
      doRecalcFromTtcEuro();
      refreshCardPreview(card);
    });

    taux?.addEventListener('change', () => {
      doRecalcFromTtcEuro();
      refreshCardPreview(card);
    });

    // si l'utilisateur touche HT/TVA manuellement : on sync cents + maj aperçu
    htEuro?.addEventListener('input', () => { syncCentsFromEuros(); refreshCardPreview(card); });
    tvaEuro?.addEventListener('input', () => { syncCentsFromEuros(); refreshCardPreview(card); });



    // ✅ DUP CHECK : debounce par carte
    const debouncedDupCheck = debounce(() => checkDuplicateForCard(card), 300);

    // Quand TTC change
    ttcEuro?.addEventListener('input', () => {
      doRecalcFromTtcEuro();
      refreshCardPreview(card);
      debouncedDupCheck();
    });

    // Quand taux change
    taux?.addEventListener('change', () => {
      doRecalcFromTtcEuro();
      refreshCardPreview(card);
      debouncedDupCheck();
    });

    // Quand date change (saisie manuelle)
    card.querySelector('input.js-date')?.addEventListener('change', debouncedDupCheck);

    // Check initial
    checkDuplicateForCard(card);


    // déductible -> hidden value + pct enable
    if (dedSwitch && dedVal && pct){
      const applyDed = () => {
        const v = !!dedSwitch.checked;
        dedVal.value = v ? '1' : '0';
        if (dedLabel) dedLabel.textContent = v ? 'Oui' : 'Non';

        pct.disabled = !v;
        if (!v) pct.value = 0;
        else if (parseFloat(pct.value || '0') <= 0) pct.value = 80;

        refreshCardPreview(card);
      };

      dedSwitch.addEventListener('change', applyDed);
      pct.addEventListener('input', () => refreshCardPreview(card));

      applyDed(); // init (important)
    }

    // catégories/fournisseurs -> preview refresh
    catSel?.addEventListener('change', () => refreshCardPreview(card));
    fourSel?.addEventListener('change', () => refreshCardPreview(card));

    // quand TomSelect change (click)
    catSel?.tomselect?.on('change', () => refreshCardPreview(card));
    fourSel?.tomselect?.on('change', () => refreshCardPreview(card));
  });

  /* =============================
    Ajout catégorie / fournisseur
    (met à jour TOUS les selects)
  ============================= */
  function showErr(id, msg){
    const el = document.getElementById(id);
    if (!el) return;
    el.textContent = msg || '';
    el.classList.toggle('d-none', !msg);
  }

  const catModalEl = document.getElementById('modalAddCategorie');
  const fourModalEl = document.getElementById('modalAddFournisseur');
  const catModal = catModalEl ? bootstrap.Modal.getOrCreateInstance(catModalEl) : null;
  const fourModal = fourModalEl ? bootstrap.Modal.getOrCreateInstance(fourModalEl) : null;

  function setOptionCategoryMeta(opt, meta){
    if (!opt) return;
    opt.dataset.type = meta.type ?? 'operating';
    opt.dataset.actif = String(meta.actif ?? 1);
    opt.dataset.includeCharts = String(meta.includeInFinanceCharts ?? 1);
  }

  /* =============================
    CREATE CATEGORIE (FIX)
  ============================= */
  document.getElementById('btnCreateCategorie')?.addEventListener('click', async () => {
    showErr('catErr','');

    const libelle = (document.getElementById('newCategorieLibelle')?.value || '').trim();
    const type = (document.getElementById('newCategorieType')?.value || 'operating').trim();
    const actif = document.getElementById('newCategorieActif')?.checked ? 1 : 0;
    const includeInFinanceCharts = document.getElementById('newCategorieIncludeCharts')?.checked ? 1 : 0;

    if (!libelle){ showErr('catErr','Le libellé est requis.'); return; }

    try {
      const url = "{{ path('app_administrateur_depense_ajax_categorie_create', { entite: entite.id }) }}";
      const res = await postForm(url, { libelle, type, actif, includeInFinanceCharts });
      const id = String(res.id);
      const text = String(res.text || libelle);

      // ✅ 1) ajoute/maj partout + stocke META dans option.dataset
      document.querySelectorAll('select.ts-cat').forEach(sel => {
        let opt = sel.querySelector(`option[value="${CSS.escape(id)}"]`);
        if (!opt){
          opt = new Option(text, id, false, false);
          sel.add(opt);
        } else {
          opt.textContent = text;
        }

        setOptionCategoryMeta(opt, {
          type: res.type ?? type,
          actif: res.actif ?? actif,
          includeInFinanceCharts: res.includeInFinanceCharts ?? includeInFinanceCharts
        });

        if (sel.tomselect){
          sel.tomselect.addOption({ value: id, text });
          sel.tomselect.refreshOptions(false);
        }
      });

      // ✅ 2) sélectionne sur la card qui a ouvert la modale
      const active = (lastOpenCard?.querySelector('select.ts-cat')) || document.querySelector('select.ts-cat');
      if (active?.tomselect){
        active.tomselect.addItem(id, true);
      } else if (active){
        active.value = id;
        active.dispatchEvent(new Event('change', { bubbles:true }));
      }

      // reset + close
      document.getElementById('newCategorieLibelle').value = '';
      document.getElementById('newCategorieType').value = 'operating';
      document.getElementById('newCategorieActif').checked = true;
      document.getElementById('newCategorieIncludeCharts').checked = true;

      catModal?.hide();

      if (lastOpenCard) refreshCardPreview(lastOpenCard);

    } catch(e){
      showErr('catErr', e?.message || 'Impossible de créer la catégorie.');
    }
  });


  function normalizeHex(v){
    v = String(v || '').trim();
    if (!v) return '';
    if (v[0] !== '#') v = '#'+v;
    v = v.toUpperCase();
    return /^#([0-9A-F]{6})$/.test(v) ? v : '';
  }

  const $fourColor = document.getElementById('newFournisseurColor');
  const $fourColorText = document.getElementById('newFournisseurColorText');
  if ($fourColor && $fourColorText){
    $fourColor.addEventListener('input', () => { $fourColorText.value = $fourColor.value.toUpperCase(); });
    $fourColorText.addEventListener('input', () => {
      const hex = normalizeHex($fourColorText.value);
      if (hex) $fourColor.value = hex;
    });
  }

  document.getElementById('btnCreateFournisseur')?.addEventListener('click', async () => {
    showErr('fourErr','');
    const nom = (document.getElementById('newFournisseurNom')?.value || '').trim();
    const siret = (document.getElementById('newFournisseurSiret')?.value || '').trim();
    const couleurHex = normalizeHex(document.getElementById('newFournisseurColorText')?.value || '');

    if (!nom){ showErr('fourErr','Le nom est requis.'); return; }
    if (document.getElementById('newFournisseurColorText')?.value && !couleurHex){
      showErr('fourErr','Couleur invalide (format attendu: #RRGGBB).'); return;
    }

    try {
      const url = "{{ path('app_administrateur_depense_ajax_fournisseur_create', { entite: entite.id }) }}";
      const res = await postForm(url, { nom, siret, couleurHex }); // {id,text,color?}

      const id = String(res.id);
      const text = String(res.text || nom);
      const color = String(res.color || couleurHex || '');

      document.querySelectorAll('select.ts-four').forEach(sel => {
        if (!sel.querySelector(`option[value="${CSS.escape(id)}"]`)){
          const opt = new Option(text, id, false, false);
          opt.dataset.color = color;
          opt.dataset.siret = siret;
          sel.add(opt);
        }

        if (sel.tomselect){
          sel.tomselect.addOption({ value: id, text });
          sel.tomselect.refreshOptions(false);
        }
      });

      const active = (lastOpenCard?.querySelector('select.ts-four')) || document.querySelector('select.ts-four');
      if (active?.tomselect){
        active.tomselect.addItem(id, true);
      } else if (active){
        active.value = id;
        active.dispatchEvent(new Event('change', { bubbles:true }));
      }

      document.getElementById('newFournisseurNom').value = '';
      document.getElementById('newFournisseurSiret').value = '';
      document.getElementById('newFournisseurColor').value = '#2563eb';
      document.getElementById('newFournisseurColorText').value = '#2563eb';

      fourModal?.hide();

      if (lastOpenCard) refreshCardPreview(lastOpenCard);

    } catch(e){
      showErr('fourErr', e?.message || 'Impossible de créer le fournisseur.');
    }
  });





  /* =============================
    EDIT modals wiring
  ============================= */
  let lastEditContext = { type: null, card: null }; // pour rafraîchir l'aperçu de la bonne carte

  const catEditModalEl = document.getElementById('modalEditCategorie');
  const fourEditModalEl = document.getElementById('modalEditFournisseur');
  const catEditModal = catEditModalEl ? bootstrap.Modal.getOrCreateInstance(catEditModalEl) : null;
  const fourEditModal = fourEditModalEl ? bootstrap.Modal.getOrCreateInstance(fourEditModalEl) : null;

  function setErr(elId, msg){
    const el = document.getElementById(elId);
    if (!el) return;
    el.textContent = msg || '';
    el.classList.toggle('d-none', !msg);
  }

  // Ouvrir modal edit categorie (par carte)
  
  /* =============================
    OPEN EDIT CATEGORIE (FIX)
  ============================= */
  document.querySelectorAll('.btnEditCategorieOpen').forEach(btn => {
    btn.addEventListener('click', () => {
      const card = btn.closest('.imp-card');
      const sel = card?.querySelector('select.ts-cat');
      const id = sel?.tomselect ? sel.tomselect.getValue() : sel?.value;

      if (!id) {
        setErr('catEditErr', 'Sélectionne une catégorie à modifier.');
        catEditModal?.show();
        return;
      }

      const opt = sel.querySelector(`option[value="${CSS.escape(String(id))}"]`);
      const label = (opt?.textContent || '').trim();

      document.getElementById('editCategorieId').value = String(id);
      document.getElementById('editCategorieLibelle').value = label;

      document.getElementById('editCategorieType').value = (opt?.dataset?.type || 'operating');
      document.getElementById('editCategorieActif').checked = (opt?.dataset?.actif ?? '1') === '1';
      document.getElementById('editCategorieIncludeCharts').checked = (opt?.dataset?.includeCharts ?? '1') === '1';

      setErr('catEditErr', '');
      lastEditContext = { type: 'cat', card };
      catEditModal?.show();
    });
  });

  // Ouvrir modal edit fournisseur (par carte)
  document.querySelectorAll('.btnEditFournisseurOpen').forEach(btn => {
    btn.addEventListener('click', () => {
      const card = btn.closest('.imp-card');
      const sel = card?.querySelector('select.ts-four');
      const id = sel?.tomselect ? sel.tomselect.getValue() : sel?.value;

      if (!id) {
        setErr('fourEditErr', 'Sélectionne un fournisseur à modifier.');
        fourEditModal?.show();
        return;
      }

      const opt = sel.querySelector(`option[value="${CSS.escape(String(id))}"]`);
      const nom = (opt?.textContent || '').trim();
      const siret = opt?.dataset?.siret || '';
      const color = opt?.dataset?.color || '#2563eb';

      document.getElementById('editFournisseurId').value = String(id);
      document.getElementById('editFournisseurNom').value = nom;
      document.getElementById('editFournisseurSiret').value = siret;
      document.getElementById('editFournisseurColor').value = (color && /^#([A-F0-9]{6})$/i.test(color)) ? color : '#2563eb';
      document.getElementById('editFournisseurColorText').value = (color && /^#([A-F0-9]{6})$/i.test(color)) ? color : '#2563eb';

      setErr('fourEditErr', '');
      lastEditContext = { type: 'four', card };
      fourEditModal?.show();
    });
  });

  // sync color text <-> picker (edit fournisseur)
  (function(){
    const c = document.getElementById('editFournisseurColor');
    const t = document.getElementById('editFournisseurColorText');
    if (!c || !t) return;

    c.addEventListener('input', () => t.value = c.value.toUpperCase());
    t.addEventListener('input', () => {
      const hex = normalizeHex(t.value);
      if (hex) c.value = hex;
    });
  })();

  // Submit update categorie
  /* =============================
    UPDATE CATEGORIE (FIX)
  ============================= */
  document.getElementById('btnUpdateCategorie')?.addEventListener('click', async () => {
    setErr('catEditErr','');

    const id = (document.getElementById('editCategorieId')?.value || '').trim();
    const libelle = (document.getElementById('editCategorieLibelle')?.value || '').trim();
    const type = (document.getElementById('editCategorieType')?.value || 'operating').trim();
    const actif = document.getElementById('editCategorieActif')?.checked ? 1 : 0;
    const includeInFinanceCharts = document.getElementById('editCategorieIncludeCharts')?.checked ? 1 : 0;

    if (!id) { setErr('catEditErr','Catégorie introuvable.'); return; }
    if (!libelle) { setErr('catEditErr','Libellé requis.'); return; }

    try {
      const urlTpl = "{{ path('app_administrateur_depense_ajax_categorie_update', { entite: entite.id, id: 999999 }) }}";
      const url = urlTpl.replace('999999', encodeURIComponent(id));
      const res = await postForm(url, { libelle, type, actif, includeInFinanceCharts });

      const text = String(res.text || libelle);

      // ✅ update partout + meta
      document.querySelectorAll('select.ts-cat').forEach(sel => {
        const opt = sel.querySelector(`option[value="${CSS.escape(String(res.id))}"]`);
        if (opt){
          opt.textContent = text;
          setOptionCategoryMeta(opt, {
            type: res.type ?? type,
            actif: res.actif ?? actif,
            includeInFinanceCharts: res.includeInFinanceCharts ?? includeInFinanceCharts
          });
        }

        if (sel.tomselect) {
          sel.tomselect.updateOption(String(res.id), { value:String(res.id), text });
          sel.tomselect.refreshOptions(false);
        }
      });

      catEditModal?.hide();

      if (lastEditContext?.card) refreshCardPreview(lastEditContext.card);

    } catch(e){
      setErr('catEditErr', e?.message || 'Impossible de modifier la catégorie.');
    }
  });

  // Submit update fournisseur
  document.getElementById('btnUpdateFournisseur')?.addEventListener('click', async () => {
    setErr('fourEditErr','');
    const id = (document.getElementById('editFournisseurId')?.value || '').trim();
    const nom = (document.getElementById('editFournisseurNom')?.value || '').trim();
    const siret = (document.getElementById('editFournisseurSiret')?.value || '').trim();
    const couleurHex = normalizeHex(document.getElementById('editFournisseurColorText')?.value || '');

    if (!id) { setErr('fourEditErr','Fournisseur introuvable.'); return; }
    if (!nom) { setErr('fourEditErr','Nom requis.'); return; }
    if (document.getElementById('editFournisseurColorText')?.value && !couleurHex){
      setErr('fourEditErr','Couleur invalide (format attendu: #RRGGBB).'); return;
    }

    try {
      const urlTpl = "{{ path('app_administrateur_depense_ajax_fournisseur_update', { entite: entite.id, id: 999999 }) }}";
      const url = urlTpl.replace('999999', encodeURIComponent(id));
      const res = await postForm(url, { nom, siret, couleurHex });

      // update options partout
      document.querySelectorAll('select.ts-four').forEach(sel => {
        const opt = sel.querySelector(`option[value="${CSS.escape(String(res.id))}"]`);
        if (opt) {
          opt.textContent = res.text;
          opt.dataset.siret = siret || '';
          opt.dataset.color = res.color || '';
        }
        if (sel.tomselect) {
          sel.tomselect.updateOption(String(res.id), { value:String(res.id), text:res.text });
        }
      });

      fourEditModal?.hide();

      if (lastEditContext?.card) refreshCardPreview(lastEditContext.card);

    } catch(e){
      setErr('fourEditErr', e?.message || 'Impossible de modifier le fournisseur.');
    }
  });



  // Libellé : autosize + compteur + warning longueur
  document.querySelectorAll('.imp-card').forEach(card => {
    const ta = card.querySelector('textarea.libelle');
    const hint = card.querySelector('.libelle-hint');
    if (!ta || !hint) return;

    function autosize(){
      ta.style.height = 'auto';
      ta.style.height = Math.min(ta.scrollHeight, 140) + 'px'; // cap = max-height
    }

    function update(){
      autosize();

      const len = (ta.value || '').length;
      const max = parseInt(ta.getAttribute('maxlength') || '2000', 10);

      hint.textContent = len ? `${len} caractère(s)` : '';

      const near = Math.max(0, max - 120); // petit warning quand on approche (optionnel)
      hint.classList.toggle('text-danger', len > max);
      hint.classList.toggle('text-warning', len >= near && len <= max);
      hint.classList.toggle('text-muted', len < near);

      if (len > max) hint.textContent += ` — dépasse ${max} (sera tronqué/refusé)`;
      else if (len >= near && len < max) hint.textContent += ` — proche de la limite (${max})`;
    }


    ta.addEventListener('input', update);
    update(); // init
  });




});
</script>

{% endblock %}
