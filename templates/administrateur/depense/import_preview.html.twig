{# templates/administrateur/depense/import_preview.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}Proposition d’import{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/material_blue.css">

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }
    .hero{
      border-radius:22px; overflow:hidden;
      background:
        radial-gradient(1200px 400px at 15% 0%, rgba(255,255,255,.12), transparent 60%),
        radial-gradient(900px 350px at 85% 10%, rgba(255,193,7,.18), transparent 55%),
        linear-gradient(135deg, rgba(35,51,66,.98), rgba(35,51,66,.78));
      color:#fff;
      box-shadow:0 18px 50px rgba(0,0,0,.14);
    }
    .imp-card{
      border-radius:18px;
      background:#fff;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 12px 30px rgba(0,0,0,.06);
      overflow:hidden;
      position:relative;
    }
    .imp-card.dup{
      border-color: rgba(220,53,69,.35);
      box-shadow: 0 14px 34px rgba(220,53,69,.10);
    }
    .imp-head{
      padding:.85rem 1rem;
      border-bottom:1px solid rgba(0,0,0,.06);
      background: linear-gradient(180deg, rgba(0,0,0,.02), transparent);
      display:flex; align-items:center; justify-content:space-between; gap:1rem;
    }
    .imp-badge{
      display:inline-flex; align-items:center; gap:.45rem;
      padding:.25rem .6rem; border-radius:999px;
      border:1px solid rgba(0,0,0,.10);
      background: rgba(0,0,0,.02);
      font-size:.82rem;
    }
    .imp-card.dup .imp-badge.dup-badge{
      border-color: rgba(220,53,69,.25);
      background: rgba(220,53,69,.08);
      color: #b02a37;
    }
    .grid{
      display:grid;
      grid-template-columns: 1.1fr .8fr .7fr .7fr .9fr .9fr;
      gap:.75rem;
    }
    @media (max-width: 1200px){ .grid{ grid-template-columns: 1fr 1fr; } }
    label{ font-weight:700; font-size:.82rem; color:rgba(0,0,0,.65); }
    .form-control, .form-select{ border-radius:14px; }
    .money{ text-align:right; }
    .footerbar{
      position: sticky; bottom: 0; z-index: 20;
      background: rgba(255,255,255,.92);
      backdrop-filter: blur(10px);
      border-top:1px solid rgba(0,0,0,.08);
      padding: .8rem 0;
      margin-top: 1.2rem;
    }


    .imp-preview .pv-ttc{ font-size: 1.05rem; }
    @media (max-width: 1199px){
      .imp-preview{ position: static !important; top:auto !important; }
    }


    /* ===== Premium form tokens ===== */
    :root{
      --bg-soft: #f6f8fc;
      --ink: #0f172a;
      --muted: rgba(15,23,42,.62);
      --stroke: rgba(15,23,42,.10);
      --stroke2: rgba(15,23,42,.14);
      --shadow-sm: 0 10px 24px rgba(15,23,42,.06);
      --shadow-md: 0 18px 40px rgba(15,23,42,.10);
      --ring: 0 0 0 .22rem rgba(255,193,7,.22);
    }

    /* Carte : plus “soft” + depth */
    .imp-card{
      background: linear-gradient(180deg, #fff, #fff 55%, rgba(15,23,42,.015));
      border: 1px solid var(--stroke);
      box-shadow: var(--shadow-sm);
    }
    .imp-card:hover{ box-shadow: var(--shadow-md); }

    /* Header : un peu plus premium */
    .imp-head{
      background:
        radial-gradient(900px 140px at 20% 0%, rgba(255,193,7,.12), transparent 60%),
        linear-gradient(180deg, rgba(15,23,42,.02), transparent);
    }

    /* ===== Grille : auto-fit => champs plus larges / plus lisibles ===== */
    .grid{
      display:grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: .9rem 1rem;
    }

    /* Labels : style “form premium” */
    .grid label{
      display:flex; align-items:center; gap:.45rem;
      font-weight: 800;
      letter-spacing: .02em;
      font-size: .78rem;
      color: var(--muted);
      margin-bottom: .35rem;
    }

    /* Inputs / selects : fond doux + focus ring + padding */
    .form-control, .form-select, .ts-control{
      border-radius: 14px !important;
      border: 1px solid var(--stroke2) !important;
      background: var(--bg-soft) !important;
      padding: .58rem .75rem !important;
      box-shadow: none !important;
    }

    .form-control:focus, .form-select:focus,
    .ts-control:focus-within{
      border-color: rgba(255,193,7,.55) !important;
      box-shadow: var(--ring) !important;
      background: #fff !important;
    }

    /* TomSelect : look bootstrap+premium */
    .ts-wrapper.single .ts-control{
      padding-right: 2.25rem !important;
    }
    .ts-wrapper .ts-control .item{
      font-weight: 650;
      color: var(--ink);
    }
    .ts-wrapper .ts-dropdown{
      border-radius: 14px;
      overflow:hidden;
      border: 1px solid var(--stroke2);
      box-shadow: 0 18px 40px rgba(15,23,42,.12);
    }

    /* Groupe € : plus clean */
    .input-group .form-control{
      background: var(--bg-soft) !important;
    }
    .input-group-text{
      border-radius: 14px !important;
      border: 1px solid var(--stroke2) !important;
      background: rgba(15,23,42,.04) !important;
      font-weight: 800;
      color: rgba(15,23,42,.65);
    }

    /* Money fields : lisibles */
    .money{
      text-align:right;
      font-variant-numeric: tabular-nums;
      font-weight: 700;
    }

    /* ===== Field actions (select + boutons) ===== */
    .field-actions{
      display:flex; gap:.5rem; align-items:stretch;
    }
    .field-actions .ts-wrapper, 
    .field-actions .form-select{
      flex: 1 1 auto;
      min-width: 0;
    }
    .field-actions .btn{
      border-radius: 14px;
      padding: .52rem .62rem;
      border: 1px solid var(--stroke2) !important;
      background: #fff;
    }
    .field-actions .btn:hover{
      background: rgba(15,23,42,.03);
    }

    /* Preview : plus premium */
    .imp-preview .p-3{
      border-radius: 18px !important;
      border: 1px solid var(--stroke2) !important;
      background:
        radial-gradient(900px 220px at 20% 0%, rgba(255,193,7,.10), transparent 55%),
        linear-gradient(180deg, rgba(15,23,42,.03), rgba(255,255,255,.92));
      box-shadow: 0 18px 40px rgba(15,23,42,.08);
    }
    .imp-preview .pv-ttc{ font-size: 1.1rem; }

    /* Deductible switch : plus visible */
    .form-check-input:checked{
      background-color: var(--theme-color-secondaire);
      border-color: var(--theme-color-secondaire);
    }


    /* =============================
      Fix € input-group (arrondi à droite uniquement)
    ============================= */

    /* Champ montant : arrondi à gauche uniquement */
    .input-group > .form-control.money{
      border-top-right-radius: 0 !important;
      border-bottom-right-radius: 0 !important;
    }

    /* Symbole € : arrondi à droite uniquement */
    .input-group > .input-group-text{
      border-top-left-radius: 0 !important;
      border-bottom-left-radius: 0 !important;

      border-top-right-radius: 14px !important;
      border-bottom-right-radius: 14px !important;

      min-width: 46px;
      justify-content: center;
    }


    /* Mise en valeur montants */
    .input-group .form-control.money{
      font-size: .95rem;
      letter-spacing: .02em;
    }

    .input-group-text{
      font-size: .85rem;
      opacity: .75;
    }




    /* ===== Libellé : prendre 2 colonnes (desktop) + meilleure lisibilité ===== */
    .field-libelle{
      grid-column: 1 / -1; /* par défaut: full width */
    }

    /* Sur grand écran: libellé très large mais pas forcément full (plus équilibré) */
    @media (min-width: 1200px){
      .field-libelle{
        grid-column: span 3; /* occupe 3 "cases" dans auto-fit */
      }
    }

    /* Libellé façon Excel : multi-lignes + retours à la ligne conservés */
    textarea.form-control.libelle{
      white-space: pre-wrap;     /* conserve \n */
      overflow-wrap: anywhere;   /* évite les débordements */
      line-height: 1.25;
      min-height: 44px;          /* hauteur “input-like” */
      max-height: 140px;         /* évite que ça prenne tout l’écran */
      resize: vertical;          /* l'utilisateur peut agrandir */
    }




  /* Input-group : assure le même rendu pour % que pour € */
  .input-group > .form-control.pctInput{
    border-top-right-radius: 0 !important;
    border-bottom-right-radius: 0 !important;
  }


  /* retire les spinners sur input number */
  input[type=number]::-webkit-outer-spin-button,
  input[type=number]::-webkit-inner-spin-button{ -webkit-appearance: none; margin: 0; }
  input[type=number]{ -moz-appearance: textfield; }


  /* Select dans input-group : arrondi à gauche seulement */
  .input-group > .form-select.tauxSelect{
    border-top-right-radius: 0 !important;
    border-bottom-right-radius: 0 !important;
  }






  </style>
{% endblock %}

{% block body %}


  <div class="hero p-4 mb-4">
    <div class="d-flex flex-wrap align-items-end gap-2">
      <div class="me-auto">
        <div class="d-flex flex-wrap gap-2 mb-2">
          <span class="badge rounded-pill" style="background:rgba(255,255,255,.14); border:1px solid rgba(255,255,255,.18);">
            <i class="bi bi-list-check"></i> Proposition
          </span>
          <span class="badge rounded-pill" style="background:rgba(255,255,255,.14); border:1px solid rgba(255,255,255,.18);">
            <i class="bi bi-building"></i> {{ entite.nom }}
          </span>
          <span class="badge rounded-pill" style="background:rgba(255,255,255,.14); border:1px solid rgba(255,255,255,.18);">
            {{ proposals|length }} ligne(s)
          </span>
        </div>
        <h2 class="fw-bold mb-1">Valide / ajuste tes dépenses</h2>
        <div class="opacity-75">
          Les doublons (même date + même TTC) sont en rouge. Tu peux les ignorer, ou importer quand même.
        </div>
      </div>

      <div class="d-flex gap-2">
        <a class="btn btn-outline-light btn-sm fw-semibold"
           href="{{ path('app_administrateur_depense_import', {entite: entite.id}) }}">
          <i class="bi bi-arrow-left"></i> Revenir à l’import
        </a>
        <button type="button" class="btn btn-light btn-sm fw-semibold" id="btnSelectNonDup">
          <i class="bi bi-check2-square"></i> Sélectionner non-doublons
        </button>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  <form method="post"
        action="{{ path('app_administrateur_depense_import_commit', {entite: entite.id}) }}"
        enctype="multipart/form-data"
        id="importForm">

    <div class="row g-3">
      {% for p in proposals %}
        {% set key = (p.date ~ '|' ~ p.montantTtcCents) %}
        {% set isDup = dupMap[key] is defined %}
        <div class="col-12">
          <div class="imp-card {{ isDup ? 'dup' : '' }}" data-idx="{{ p.idx }}" data-dup="{{ isDup ? 1 : 0 }}">
            <div class="imp-head">
              <div class="d-flex flex-wrap gap-2 align-items-center">
                <span class="imp-badge"><i class="bi bi-hash"></i> {{ p.idx + 1 }}</span>
                <span class="imp-badge"><i class="bi bi-calendar"></i> {{ p.dateFr ?: '—' }}</span>
                <span class="imp-badge"><i class="bi bi-cash-coin"></i> {{ (p.montantTtcCents/100)|number_format(2, ',', ' ') }} €</span>

                {% if isDup %}
                  <div class="dup-zone d-flex gap-2 {{ isDup ? '' : 'd-none' }}">
                    <span class="imp-badge dup-badge dup-label">
                      <i class="bi bi-exclamation-triangle"></i> Doublon probable
                    </span>

                    <a class="imp-badge dup-badge dup-link {{ isDup ? '' : 'disabled' }}"
                      href="#"
                      {{ isDup ? ('data-existing-id="' ~ dupMap[key].depenseId ~ '"') : '' }}
                      aria-label="Voir existant (modal)"
                      aria-disabled="{{ isDup ? 'false' : 'true' }}">
                      <i class="bi bi-eye"></i> Voir existant
                    </a>
                  </div>
                {% endif %}
              </div>

              <div class="d-flex gap-2 align-items-center">
                <div class="form-check form-switch">
                  <input class="form-check-input accept-switch" type="checkbox"
                         name="rows[{{ p.idx }}][accept]" value="1"
                         id="accept_{{ p.idx }}" checked>
                  <label class="form-check-label" for="accept_{{ p.idx }}">Importer</label>
                </div>

                <button type="button" class="btn btn-outline-secondary btn-sm btnRemoveCard">
                  <i class="bi bi-x-lg"></i> Retirer
                </button>
              </div>
            </div>


            

            <div class="p-3 p-md-4">


              <div class="row g-3">
                <div class="col-xl-9">
                  <div class="grid">
                    <div class="field-libelle">
                      <label>Libellé</label>
                      <textarea class="form-control libelle"
                        name="rows[{{ p.idx }}][libelle]"
                        maxlength="2000"
                        rows="1">{{ p.libelle|e }}</textarea>

                      <div class="small text-muted mt-1 libelle-hint"></div>
                    </div>
                    <div>
                      <label>Date</label>
                      <input class="form-control js-date"
                        type="text"
                        inputmode="numeric"
                        autocomplete="off"
                        placeholder="jj/mm/aaaa"
                        data-default-date="{{ p.date }}"
                        name="rows[{{ p.idx }}][date]"
                        value="{{ p.date }}">

                    </div>


                    <div>
                      <label>Payeur</label>
                      <select class="form-select ts"
                              name="rows[{{ p.idx }}][payeurId]">
                        <option value="">—</option>
                        {% for u in payeurs %}
                          <option value="{{ u.id }}" {{ p.payeurId == u.id ? 'selected' : '' }}>
                            {{ (u.nom ~ ' ' ~ u.prenom)|trim ?: u.email }}
                          </option>
                        {% endfor %}
                      </select>
                    </div>

                    <div>
                      <label>Devise</label>
                      <select class="form-select"
                              name="rows[{{ p.idx }}][devise]">
                        {% for code in ['EUR','USD','CHF','GBP'] %}
                          <option value="{{ code }}" {{ p.devise == code ? 'selected' : '' }}>{{ code }}</option>
                        {% endfor %}
                      </select>
                    </div>

                    <div>
                      <label>Catégorie</label>

                      <div class="field-actions">
                        <select class="form-select ts ts-cat" name="rows[{{ p.idx }}][categorieId]">
                          <option value="">—</option>
                          {% for c in categories %}
                            <option
                              value="{{ c.id }}"
                              {{ p.categorieId == c.id ? 'selected' : '' }}
                              data-type="{{ c.type }}"
                              data-actif="{{ c.actif ? 1 : 0 }}"
                              data-include-charts="{{ c.includeInFinanceCharts ? 1 : 0 }}"
                            >
                              {{ c.libelle }}
                            </option>
                          {% endfor %}
                        </select>

                        <button type="button" class="btn"
                                data-bs-toggle="modal" data-bs-target="#modalAddCategorie"
                                title="Ajouter une catégorie">
                          <i class="bi bi-plus-lg"></i>
                        </button>

                        <button type="button" class="btn btnEditCategorieOpen"
                                title="Éditer la catégorie sélectionnée">
                          <i class="bi bi-pencil"></i>
                        </button>
                      </div>
                    </div>


                    <div>
                      <label>Fournisseur</label>

                      <div class="field-actions">
                        <select class="form-select ts ts-four" name="rows[{{ p.idx }}][fournisseurId]">
                          <option value="">—</option>
                          {% for f in fournisseurs %}
                            <option value="{{ f.id }}" {{ p.fournisseurId == f.id ? 'selected' : '' }}>{{ f.nom }}</option>
                          {% endfor %}
                        </select>

                        <button type="button" class="btn"
                                data-bs-toggle="modal" data-bs-target="#modalAddFournisseur"
                                title="Ajouter un fournisseur">
                          <i class="bi bi-plus-lg"></i>
                        </button>

                        <button type="button" class="btn btnEditFournisseurOpen"
                                title="Éditer le fournisseur sélectionné">
                          <i class="bi bi-pencil"></i>
                        </button>
                      </div>
                    </div>



                    <div>
                      <label>Justificatif</label>
                      <input class="form-control"
                            type="file"
                            name="proofs[{{ p.idx }}]"
                            accept="application/pdf,image/jpeg,image/png,image/webp">
                      <div class="small text-muted mt-1">
                        PDF / JPG / PNG / WebP
                      </div>

                    </div>


                    

                    <div>
                      <label>TVA déductible</label>

                      <div class="d-flex align-items-center justify-content-between gap-2"
                          style="min-height:42px; background: var(--bg-soft); border:1px solid var(--stroke2); border-radius:14px; padding:.5rem .75rem;">
                        <div class="small fw-semibold" style="color: var(--muted);">
                          <span class="ded-label">{{ (p.tvaDeductible ?? 1) ? 'Oui' : 'Non' }}</span>
                        </div>

                        <div class="form-check form-switch m-0">
                          <input class="form-check-input dedSwitch"
                                type="checkbox"
                                id="ded_{{ p.idx }}"
                                {{ (p.tvaDeductible ?? 1) ? 'checked' : '' }}>
                          <label class="form-check-label visually-hidden" for="ded_{{ p.idx }}">TVA déductible</label>
                        </div>
                      </div>

                      <input type="hidden"
                            name="rows[{{ p.idx }}][tvaDeductible]"
                            value="{{ (p.tvaDeductible ?? 1) ? 1 : 0 }}"
                            class="dedVal">
                    </div>



                    <div>
                      <label>Taux TVA</label>
                      <div class="input-group">
                        <select class="form-select taux tauxSelect"
                                name="rows[{{ p.idx }}][tauxTva]">
                          {% for v in [20,10,5.5,2.1,0] %}
                            <option value="{{ v }}" {{ p.tauxTva == v ? 'selected' : '' }}>
                              {{ v|replace({'.':','}) }}
                            </option>
                          {% endfor %}
                        </select>
                        <span class="input-group-text">%</span>
                      </div>
                    </div>


                    <div>
                      <label>% TVA déductible</label>
                      <div class="input-group">
                        <input class="form-control pct money pctInput"
                              name="rows[{{ p.idx }}][tvaDeductiblePct]"
                              value="{{ p.tvaDeductiblePct ?? 80 }}"
                              step="0.5" min="0" max="100" type="number">
                        <span class="input-group-text">%</span>
                      </div>
                    </div>


                    {# ===== Montant HT (visible € + hidden cents) ===== #}
                    <div>
                      <label>Montant HT</label>
                      <div class="input-group">
                        <input class="form-control money htEuro"
                              type="text"
                              inputmode="decimal"
                              value="{{ (p.montantHtCents/100)|number_format(2, ',', ' ') }}"
                              placeholder="0,00">
                        <span class="input-group-text">€</span>
                      </div>
                      <input type="hidden" class="htCents"
                            name="rows[{{ p.idx }}][montantHtCents]"
                            value="{{ p.montantHtCents }}">
                    </div>

                    {# ===== Montant TVA ===== #}
                    <div>
                      <label>Montant TVA</label>
                      <div class="input-group">
                        <input class="form-control money tvaEuro"
                              type="text"
                              inputmode="decimal"
                              value="{{ (p.montantTvaCents/100)|number_format(2, ',', ' ') }}"
                              placeholder="0,00">
                        <span class="input-group-text">€</span>
                      </div>
                      <input type="hidden" class="tvaCents"
                            name="rows[{{ p.idx }}][montantTvaCents]"
                            value="{{ p.montantTvaCents }}">
                    </div>

                    {# ===== Montant TTC ===== #}
                    <div>
                      <label>Montant TTC</label>
                      <div class="input-group">
                        <input class="form-control money ttcEuro"
                              type="text"
                              inputmode="decimal"
                              value="{{ (p.montantTtcCents/100)|number_format(2, ',', ' ') }}"
                              placeholder="0,00">
                        <span class="input-group-text">€</span>
                      </div>
                      <input type="hidden" class="ttcCents"
                            name="rows[{{ p.idx }}][montantTtcCents]"
                            value="{{ p.montantTtcCents }}">
                      <div class="small text-muted mt-1">banque (débit)</div>
                    </div>


                    
                  </div>
                </div>

                <div class="col-xl-3">
                  <div class="imp-preview sticky-top" style="top: 96px;">
                    <div class="p-3" style="border:1px solid rgba(0,0,0,.08); border-radius:16px; background:rgba(0,0,0,.02);">
                      <div class="small text-muted mb-2"><i class="bi bi-eye"></i> Aperçu</div>

                      <div class="d-flex justify-content-between small py-1">
                        <span class="text-muted">HT</span>
                        <span class="fw-semibold pv-ht">—</span>
                      </div>
                      <div class="d-flex justify-content-between small py-1">
                        <span class="text-muted">TVA</span>
                        <span class="fw-semibold pv-tva">—</span>
                      </div>
                      <div class="d-flex justify-content-between small py-1">
                        <span class="text-muted">TTC</span>
                        <span class="fw-bold pv-ttc">—</span>
                      </div>

                      <hr class="my-2">

                      <div class="small">
                        <div class="d-flex justify-content-between py-1">
                          <span class="text-muted">Cat.</span>
                          <span class="fw-semibold pv-cat text-end">—</span>
                        </div>
                        <div class="d-flex justify-content-between py-1">
                          <span class="text-muted">Four.</span>
                          <span class="fw-semibold pv-four text-end">—</span>
                        </div>
                        <div class="d-flex justify-content-between py-1">
                          <span class="text-muted">Déduct.</span>
                          <span class="fw-semibold pv-ded text-end">—</span>
                        </div>
                        <div class="d-flex justify-content-between py-1">
                          <span class="text-muted">TVA déd.</span>
                          <span class="fw-semibold pv-tvaded text-end">—</span>
                        </div>
                      </div>

                    </div>
                  </div>
                </div>
              </div>


              <div class="mt-3 small text-muted">
                <i class="bi bi-info-circle"></i>
                Astuce : si tu touches le <strong>TTC</strong> ou le <strong>taux</strong>, HT/TVA se recalculent automatiquement.
              </div>

            </div>
          </div>
        </div>
      {% endfor %}
    </div>

