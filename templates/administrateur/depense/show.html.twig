{# templates/administrateur/depense/show.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}Dépense {{ d.id ? ('#' ~ d.id) : '' }}{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};

      --bg:#f6f8fb;
      --panel:#ffffff;
      --ink:#0f172a;
      --muted:rgba(15,23,42,.62);
      --stroke:rgba(15,23,42,.10);
      --shadow: 0 18px 55px rgba(0,0,0,.08);
      --r: 22px;
    }

    body{ background: var(--bg); }

    .hero{
      position:relative; overflow:hidden;
      border-radius: calc(var(--r) + 6px);
      padding: 22px 22px;
      color:#fff;
      box-shadow: 0 24px 70px rgba(0,0,0,.18);
      background:
        radial-gradient(1100px 420px at 12% 0%, rgba(255,255,255,.16), transparent 60%),
        radial-gradient(900px 360px at 88% 12%, rgba(255,193,7,.22), transparent 56%),
        linear-gradient(135deg, rgba(35,51,66,.98), rgba(35,51,66,.78));
    }
    .hero:before{
      content:""; position:absolute; inset:0;
      background:
        radial-gradient(900px 220px at 18% 0%, rgba(255,255,255,.10), transparent 60%),
        linear-gradient(90deg, rgba(255,255,255,.08), transparent 70%);
      pointer-events:none;
    }
    .hero .topline{
      display:flex; flex-wrap:wrap; gap:.5rem; align-items:center;
      position:relative; z-index:2;
    }
    .chip{
      display:inline-flex; align-items:center; gap:.5rem;
      padding:.38rem .72rem;
      border-radius:999px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(255,255,255,.16);
      backdrop-filter: blur(7px);
      font-size:.85rem;
      color: rgba(255,255,255,.92);
    }
    .hero h1{
      position:relative; z-index:2;
      font-weight: 900;
      letter-spacing: -.02em;
      font-size: 1.65rem;
      margin: .6rem 0 .25rem;
    }
    .hero .sub{
      position:relative; z-index:2;
      color: rgba(255,255,255,.82);
      font-size:.95rem;
    }
    .hero-actions{
      position:relative; z-index:2;
      display:flex; gap:.5rem; flex-wrap:wrap; justify-content:flex-end;
    }
    .btn-pill{
      border-radius:999px !important;
      font-weight:800;
      padding: .52rem .85rem;
      box-shadow: 0 10px 24px rgba(0,0,0,.18);
      border: 1px solid rgba(255,255,255,.18);
      backdrop-filter: blur(6px);
    }
    .btn-ghost{
      background: rgba(255,255,255,.10) !important;
      color:#fff !important;
    }
    .btn-ghost:hover{ background: rgba(255,255,255,.16) !important; }

    .panel{
      background: var(--panel);
      border: 1px solid var(--stroke);
      border-radius: var(--r);
      box-shadow: var(--shadow);
      overflow:hidden;
    }
    .panel-hd{
      padding: 14px 16px;
      display:flex; align-items:center; justify-content:space-between; gap:1rem;
      border-bottom: 1px solid var(--stroke);
      background:
        radial-gradient(700px 140px at 18% 0%, rgba(255,193,7,.12), transparent 60%),
        linear-gradient(180deg, rgba(255,255,255,.82), rgba(255,255,255,1));
    }
    .panel-title{
      display:flex; align-items:center; gap:.65rem;
      font-weight:900; color: var(--ink);
      letter-spacing: -.01em;
    }
    .panel-title i{
      width: 40px; height:40px; display:grid; place-items:center;
      border-radius: 14px;
      background: rgba(15,23,42,.04);
      border: 1px solid rgba(15,23,42,.08);
    }
    .panel-bd{ padding: 16px; }

    .kpi{
      display:flex; align-items:center; gap:12px;
      padding: 14px 14px;
      border-radius: 18px;
      border: 1px solid var(--stroke);
      background:
        radial-gradient(700px 140px at 18% 0%, rgba(255,193,7,.12), transparent 60%),
        #fff;
    }
    .kpi .ico{
      width: 46px; height:46px; border-radius: 16px;
      display:grid; place-items:center;
      background: rgba(15,23,42,.04);
      border: 1px solid rgba(15,23,42,.08);
      color: var(--ink);
    }
    .kpi .label{ color: rgba(15,23,42,.60); font-size:.86rem; }
    .kpi .val{ font-weight: 950; font-size: 1.35rem; letter-spacing:-.02em; color: var(--ink); }
    .kpi .sub{ color: rgba(15,23,42,.55); font-size:.82rem; }
    .mono{ font-variant-numeric: tabular-nums; font-feature-settings: "tnum" 1; }

    .badge-soft{
      border-radius: 999px;
      border: 1px solid rgba(15,23,42,.12);
      background: rgba(15,23,42,.04);
      padding: .3rem .55rem;
      font-weight: 800;
      display:inline-flex;
      align-items:center;
      gap:.35rem;
      white-space:nowrap;
    }
    .pill-success{ background: rgba(25,135,84,.10); border-color: rgba(25,135,84,.22); color:#146c43; }
    .pill-danger{  background: rgba(220,53,69,.10); border-color: rgba(220,53,69,.22); color:#b02a37; }
    .pill-warn{    background: rgba(255,193,7,.16); border-color: rgba(255,193,7,.30); color:#8a6a00; }
    .pill-muted{   background: rgba(108,117,125,.10); border-color: rgba(108,117,125,.20); color:#495057; }

    .info-grid{
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    @media (max-width: 992px){ .info-grid{ grid-template-columns: 1fr; } }

    .info{
      border:1px solid var(--stroke);
      border-radius: 18px;
      padding: 12px 12px;
      background: #fff;
    }
    .info .k{ color: rgba(15,23,42,.55); font-size:.82rem; }
    .info .v{ font-weight: 850; color: var(--ink); margin-top:.15rem; }

    .proof-frame{
      width:100%;
      height: 560px;
      border: 1px solid rgba(15,23,42,.10);
      border-radius: 18px;
      background: #fff;
    }

    @media (max-width: 768px){
      .sticky-actions{
        position: sticky;
        bottom: 10px;
        z-index: 20;
        display:flex; gap:.5rem; flex-wrap:wrap;
        padding: 10px;
        border-radius: 18px;
        background: rgba(255,255,255,.86);
        border: 1px solid rgba(15,23,42,.10);
        box-shadow: 0 18px 55px rgba(0,0,0,.10);
        backdrop-filter: blur(10px);
      }
    }
  </style>
{% endblock %}

{% block body %}
  {% set htEur  = (d.montantHtCents  / 100) %}
  {% set tvaEur = (d.montantTvaCents / 100) %}
  {% set ttcEur = (d.montantTtcCents / 100) %}
  {% set tvaDedEur = (d.tvaDeductibleCents / 100) %}
  {% set rate = d.tauxTva|default(0) %}
  {% set pct = d.tvaDeductiblePct|default(0) %}


    {# ===== HERO ===== #}
    <div class="hero mb-3">
      <div class="topline">
        <span class="chip"><i class="bi bi-receipt"></i> Dépense</span>
        <span class="chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
        <span class="chip"><i class="bi bi-calendar3"></i> {{ d.dateDepense ? d.dateDepense|date('d/m/Y') : '—' }}</span>

        {% if d.tvaDeductible %}
          <span class="chip" style="border-color: rgba(25,135,84,.35); background: rgba(25,135,84,.16);">
            <i class="bi bi-check2-circle"></i> TVA déductible
          </span>
        {% else %}
          <span class="chip" style="border-color: rgba(108,117,125,.35); background: rgba(108,117,125,.18);">
            <i class="bi bi-slash-circle"></i> TVA non déductible
          </span>
        {% endif %}
      </div>

      <div class="d-flex flex-wrap gap-3 align-items-start justify-content-between mt-2">
        <div>
          <h1 class="mb-0">{{ d.libelle ?: ('Dépense #' ~ d.id) }}</h1>
          <div class="sub">
            {% if d.fournisseur %}
              Fournisseur : <span class="fw-semibold text-white">{{ d.fournisseur.nom }}</span>
            {% else %}
              <span class="text-white-50">Aucun fournisseur</span>
            {% endif %}
            {% if d.categorie %}
              <span class="ms-2 chip"><i class="bi bi-tag"></i> {{ d.categorie.libelle }}</span>
            {% endif %}
          </div>
        </div>

        <div class="hero-actions">
          <a class="btn btn-pill btn-ghost btn-sm"
             href="{{ path('app_administrateur_depense_index', {entite: entite.id}) }}">
            <i class="bi bi-arrow-left"></i> Retour
          </a>

          <a class="btn btn-pill btn-ghost btn-sm"
             href="{{ path('app_administrateur_depense_edit', {entite: entite.id, id: d.id}) }}">
            <i class="bi bi-pencil-square"></i> Éditer
          </a>

          {% if d.justificatifPath %}
            <a class="btn btn-pill btn-sm"
               style="background: rgba(255,193,7,.18); color:#fff;"
               href="{{ path('app_administrateur_depense_proof', {entite: entite.id, id: d.id}) }}"
               target="_blank" rel="noopener">
              <i class="bi bi-file-earmark-text"></i> Justificatif
            </a>
          {% endif %}

          <form method="post"
                action="{{ path('app_administrateur_depense_delete', {entite: entite.id, id: d.id}) }}"
                onsubmit="return confirm('Supprimer cette dépense ?');"
                class="d-inline">
            <input type="hidden" name="_token" value="{{ csrf_token('depense_delete_' ~ d.id) }}">
            <button class="btn btn-pill btn-sm"
                    style="background: rgba(220,53,69,.18); color:#fff;">
              <i class="bi bi-trash"></i> Supprimer
            </button>
          </form>
        </div>
      </div>
    </div>

    {# ===== KPIs ===== #}
    <div class="row g-3 mb-3">
      <div class="col-12 col-md-6 col-xl-3">
        <div class="kpi">
          <div class="ico"><i class="bi bi-cash-stack fs-4"></i></div>
          <div class="flex-grow-1">
            <div class="label">Total TTC</div>
            <div class="val mono">{{ ttcEur|number_format(2, ',', ' ') }} €</div>
            <div class="sub">Montant payé / constaté</div>
          </div>
        </div>
      </div>

      <div class="col-12 col-md-6 col-xl-3">
        <div class="kpi">
          <div class="ico"><i class="bi bi-receipt-cutoff fs-4"></i></div>
          <div class="flex-grow-1">
            <div class="label">HT</div>
            <div class="val mono">{{ htEur|number_format(2, ',', ' ') }} €</div>
            <div class="sub">Base hors taxe</div>
          </div>
        </div>
      </div>

      <div class="col-12 col-md-6 col-xl-3">
        <div class="kpi">
          <div class="ico"><i class="bi bi-percent fs-4"></i></div>
          <div class="flex-grow-1">
            <div class="label">TVA ({{ rate|number_format(1, ',', ' ') }} %)</div>
            <div class="val mono">{{ tvaEur|number_format(2, ',', ' ') }} €</div>
            <div class="sub">
              {% if d.tvaDeductible %}
                Part déductible : {{ tvaDedEur|number_format(2, ',', ' ') }} €
              {% else %}
                Non récupérable
              {% endif %}
            </div>
          </div>
        </div>
      </div>

      <div class="col-12 col-md-6 col-xl-3">
        <div class="kpi">
          <div class="ico"><i class="bi bi-check2-circle fs-4"></i></div>
          <div class="flex-grow-1">
            <div class="label">TVA récup. (%)</div>
            <div class="val mono">
              {% if d.tvaDeductible %}
                {{ pct|number_format(1, ',', ' ') }} %
              {% else %}
                —
              {% endif %}
            </div>
            <div class="sub">Selon la règle de déduction</div>
          </div>
        </div>
      </div>
    </div>

    {# ===== Main grid ===== #}
    <div class="row g-3">

      <div class="col-lg-7">
        <div class="panel mb-3">
          <div class="panel-hd">
            <div class="panel-title">
              <i class="bi bi-info-circle"></i>
              Informations
            </div>
            <span class="badge-soft pill-muted">ID #{{ d.id }}</span>
          </div>

          <div class="panel-bd">
            <div class="info-grid">
              <div class="info">
                <div class="k">Date dépense</div>
                <div class="v mono">{{ d.dateDepense ? d.dateDepense|date('d/m/Y') : '—' }}</div>
              </div>

              <div class="info">
                <div class="k">Devise</div>
                <div class="v mono">{{ d.devise|default('EUR') }}</div>
              </div>

              <div class="info">
                <div class="k">Catégorie</div>
                <div class="v">{{ d.categorie ? d.categorie.libelle : '—' }}</div>
              </div>

              <div class="info">
                <div class="k">Fournisseur</div>
                <div class="v">
                  {% if d.fournisseur %}
                    {{ d.fournisseur.nom }}
                    {% if d.fournisseur.siret %}
                      <div class="text-muted small mono">SIRET : {{ d.fournisseur.siret }}</div>
                    {% endif %}
                  {% else %}
                    —
                  {% endif %}
                </div>
              </div>

              <div class="info">
                <div class="k">Créée par</div>
                <div class="v">
                  {{ d.createur ? (d.createur.nom ?? d.createur.prenom ?? d.createur.email ?? ('Utilisateur #' ~ d.createur.id)) : '—' }}
                </div>
              </div>

              <div class="info">
                <div class="k">Payée par</div>
                <div class="v">
                  {{ d.payeur ? (d.payeur.nom ?? d.payeur.prenom ?? d.payeur.email ?? ('Utilisateur #' ~ d.payeur.id)) : '—' }}
                </div>
              </div>

              <div class="info" style="grid-column: 1 / -1;">
                <div class="k">TVA</div>
                <div class="v d-flex flex-wrap gap-2 align-items-center">
                  <span class="badge-soft pill-warn">
                    <i class="bi bi-percent"></i> {{ rate|number_format(1, ',', ' ') }} %
                  </span>

                  {% if d.tvaDeductible %}
                    <span class="badge-soft pill-success">
                      <i class="bi bi-check2-circle"></i> Déductible ({{ pct|number_format(1, ',', ' ') }} %)
                    </span>
                  {% else %}
                    <span class="badge-soft pill-muted">
                      <i class="bi bi-slash-circle"></i> Non déductible
                    </span>
                  {% endif %}

                  <span class="badge-soft">
                    TVA déductible : <span class="mono">{{ tvaDedEur|number_format(2, ',', ' ') }} €</span>
                  </span>
                </div>
              </div>

              {% if d.meta is not null %}
                <div class="info" style="grid-column: 1 / -1;">
                  <div class="k">Meta</div>
                  <div class="v">
                    <code class="d-block small" style="white-space: pre-wrap; color: rgba(15,23,42,.70);">
                    {{ d.meta|json_encode(constant('JSON_PRETTY_PRINT')) }}
                    </code>
                  </div>
                </div>
              {% endif %}

              <div class="info">
                <div class="k">Création</div>
                <div class="v mono">{{ d.dateCreation ? d.dateCreation|date('d/m/Y H:i') : '—' }}</div>
              </div>

              <div class="info">
                <div class="k">Dernière MAJ</div>
                <div class="v mono">{{ d.dateMaj ? d.dateMaj|date('d/m/Y H:i') : '—' }}</div>
              </div>

            </div>
          </div>
        </div>

        <div class="panel">
          <div class="panel-hd">
            <div class="panel-title">
              <i class="bi bi-shield-check"></i>
              Raccourcis
            </div>
          </div>
          <div class="panel-bd d-grid gap-2">
            <a class="btn btn-outline-secondary btn-pill"
               href="{{ path('app_administrateur_depense_edit', {entite: entite.id, id: d.id}) }}">
              <i class="bi bi-pencil-square"></i> Modifier la dépense
            </a>

            {% if d.justificatifPath %}
              <a class="btn btn-outline-warning btn-pill"
                 href="{{ path('app_administrateur_depense_proof', {entite: entite.id, id: d.id}) }}"
                 target="_blank" rel="noopener">
                <i class="bi bi-file-earmark-text"></i> Ouvrir le justificatif
              </a>
            {% endif %}

            <a class="btn btn-outline-secondary btn-pill"
               href="{{ path('app_administrateur_depense_index', {entite: entite.id}) }}">
              <i class="bi bi-list-ul"></i> Retour à la liste
            </a>
          </div>
        </div>
      </div>

      <div class="col-lg-5">
        <div class="panel">
          <div class="panel-hd">
            <div class="panel-title">
              <i class="bi bi-file-earmark-text"></i>
              Justificatif
            </div>

            {% if d.justificatifPath %}
              <span class="badge-soft pill-success"><i class="bi bi-check2-circle"></i> Présent</span>
            {% else %}
              <span class="badge-soft pill-muted"><i class="bi bi-dash-circle"></i> Aucun</span>
            {% endif %}
          </div>

          <div class="panel-bd">
            {% if d.justificatifPath %}
              {# Affichage inline via ta route /{id}/proof #}
              <iframe class="proof-frame"
                      src="{{ path('app_administrateur_depense_proof', {entite: entite.id, id: d.id}) }}"
                      title="Justificatif dépense #{{ d.id }}"></iframe>

              <div class="d-flex gap-2 mt-3 flex-wrap">
                <a class="btn btn-outline-secondary btn-pill btn-sm"
                   href="{{ path('app_administrateur_depense_proof', {entite: entite.id, id: d.id}) }}"
                   target="_blank" rel="noopener">
                  <i class="bi bi-box-arrow-up-right"></i> Ouvrir dans un onglet
                </a>
              </div>
            {% else %}
              <div class="text-muted">
                Aucun justificatif associé à cette dépense.
              </div>
              <div class="mt-2">
                <a class="btn btn-outline-secondary btn-pill btn-sm"
                   href="{{ path('app_administrateur_depense_edit', {entite: entite.id, id: d.id}) }}">
                  <i class="bi bi-paperclip"></i> Ajouter un justificatif
                </a>
              </div>
            {% endif %}
          </div>
        </div>
      </div>

    </div>

    {# Mobile sticky actions #}
    <div class="sticky-actions mt-3 d-md-none">
      <a class="btn btn-outline-secondary btn-pill btn-sm flex-grow-1"
         href="{{ path('app_administrateur_depense_index', {entite: entite.id}) }}">
        <i class="bi bi-arrow-left"></i> Retour
      </a>

      <a class="btn btn-outline-secondary btn-pill btn-sm flex-grow-1"
         href="{{ path('app_administrateur_depense_edit', {entite: entite.id, id: d.id}) }}">
        <i class="bi bi-pencil-square"></i> Éditer
      </a>

      <form method="post"
            action="{{ path('app_administrateur_depense_delete', {entite: entite.id, id: d.id}) }}"
            onsubmit="return confirm('Supprimer cette dépense ?');"
            class="flex-grow-1">
        <input type="hidden" name="_token" value="{{ csrf_token('depense_delete_' ~ d.id) }}">
        <button class="btn btn-danger btn-pill btn-sm w-100">
          <i class="bi bi-trash"></i> Supprimer
        </button>
      </form>
    </div>

{% endblock %}
