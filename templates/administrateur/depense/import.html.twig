{% extends 'base_admin.html.twig' %}
{% block title %}Importer des dépenses{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/formulaire.css') }}">
  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }
    .hero{
      border-radius:22px; overflow:hidden;
      background:
        radial-gradient(1200px 400px at 15% 0%, rgba(255,255,255,.12), transparent 60%),
        radial-gradient(900px 350px at 85% 10%, rgba(255,193,7,.18), transparent 55%),
        linear-gradient(135deg, rgba(35,51,66,.98), rgba(35,51,66,.78));
      color:#fff;
      box-shadow:0 18px 50px rgba(0,0,0,.14);
    }
    .upload-card{
      border-radius:18px; background:#fff;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 12px 30px rgba(0,0,0,.06);
      overflow:hidden;
    }
    .dropzone{
      border: 1.5px dashed rgba(0,0,0,.15);
      border-radius: 16px;
      padding: 1.2rem;
      background: rgba(35,51,66,.02);
    }
  </style>
{% endblock %}

{% block body %}

  <div class="hero p-4 mb-4">
    <div class="d-flex flex-wrap align-items-end gap-2">
      <div class="me-auto">
        <div class="d-flex flex-wrap gap-2 mb-2">
          <span class="badge rounded-pill" style="background:rgba(255,255,255,.14); border:1px solid rgba(255,255,255,.18);">
            <i class="bi bi-upload"></i> Import
          </span>
          <span class="badge rounded-pill" style="background:rgba(255,255,255,.14); border:1px solid rgba(255,255,255,.18);">
            <i class="bi bi-building"></i> {{ entite.nom }}
          </span>
        </div>
        <h2 class="fw-bold mb-1">Importer des dépenses</h2>
        <div class="opacity-75">
          On lit uniquement les <strong>débits</strong> (positifs). Aucune écriture en base tant que tu n’as pas validé.
        </div>
      </div>




      <a class="btn btn-light btn-sm fw-semibold"
        href="{{ path('app_administrateur_depense_import_template', { entite: entite.id, format: 'xlsx' }) }}">
        <i class="bi bi-file-earmark-arrow-down"></i> Modèle XLSX
      </a>

      <a class="btn btn-light btn-sm fw-semibold"
        href="{{ path('app_administrateur_depense_import_template', { entite: entite.id, format: 'csv' }) }}">
        <i class="bi bi-file-earmark-arrow-down"></i> Modèle CSV
      </a>

      <div class="d-flex gap-2">
        <a class="btn btn-outline-light btn-sm fw-semibold"
           href="{{ path('app_administrateur_depense_index', {entite: entite.id}) }}">
          <i class="bi bi-arrow-left"></i> Retour
        </a>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  <div class="upload-card">
    <div class="p-3 p-md-4">

      <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
        <a class="btn btn-light btn-sm fw-semibold"
           href="{{ path('app_administrateur_depense_import_template', {entite: entite.id, format:'xlsx'}) }}">
          <i class="bi bi-file-earmark-excel"></i> Modèle XLSX
        </a>

        <a class="btn btn-light btn-sm fw-semibold"
           href="{{ path('app_administrateur_depense_import_template', {entite: entite.id, format:'csv'}) }}">
          <i class="bi bi-filetype-csv"></i> Modèle CSV
        </a>

        <span class="text-muted small ms-auto">
          Colonnes attendues : Date / Libellé / Débit euros / Crédit euros
        </span>
      </div>

      <form method="post" action="{{ path('app_administrateur_depense_import_preview', {entite: entite.id}) }}" enctype="multipart/form-data">
        <div class="dropzone">
          <div class="d-flex align-items-start gap-3">
            <div class="fs-2"><i class="bi bi-cloud-arrow-up"></i></div>
            <div class="flex-grow-1">
              <div class="fw-bold">Choisis ton fichier banque</div>
              <div class="small text-muted">Formats acceptés : <strong>.xlsx</strong> / <strong>.csv</strong></div>

              <div class="mt-2">
                <input class="form-control" type="file" name="importFile" accept=".csv,.xlsx,.xls" required>
              </div>

              <div class="mt-3 d-flex gap-2">
                <button class="btn btn-warning fw-semibold" type="submit">
                  <i class="bi bi-magic"></i> Générer la proposition
                </button>
                <span class="small text-muted align-self-center">Aucune insertion en base avant validation.</span>
              </div>
            </div>
          </div>
        </div>
      </form>

    </div>
  </div>

{% endblock %}
