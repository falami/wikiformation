    $('#btnReset').on('click', function(){
      // reset période = année courante
      const now = new Date();
      $periodType.val('year');
      $periodYear.val(String(now.getFullYear()));
      $periodMonth.val(String(now.getMonth()+1));
      $periodQuarter.val(String(Math.floor(now.getMonth()/3)+1));
      updatePeriodUi();
      updatePeriodLabel();

      $tvaOnly.val('all');
      $('.dep-filter-cat, .dep-filter-four').prop('checked', false);
      $('input[data-filter="cat"], input[data-filter="four"]').val('').trigger('input');

      updateSelectedCounts();
      table.search('').draw();
      table.ajax.reload(null, true);
    });

  });


  document.addEventListener('show.bs.dropdown', function (e) {
  const toggle = e.target;
  if (!toggle.closest('#tableauDepenses')) return;

  // mobile uniquement
  if (window.innerWidth > 768) return;

  const menu = toggle.closest('.dropdown, .btn-group')?.querySelector('.dropdown-menu');
  if (!menu) return;

  // on détache le menu du tableau
  document.body.appendChild(menu);

  const rect = toggle.getBoundingClientRect();
  const menuHeight = menu.offsetHeight || 180;

  menu.style.position = 'fixed';
  menu.style.left = Math.min(rect.right - menu.offsetWidth, window.innerWidth - 8) + 'px';
  menu.style.top  = Math.max(8, rect.top - menuHeight - 8) + 'px';
  menu.style.zIndex = 1055;

  menu.__fromToggle = toggle;
}, true);

document.addEventListener('hidden.bs.dropdown', function (e) {
  const toggle = e.target;
  const menu = document.querySelector('.dropdown-menu[style][data-bs-popper]');
  if (!menu || !menu.__fromToggle) return;

  // on remet le menu à sa place
  const parent = menu.__fromToggle.closest('.dropdown, .btn-group');
  if (parent) parent.appendChild(menu);

  menu.style.position = '';
  menu.style.top = '';
  menu.style.left = '';
  menu.style.zIndex = '';
  delete menu.__fromToggle;
}, true);

  </script>
