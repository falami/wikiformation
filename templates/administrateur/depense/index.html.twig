    // ===============================
// ✅ DROPDOWNS : comportement stable
// - Export (dt-actions) => float dans body
// - Actions (dep-actions) => autorise overflow visible du scrollBody
// - Mobile dep-actions => menu en fixed, au-dessus du bouton
// ===============================
(function setupDropdownsOnce(){
  if (window.__dep_dropdowns_ready__) return;
  window.__dep_dropdowns_ready__ = true;

  function setScrollBodyOverflow(toggle, value){
    const scrollBody = toggle.closest('.dataTables_scrollBody');
    if (!scrollBody) return;

    if (value === 'visible') {
      if (scrollBody.dataset.prevOverflow === undefined) {
        scrollBody.dataset.prevOverflow = scrollBody.style.overflow || '';
      }
      scrollBody.style.overflow = 'visible';
    } else {
      scrollBody.style.overflow = scrollBody.dataset.prevOverflow || '';
      delete scrollBody.dataset.prevOverflow;
    }
  }

  function floatMenuToBody(toggle, menu, cls){
    const dd = toggle.closest('.dropdown, .btn-group');
    if (!dd || !menu) return;

    if (!menu.__originalParent) menu.__originalParent = dd;
    document.body.appendChild(menu);
    menu.classList.add(cls);

    // position absolute sous le bouton
    const rect = toggle.getBoundingClientRect();
    const menuRect = menu.getBoundingClientRect();
    const isEnd = menu.classList.contains('dropdown-menu-end');

    const top = rect.bottom + window.scrollY + 6;
    let left = isEnd ? (rect.right + window.scrollX - menuRect.width) : (rect.left + window.scrollX);
    left = Math.max(8, Math.min(left, window.scrollX + window.innerWidth - menuRect.width - 8));

    menu.style.position = 'absolute';
    menu.style.top = `${top}px`;
    menu.style.left = `${left}px`;
    menu.style.zIndex = 20000;
  }

  function floatMenuFixedMobile(toggle, menu){
    // menu fixed au-dessus du bouton (mobile)
    const rect = toggle.getBoundingClientRect();

    if (!menu.__originalParent) {
      menu.__originalParent = toggle.closest('.dropdown, .btn-group');
    }
    document.body.appendChild(menu);
    menu.classList.add('dep-floating-dropdown');

    // force display pour mesurer correctement
    menu.style.position = 'fixed';
    menu.style.left = '0px';
    menu.style.top = '0px';
    menu.style.zIndex = 20000;

    const menuW = menu.offsetWidth || 260;
    const menuH = menu.offsetHeight || 220;

    const left = Math.max(8, Math.min(rect.right - menuW, window.innerWidth - menuW - 8));
    const top  = Math.max(8, rect.top - menuH - 8);

    menu.style.left = `${left}px`;
    menu.style.top  = `${top}px`;
  }

  function restoreMenu(menu, cls){
    if (!menu || !menu.__originalParent) return;
    menu.__originalParent.appendChild(menu);
    menu.classList.remove(cls);

    menu.style.position = '';
    menu.style.top = '';
    menu.style.left = '';
    menu.style.zIndex = '';
  }

  // ---------- SHOW ----------
  document.addEventListener('show.bs.dropdown', function(e){
    const toggle = e.target;
    const dd = toggle.closest('.dropdown, .btn-group');
    if (!dd) return;

    const menu = dd.querySelector('.dropdown-menu');
    if (!menu) return;

    // 1) Actions table : on autorise dépassement scrollBody
    if (toggle.closest('.dep-actions')) {
      setScrollBodyOverflow(toggle, 'visible');

      // mobile => fixed
      if (window.innerWidth <= 768) {
        floatMenuFixedMobile(toggle, menu);
      }
      return;
    }

    // 2) Export dt-actions uniquement => float
    if (toggle.closest('.dt-actions')) {
      floatMenuToBody(toggle, menu, 'dt-floating-dropdown');
      return;
    }

    // sinon : toolbar dropdowns => default Bootstrap (ne rien faire)
  }, true);

  // ---------- HIDE ----------
  document.addEventListener('hidden.bs.dropdown', function(e){
    const toggle = e.target;
    const dd = toggle.closest('.dropdown, .btn-group');
    if (!dd) return;

    const menu = dd.querySelector('.dropdown-menu')
      || document.querySelector('.dt-floating-dropdown.__owned')
      || null;

    // restore overflow si dep-actions
    if (toggle.closest('.dep-actions')) {
      setScrollBodyOverflow(toggle, 'restore');
      // si on l'avait détaché en mobile
      restoreMenu(dd.querySelector('.dropdown-menu'), 'dep-floating-dropdown');
      return;
    }

    // restore export dt-actions
    if (toggle.closest('.dt-actions')) {
      restoreMenu(document.querySelector('.dt-floating-dropdown'), 'dt-floating-dropdown');
      return;
    }
  }, true);

  // Ferme les dropdowns flottants sur scroll/resize (uniquement export)
  window.addEventListener('scroll', () => {
    document.querySelectorAll('.dt-actions [aria-expanded="true"][data-bs-toggle="dropdown"]')
      .forEach(btn => btn.click());
  }, true);

  window.addEventListener('resize', () => {
    document.querySelectorAll('.dt-actions [aria-expanded="true"][data-bs-toggle="dropdown"]')
      .forEach(btn => btn.click());
  });
})();


    initTooltips();
    table.on('draw.dt', function(){
      initTooltips();
      $('#hero-last-refresh').text('Maj : ' + nowLabel());
    });

    //loadDepenseKpis();

    $tvaOnly.on('change', function(){
      table.ajax.reload(null, true);
      loadDepenseKpis();
