{# templates/administrateur/depense/index.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}Dépenses{% endblock %}

{% block stylesheets %}
  {{ parent() }}

  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/style-table.css') }}">
  <link rel="stylesheet" href="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/datatables.min.css"/>
  <link rel="stylesheet" href="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.css"/>

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }
    /* ===== HERO (dark glass like Factures) ===== */
    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;

      /* Ombre douce premium */
      box-shadow: 0 18px 50px rgba(0,0,0,.14);

      /* Fond piloté par les couleurs de l'entité */
      background:
        /* halo clair (tertiaire) */
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        /* halo accent (secondaire) */
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        /* voile subtil (quaternaire) pour la profondeur */
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        /* dégradé principal (principal -> plus clair) */
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    /* léger glass highlight */
    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    /* barre accent = secondaire (et glow basé sur secondaire) */
    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }
    /* ===== Chips HERO (comme site/index) ===== */
    .hero .chip{
      display:inline-flex;
      align-items:center;
      gap:.5rem;
      padding:.32rem .7rem;
      border-radius: 999px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(255,255,255,.14);
      font-size:.82rem;
      color: rgba(255,255,255,.92);
      backdrop-filter: blur(6px);
      white-space: nowrap;
    }
    .hero .chip i{ color: var(--theme-color-secondaire); }

    /* chip highlight */
    .hero .chip--pill{
      background: color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
      border-color: color-mix(in srgb, var(--theme-color-secondaire) 28%, rgba(255,255,255,.14));
      color:#fff;
    }

    /* boutons hero comme site/index */
    .hero .btn{
      border-radius: 14px;
      font-weight: 800;
    }
    .hero .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .hero .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }

    /* ===== KPI CARDS ===== */
    .kpi-card{
      border: 1px solid rgba(0,0,0,.06);
      box-shadow: 0 10px 26px rgba(0,0,0,.06);
      border-radius: 18px;
      overflow:hidden;
      background: #fff;
      position:relative;
    }
    .kpi-card:before{
      content:"";
      position:absolute; inset:0;
      background: radial-gradient(700px 120px at 20% 0%, rgba(255,193,7,.12), transparent 55%);
      pointer-events:none;
    }
    .kpi-ico{
      width:44px; height:44px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }

    .filter-icon{
      width:38px; height:38px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }
    .kpi-label{ color: rgba(0,0,0,.55); font-size:.85rem }
    .kpi-value{ font-weight: 800; font-size: 1.6rem; letter-spacing:-.02em }
    .kpi-sub{ color: rgba(0,0,0,.50); font-size:.82rem }
    .kpi-bar{
      height: 6px; border-radius: 999px;
      background: rgba(0,0,0,.06);
      overflow:hidden;
    }
    .kpi-bar > span{
      display:block; height:100%;
      width: 0%;
      background: var(--theme-color-secondaire);
      border-radius: 999px;
      transition: width .35s ease;
    }

    /* ===== TOOLBAR ===== */
    .toolbar{
      border-radius: 16px;
      background: #fff;
      border: 1px solid rgba(0,0,0,.06);
      box-shadow: 0 10px 24px rgba(0,0,0,.05);
      padding: .85rem;
    }
    .toolbar .hint{ font-size:.85rem; color: rgba(0,0,0,.55); }
    .chip{
      display:inline-flex; align-items:center; gap:.5rem;
      padding:.35rem .7rem;
      border-radius:999px;
      background: rgba(0,0,0,.03);
      border: 1px solid rgba(0,0,0,.06);
      font-size:.85rem;
      color: rgba(0,0,0,.65);
    }

    /* ===== DATATABLE CARD ===== */
    .table-card{
      border-radius: 18px;
      background: #fff;
      border: 1px solid rgba(0,0,0,.06);
      box-shadow: 0 12px 30px rgba(0,0,0,.06);
      overflow:hidden;
    }
    table.dataTable{ margin:0 !important; }
    table.dataTable thead th{
      position: sticky; top: 0; z-index: 2;
      background: #f7f8fa !important;
      border-bottom: 1px solid rgba(0,0,0,.08) !important;
      text-transform: uppercase;
      font-size: .78rem;
      letter-spacing:.06em;
      color: rgba(0,0,0,.55);
      white-space: nowrap;
    }

    #tableauDepenses tbody tr:nth-child(odd) > *{ background-color:#fff !important; }
    #tableauDepenses tbody tr:nth-child(even) > *{ background-color: rgba(35,51,66,.035) !important; }
    #tableauDepenses tbody tr:hover > *{ background-color: rgba(255,193,7,.08) !important; }
    #tableauDepenses tbody td{ padding-top:.75rem !important; padding-bottom:.75rem !important; vertical-align: middle; }

    .dataTables_wrapper .dataTables_filter input{
      border-radius: 999px !important;
      padding: .45rem .85rem !important;
      border: 1px solid rgba(0,0,0,.12) !important;
      outline: none !important;
      box-shadow: none !important;
    }
    .dataTables_wrapper .dataTables_length select{
      border-radius: 999px !important;
      border: 1px solid rgba(0,0,0,.12) !important;
      padding: .35rem .7rem !important;
    }
    .dt-top{
      padding: .75rem .85rem;
      border-bottom: 1px solid rgba(0,0,0,.06);
      background: #fff;
    }
    .dt-bottom-internal{
      padding: 1rem .85rem !important;
      background: #fff;
      border-top: 1px solid rgba(0,0,0,.06);
      margin-top: .75rem !important;
    }
    .dt-actions .btn{
      border-radius: 999px;
      font-weight: 700;
      padding: .40rem .75rem;
    }

    #tableauDepenses td.action-column{ white-space: nowrap; }

    body .dt-floating-dropdown{ z-index: 9999 !important; }

    @media (max-width: 768px){
      table.dataTable td.action-column{
        position: sticky; right:0; background:#fff; z-index:5;
        box-shadow: -12px 0 18px -14px rgba(0,0,0,.22);
      }
      .hero{ border-radius: 16px; }
    }

    /* TomSelect: zone des chips (valeurs sélectionnées) */
    .ts-wrapper.multi .ts-control{
      /* garde une hauteur raisonnable */
      max-height: 96px;            /* ajuste: 72/96/120 */
      overflow-y: auto;            /* ✅ scroll interne */
      overflow-x: hidden;
      flex-wrap: wrap;
      align-items: flex-start;     /* ✅ évite l'effet "bloqué" */
      padding-right: 2.2rem;       /* laisse la place au caret */
    }

    /* (optionnel) scroll visible sur Mac/Win */
    .ts-wrapper.multi .ts-control::-webkit-scrollbar{
      width: 10px;
    }
    .ts-wrapper.multi .ts-control::-webkit-scrollbar-thumb{
      border-radius: 999px;
    }

    /* Empêche le champ de saisie de prendre trop de place */
    .ts-wrapper.multi .ts-control > input{
      min-width: 60px;
      flex: 1 1 60px;
    }

    /* =========================
   ✅ Dropdown "premium" (même design que Paiements)
   ========================= */

    /* Le bouton toggle (dans la chip) */
    .chip .dropdown-toggle{
      border-radius: 999px;
      border: 1px solid rgba(0,0,0,.10);
      background: rgba(255,255,255,.75);
      box-shadow: 0 8px 18px rgba(0,0,0,.06);
      color: rgba(0,0,0,.72);
      font-weight: 700;
      padding: .38rem .70rem;
      line-height: 1.1;
      transition: transform .08s ease, box-shadow .18s ease, border-color .18s ease;
    }
    .chip .dropdown-toggle:hover{
      border-color: rgba(0,0,0,.16);
      box-shadow: 0 12px 22px rgba(0,0,0,.08);
    }
    .chip .dropdown-toggle:active{
      transform: translateY(1px);
    }

    /* Badge compteur dans le bouton */
    .chip .dropdown-toggle .badge{
      border-radius: 999px;
      font-weight: 800;
      letter-spacing: .02em;
    }

    /* Le menu */
    .toolbar .dropdown-menu{
      border-radius: 16px;
      border: 1px solid rgba(0,0,0,.10);
      box-shadow: 0 18px 46px rgba(0,0,0,.18);
      padding: .65rem;
      background:
        radial-gradient(900px 220px at 10% 0%, rgba(255,193,7,.10), transparent 55%),
        #fff;
      overflow: hidden;
    }

    /* Petit "header" du menu : zone recherche */
    .toolbar .dropdown-menu .form-control{
      border-radius: 999px;
      border: 1px solid rgba(0,0,0,.12);
      background: rgba(255,255,255,.95);
      padding: .42rem .85rem;
      box-shadow: none !important;
    }
    .toolbar .dropdown-menu .form-control:focus{
      border-color: rgba(255,193,7,.55);
      box-shadow: 0 0 0 .2rem rgba(255,193,7,.18) !important;
    }

    /* Boutons Tout / Aucun */
    .toolbar .dropdown-menu .btn{
      border-radius: 999px;
      border: 1px solid rgba(0,0,0,.10);
      background: rgba(0,0,0,.03);
      font-weight: 700;
      padding: .35rem .7rem;
    }
    .toolbar .dropdown-menu .btn:hover{
      background: rgba(255,193,7,.12);
      border-color: rgba(255,193,7,.35);
    }

    /* Liste scrollable (comme Paiements) */
    .toolbar .dropdown-menu [id^="list"], /* si tu gardes les ids list... */
    .toolbar .dropdown-menu .dropdown-list{
      border-radius: 12px;
      border: 1px solid rgba(0,0,0,.06);
      background: rgba(255,255,255,.92);
      padding: .25rem;
      max-height: 280px;
      overflow: auto;
    }

    /* Item ligne */
    .toolbar .dropdown-menu .dropdown-item{
      border-radius: 12px;
      padding: .45rem .55rem;
      margin: .10rem 0;
      border: 1px solid transparent;
      background: transparent;
    }
    .toolbar .dropdown-menu .dropdown-item:hover{
      background: rgba(255,193,7,.10);
      border-color: rgba(255,193,7,.20);
    }

    /* Checkbox */
    .toolbar .dropdown-menu .form-check-input{
      width: 1.05rem;
      height: 1.05rem;
      border-radius: .35rem;
      border: 1px solid rgba(0,0,0,.18);
      margin-top: 0;
    }
    .toolbar .dropdown-menu .form-check-input:checked{
      background-color: var(--theme-color-secondaire);
      border-color: rgba(0,0,0,.10);
    }

    /* Texte secondaire */
    .toolbar .dropdown-menu .text-muted{
      color: rgba(0,0,0,.52) !important;
    }

    /* Scrollbar clean */
    .toolbar .dropdown-menu *::-webkit-scrollbar{ width: 10px; }
    .toolbar .dropdown-menu *::-webkit-scrollbar-track{ background: rgba(0,0,0,.04); border-radius: 999px; }
    .toolbar .dropdown-menu *::-webkit-scrollbar-thumb{ background: rgba(0,0,0,.18); border-radius: 999px; }
    .toolbar .dropdown-menu *::-webkit-scrollbar-thumb:hover{ background: rgba(0,0,0,.26); }




    /* Actions (comme Factures) */
    #tableauDepenses td.action-column .btn{
      border-radius: 999px;
      font-weight: 700;
      padding: .40rem .75rem;
    }

    #tableauDepenses td.action-column .dropdown-menu{
      border-radius: 14px;
      border: 1px solid rgba(0,0,0,.10);
      box-shadow: 0 18px 46px rgba(0,0,0,.18);
      padding: .45rem;
    }

    #tableauDepenses td.action-column .dropdown-item{
      border-radius: 10px;
      padding: .45rem .55rem;
    }
    #tableauDepenses td.action-column .dropdown-item:hover{
      background: rgba(255,193,7,.10);
    }


    /* =========================
      ✅ Actions (premium, aligné Factures)
      ========================= */

    /* ✅ Actions: largeur mini */
    #tableauDepenses th:last-child,
    #tableauDepenses td:last-child{
      width: 1% !important;       /* laisse le navigateur minimiser */
      min-width: 0 !important;    /* autorise la réduction */
      white-space: nowrap;        /* pas de retour à la ligne */
    }


    /* optionnel: boutons un peu plus compacts */
    .dep-actions .btn{
      padding: .32rem .55rem;     /* réduit l’empreinte */
    }


    /* Bouton principal (Justif / Aucun) */
    .dep-actions .dep-main{
      background: rgba(255,255,255,.85);
      border-color: rgba(0,0,0,.12);
      box-shadow: 0 10px 22px rgba(0,0,0,.06);
    }
    .dep-actions .dep-main:hover{
      box-shadow: 0 14px 28px rgba(0,0,0,.10);
      border-color: rgba(0,0,0,.18);
    }

    /* Disabled “Aucun” -> plus élégant */
    .dep-actions .dep-main:disabled{
      opacity: 1 !important;
      color: rgba(0,0,0,.45) !important;
      background: rgba(0,0,0,.03) !important;
      border-color: rgba(0,0,0,.10) !important;
      box-shadow: none !important;
    }


    /* ✅ Fusion visuelle du bouton principal + split dropdown (1 seule pill) */
    .dep-actions.btn-group .dep-secondary{
      border-top-right-radius: 0 !important;
      border-bottom-right-radius: 0 !important;
      border-top-left-radius: 0 !important;
      border-bottom-left-radius: 0 !important;
    }


    /* Bouton principal (Justif / Aucun) */
    .dep-actions .dep-secondary{
      background: rgba(255,255,255,.85);
      border-color: rgba(0,0,0,.12);
      box-shadow: 0 10px 22px rgba(0,0,0,.06);
      padding: .40rem .40rem !important;
    }
    .dep-actions .dep-secondary:hover{
      box-shadow: 0 14px 28px rgba(0,0,0,.10);
      border-color: rgba(0,0,0,.18);
    }

    /* Disabled “Aucun” -> plus élégant */
    .dep-actions .dep-secondary:disabled{
      opacity: 1 !important;
      color: rgba(0,0,0,.45) !important;
      background: rgba(0,0,0,.03) !important;
      border-color: rgba(0,0,0,.10) !important;
      box-shadow: none !important;
    }

    /* Split */
    .dep-actions .dep-split{
      padding-left: .55rem;
      padding-right: .55rem;
      border-color: rgba(0,0,0,.12);
      background: rgba(255,255,255,.85);
    }

    /* Menu dropdown */
    .dep-actions .dep-menu{
      border-radius: 16px;
      border: 1px solid rgba(0,0,0,.10);
      box-shadow: 0 18px 46px rgba(0,0,0,.18);
      padding: .55rem;
      background:
        radial-gradient(900px 220px at 10% 0%, rgba(255,193,7,.10), transparent 55%),
        #fff;
      overflow: hidden;
    }

    .dep-actions .dep-menu .dropdown-item{
      border-radius: 12px;
      padding: .50rem .60rem;
      margin: .10rem 0;
      border: 1px solid transparent;
    }
    .dep-actions .dep-menu .dropdown-item:hover{
      background: rgba(255,193,7,.10);
      border-color: rgba(255,193,7,.22);
    }

    /* Mobile : on masque le texte, icône only */
    @media (max-width: 992px){
      .dep-actions .dep-main span{ display:none !important; }
    }

    /* ✅ Fusion visuelle du bouton principal + split dropdown (1 seule pill) */
    .dep-actions.btn-group .dep-main{
      border-top-right-radius: 0 !important;
      border-bottom-right-radius: 0 !important;
    }

    .dep-actions.btn-group .dep-split{
      border-top-left-radius: 0 !important;
      border-bottom-left-radius: 0 !important;

      /* supprime la double bordure au milieu */
      margin-left: -1px; /* recouvre la bordure du bouton gauche */
    }

    /* Optionnel : joli séparateur fin au milieu (au lieu de double bordure) */
    .dep-actions.btn-group .dep-split{
      position: relative;
    }
    .dep-actions.btn-group .dep-split:before{
      content:"";
      position:absolute;
      left:0;
      top:20%;
      bottom:20%;
      width:1px;
      background: rgba(0,0,0,.10);
    }

    /* ✅ Ne jamais masquer les actions quand le dropdown est ouvert */
    #tableauDepenses td.action-column .dep-actions{
      opacity: 1 !important;
      visibility: visible !important;
    }

    /* ✅ quand le menu est ouvert, on force l’affichage même si tr:hover se perd */
    #tableauDepenses td.action-column .dep-actions:focus-within{
      opacity: 1 !important;
      visibility: visible !important;
    }

    /* ✅ GARDE UNIQUEMENT CELLE-CI */
    #tableauDepenses td.action-column{
      padding-left: 0 !important;  /* supprime complètement le padding gauche */
      padding-right: .15rem !important;
      text-align: right;
    }

    /* Le menu flottant doit toujours passer au-dessus du DataTable */
    body .dep-floating-dropdown{
      z-index: 20000 !important;
    }




  </style>
{% endblock %}

{% block body %}

  {# HERO (identique à site/index) #}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>

    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-wallet2 me-2" style="color:var(--theme-color-secondaire)"></i>
            Dépenses
          </h2>
          <div class="opacity-75 mt-1">Suivi TVA, justificatifs, exports & impression.</div>

          <div class="d-flex flex-wrap gap-2 mt-3">
            <span class="chip"><i class="bi bi-wallet2"></i> Comptabilité</span>
            <span class="chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
            <span class="chip chip--pill"><i class="bi bi-clock-history"></i> <span id="hero-last-refresh">—</span></span>
          </div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
          <a class="btn btn-light btn-sm fw-semibold"
            href="{{ path('app_administrateur_depense_new', { entite: entite.id }) }}">
            <i class="bi bi-plus-lg me-1"></i> Nouvelle dépense
          </a>

          <a class="btn btn-outline-theme btn-sm fw-semibold"
            href="{{ path('app_administrateur_depense_import', { entite: entite.id }) }}">
            <i class="bi bi-upload me-1"></i> Importer
          </a>

          <a class="btn btn-outline-theme btn-sm fw-semibold"
            href="{{ path('app_administrateur_dashboard_index', { entite: entite.id })|default('#') }}">
            <i class="bi bi-arrow-left me-1"></i> Retour
          </a>
        </div>
      </div>
    </div>
  </div>

  {# ===== KPI ===== #}
  <div class="row g-3 mb-3">
    <div class="col-12 col-md-6 col-xl-2">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-receipt fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Dépenses</div>
              <div class="kpi-value" id="kpi-count">—</div>
              <div class="kpi-sub" id="kpi-range">{{ entite.nom }}</div>
            </div>
          </div>
          <div class="mt-3 kpi-bar"><span id="kpi-bar-count"></span></div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-cash-coin fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Total TTC</div>
              <div class="kpi-value" id="kpi-ttc">—</div>
              <div class="kpi-sub">Somme TTC</div>
            </div>
          </div>
          <div class="mt-3 kpi-bar"><span id="kpi-bar-ttc"></span></div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-percent fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">TVA totale</div>
              <div class="kpi-value" id="kpi-tva">—</div>
              <div class="kpi-sub">TVA sur les dépenses</div>
            </div>
          </div>
          <div class="mt-3 kpi-bar"><span id="kpi-bar-tva"></span></div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-xl-4">
      <div class="kpi-card h-100">
        <div class="p-3">
