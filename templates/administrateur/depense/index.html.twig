  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
  <script src="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.js"></script>


<script>
  window.__ALL_CAT_IDS__  = {{ categories|map(c => c.id)|json_encode|raw }};
  window.__ALL_FOUR_IDS__ = {{ fournisseurs|map(f => f.id)|json_encode|raw }};
</script>



<script type="module">
  import * as pdfjsLib from "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.10.38/pdf.min.mjs";

  // worker ESM (CDN -> bon MIME type)
  pdfjsLib.GlobalWorkerOptions.workerSrc =
    "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.10.38/pdf.worker.min.mjs";

  // on expose pour ton code jQuery
  window.pdfjsLib = pdfjsLib;

  console.log("pdfjsLib ready =", window.pdfjsLib);


  $(function () {
    function getPdfJs(){
      return window.pdfjsLib || null;
    }

    function waitPdfJs(timeoutMs = 3000){
      return new Promise((resolve, reject) => {
        const start = Date.now();
        (function tick(){
          const lib = getPdfJs();
          if (lib) return resolve(lib);
          if (Date.now() - start > timeoutMs) return reject(new Error("PDF.js n'est pas chargé (pdfjsLib introuvable)."));
          setTimeout(tick, 50);
        })();
      });
    }


    // ✅ INIT: tout coché au départ
    $('.dep-filter-cat').prop('checked', true);
    $('.dep-filter-four').prop('checked', true);

    // si "tout coché" doit filtrer (IN sur tout), mets some :
    window.__catMode = 'some';
    window.__fourMode = 'some';

    updateSelectedCounts();







    const $tvaOnly = $('#tvaOnly');
    const $periodType = $('#periodType');
    const $periodYear = $('#periodYear');
    const $periodQuarter = $('#periodQuarter');
    const $periodMonth = $('#periodMonth');



    function pad2(n){ return String(n).padStart(2,'0'); }

    function initPeriodSelectors(){
      const now = new Date();
      const curY = now.getFullYear();
      const curM = now.getMonth() + 1; // 1..12
      const curQ = Math.floor((curM - 1) / 3) + 1;

      // Années : de curY à curY-8 (ajuste si tu veux)
      $periodYear.empty();
      for(let y = curY; y >= curY - 8; y--){
        $periodYear.append(`<option value="${y}">${y}</option>`);
      }
      $periodYear.val(String(curY));

      // Mois
      $periodMonth.empty();
      for(let m = 1; m <= 12; m++){
        $periodMonth.append(`<option value="${m}">${pad2(m)}</option>`);
      }
      $periodMonth.val(String(curM));

      // Trimestre
      $periodQuarter.val(String(curQ));

      updatePeriodUi();
      updatePeriodLabel();
    }

    function updatePeriodUi(){
      const t = $periodType.val();
      $periodQuarter.toggle(t === 'quarter');
      $periodMonth.toggle(t === 'month');

      // année visible sauf "Tout"
      $periodYear.toggle(t !== 'all');
    }

    function updatePeriodLabel(){
      const t = $periodType.val();
      const y = $periodYear.val();
      const q = $periodQuarter.val();
      const m = $periodMonth.val();

      let label = 'Tout';
      if (t === 'year') label = `Année ${y}`;
      if (t === 'quarter') label = `T${q} ${y}`;
      if (t === 'month') label = `${pad2(m)}/${y}`;

      $('#kpi-range').text(label);
    }

    initPeriodSelectors();




    function euro(cents){
      const v = (cents || 0) / 100;
      return v.toLocaleString('fr-FR', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €';
    }
    function nowLabel(){
      const d = new Date();
      return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
    }
    function initTooltips(){
      document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => {
        bootstrap.Tooltip.getOrCreateInstance(el);
      });
    }



    function clampPct(x){
      x = Number(x || 0);
      if (!isFinite(x)) return 0;
      return Math.max(0, Math.min(100, x));
    }

    function pct(part, total){
      if (!total || total <= 0) return 0;
      return clampPct((part / total) * 100);
    }

    function setBar(id, part, total){
      const w = pct(part, total);
      $(id).css('width', w.toFixed(0) + '%');
    }

    function setKpis(k, kAll){
      const count = k?.count || 0;
      const ttc   = k?.ttcCents || 0;
      const tva   = k?.tvaCents || 0;
      const tvaDed= k?.tvaDeductibleCents || 0;

      const allCount = kAll?.count || 0;
      const allTtc   = kAll?.ttcCents || 0;
      const allTva   = kAll?.tvaCents || 0;
      const allTvaDed= kAll?.tvaDeductibleCents || 0;

      // Valeurs
      $('#kpi-count').text(count);
      $('#kpi-ttc').text(euro(ttc));
      $('#kpi-tva').text(euro(tva));
      $('#kpi-tvaDed').text(euro(tvaDed));

      // Barres = filtré / total(all)
      setBar('#kpi-bar-count', count, allCount);
      setBar('#kpi-bar-ttc',   ttc,   allTtc);
      setBar('#kpi-bar-tva',   tva,   allTva);
      setBar('#kpi-bar-tvaDed',tvaDed,allTvaDed);

      // Chip % TVA déductible sur TVA filtrée (comme avant)
      const pctDed = (tva > 0) ? (tvaDed / tva) * 100 : 0;
      $('#kpi-tvaDedPct').text(pctDed.toLocaleString('fr-FR',{maximumFractionDigits:1}) + ' %');

      $('#hero-last-refresh').text('Maj : ' + nowLabel());
    }


    async function loadDepenseKpis(){
      const url = "{{ path('app_administrateur_depense_kpis', { entite: entite.id }) }}";
      const res = await fetch(url, { headers: { 'Accept': 'application/json' }});
      if(!res.ok) return;
      const k = await res.json();

      const count = k.count || 0;
      const ttc = k.ttcCents || 0;
      const tva = k.tvaCents || 0;
      const tvaDed = k.tvaDeductibleCents || 0;
      const tvaDedPctGlobal = (k.tvaDeductiblePctGlobal ?? 0);

      $('#kpi-count').text(count);
      $('#kpi-ttc').text(euro(ttc));
      $('#kpi-tva').text(euro(tva));
      $('#kpi-tvaDed').text(euro(tvaDed));

      $('#kpi-bar-count').css('width', count ? '100%' : '0%');
      $('#kpi-bar-ttc').css('width', '100%');
      $('#kpi-bar-tva').css('width', ttc > 0 ? Math.min(100, Math.round((tva / ttc) * 100)) + '%' : '0%');
      $('#kpi-bar-tvaDed').css('width', tva > 0 ? Math.min(100, Math.round((tvaDed / tva) * 100)) + '%' : '0%');
      $('#kpi-tvaDedPct').text(tvaDedPctGlobal.toLocaleString('fr-FR', {maximumFractionDigits:1}) + ' %');

      $('#hero-last-refresh').text('Maj : ' + nowLabel());
    }


    function getCheckedValues(selector){
      return $(selector + ':checked').map(function(){ return parseInt(this.value, 10); }).get().filter(Number.isFinite);
      }

      function updateSelectedCounts(){
        const cat = getCheckedValues('.dep-filter-cat');
        const fou = getCheckedValues('.dep-filter-four');

        $('#catSelectedCount').text(cat.length ? (cat.length + ' sel.') : 'Toutes');
        $('#fourSelectedCount').text(fou.length ? (fou.length + ' sel.') : 'Tous');
    }

    function filterMode(selector){
      const total = $(selector).length;
      const checked = $(selector + ':checked').length;

      // IMPORTANT : au chargement initial tu veux "all"
      // donc on ne renvoie "none" que si l'utilisateur a explicitement vidé (voir bouton)
      return (total > 0 && checked === 0) ? 'none' : 'some';
    }



    const table = $('#tableauDepenses').DataTable({
      serverSide: true,
      processing: true,
      autoWidth: false,
      scrollX: true,
      scrollCollapse: true,
      responsive: false,

      ajax: {
        url: "{{ path('app_administrateur_depense_ajax', { entite: entite.id }) }}",
        type: "POST",
        data: function (d) {
          d.tvaOnly = $tvaOnly.val() || 'all';
          d.periodType = $periodType.val() || 'year';
          d.periodYear = parseInt($periodYear.val() || '0', 10) || null;
          d.periodQuarter = parseInt($periodQuarter.val() || '0', 10) || null;
          d.periodMonth = parseInt($periodMonth.val() || '0', 10) || null;


          const catIds  = getCheckedValues('.dep-filter-cat');
          const fourIds = getCheckedValues('.dep-filter-four');

          d.catIds = catIds;
          d.fourIds = fourIds;

          d.catMode  = window.__catMode  || 'all';   // all | some | none
          d.fourMode = window.__fourMode || 'all';   // all | some | none
        }
      },

      dom:
        '<"dt-top d-flex flex-wrap gap-2 align-items-center justify-content-between"'
          + '<"dt-actions d-flex gap-2 align-items-center"B>'
          + '<"dt-search"f>'
        + '>'
        + 'rt'
        + '<"dt-bottom-internal d-flex flex-wrap gap-2 align-items-center justify-content-between"lip>',

      buttons: [
        { extend: 'copy',  title: 'Depenses', text: 'Copier' },
        { extend: 'csv',   title: 'Depenses', text: 'CSV' },
        { extend: 'excel', title: 'Depenses', text: 'Excel' },
        { extend: 'pdf',   title: 'Depenses', text: 'PDF' },
        { extend: 'print', title: 'Depenses', text: 'Imprimer' },
      ],

      lengthMenu: [[10,25,50,100,500],[10,25,50,100,500]],

      columns: [
        { data:'id', type: 'num' },
        { data:'date' },
        { data:'libelle' },
        { data:'categorie' },
        { data:'fournisseur' },
        { data:'ttc' },
        { data:'tva' },
        { data:'tvaDed' },
        { data:'tvaPct' },
        { data:'deductible' },
        { data:'actions' }
      ],

      columnDefs: [
        { targets: 0, type: 'num', className: 'text-muted fw-semibold' },
        { targets:[5,6,7,8,10], className:'text-end' },
        { targets:9, className:'text-center', searchable:false },
        { targets:10, className:'action-column text-end', orderable:false, searchable:false },
        { targets:[5,6,7,8,9,10], searchable:false },
        { targets:[4,5,6,7,8,9,10], render: function(data){ return data; } }, // HTML OK
        { targets:10, width:'1%', className:'action-column text-end', orderable:false, searchable:false },

      ],

      order: [[1,'desc']],
      language: { url:'https://cdn.datatables.net/plug-ins/2.2.2/i18n/fr-FR.json' },
      deferRender: true,

      initComplete: function(){
        const api = this.api();
        const container = api.buttons().container();
        const $btns = $(container).find('button');

        $('#exportMenu').empty();
        $btns.each(function(){
          const $b = $(this);
          const label = $b.text().trim();
          const icon = label === 'Excel' ? 'bi-file-earmark-excel' :
                      label === 'PDF' ? 'bi-file-earmark-pdf' :
                      label === 'CSV' ? 'bi-filetype-csv' :
                      label === 'Imprimer' ? 'bi-printer' :
                      label === 'Copier' ? 'bi-clipboard' : 'bi-download';

          const $item = $(`
            <li>
              <a class="dropdown-item d-flex align-items-center gap-2" href="#">
                <i class="bi ${icon}"></i> <span>${label}</span>
              </a>
            </li>
          `);

          $item.on('click', function(e){
            e.preventDefault();
            $b.trigger('click');
          });

          $('#exportMenu').append($item);
        });

        $(container).hide();
      }
    });



    table.on('xhr.dt', function(e, settings, json){
      // json = réponse du controller (celle où on a ajouté kpis/kpisAll)
      if (!json) return;
      setKpis(json.kpis, json.kpisAll);
    });


    // ===== PREVIEW MODAL avec PDF.js ===== 
    const previewModalEl = document.getElementById('modalFacturePreview');
    const previewModal = previewModalEl ? bootstrap.Modal.getOrCreateInstance(previewModalEl) : null;
    const canvas = document.getElementById('previewCanvas');
    const ctx = canvas ? canvas.getContext('2d') : null;

    function resetPreview(){
      $('#previewLoading').show();
      $('#previewCanvasContainer').hide();
      $('#previewError').hide();
      $('#previewOpenNewTab').attr('href', '#');
      $('#previewErrorOpenBtn').attr('href', '#');
      $('#previewTitle').text('Aperçu');
      $('#previewSubtitle').text('—');
      if (ctx) {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        canvas.width = 0;
        canvas.height = 0;
      }
    }

    function showError(message, pdfUrl){
      $('#previewLoading').hide();
      $('#previewCanvasContainer').hide();
      $('#previewError').show();
      $('#previewErrorMsg').text(message);
      $('#previewErrorOpenBtn').attr('href', pdfUrl);
    }

    async function loadPdfPreview(pdfUrl, title, subtitle){
      if (!previewModal || !canvas || !ctx) return;

      resetPreview();

      $('#previewTitle').text(title || 'Aperçu justificatif');
      $('#previewSubtitle').text(subtitle || '');
      $('#previewOpenNewTab').attr('href', pdfUrl);

      previewModal.show();

      try {
        const PDFJS = getPdfJs();
        if (!PDFJS) {
          throw new Error("PDF.js non chargé (pdfjsLib introuvable).");
        }
        

        const loadingTask = PDFJS.getDocument({ url: pdfUrl });

        const pdf = await loadingTask.promise;
        const page = await pdf.getPage(1);

        const viewport0 = page.getViewport({ scale: 1 });
        const containerW = document.getElementById('previewCanvasContainer').clientWidth || (window.innerWidth - 80);
        const maxW = Math.min(1100, containerW - 30);
        const scale = maxW / viewport0.width;

        const viewport = page.getViewport({ scale });
        canvas.width = Math.floor(viewport.width);
        canvas.height = Math.floor(viewport.height);

        await page.render({ canvasContext: ctx, viewport }).promise;

        $('#previewLoading').hide();
