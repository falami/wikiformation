{# templates/administrateur/paiement/form.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}{{ title }}{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/formulaire.css') }}">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};

      --bg: #f5f7fb;
      --panel: #ffffff;
      --ink: #0f172a;
      --muted:#64748b;
      --stroke: rgba(15, 23, 42, .10);
      --shadow: 0 18px 55px rgba(15, 23, 42, .10);
      --radius: 18px;
    }
    body{ background: var(--bg); }

    /* ===== HERO sombre (comme site/index) ===== */
    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;

      /* Ombre douce premium */
      box-shadow: 0 18px 50px rgba(0,0,0,.14);

      /* Fond piloté par les couleurs de l'entité */
      background:
        /* halo clair (tertiaire) */
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        /* halo accent (secondaire) */
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        /* voile subtil (quaternaire) pour la profondeur */
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        /* dégradé principal (principal -> plus clair) */
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    /* léger glass highlight */
    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    /* barre accent = secondaire (et glow basé sur secondaire) */
    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }
    /* ===== Chips HERO (style Sessions) ===== */
    .hero .chip--hero{
      display:inline-flex;
      align-items:center;
      gap:.5rem;
      padding:.32rem .7rem;
      border-radius:999px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(255,255,255,.14);
      backdrop-filter: blur(6px);
      font-size:.825rem;
      color: rgba(255,255,255,.92);
      white-space: nowrap;
    }

    .hero .chip--hero i{
      color: var(--theme-color-secondaire);
    }

    .hero .chip--pill{
      background: color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
      border-color: color-mix(in srgb, var(--theme-color-secondaire) 28%, rgba(255,255,255,.14));
      color:#fff;
    }

    /* ===== Cards premium ===== */
    .cardx{
      background: var(--panel);
      border: 1px solid var(--stroke);
      border-radius: var(--radius);
      box-shadow: 0 10px 28px rgba(15,23,42,.08);
      overflow:hidden;
    }
    .cardx-h{
      padding: .95rem 1.05rem;
      display:flex; align-items:center; justify-content:space-between; gap:1rem;
      background: linear-gradient(180deg, rgba(0,0,0,.015), transparent);
      border-bottom: 1px solid var(--stroke);
    }
    .cardx-title{
      margin:0; font-weight:800; letter-spacing:-.01em; color: var(--ink);
      display:flex; align-items:center; gap:.6rem;
    }
    .chip{
      font-size:.78rem; padding:.25rem .55rem; border-radius:999px;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, var(--stroke));
      color: var(--muted);
      white-space:nowrap;
    }

    /* ===== Form polish ===== */
    label.form-label{ font-weight: 700; color: var(--ink); }
    .form-text, .text-muted, .small{ color: var(--muted) !important; }
    .form-control, .form-select{
      border-radius: 14px;
      border: 1px solid var(--stroke);
      padding: .65rem .85rem;
    }
    .form-control:focus, .form-select:focus{
      border-color: color-mix(in srgb, var(--theme-color-principal) 55%, var(--stroke));
      box-shadow: 0 0 0 .2rem color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
    }

    /* TomSelect premium */
    .ts-wrapper .ts-control{
      border-radius: 14px !important;
      padding: .55rem .75rem !important;
      border-color: var(--stroke) !important;
    }
    .ts-wrapper.focus .ts-control{
      box-shadow: 0 0 0 .2rem color-mix(in srgb, var(--theme-color-principal) 18%, transparent) !important;
      border-color: color-mix(in srgb, var(--theme-color-principal) 55%, var(--stroke)) !important;
    }

    /* Input € premium (sans doublon) */
    .input-euro .form-control{
      border-top-right-radius: 0 !important;
      border-bottom-right-radius: 0 !important;
    }
    .input-euro .euro-suffix{
      border-top-left-radius: 0 !important;
      border-bottom-left-radius: 0 !important;
      font-weight: 800;
      letter-spacing: .02em;
      color: var(--theme-color-principal);
      border-color: var(--stroke);
      min-width: 46px;
      justify-content: center;
      border: 1px solid var(--stroke);
    }

    /* Résumé box */
    .summary-box{
      border: 1px solid var(--stroke);
      border-radius: 18px;
      background: linear-gradient(180deg, color-mix(in srgb, var(--theme-color-principal) 8%, transparent), transparent);
      padding: 1rem;
    }

    /* Sticky actions */
    .sticky-actions{
      position: sticky; bottom: 14px; z-index: 5;
      background: color-mix(in srgb, var(--panel) 82%, transparent);
      backdrop-filter: blur(10px);
      border: 1px solid var(--stroke);
      border-radius: var(--radius);
      padding: .75rem;
      box-shadow: var(--shadow);
    }

    .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }

    @media (max-width:768px){
      .hero{ border-radius:16px; }
    }

    /* TomSelect : base neutre */
    .ts-wrapper{
      position: relative;
      z-index: 1; /* tous au même niveau */
    }

    /* Quand un TomSelect est ouvert/focus, il passe au-dessus des autres champs */
    .ts-wrapper.focus{
      z-index: 50;
    }

    /* Le dropdown doit être au-dessus du control ET des champs suivants */
    .ts-wrapper.focus .ts-dropdown{
      z-index: 51 !important;
      width: 100% !important;
      min-width: 100% !important;
      max-width: 100% !important;
      box-sizing: border-box;
    }

    /* Limite la hauteur pour éviter de recouvrir trop */
    .ts-dropdown .ts-dropdown-content{
      max-height: 240px;
      overflow-y: auto;
    }

    /* IMPORTANT : laisser visible la card (sinon dropdown coupé) */
    .cardx{ overflow: visible; }

    /* Ton hero peut rester propre */
    .hero{ overflow: hidden; }


    /* Ventilation readonly */
    .js-ventil[readonly]{
      background: color-mix(in srgb, var(--panel) 70%, #f3f4f6);
      opacity: .95;
      cursor: not-allowed;
    }
    .js-ventil[readonly]:focus{
      box-shadow: none !important;
      border-color: var(--stroke) !important;
    }


    .js-ventil[readonly]{
      pointer-events: none;
    }




  </style>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  <script src="https://npmcdn.com/flatpickr/dist/l10n/fr.js"></script>
{% endblock %}

{% block body %}

  {# ===== HERO (style Sessions) ===== #}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>

    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-credit-card me-2" style="color:var(--theme-color-secondaire)"></i>
            {{ title }}
          </h2>

          <div class="opacity-75 mt-1">
            Références + détails.
          </div>

          <div class="d-flex flex-wrap gap-2 mt-3">
            <span class="chip--hero">
              <i class="bi bi-credit-card"></i>
              Paiement
            </span>

            <span class="chip--hero">
              <i class="bi bi-building"></i>
              {{ entite.nom }}
            </span>

            <span class="chip--hero chip--pill">
              <i class="bi bi-pencil-square"></i>
              {{ title }}
            </span>
          </div>
        </div>

        <div class="d-flex flex-wrap gap-2">
          <a class="btn btn-outline-theme btn-sm fw-semibold"
            href="{{ path('app_administrateur_paiement_index', {entite: entite.id}) }}">
            <i class="bi bi-arrow-left"></i> Annuler
          </a>

          <button form="{{ form.vars.id }}" type="submit" class="btn btn-light btn-sm fw-semibold">
            <i class="bi bi-check2"></i> Enregistrer
          </button>
        </div>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  {{ form_start(form, { attr: { id: form.vars.id, novalidate:'novalidate', name:'paiement_form' } }) }}
  {{ form_errors(form) }}

  <div class="row g-4">
    {# ===== COL LEFT ===== #}
    <div class="col-lg-7">

      {# ===== Références ===== #}
      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="fa fa-link text-warning"></i> Références</h5>
          <span class="chip">Étape 1</span>
        </div>
        <div class="p-3 p-md-4">
          <div class="row g-3">
            <div class="col-md-6">{{ form_row(form.payeurUtilisateur) }}</div>
            <div class="col-md-6">{{ form_row(form.payeurEntreprise) }}</div>
            <div class="col-md-12">{{ form_row(form.facture) }}</div>
          </div>
          <div class="form-text mt-2">Tu peux lier le paiement à une inscription et/ou à une facture.</div>
        </div>
      </div>

      {# ===== Détails ===== #}
      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="fa fa-credit-card text-warning"></i> Détails du paiement</h5>
          <span class="chip">Étape 2</span>
        </div>
        <div class="p-3 p-md-4">
          <div class="row g-3">

            <div class="col-md-4">
              {{ form_label(form.montantCents) }}
              <div class="input-group input-euro">
                {{ form_widget(form.montantCents, {'attr': {'class': 'form-control text-end', 'placeholder': '0,00'}}) }}
                <span class="input-group-text euro-suffix">€</span>
              </div>
              <div id="montant-euros-hint" class="form-text"></div>
              {{ form_errors(form.montantCents) }}
            </div>

            <div class="col-md-4">{{ form_row(form.mode) }}</div>
            <div class="col-md-4">{{ form_row(form.datePaiement) }}</div>

            <div class="col-md-12">{{ form_row(form.justificatif) }}</div>
          </div>

          <div class="small text-muted mt-2">
            Le justificatif est optionnel (reçu CB, virement, chèque scanné, etc.).
          </div>
        </div>
      </div>


      {# ===== Ventilation ===== #}
      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="fa fa-chart-pie text-warning"></i> Ventilation (automatique)</h5>
          <span class="chip">Info</span>
        </div>
        <div class="p-3 p-md-4">
          <div class="row g-3">
            <div class="col-md-4">
              {{ form_label(form.ventilationHtHorsDeboursCents) }}
              <div class="input-group input-euro">
                {{ form_widget(form.ventilationHtHorsDeboursCents, {'attr': {'class':'form-control text-end js-ventil', 'readonly':'readonly'}}) }}
                <span class="input-group-text euro-suffix">€</span>
              </div>
              {{ form_errors(form.ventilationHtHorsDeboursCents) }}
            </div>

            <div class="col-md-4">
              {{ form_label(form.ventilationTvaHorsDeboursCents) }}
              <div class="input-group input-euro">
                {{ form_widget(form.ventilationTvaHorsDeboursCents, {'attr': {'class':'form-control text-end js-ventil', 'readonly':'readonly'}}) }}
                <span class="input-group-text euro-suffix">€</span>
              </div>
              {{ form_errors(form.ventilationTvaHorsDeboursCents) }}
            </div>

            <div class="col-md-4">
              {{ form_label(form.ventilationDeboursCents) }}
              <div class="input-group input-euro">
                {{ form_widget(form.ventilationDeboursCents, {'attr': {'class':'form-control text-end js-ventil', 'readonly':'readonly'}}) }}
                <span class="input-group-text euro-suffix">€</span>
              </div>
              {{ form_errors(form.ventilationDeboursCents) }}
            </div>
          </div>

          <div class="form-text mt-2">
            Ces montants sont calculés depuis la facture (si liée) et enregistrés en “snapshot”.
          </div>
        </div>
      </div>

      {# champ hidden optionnel #}
      {% if form.ventilationSource is defined %}
        {{ form_widget(form.ventilationSource) }}
      {% endif %}


      <div class="d-flex gap-2">
        <a class="btn btn-light" href="{{ path('app_administrateur_paiement_index', {entite: entite.id}) }}">Annuler</a>
        <button type="submit" class="btn btn-gradient">
          <i class="fa fa-check"></i> Enregistrer
        </button>
      </div>

    </div>

    {# ===== COL RIGHT (Résumé) ===== #}
    <div class="col-lg-5">

      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="fa fa-circle-info text-warning"></i> Résumé</h5>
          <span class="chip">Contrôle</span>
        </div>

        <div class="p-3 p-md-4">
          <div class="small text-muted mb-3">Vérifie avant d’enregistrer.</div>

          <div class="summary-box mb-3">
            <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
              <div class="fw-bold">Choix actuels</div>
              <span id="resume-valid-pill"
                    class="badge rounded-pill px-3 py-2"
                    style="border:1px solid var(--stroke); background: rgba(255,193,7,.15); color: var(--ink);">
                ⚠️ Incomplet
              </span>
            </div>

            <div class="mt-2 small">
              <div class="d-flex justify-content-between gap-3 py-1">
                <span class="text-muted">Payeur</span>
                <span class="fw-semibold text-end" id="resume-payeur">—</span>
              </div>
              <div class="d-flex justify-content-between gap-3 py-1">
                <span class="text-muted">Facture</span>
                <span class="fw-semibold text-end" id="resume-facture">—</span>
              </div>

              <hr class="my-2" style="border-color: var(--stroke);">

              <div class="d-flex justify-content-between gap-3 py-1">
                <span class="text-muted">Montant</span>
                <span class="fw-bold text-end" id="resume-montant">—</span>
              </div>
              <div class="d-flex justify-content-between gap-3 py-1">
                <span class="text-muted">Mode</span>
                <span class="fw-semibold text-end" id="resume-mode">—</span>
              </div>
              <div class="d-flex justify-content-between gap-3 py-1">
                <span class="text-muted">Date</span>
                <span class="fw-semibold text-end" id="resume-date">—</span>
              </div>
              <div class="d-flex justify-content-between gap-3 py-1">
                <span class="text-muted">Justificatif</span>
                <span class="fw-semibold text-end" id="resume-justif">—</span>
              </div>
            </div>
          </div>

          <div class="d-flex gap-2">
            <a class="btn btn-light w-50" href="{{ path('app_administrateur_paiement_index', {entite: entite.id}) }}">Annuler</a>
            <button type="submit" class="btn btn-gradient w-50">
              <i class="fa fa-check"></i> Enregistrer
            </button>
          </div>
        </div>
      </div>

      <div class="sticky-actions d-none d-lg-block">
        <div class="d-flex align-items-center justify-content-between">
          <div class="small text-muted">
            <strong class="text-dark">Astuce :</strong> si tu choisis une facture, on propose le “restant dû”.
          </div>
          <span class="badge rounded-pill"
                style="border:1px solid var(--stroke); background: rgba(255,193,7,.15); color: var(--ink);">
            Paiement
          </span>
        </div>
      </div>

    </div>
  </div>

  {{ form_end(form) }}

<script>
document.addEventListener('DOMContentLoaded', function () {

  const idFacture     = '{{ form.facture.vars.id|e('js') }}';
  const idMode        = '{{ form.mode.vars.id|e('js') }}';
  const idMontant     = '{{ form.montantCents.vars.id|e('js') }}';
  const idDate        = '{{ form.datePaiement.vars.id|e('js') }}';
  const idJustif      = '{{ form.justificatif.vars.id|e('js') }}';
  const idPayUser     = '{{ form.payeurUtilisateur.vars.id|e('js') }}';
  const idPayEnt      = '{{ form.payeurEntreprise.vars.id|e('js') }}';

  const $facture = document.getElementById(idFacture);
  const $mode    = document.getElementById(idMode);
  const $montant = document.getElementById(idMontant);
  const $date    = document.getElementById(idDate);
  const $justif  = document.getElementById(idJustif);
  const $payUser = document.getElementById(idPayUser);
  const $payEnt  = document.getElementById(idPayEnt);
  const $hint    = document.getElementById('montant-euros-hint');

  const form = document.querySelector('form[name="paiement_form"]');
  const submitButtons = form ? [...form.querySelectorAll('button[type="submit"]')] : [];

  const $r = {
    payeur: document.getElementById('resume-payeur'),
    facture: document.getElementById('resume-facture'),
    montant: document.getElementById('resume-montant'),
    mode: document.getElementById('resume-mode'),
    date: document.getElementById('resume-date'),
    justif: document.getElementById('resume-justif'),
    pill: document.getElementById('resume-valid-pill'),
  };

  function selectedText(selectEl){
    if (!selectEl || !selectEl.value) return '';
    const opt = selectEl.selectedOptions && selectEl.selectedOptions[0];
    return (opt ? opt.textContent : '').trim();
  }

  // TomSelect
  [idFacture, idMode, idPayUser, idPayEnt].forEach(id => {
    const el = document.getElementById(id);
    if (el && !el.tomselect) {
      new TomSelect(el, {
        create: false,
        allowEmptyOption: true,
        plugins: ['remove_button'],
        onChange: () => { handleFactureChange(); refreshResume(); }
      });
    }
  });

  // Flatpickr
  if (window.flatpickr?.l10ns?.fr) flatpickr.localize(flatpickr.l10ns.fr);
  document.querySelectorAll('.flatpickr-datetime').forEach(el=>{
    if (!el._fp) flatpickr(el, { enableTime:false, time_24hr:true, dateFormat:'d/m/Y', allowInput:true });
  });

  $montant?.addEventListener('input', () => { updateHintFromInput(); refreshResume(); });
  $date?.addEventListener('input', refreshResume);
  $date?.addEventListener('change', refreshResume);
  $justif?.addEventListener('change', refreshResume);

  function handleFactureChange(){
    if (!$facture || !$montant) return;

    const v = ($facture.value || '').trim();
    if (!v) return;

    // ✅ Si montant déjà renseigné (édition), on ne touche pas
    const current = normalizeToNumber($montant.value || '');
    if (!isNaN(current) && current > 0) {
      return;
    }

    const opt = $facture.querySelector(`option[value="${CSS.escape(v)}"]`);
    if (!opt) return;

    const restant = parseInt(opt.dataset.restantCents ?? '0', 10);
    const ttc     = parseInt(opt.dataset.ttcCents ?? '0', 10);
    const cents   = (Number.isFinite(restant) && restant > 0) ? restant : ttc;
    if (!cents) return;

    $montant.value = formatForInputEuros(cents / 100);
    $montant.dispatchEvent(new Event('input', { bubbles: true }));

    // ✅ On vide la ventilation seulement si on vient d'appliquer un nouveau montant
    setVentilEmpty();
  }



  function setVentilEmpty(){
    const ht  = document.getElementById('{{ form.ventilationHtHorsDeboursCents.vars.id|e('js') }}');
    const tva = document.getElementById('{{ form.ventilationTvaHorsDeboursCents.vars.id|e('js') }}');
    const deb = document.getElementById('{{ form.ventilationDeboursCents.vars.id|e('js') }}');
    [ht,tva,deb].forEach(el=>{
      if(!el) return;
      el.value = '';
      el.dispatchEvent(new Event('input', {bubbles:true}));
    });
  }


  function formatForInputEuros(nb){
    return (Math.round(nb * 100) / 100).toFixed(2).replace('.', ',');
  }


  function updateHintFromInput(){
    if (!$montant || !$hint) return;
    const euros = normalizeToNumber($montant.value);
    if (isNaN(euros)) { $hint.textContent = ''; return; }
    $hint.textContent = `Soit ${formatEuros(euros)} €`;
  }

  function refreshResume(){
    const payUserTxt = selectedText($payUser);
    const payEntTxt  = selectedText($payEnt);
    const payTxt = payEntTxt || payUserTxt;

    if ($r.payeur) $r.payeur.textContent = payTxt || '—';
    if ($r.facture) $r.facture.textContent = selectedText($facture) || '—';
    if ($r.mode) $r.mode.textContent = selectedText($mode) || '—';

    const euros = normalizeToNumber($montant?.value || '');
    if ($r.montant) $r.montant.textContent = (!isNaN(euros) && euros > 0) ? formatMoney(euros) : '—';
    if ($r.date) $r.date.textContent = ($date?.value || '').trim() || '—';

    const hasJustif = ($justif?.files && $justif.files.length > 0) || (($justif?.value || '').trim().length > 0);
    if ($r.justif) $r.justif.textContent = hasJustif ? '✅ Ajouté' : '—';

    // ✅ règles : (facture OU payeur) + montant + mode + date
    const linkOk = !!(($facture?.value || '').trim() || ($payUser?.value || '').trim() || ($payEnt?.value || '').trim());
    const montantOk= !isNaN(euros) && euros > 0;
    const modeOk   = !!(($mode?.value || '').trim());
    const dateOk   = !!(($date?.value || '').trim());
    const ok = linkOk && montantOk && modeOk && dateOk;

    submitButtons.forEach(b => b.disabled = !ok);

    if ($r.pill) {
      if (ok) {
        $r.pill.textContent = '✅ Complet';
        $r.pill.style.background = 'rgba(25,135,84,.15)';
        $r.pill.style.borderColor = 'rgba(25,135,84,.35)';
      } else {
        $r.pill.textContent = '⚠️ Incomplet';
        $r.pill.style.background = 'rgba(255,193,7,.15)';
        $r.pill.style.borderColor = 'rgba(255,193,7,.35)';
      }
      $r.pill.style.color = 'var(--ink)';
    }
  }

  function normalizeToNumber(str){
    if (!str) return NaN;
    const s = (''+str).replace(/\s+/g,'').replace(/\u00A0/g,'').replace(',', '.');
    const n = Number(s);
    return isNaN(n) ? NaN : n;
  }

  function formatEuros(nb){
    try { return new Intl.NumberFormat('fr-FR', { minimumFractionDigits:2, maximumFractionDigits:2 }).format(nb); }
    catch(e){ return (Math.round(nb*100)/100).toFixed(2).replace('.', ','); }
  }

  function formatMoney(nb){
    try { return new Intl.NumberFormat('fr-FR', { style:'currency', currency:'EUR' }).format(nb); }
    catch(e){ return formatEuros(nb) + ' €'; }
  }

  // init
  handleFactureChange();
  updateHintFromInput();
  refreshResume();
});


// Validation légère (inchangée)
function initFormValidation({ formName }){
  const form = document.querySelector(`form[name="${formName}"]`);
  if (!form) return;

  let errorAlert = document.getElementById('form-error-alert');
  if (!errorAlert) {
    errorAlert = document.createElement('div');
    errorAlert.className = 'alert alert-danger d-none';
    errorAlert.id = 'form-error-alert';
    form.appendChild(errorAlert);
  }

  form.addEventListener('submit', e=>{
    const messages = new Set();
    let first = null;

    form.querySelectorAll(':invalid').forEach(el=>{
      el.classList.add('is-invalid'); if(!first) first = el;
      const l = form.querySelector(`label[for="${el.id}"]`);
      if (l) messages.add(`- ${l.textContent.trim()}`);
    });

    if (messages.size) {
      e.preventDefault();
      errorAlert.innerHTML = `<strong>Champs requis manquants :</strong><br>${[...messages].join('<br>')}`;
      errorAlert.classList.remove('d-none');
      if (first?.scrollIntoView) first.scrollIntoView({behavior:'smooth', block:'center'});
      setTimeout(()=>errorAlert.classList.add('d-none'), 6000);
    }
  });
}
</script>
{% endblock %}
