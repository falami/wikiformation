{% extends 'base_admin.html.twig' %}
{% block title %}Paiement en ligne — Stripe{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }

    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;
      box-shadow: 0 18px 50px rgba(0,0,0,.14);
      background:
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }
    .hero::after{
      content:""; position:absolute; inset:0; pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }
    .hero .accent{
      width: 12px; border-radius: 999px; background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }

    .card-premium{
      border-radius: 18px;
      border: 1px solid rgba(0,0,0,.06);
      box-shadow: 0 12px 30px rgba(0,0,0,.06);
      overflow:hidden;
      background:#fff;
    }
    .status-pill{
      border-radius:999px;
      padding:.35rem .7rem;
      font-weight:800;
      letter-spacing:.02em;
      border:1px solid rgba(0,0,0,.08);
      background: rgba(0,0,0,.03);
    }
    .status-pill.ok{ background: rgba(25,135,84,.12); border-color: rgba(25,135,84,.25); color:#146c43; }
    .status-pill.ko{ background: rgba(220,53,69,.10); border-color: rgba(220,53,69,.20); color:#b02a37; }

    .btn-premium{
      border-radius:14px;
      font-weight:800;
      box-shadow: 0 14px 28px rgba(0,0,0,.10);
    }
    .btn-premium:hover{ box-shadow: 0 18px 40px rgba(0,0,0,.14); }
  </style>
{% endblock %}

{% block body %}

  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>
    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-stripe me-2" style="color:var(--theme-color-secondaire)"></i>
            Stripe Connect
          </h2>
          <div class="opacity-75 mt-1">Connecte l’Entité à Stripe pour encaisser les factures en ligne.</div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
          <a class="btn btn-light btn-sm fw-semibold"
             href="{{ path('app_admin_billing_connect_refresh', {entite: entite.id}) }}">
            <i class="bi bi-arrow-repeat me-1"></i> Rafraîchir
          </a>

          <form method="post" action="{{ path('app_admin_billing_connect_start', {entite: entite.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('connect_start') }}">
            <button class="btn btn-warning btn-sm btn-premium" type="submit">
              <i class="bi bi-link-45deg me-1"></i> Démarrer / Reprendre l’onboarding
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  <div class="row g-3">
    <div class="col-12 col-lg-6">
      <div class="card-premium p-3">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
          <div class="fw-bold">Statut du compte</div>
          <div class="d-flex gap-2 flex-wrap">
            <span class="status-pill {{ connect.detailsSubmitted ? 'ok' : 'ko' }}">
              Détails {{ connect.detailsSubmitted ? 'OK' : 'KO' }}
            </span>
            <span class="status-pill {{ connect.chargesEnabled ? 'ok' : 'ko' }}">
              Charges {{ connect.chargesEnabled ? 'OK' : 'KO' }}
            </span>
            <span class="status-pill {{ connect.payoutsEnabled ? 'ok' : 'ko' }}">
              Payouts {{ connect.payoutsEnabled ? 'OK' : 'KO' }}
            </span>
          </div>
        </div>

        <hr>

        <div class="small text-muted">Stripe Account Id</div>
        <div class="fw-semibold">{{ connect.stripeAccountId ?? '—' }}</div>

        <div class="mt-3 alert {{ connect.isReadyForCheckout ? 'alert-success' : 'alert-warning' }} mb-0">
          {% if connect.isReadyForCheckout %}
            <i class="bi bi-check-circle me-1"></i>
            Compte prêt : tu peux encaisser des factures en ligne.
          {% else %}
            <i class="bi bi-exclamation-triangle me-1"></i>
            Compte non prêt : termine l’onboarding Stripe.
          {% endif %}
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-6">
      <div class="card-premium p-3">
        <div class="fw-bold mb-2">Paramètres de paiement en ligne</div>

        {# Si tu veux : brancher le EntiteConnectType ici #}
        <div class="text-muted small">
          (Ici tu peux ajouter un formulaire Symfony EntiteConnectType pour activer/désactiver le paiement en ligne
          et configurer les frais de service.)
        </div>

        <div class="mt-3">
          <div class="d-flex align-items-center justify-content-between">
            <div>
              <div class="fw-semibold">Paiement en ligne</div>
              <div class="text-muted small">Stripe Checkout</div>
            </div>
            <span class="status-pill {{ connect.onlinePaymentEnabled ? 'ok' : 'ko' }}">
              {{ connect.onlinePaymentEnabled ? 'ACTIF' : 'OFF' }}
            </span>
          </div>

          <div class="mt-3 p-3 rounded-3" style="background: rgba(0,0,0,.03); border:1px solid rgba(0,0,0,.06);">
            <div class="fw-semibold">Frais de service répercutés</div>
            <div class="text-muted small">
              Fixe : {{ (connect.feeFixedCents/100)|number_format(2, ',', ' ') }} €
              — Pourcentage : {{ (connect.feePercentBp/100)|number_format(2, ',', ' ') }} %
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

{% endblock %}