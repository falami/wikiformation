{# templates/administrateur/attestation/_actions.html.twig #}

<div class="btn-group btn-group-sm attestation-actions" role="group">

  {# ✅ Bouton principal = Éditer #}
  <a class="btn btn-light attestation-main"
     data-bs-toggle="tooltip" title="Éditer"
     href="{{ path('app_administrateur_attestation_edit', { entite: entite.id, id: a.id }) }}">
    <i class="bi bi-pencil"></i>
  </a>

  {# ✅ Split dropdown #}
  <button type="button"
          class="btn btn-light dropdown-toggle dropdown-toggle-split attestation-split"
          data-bs-toggle="dropdown" aria-expanded="false">
    <span class="visually-hidden">Actions</span>
  </button>

  <ul class="dropdown-menu dropdown-menu-end attestation-menu">

    {# PDF (si tu as une route PDF) #}
    {# adapte le nom de route si besoin #}
    <li>
      <a class="dropdown-item d-flex align-items-center"
         href="{{ path('app_administrateur_attestation_pdf', { entite: entite.id, id: a.id }) }}">
        <i class="bi bi-file-earmark-pdf me-2"></i> Télécharger PDF
      </a>
    </li>

    <li><hr class="dropdown-divider"></li>

    {# Supprimer (ouvre la modale) #}
    <li>
      <button type="button"
              class="dropdown-item d-flex align-items-center text-danger delete-btn"
              data-bs-toggle="modal" data-bs-target="#deleteModal"
              data-url="{{ path('app_administrateur_attestation_delete', { entite: entite.id, id: a.id }) }}"
              data-token="{{ csrf_token('del_attestation_' ~ a.id) }}">
        <i class="bi bi-trash me-2"></i> Supprimer
      </button>
    </li>

  </ul>
</div>
