{% extends 'base_admin.html.twig' %}
{% block title %}{{ title }}{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/formulaire.css') }}">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};

      --bg:#f5f7fb;
      --panel:#fff;
      --ink:#0f172a;
      --muted:#64748b;
      --stroke: rgba(15, 23, 42, .10);
      --shadow: 0 18px 55px rgba(15, 23, 42, .10);
      --radius:18px;
    }

    body{ background: var(--bg); }

    /* HERO sombre */
    .hero{
      border-radius:22px;
      background:
        radial-gradient(1200px 400px at 15% 0%, rgba(255,255,255,.12), transparent 60%),
        radial-gradient(900px 350px at 85% 10%, rgba(255,193,7,.18), transparent 55%),
        linear-gradient(135deg, rgba(35,51,66,.98), rgba(35,51,66,.78));
      color:#fff;
      box-shadow:0 18px 50px rgba(0,0,0,.14);
      overflow:hidden;
      position:relative;
    }
    .hero .accent{
      width:12px;
      background:var(--theme-color-secondaire);
      border-radius:999px;
      box-shadow:0 0 0 6px rgba(255,193,7,.10);
    }
    .meta-chip{
      display:inline-flex; align-items:center; gap:.45rem;
      padding:.35rem .65rem; border-radius:999px;
      background:rgba(255,255,255,.12);
      border:1px solid rgba(255,255,255,.14);
      font-size:.82rem;
      white-space: nowrap;
    }
    .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }

    /* Cards premium */
    .cardx{
      background: var(--panel);
      border: 1px solid var(--stroke);
      border-radius: var(--radius);
      box-shadow: 0 10px 28px rgba(15,23,42,.08);
      overflow: visible !important;
    }
    .cardx-h{
      padding: .95rem 1.05rem;
      display:flex; align-items:center; justify-content:space-between; gap:1rem;
      background: linear-gradient(180deg, rgba(0,0,0,.015), transparent);
      border-bottom: 1px solid var(--stroke);
    }
    .cardx-title{
      margin:0; font-weight:800; letter-spacing:-.01em; color: var(--ink);
      display:flex; align-items:center; gap:.6rem;
    }
    .chip{
      font-size:.78rem; padding:.25rem .55rem; border-radius:999px;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, var(--stroke));
      color: var(--muted);
      white-space:nowrap;
    }

    /* Form polish */
    label.form-label{ font-weight: 700; color: var(--ink); }
    .form-text, .text-muted, .small{ color: var(--muted) !important; }
    .form-control, .form-select{
      border-radius: 14px;
      border: 1px solid var(--stroke);
      padding: .65rem .85rem;
    }
    .form-control:focus, .form-select:focus{
      border-color: color-mix(in srgb, var(--theme-color-principal) 55%, var(--stroke));
      box-shadow: 0 0 0 .2rem color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
    }

    /* TomSelect premium */
    .ts-wrapper .ts-control{
      border-radius: 14px !important;
      padding: .55rem .75rem !important;
      border-color: var(--stroke) !important;
    }
    .ts-wrapper.focus .ts-control{
      box-shadow: 0 0 0 .2rem color-mix(in srgb, var(--theme-color-principal) 18%, transparent) !important;
      border-color: color-mix(in srgb, var(--theme-color-principal) 55%, var(--stroke)) !important;
    }

    /* Résumé */
    .summary-box{
      border: 1px solid var(--stroke);
      border-radius: 18px;
      background: linear-gradient(180deg, color-mix(in srgb, var(--theme-color-principal) 8%, transparent), transparent);
      padding: 1rem;
    }

    @media (max-width:768px){
      .hero{ border-radius:16px; }
    }
  </style>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  <script src="https://npmcdn.com/flatpickr/dist/l10n/fr.js"></script>
{% endblock %}

{% block body %}

  {# ===== HERO ===== #}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>
    <div class="flex-grow-1">
      <div class="d-flex flex-wrap gap-2 mb-2">
        <span class="meta-chip"><i class="bi bi-patch-check"></i> Attestation</span>
        <span class="meta-chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
        <span class="meta-chip"><i class="bi bi-pencil-square"></i> {{ title }}</span>
      </div>

      <div class="d-flex flex-wrap align-items-end gap-2">
        <div class="me-auto">
          <h2 class="fw-bold mb-1">{{ title }}</h2>
          <div class="opacity-75">Inscription, date de délivrance, durée et résultat — contrôle en temps réel.</div>
        </div>

        <div class="d-flex gap-2">
          <a class="btn btn-outline-theme btn-sm fw-semibold"
             href="{{ path('app_administrateur_attestation_index', {entite: entite.id}) }}">
            <i class="bi bi-arrow-left"></i> Annuler
          </a>

          <button form="{{ form.vars.id }}" type="submit" class="btn btn-light btn-sm fw-semibold" id="heroSubmitBtn">
            <i class="bi bi-check2"></i> Enregistrer
          </button>
        </div>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  {{ form_start(form, { attr: { id: form.vars.id, novalidate:'novalidate', name:'attestation_form' } }) }}
  {{ form_errors(form) }}

  <div class="row g-4">

    {# ===== LEFT ===== #}
    <div class="col-lg-7">

      {# ===== Références ===== #}
      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="fa fa-link text-warning"></i> Références</h5>
          <span class="chip">Étape 1</span>
        </div>

        <div class="p-3 p-md-4">
          <div class="row g-3">
            <div class="col-md-8">{{ form_row(form.inscription) }}</div>
            <div class="col-md-4">{{ form_row(form.dateDelivrance) }}</div>
          </div>
          <div class="form-text mt-2">
            L’attestation est rattachée à une inscription et possède un numéro unique.
          </div>
        </div>
      </div>

      {# ===== Détails ===== #}
      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="fa fa-file-circle-check text-warning"></i> Détails</h5>
          <span class="chip">Étape 2</span>
        </div>

        <div class="p-3 p-md-4">
          <div class="row g-3 align-items-end">
            <div class="col-md-3">{{ form_row(form.dureeHeures) }}</div>
            <div class="col-md-3 d-flex align-items-center gap-2">
              {{ form_row(form.reussi) }}
            </div>
          </div>
        </div>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary" id="bottomSubmitBtn">
          <i class="fa fa-check"></i> Enregistrer
        </button>
        <a class="btn btn-light" href="{{ path('app_administrateur_attestation_index', {entite: entite.id}) }}">Annuler</a>
      </div>

    </div>

    {# ===== RIGHT (Résumé + validation live) ===== #}
    <div class="col-lg-5">
      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="fa fa-circle-info text-warning"></i> Résumé</h5>
          <span class="chip">Contrôle</span>
        </div>

        <div class="p-3 p-md-4">
          <div class="small text-muted mb-3">Vérifie avant d’enregistrer.</div>

          <div class="summary-box mb-3">
            <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
              <div class="fw-bold">État</div>
              <span id="resume-valid-pill"
                    class="badge rounded-pill px-3 py-2"
                    style="border:1px solid var(--stroke); background: rgba(255,193,7,.15); color: var(--ink);">
                ⚠️ Incomplet
              </span>
            </div>

            <div class="mt-2 small">
              <div class="d-flex justify-content-between gap-3 py-1">
                <span class="text-muted">Inscription</span>
                <span class="fw-semibold text-end" id="resume-inscription">—</span>
              </div>
              <div class="d-flex justify-content-between gap-3 py-1">
                <span class="text-muted">Date délivrance</span>
                <span class="fw-semibold text-end" id="resume-date">—</span>
              </div>
              <div class="d-flex justify-content-between gap-3 py-1">
                <span class="text-muted">Durée</span>
                <span class="fw-semibold text-end" id="resume-duree">—</span>
              </div>
              <div class="d-flex justify-content-between gap-3 py-1">
                <span class="text-muted">Résultat</span>
                <span class="fw-semibold text-end" id="resume-reussi">—</span>
              </div>
            </div>
          </div>

          <div class="d-flex gap-2">
            <a class="btn btn-light w-50" href="{{ path('app_administrateur_attestation_index', {entite: entite.id}) }}">Annuler</a>
            <button type="submit" class="btn btn-primary w-50" id="sideSubmitBtn">
              <i class="fa fa-check"></i> Enregistrer
            </button>
          </div>
        </div>
      </div>
    </div>

  </div>

  {{ form_end(form) }}

<script>
document.addEventListener('DOMContentLoaded', function () {

  const form = document.querySelector('form[name="attestation_form"]');
  const submitBtns = [
    document.getElementById('heroSubmitBtn'),
    document.getElementById('bottomSubmitBtn'),
    document.getElementById('sideSubmitBtn')
  ].filter(Boolean);

  const inscId  = '{{ form.inscription.vars.id|e('js') }}';
  const dateId  = '{{ form.dateDelivrance.vars.id|e('js') }}';
  const dureeId = '{{ form.dureeHeures.vars.id|e('js') }}';
  const reussiId = '{{ form.reussi.vars.id|e('js') }}';

  const $insc  = document.getElementById(inscId);
  const $date  = document.getElementById(dateId);
  const $duree = document.getElementById(dureeId);
  const $reussi = document.getElementById(reussiId);

  const $resume = {
    pill: document.getElementById('resume-valid-pill'),
    inscription: document.getElementById('resume-inscription'),
    date: document.getElementById('resume-date'),
    duree: document.getElementById('resume-duree'),
    reussi: document.getElementById('resume-reussi'),
  };

  // TomSelect inscription
  if ($insc && !$insc.tomselect) {
    new TomSelect($insc, {
      create: false,
      allowEmptyOption: true,
      sortField: { field: 'text', direction: 'asc' },
      plugins: ['remove_button']
    });
  }

  // Flatpickr FR date
  if (window.flatpickr?.l10ns?.fr) flatpickr.localize(flatpickr.l10ns.fr);
  if ($date && !$date._fp) {
    flatpickr($date, { dateFormat:'d/m/Y', allowInput:true });
  }

  // Auto-remplissage durée selon data-heures
  function applyHeuresFromSelected(){
    if (!$insc || !$duree) return;
    const v = $insc.value;
    if (!v) return;
    const opt = $insc.querySelector(`option[value="${CSS.escape(v)}"]`);
    if (!opt) return;

    const heures = parseInt(opt.dataset.heures ?? '0', 10);
    if (Number.isFinite(heures) && heures > 0) $duree.value = heures;
  }

  // Résumé live + validation
  function getSelectedText(selectEl){
    if (!selectEl || !selectEl.value) return '';
    const opt = selectEl.selectedOptions && selectEl.selectedOptions[0];
    return (opt ? opt.textContent : '').trim();
  }

  function refreshResume(){
    const inscText = getSelectedText($insc);
    const dateText = ($date?.value || '').trim();
    const dureeVal = ($duree?.value || '').toString().trim();
    const reussiVal = $reussi
      ? ((($reussi.type === 'checkbox') ? $reussi.checked : !!$reussi.value) ? 'Réussi' : 'Non réussi')
      : '—';

    if ($resume.inscription) $resume.inscription.textContent = inscText || '—';
    if ($resume.date) $resume.date.textContent = dateText || '—';
    if ($resume.duree) $resume.duree.textContent = dureeVal ? `${dureeVal} h` : '—';
    if ($resume.reussi) $resume.reussi.textContent = reussiVal;

    const okInsc = !!($insc?.value && $insc.value.trim());
    const okDate = !!dateText;
    const okDuree = !!(dureeVal && parseFloat(dureeVal.replace(',', '.')) > 0);

    const okNative = form ? form.checkValidity() : true;
    const ok = okInsc && okDate && okDuree && okNative;

    submitBtns.forEach(b => b.disabled = !ok);

    if ($resume.pill) {
      if (ok) {
        $resume.pill.textContent = '✅ Complet';
        $resume.pill.style.background = 'rgba(25,135,84,.15)';
        $resume.pill.style.borderColor = 'rgba(25,135,84,.35)';
      } else {
        $resume.pill.textContent = '⚠️ Incomplet';
        $resume.pill.style.background = 'rgba(255,193,7,.15)';
        $resume.pill.style.borderColor = 'rgba(255,193,7,.35)';
      }
      $resume.pill.style.color = 'var(--ink)';
    }
  }

  // events
  const bindRefresh = (el) => {
    if (!el) return;
    el.addEventListener('change', refreshResume);
    el.addEventListener('input', refreshResume);
  };

  if ($insc?.tomselect) $insc.tomselect.on('change', () => { applyHeuresFromSelected(); refreshResume(); });
  else bindRefresh($insc);

  bindRefresh($date);
  bindRefresh($duree);
  bindRefresh($reussi);

  // init
  applyHeuresFromSelected();
  refreshResume();

  // Validation légère (ton code)
  initFormValidation({ formName: 'attestation_form' });
});

function initFormValidation({ formName }){
  const form = document.querySelector(`form[name="${formName}"]`);
  if (!form) return;

  let errorAlert = document.getElementById('form-error-alert');
  if (!errorAlert) {
    errorAlert = document.createElement('div');
    errorAlert.className = 'alert alert-danger d-none';
    errorAlert.id = 'form-error-alert';
    form.appendChild(errorAlert);
  }

  form.addEventListener('submit', e=>{
    const messages = new Set();

    form.querySelectorAll(':invalid').forEach(el=>{
      el.classList.add('is-invalid');
      const l = form.querySelector(`label[for="${el.id}"]`);
      if (l) messages.add(`- ${l.textContent.trim()}`);
    });

    if (messages.size) {
      e.preventDefault();
      errorAlert.innerHTML = `<strong>Champs requis manquants :</strong><br>${[...messages].join('<br>')}`;
      errorAlert.classList.remove('d-none');
      errorAlert.scrollIntoView?.({behavior:'smooth', block:'start'});
      setTimeout(()=>errorAlert.classList.add('d-none'), 6000);
    }
  });
}
</script>
{% endblock %}
