{# templates/administrateur/attestation/index.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}Attestations{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
      --ink:#0f2336; --muted:#6f8897;
    }


    /* HERO (comme Sessions) */
    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;

      /* Ombre douce premium */
      box-shadow: 0 18px 50px rgba(0,0,0,.14);

      /* Fond piloté par les couleurs de l'entité */
      background:
        /* halo clair (tertiaire) */
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        /* halo accent (secondaire) */
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        /* voile subtil (quaternaire) pour la profondeur */
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        /* dégradé principal (principal -> plus clair) */
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    /* léger glass highlight */
    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    /* barre accent = secondaire (et glow basé sur secondaire) */
    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }
    /* ✅ Chips HERO (comme Sessions) */
    .hero .chip{
      display:inline-flex;
      align-items:center;
      gap:.5rem;
      padding:.32rem .7rem;
      border-radius: 999px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(255,255,255,.14);
      font-size:.82rem;
      color: rgba(255,255,255,.92);
      backdrop-filter: blur(6px);
      white-space: nowrap;
    }
    .hero .chip i{
      color: var(--theme-color-secondaire);
    }
    .hero .chip--pill{
      background: color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
      border-color: color-mix(in srgb, var(--theme-color-secondaire) 28%, rgba(255,255,255,.14));
      color:#fff;
    }

    /* ✅ Boutons HERO (comme Sessions) */
    .hero .btn{
      border-radius: 14px;
      font-weight: 800;
    }
    .hero .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .hero .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }

    /* TOOLBAR (nouvelle version) — Export dropdown comme Sessions */
    .filterbar{
      background:#fff;
      border-radius:18px;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 10px 24px rgba(0,0,0,.05);
      overflow-x: clip;
      overflow-y: visible;
    }
    .filterbar__top{
      padding: .9rem 1rem;
      border-bottom:1px solid rgba(0,0,0,.06);
      background: linear-gradient(180deg, rgba(0,0,0,.015), transparent);
      display:flex;
      align-items:center;
      gap:.75rem;
    }
    .filterbar__title{ font-weight:800; margin:0; font-size:1rem; }
    .filterbar__hint{ color: rgba(0,0,0,.55); font-size:.85rem; margin-left:.25rem; }
    .kpi-ico{
      width:44px; height:44px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }

    .filter-icon{
      width:38px; height:38px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }

    /* DATATABLE CARD */
    .table-card{
      background:#fff;
      border-radius:18px;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 12px 30px rgba(0,0,0,.06);
      overflow:hidden;
    }
    table.dataTable{ margin:0 !important; }
    table.dataTable thead th{
      background:#f7f8fa!important;
      border-bottom:1px solid rgba(0,0,0,.08)!important;
      font-size:.78rem;
      text-transform:uppercase;
      letter-spacing:.05em;
      color: rgba(0,0,0,.55);
      white-space: nowrap;
      text-align:center;
    }

    .dt-top{
      padding:.75rem .85rem;
      border-bottom:1px solid rgba(0,0,0,.06);
      background:#fff;
    }
    .dt-bottom-internal{
      padding:1rem .85rem!important;
      border-top:1px solid rgba(0,0,0,.06);
      background:#fff;
      margin-top:.75rem!important;
    }

    /* center TD */
    #tableauAttestations td{ text-align:center; vertical-align:middle; }

    /* Mobile sticky actions */
    @media (max-width: 768px){
      td.action-column{
        position: sticky;
        right:0;
        background:#fff;
        z-index:5;
        box-shadow:-12px 0 18px -14px rgba(0,0,0,.22);
      }
      .hero{ border-radius:16px; }
    }



    /* =========================
      ✅ Actions Attestations (copie du design Devis)
      ========================= */

    /* largeur mini colonne actions */
    #tableauAttestations th:last-child,
    #tableauAttestations td:last-child{
      width: 1% !important;
      min-width: 0 !important;
      white-space: nowrap;
    }

    /* boutons compacts */
    .attestation-actions .btn{
      padding: .32rem .55rem;
    }

    /* bouton principal */
    .attestation-actions .attestation-main{
      background: rgba(255,255,255,.85);
      border-color: rgba(0,0,0,.12);
      box-shadow: 0 10px 22px rgba(0,0,0,.06);
    }
    .attestation-actions .attestation-main:hover{
      box-shadow: 0 14px 28px rgba(0,0,0,.10);
      border-color: rgba(0,0,0,.18);
    }

    /* split */
    .attestation-actions .attestation-split{
      padding-left: .55rem;
      padding-right: .55rem;
      border-color: rgba(0,0,0,.12);
      background: rgba(255,255,255,.85);
    }

    /* menu dropdown */
    .attestation-actions .attestation-menu{
      border-radius: 16px;
      border: 1px solid rgba(0,0,0,.10);
      box-shadow: 0 18px 46px rgba(0,0,0,.18);
      padding: .55rem;
      background:
        radial-gradient(900px 220px at 10% 0%, rgba(255,193,7,.10), transparent 55%),
        #fff;
      overflow: hidden;
    }
    .attestation-actions .attestation-menu .dropdown-item{
      border-radius: 12px;
      padding: .50rem .60rem;
      margin: .10rem 0;
      border: 1px solid transparent;
    }
    .attestation-actions .attestation-menu .dropdown-item:hover{
      background: rgba(255,193,7,.10);
      border-color: rgba(255,193,7,.22);
    }

    /* fusion pill (main + split) */
    .attestation-actions.btn-group .attestation-main{
      border-top-right-radius: 0 !important;
      border-bottom-right-radius: 0 !important;
    }
    .attestation-actions.btn-group .attestation-split{
      border-top-left-radius: 0 !important;
      border-bottom-left-radius: 0 !important;
      margin-left: -1px;
      position: relative;
    }
    .attestation-actions.btn-group .attestation-split:before{
      content:"";
      position:absolute;
      left:0;
      top:20%;
      bottom:20%;
      width:1px;
      background: rgba(0,0,0,.10);
    }

    /* ne jamais masquer quand dropdown ouvert */
    #tableauAttestations td.action-column .attestation-actions{
      opacity: 1 !important;
      visibility: visible !important;
    }
    #tableauAttestations td.action-column .attestation-actions:focus-within{
      opacity: 1 !important;
      visibility: visible !important;
    }

    /* alignement colonne */
    #tableauAttestations td.action-column{
      padding-left: 0 !important;
      padding-right: .15rem !important;
      text-align: right;
    }

    /* ✅ menu au-dessus (si DataTables clip) */
    body .attestation-floating-dropdown{
      z-index: 20000 !important;
    }

  </style>

  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/style-table.css') }}">

  {# ✅ DataTables + Buttons (comme Sessions) #}
  <link rel="stylesheet" href="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.css"/>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

  {# Buttons deps #}
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

  {# ✅ DataTables + Buttons #}
  <script src="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.js"></script>
{% endblock %}

{% block body %}

  {# ✅ HERO (même structure que Sessions) #}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>

    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-patch-check me-2" style="color:var(--theme-color-secondaire)"></i>
            Attestations
          </h2>
          <div class="opacity-75 mt-1">Création, édition, PDF et suppression.</div>

          <div class="d-flex flex-wrap gap-2 mt-3">
            <span class="chip"><i class="bi bi-patch-check"></i> Attestation</span>
            <span class="chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
            <span class="chip chip--pill"><i class="bi bi-clock-history"></i> <span id="hero-last-refresh">—</span></span>
          </div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
          <a class="btn btn-light btn-sm fw-semibold"
            href="{{ path('app_administrateur_attestation_new', {'entite': entite.id}) }}">
            <i class="bi bi-file-earmark-plus me-1"></i> Nouvelle attestation
          </a>
        </div>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  {# TOOLBAR (nouvelle version) — Export dropdown comme Sessions #}
  <div class="filterbar mb-3">
    <div class="filterbar__top">
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <div class="filter-icon"><i class="bi bi-sliders"></i></div>
        <div>
          <div class="filterbar__title">Outils</div>
          <div class="filterbar__hint">Recherche + export (CSV/Excel/PDF…)</div>
        </div>
      </div>

      <div class="ms-auto d-flex gap-2 align-items-center">
        <div class="dropdown">
          <button class="btn btn-warning btn-sm fw-semibold dropdown-toggle" data-bs-toggle="dropdown">
            <i class="bi bi-download"></i> Export
          </button>
          <ul class="dropdown-menu dropdown-menu-end" id="exportMenu"></ul>
        </div>
      </div>
    </div>
  </div>

  {# TABLE #}
  <div class="table-card mb-4 p-3">
    <table id="tableauAttestations" class="table table-hover align-middle mb-0 w-100">
      <thead>
        <tr>
          <th>Numéro</th>
          <th>Inscription</th>
          <th>Durée (h)</th>
          <th>Réussi</th>
          <th>Date de délivrance</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody></tbody>
    </table>
  </div>


{# ✅ Modale delete (version propre, POST + CSRF) #}
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Confirmer la suppression</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
      </div>

      <div class="modal-body">
        Cette suppression est définitive. Continuer ?
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Annuler</button>

        <form id="deleteForm" method="post" action="">
          <input type="hidden" name="_token" id="deleteToken" value="">
          <button type="submit" class="btn btn-danger">
            <i class="bi bi-trash"></i> Supprimer
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
$(function(){

  function nowLabel(){
    const d = new Date();
    return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
  }


  function initTooltips(){
    if (typeof bootstrap === 'undefined' || !bootstrap.Tooltip) return;
    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => {
      bootstrap.Tooltip.getOrCreateInstance(el);
    });
  }


  const table = $('#tableauAttestations').DataTable({
    serverSide:true,
    processing:true,
    autoWidth: false,
    scrollX: true,
    scrollCollapse: true,
    responsive: false,

    ajax:{
      url:"{{ path('app_administrateur_attestation_ajax', { entite: entite.id }) }}",
      type:"POST",
    },

    dom:
      '<"dt-top d-flex flex-wrap gap-2 align-items-center justify-content-between"'
        + '<"dt-actions d-flex gap-2 align-items-center"B>'
        + '<"dt-search"f>'
      + '>'
      + 'rt'
      + '<"dt-bottom-internal d-flex flex-wrap gap-2 align-items-center justify-content-between"lip>',

    buttons:['copy','csv','excel','pdf','print'],
    lengthMenu:[[10,25,50,200],[10,25,50,200]],
    order:[[0,'desc']],
    language:{ url:'https://cdn.datatables.net/plug-ins/2.2.2/i18n/fr-FR.json' },

    columns:[
      {data:'numero'},
      {data:'inscription'},
      {data:'dureeHeures'},
      {data:'reussi'},          // HTML badge
      {data:'dateDelivrance'},
      {data:'actions'}          // HTML actions
    ],

    columnDefs:[
      {targets:5, className:'action-column text-end', orderable:false, searchable:false},
      {targets:3, orderable:false, searchable:false}, // badge HTML
      {type:'num', targets:0}
    ],

    initComplete:function(){
      const api = this.api();
      const $btns = $(api.buttons().container()).find('button');

      // ✅ menu Export comme Sessions
      $('#exportMenu').empty();
      $btns.each(function(){
        const $b=$(this);
        $('<li><a class="dropdown-item" href="#">'+$b.text()+'</a></li>')
          .on('click', e => { e.preventDefault(); $b.click(); })
          .appendTo('#exportMenu');
      });

      // ✅ on cache la barre de boutons native
      $(api.buttons().container()).hide();

      api.columns.adjust();
      $('#hero-last-refresh').text('Maj : ' + nowLabel());
      initTooltips();
    }
  });



  (function enableAttestationActionsFloatingDropdown(){
    document.addEventListener('show.bs.dropdown', function(e){
      const toggle = e.target;
      if (!toggle.closest('.attestation-actions')) return;

      const dd = toggle.closest('.dropdown, .btn-group');
      if (!dd) return;

      const menu = dd.querySelector('.dropdown-menu');
      if (!menu) return;

      if (!menu.__originalParent) menu.__originalParent = dd;

      document.body.appendChild(menu);
      menu.classList.add('attestation-floating-dropdown');

      const rect = toggle.getBoundingClientRect();

      menu.style.position = 'absolute';
      menu.style.top = '0px';
      menu.style.left = '0px';
      menu.style.display = 'block';

      const menuRect = menu.getBoundingClientRect();
      const isEnd = menu.classList.contains('dropdown-menu-end');

      const top = rect.bottom + window.scrollY + 6;
      let left = isEnd
        ? (rect.right + window.scrollX - menuRect.width)
        : (rect.left + window.scrollX);

      left = Math.max(8, Math.min(left, window.scrollX + window.innerWidth - menuRect.width - 8));

      menu.style.top = `${top}px`;
      menu.style.left = `${left}px`;
    }, true);

    document.addEventListener('hidden.bs.dropdown', function(e){
      const toggle = e.target;
      if (!toggle.closest('.attestation-actions')) return;

      const dd = toggle.closest('.dropdown, .btn-group');
      if (!dd) return;

      document.querySelectorAll('body .attestation-floating-dropdown').forEach(menu => {
        if (menu.__originalParent === dd) {
          dd.appendChild(menu);
          menu.classList.remove('attestation-floating-dropdown');
          menu.style.position = '';
          menu.style.top = '';
          menu.style.left = '';
          menu.style.display = '';
        }
      });
    }, true);

    window.addEventListener('scroll', () => {
      document.querySelectorAll('.attestation-actions [aria-expanded="true"][data-bs-toggle="dropdown"]')
        .forEach(btn => btn.click());
    }, true);

    window.addEventListener('resize', () => {
      document.querySelectorAll('.attestation-actions [aria-expanded="true"][data-bs-toggle="dropdown"]')
        .forEach(btn => btn.click());
    }, true);
  })();


  table.on('draw.dt', function(){
    $('#hero-last-refresh').text('Maj : ' + nowLabel());
    table.columns.adjust();
    initTooltips();
  });

  // ✅ branche la modale delete sur le bouton (data-url + data-token)
  // 👉 adapte ton _actions.html.twig pour mettre data-bs-toggle/modal + data-url + data-token
  $(document).on('click', '.delete-btn', function(){
    const url = $(this).data('url');
    const token = $(this).data('token');

    $('#deleteForm').attr('action', url);
    $('#deleteToken').val(token || '');
  });

});
</script>
{% endblock %}
