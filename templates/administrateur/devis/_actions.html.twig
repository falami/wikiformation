{# templates/administrateur/devis/_actions.html.twig #}
{% set st = (d.status.value ?? d.status) %}
{% set canSend = d.prospect and (d.prospect.email ?? false) %}
{% set hasInvoice = d.factureCreee is not empty %}
{% set canToInvoice = (not hasInvoice) and (st in ['sent','accepted']) %}

<div class="btn-group btn-group-sm devis-actions" role="group">

  {# ✅ Bouton principal = Éditer (gauche) #}
  <a class="btn btn-light devis-main"
     data-bs-toggle="tooltip" title="Éditer"
     href="{{ path('app_administrateur_devis_edit', {entite: entite.id, id: d.id}) }}">
    <i class="fa fa-pen"></i>
  </a>

  {# ✅ Split dropdown (droite) #}
  <button type="button"
          class="btn btn-light dropdown-toggle dropdown-toggle-split devis-split"
          data-bs-toggle="dropdown" aria-expanded="false">
    <span class="visually-hidden">Actions</span>
  </button>

  <ul class="dropdown-menu dropdown-menu-end devis-menu">

    {# ✅ Envoyer email (déplacé dans le menu -> pill identique Dépenses) #}
    {% if canSend %}
      <li>
        <button type="button"
                class="dropdown-item d-flex align-items-center"
                onclick="openDevisEmailModal({{ d.prospect.id }}, {{ d.id }})">
          <i class="bi bi-send me-2"></i> Envoyer par email
        </button>
      </li>
      <li><hr class="dropdown-divider"></li>
    {% endif %}

    {# PDF #}
    <li>
      <a class="dropdown-item d-flex align-items-center"
         data-bs-toggle="tooltip" title="Télécharger PDF"
         href="{{ path('app_administrateur_devis_pdf', {entite: entite.id, id: d.id}) }}">
        <i class="fa fa-file-pdf me-2"></i> Télécharger PDF
      </a>
    </li>

    <li><hr class="dropdown-divider"></li>

    {# Dupliquer #}
    <li>
      <form method="post"
            action="{{ path('app_administrateur_devis_duplicate', { entite: entite.id, id: d.id }) }}"
            onsubmit="return confirm('Dupliquer ce devis ?');">
        <input type="hidden" name="_token" value="{{ csrf_token('devis_duplicate_' ~ d.id) }}">
        <button class="dropdown-item d-flex align-items-center" type="submit">
          <i class="bi bi-files me-2"></i> Dupliquer
        </button>
      </form>
    </li>

    {# Facture / Transformer #}
    <li>
      {% if hasInvoice %}
        <a class="dropdown-item d-flex align-items-center text-success"
          href="{{ path('app_administrateur_facture_edit', {entite: entite.id, id: d.factureCreee.id}) }}">
          <i class="fa fa-receipt me-2"></i> Voir la facture créée
        </a>
      {% else %}

        {# ✅ Bouton -> ouvre la modale (au lieu du confirm) #}
        <button type="button"
                class="dropdown-item d-flex align-items-center {% if not canToInvoice %}disabled{% endif %}"
                {% if not canToInvoice %}disabled{% endif %}
                data-bs-toggle="modal"
                data-bs-target="#devisToInvoiceModal"
                data-devis-id="{{ d.id }}"
                data-devis-numero="{{ d.numero|default('Devis #' ~ d.id) }}"
                data-devis-status="{{ st }}"
        >
          <i class="fa fa-arrow-right me-2"></i>
          {% if canToInvoice %}Transformer en facture{% else %}Statut non facturable{% endif %}
        </button>

        {# ✅ Form réel (soumis depuis la modale) #}
        <form id="devisToInvoiceForm-{{ d.id }}"
              method="post"
              action="{{ path('app_administrateur_devis_to_facture', {entite: entite.id, id: d.id}) }}"
              class="d-none">
          <input type="hidden" name="_token" value="{{ csrf_token('devis_to_facture_' ~ d.id) }}">
        </form>

      {% endif %}
    </li>

    <li><hr class="dropdown-divider"></li>

    {# Supprimer #}
    <li>
      <form method="post"
            action="{{ path('app_administrateur_devis_delete', { entite: entite.id, id: d.id }) }}"
            onsubmit="return confirm('Supprimer ce devis ? Cette action est irréversible.');">
        <input type="hidden" name="_token" value="{{ csrf_token('devis_delete_' ~ d.id) }}">
        <button class="dropdown-item d-flex align-items-center text-danger"
                type="submit" {% if hasInvoice or st in ['invoiced'] %}disabled{% endif %}>
          <i class="bi bi-trash me-2"></i> Supprimer
        </button>
      </form>
    </li>

  </ul>
</div>
