  const idHT            = '#{{ form.montantHtCents.vars.id }}';
  const idTVA           = '#{{ form.montantTvaCents.vars.id }}';
  const idTTC           = '#{{ form.montantTtcCents.vars.id }}';

  const idRemiseGlobPct = '#{{ form.remiseGlobalePourcent.vars.id }}';
  const idRemiseGlobEur = '#{{ form.remiseGlobaleMontantCents.vars.id }}';

  const $formation = document.querySelector(idFormation);
  const $ht  = document.querySelector(idHT);
  const $tva = document.querySelector(idTVA);
  const $ttc = document.querySelector(idTTC);

  const $remiseGlobPct = document.querySelector(idRemiseGlobPct);
  const $remiseGlobEur = document.querySelector(idRemiseGlobEur);

  const form = document.querySelector('form[name="devis_form"]');
  const submitButtons = form ? [...form.querySelectorAll('button[type="submit"]')] : [];

  const $resume = {
    pill: document.getElementById('resume-valid-pill'),
    formation: document.getElementById('resume-formation'),
    formationHours: document.getElementById('resume-formation-hours'),
    destinataire: document.getElementById('resume-destinataire'),
    prospect: document.getElementById('resume-prospect'),
    entreprise: document.getElementById('resume-entreprise'),
    inscriptions: document.getElementById('resume-inscriptions'),
    date: document.getElementById('resume-date'),
    devise: document.getElementById('resume-devise'),
    status: document.getElementById('resume-status'),
    ht: document.getElementById('resume-ht'),
    tva: document.getElementById('resume-tva'),
    ttc: document.getElementById('resume-ttc'),
    lines: document.getElementById('resume-lines')
  };

  const $formationUi = {
    title: document.getElementById('formation-title'),
    hours: document.getElementById('formation-hours'),
    price: document.getElementById('formation-price'),
  };

  /* =========================================================
     TomSelect
  ========================================================= */
  function initTomSelect(selector, opts = {}){
    const el = document.querySelector(selector);
    if (!el || el.tomselect) return el;
    new TomSelect(el, Object.assign({
      create:false,
      plugins: el.multiple ? ['remove_button'] : [],
      sortField: { field:'text', direction:'asc' }
    }, opts));
    return el;
  }

  initTomSelect(idFormation);
  initTomSelect(idDestinataire);
  initTomSelect(idProspect);
  initTomSelect(idInscriptions);
  initTomSelect(idDevise);
  initTomSelect(idStatus);
  initTomSelect(idEntreprise, { allowEmptyOption:true });

  /* =========================================================
     Flatpickr FR
  ========================================================= */
  if (window.flatpickr && window.flatpickr.l10ns?.fr) flatpickr.localize(flatpickr.l10ns.fr);
  document.querySelectorAll('.flatpickr-date').forEach(el => {
    if (!el._fp) flatpickr(el, { dateFormat:'d/m/Y', allowInput:true });
  });

  /* =========================================================
     Remise globale exclusivité % / €
  ========================================================= */
  function bindExclusivePair(pctInput, eurInput){
    if (!pctInput || !eurInput) return;
    const clearPct = () => { pctInput.value = ''; };
    const clearEur = () => { eurInput.value = ''; };

    pctInput.addEventListener('input', () => {
      const pct = parseNumberFR(pctInput.value);
      if (pct > 0) clearEur();
      recomputeTotalsFromLines();
    });
    eurInput.addEventListener('input', () => {
      const eurCents = parseEurosToCents(eurInput.value);
      if (eurCents > 0) clearPct();
      recomputeTotalsFromLines();
    });
  }
  bindExclusivePair($remiseGlobPct, $remiseGlobEur);

  /* =========================================================
     Lignes: collection / prototype
  ========================================================= */
  const collection = document.getElementById('lignes-collection');
  const proto = collection?.dataset.prototype || '';
  let index = {{ form.lignes|length }};

  function attachLineEvents(item){
    if (!item) return;

    const qInput   = item.querySelector('input[name$="[qte]"]');
    const puInput  = item.querySelector('input[name$="[puHtCents]"]');
    const tvaInput = item.querySelector('select[name$="[tva]"], input[name$="[tva]"]');

    const rpInput  = item.querySelector('input[name$="[remisePourcent]"]');
    const reInput  = item.querySelector('input[name$="[remiseMontantCents]"]');

    // exclusivité remise ligne
    if (rpInput && reInput){
      rpInput.addEventListener('input', () => {
        const pct = parseNumberFR(rpInput.value);
        if (pct > 0) reInput.value = '';
        recomputeTotalsFromLines();
      });
      reInput.addEventListener('input', () => {
        const eurCents = parseEurosToCents(reInput.value);
        if (eurCents > 0) rpInput.value = '';
        recomputeTotalsFromLines();
      });
    }

    [qInput, puInput, tvaInput, rpInput, reInput].forEach(el => {
      if (!el) return;
      el.addEventListener('input', recomputeTotalsFromLines);
      el.addEventListener('change', recomputeTotalsFromLines);
    });
  }

  function addLigne(prefill = null){
    const html = proto.replace(/__name__/g, index++);
    const wrapper = document.createElement('div');
    wrapper.className = 'ligne-item mb-3';
    wrapper.innerHTML = `
      <div class="card p-3">
        ${html}
        <div class="mt-2 d-flex justify-content-end">
          <button type="button" class="btn btn-outline-danger btn-remove-ligne">
            <i class="fa fa-trash"></i> Supprimer
          </button>
        </div>
      </div>
    `;
    collection.appendChild(wrapper);

    // si tu veux préremplir
    if (prefill){
      const label = wrapper.querySelector('input[name$="[label]"], textarea[name$="[label]"]');
      const qte   = wrapper.querySelector('input[name$="[qte]"]');
      const pu    = wrapper.querySelector('input[name$="[puHtCents]"]');
      const tva   = wrapper.querySelector('select[name$="[tva]"], input[name$="[tva]"]');

      if (label && prefill.label) label.value = prefill.label;
      if (qte && prefill.qte !== undefined) qte.value = String(prefill.qte);
      if (pu && prefill.puEuros !== undefined) pu.value = String(prefill.puEuros).replace('.', ',');
      if (tva && prefill.tva !== undefined) tva.value = String(prefill.tva);
    }

    attachLineEvents(wrapper);
    recomputeTotalsFromLines();
    return wrapper;
  }

  document.querySelectorAll('#lignes-collection .ligne-item').forEach(attachLineEvents);

  collection?.addEventListener('click', (e)=>{
    const btn = e.target.closest('.btn-remove-ligne');
    if (btn){
      e.preventDefault();
      btn.closest('.ligne-item')?.remove();
      recomputeTotalsFromLines();
    }
  });

  document.getElementById('btn-add-ligne')?.addEventListener('click', () => addLigne());

  /* =========================================================
     Calcul robuste (centimes + prorata remise globale)
     - Remise ligne: € prioritaire sinon %
     - Remise globale: € prioritaire sinon %
     - TVA calculée par ligne sur HT net après prorata
  ========================================================= */
  function readLine(item){
    const qInput   = item.querySelector('input[name$="[qte]"]');
    const puInput  = item.querySelector('input[name$="[puHtCents]"]');
    const tvaInput = item.querySelector('select[name$="[tva]"], input[name$="[tva]"]');
    const rpInput  = item.querySelector('input[name$="[remisePourcent]"]');
    const reInput  = item.querySelector('input[name$="[remiseMontantCents]"]');
    const labelInp = item.querySelector('input[name$="[label]"], textarea[name$="[label]"]');

    const qte = clamp(parseNumberFR(qInput?.value || 0), 0, 999999);
    const puCents = clamp(parseEurosToCents(puInput?.value || 0), 0, 999999999);
    const tva = clamp(parseNumberFR(tvaInput?.value || 0), 0, 100);

    const brutHtCents = Math.round(qte * puCents);

    const remiseEurCents = clamp(parseEurosToCents(reInput?.value || 0), 0, brutHtCents);
    const remisePct = clamp(parseNumberFR(rpInput?.value || 0), 0, 100);

    let remiseLigneCents = 0;
    if (remiseEurCents > 0) {
      remiseLigneCents = remiseEurCents;
    } else if (remisePct > 0) {
      remiseLigneCents = Math.round(brutHtCents * (remisePct / 100));
    }

    remiseLigneCents = clamp(remiseLigneCents, 0, brutHtCents);
    const netHtCents = brutHtCents - remiseLigneCents;

    return {
      item,
      label: (labelInp?.value || '').trim(),
      qte,
      puCents,
      tva,
      brutHtCents,
      remiseLigneCents,
      netHtCents
    };
  }

  function computeGlobalDiscountCents(baseNetHtCents){
    const gEur = clamp(parseEurosToCents($remiseGlobEur?.value || 0), 0, baseNetHtCents);
    const gPct = clamp(parseNumberFR($remiseGlobPct?.value || 0), 0, 100);

    if (gEur > 0) return gEur;
    if (gPct > 0) return Math.round(baseNetHtCents * (gPct / 100));
    return 0;
  }

  function recomputeTotalsFromLines(){
    const items = Array.from(document.querySelectorAll('#lignes-collection .ligne-item'));
    const lines = items.map(readLine).filter(l => l.qte > 0 || l.puCents > 0 || l.label);

    // base net HT (après remises lignes)
    const baseNetHt = lines.reduce((s,l)=> s + l.netHtCents, 0);

    // remise globale
    const globalDiscount = clamp(computeGlobalDiscountCents(baseNetHt), 0, baseNetHt);

    // prorata remise globale sur lignes (pour TVA correcte multi-taux)
    // -> répartit en centimes sur les lignes avec netHtCents > 0
    const proratables = lines.filter(l => l.netHtCents > 0);
    const totalProratable = proratables.reduce((s,l)=> s + l.netHtCents, 0);

    let remaining = globalDiscount;
    const prorataMap = new Map();

    if (globalDiscount > 0 && totalProratable > 0){
      proratables.forEach((l, idx) => {
        let share = (idx === proratables.length - 1)
          ? remaining
          : Math.round(globalDiscount * (l.netHtCents / totalProratable));

        share = clamp(share, 0, remaining);
        prorataMap.set(l, share);
        remaining -= share;
      });
    }

    // totals
    let totalHtFinal = 0;
    let totalTva = 0;

    lines.forEach(l => {
      const share = prorataMap.get(l) || 0;
      const htAfterGlobal = clamp(l.netHtCents - share, 0, l.netHtCents);

      const tvaCents = Math.round(htAfterGlobal * (l.tva / 100));

      totalHtFinal += htAfterGlobal;
      totalTva += tvaCents;
    });

    const totalTtc = totalHtFinal + totalTva;

    // push into form fields (euros FR)
    if ($ht)  $ht.value  = centsToEurosFR(totalHtFinal);
    if ($tva) $tva.value = centsToEurosFR(totalTva);
    if ($ttc) $ttc.value = centsToEurosFR(totalTtc);

    refreshResume();
  }

  /* =========================================================
     Auto depuis formation (choice_attr dataset)
  ========================================================= */
  function optionDataForFormation() {
    if (!$formation || !$formation.value) return null;
    const opt = $formation.selectedOptions?.[0];
    if (!opt) return null;

    const d = opt.dataset || {};
    const prixBaseCents   = parseInt(d.prixBaseCents || '0', 10) || 0;
    const prixReduitCents = parseInt(d.prixReduitCents || '0', 10) || 0;

    return {
      id: $formation.value,
      title: (d.title || '').trim() || getSelectedText($formation),
      days: parseInt(d.days || '0', 10) || 0,
      hours: parseInt(d.hours || '0', 10) || 0,
      prixBaseCents,
      prixReduitCents,
    };
  }

  function setFormationUi(data){
    if (!data){
      $formationUi.title.textContent = '—';
      $formationUi.hours.textContent = '—';
      $formationUi.price.textContent = '—';
      return;
    }
    $formationUi.title.textContent = data.title || '—';
    const parts = [];
    if (data.days > 0) parts.push(`${data.days} j`);
    if (data.hours > 0) parts.push(`${data.hours} h`);
    $formationUi.hours.textContent = parts.length ? parts.join(' • ') : '—';

    const cents = (data.prixReduitCents && data.prixReduitCents > 0) ? data.prixReduitCents : data.prixBaseCents;
    $formationUi.price.textContent = cents > 0 ? formatMoneyEURFromCents(cents) : '—';
  }

  function ensureOneLineFromFormation(data){
    if (!data) return;

    // politique: 1 formation => 1 ligne (remplace les lignes)
    collection.querySelectorAll('.ligne-item').forEach(el => el.remove());

    const cents = (data.prixReduitCents && data.prixReduitCents > 0) ? data.prixReduitCents : data.prixBaseCents;

    addLigne({
      label: data.title || 'Formation',
      qte: 1,
      puEuros: (cents / 100).toFixed(2),
      tva: 20
    });
  }

  function applyFormationAuto(){
    if (!$formation?.value){
      setFormationUi(null);
      refreshResume();
      return;
    }

    const data = optionDataForFormation();
    setFormationUi(data || { title: getSelectedText($formation), days:0, hours:0, prixBaseCents:0, prixReduitCents:0 });

    // ✅ IMPORTANT : en édition, on n’écrase pas les lignes existantes (donc on garde le libellé multi-lignes)
    if (IS_EDIT) {
      recomputeTotalsFromLines();
      return;
    }

    // ✅ en création : auto-remplir seulement si aucune "vraie" ligne n’existe
    const existingItems = Array.from(collection.querySelectorAll('.ligne-item'));
    const hasRealLine = existingItems.some(item => {
      const label = item.querySelector('input[name$="[label]"], textarea[name$="[label]"]')?.value?.trim();
      const q     = parseNumberFR(item.querySelector('input[name$="[qte]"]')?.value || 0);
      const pu    = parseEurosToCents(item.querySelector('input[name$="[puHtCents]"]')?.value || 0);
      return !!label || q > 0 || pu > 0;
    });

    if (data && (data.prixBaseCents > 0 || data.prixReduitCents > 0) && !hasRealLine){
      ensureOneLineFromFormation(data);
    } else {
      recomputeTotalsFromLines();
    }
  }


  $formation?.addEventListener('change', applyFormationAuto);

  /* =========================================================
     Exclusivité destinataire / entreprise
  ========================================================= */
  const destEl = document.querySelector(idDestinataire);
  const entEl  = document.querySelector(idEntreprise);
  const proEl  = document.querySelector(idProspect);

  function clearSelect(el){
    if (!el) return;
    if (el.tomselect) el.tomselect.clear(true);
    else el.value = '';
  }


  function bindProspectExclusive(prospectEl, userEl, entEl){
    if (!prospectEl) return;

    prospectEl.addEventListener('change', () => {
      if (prospectEl.value) {
        clearSelect(userEl);
        clearSelect(entEl);
      }
      refreshResume();
    });

    const clearProspect = () => {
      if (prospectEl.value) clearSelect(prospectEl);
    };

    userEl?.addEventListener('change', () => { if (userEl.value) clearProspect(); refreshResume(); });
    entEl?.addEventListener('change',  () => { if (entEl.value)  clearProspect(); refreshResume(); });
  }

  bindProspectExclusive(proEl, destEl, entEl);


  if (destEl && entEl) {
    destEl.addEventListener('change', () => { if (destEl.value) clearSelect(entEl); refreshResume(); });
    entEl.addEventListener('change',  () => { if (entEl.value)  clearSelect(destEl); refreshResume(); });
  }

  /* =========================================================
     Résumé + bouton submit
  ========================================================= */
  function countValidLines(){
    const items = document.querySelectorAll('#lignes-collection .ligne-item');
    let ok = 0;

    items.forEach(item => {
      const label = item.querySelector('input[name$="[label]"], textarea[name$="[label]"]');
      const q     = item.querySelector('input[name$="[qte]"]');
      const pu    = item.querySelector('input[name$="[puHtCents]"]');

      const labelOk = !!((label?.value || '').trim());
      const qOk     = (parseNumberFR(q?.value || 0)) > 0;
      const puOk    = (parseEurosToCents(pu?.value || 0)) > 0;

      if (labelOk && qOk && puOk) ok++;
    });

    return ok;
  }

  function refreshResume(){
    const selForm = document.querySelector(idFormation);
    const selPro  = document.querySelector(idProspect);
    const selDest = document.querySelector(idDestinataire);
    const selEnt  = document.querySelector(idEntreprise);
    const selIns  = document.querySelector(idInscriptions);
    const selDev  = document.querySelector(idDevise);
    const selSta  = document.querySelector(idStatus);
    const inpDate = document.querySelector(idDate);

    const htCents  = parseEurosToCents($ht?.value || 0);
    const tvaCents = parseEurosToCents($tva?.value || 0);
    const ttcCents = parseEurosToCents($ttc?.value || 0);

    if ($resume.formation) $resume.formation.textContent = getSelectedText(selForm) || '—';
    if ($resume.formationHours) {
      const h = ($formationUi.hours?.textContent || '').trim();
      $resume.formationHours.textContent = (h && h !== '—') ? h : '—';
    }

    if ($resume.prospect) $resume.prospect.textContent = getSelectedText(selPro) || '—';

    if ($resume.destinataire) $resume.destinataire.textContent = getSelectedText(selDest) || '—';
    if ($resume.entreprise)   $resume.entreprise.textContent   = getSelectedText(selEnt)  || '—';

    const insTexts = getSelectedTexts(selIns);
    if ($resume.inscriptions) $resume.inscriptions.textContent = insTexts.length ? insTexts.join(', ') : '—';

    if ($resume.date)   $resume.date.textContent   = (inpDate?.value || '').trim() || '—';
    if ($resume.devise) $resume.devise.textContent = getSelectedText(selDev) || '—';
    if ($resume.status) $resume.status.textContent = getSelectedText(selSta) || '—';

    if ($resume.ht)  $resume.ht.textContent  = (htCents  > 0) ? formatMoneyEURFromCents(htCents)  : '—';
    if ($resume.tva) $resume.tva.textContent = (tvaCents > 0) ? formatMoneyEURFromCents(tvaCents) : '—';
    if ($resume.ttc) $resume.ttc.textContent = (ttcCents > 0) ? formatMoneyEURFromCents(ttcCents) : '—';

    const validLines = countValidLines();
    if ($resume.lines) $resume.lines.textContent = String(validLines);

    const linkOk = !!(
      (selDest?.value && selDest.value.trim()) ||
      (selEnt?.value && selEnt.value.trim()) ||
      (selPro?.value && selPro.value.trim())
    );

    const dateOk   = !!((inpDate?.value || '').trim());
    const deviseOk = !!(selDev?.value && selDev.value.trim());
    const statusOk = !!(selSta?.value && selSta.value.trim());
    const linesOk  = validLines > 0;
    const okHtml   = form ? form.checkValidity() : true;

    const ok = linkOk && dateOk && deviseOk && statusOk && linesOk && okHtml;
    submitButtons.forEach(b => b.disabled = !ok);

    if ($resume.pill) {
      if (ok) {
        $resume.pill.textContent = '✅ Complet';
        $resume.pill.style.background = 'rgba(25,135,84,.15)';
        $resume.pill.style.borderColor = 'rgba(25,135,84,.35)';
        $resume.pill.style.color = 'var(--ink)';
      } else {
        $resume.pill.textContent = '⚠️ Incomplet';
        $resume.pill.style.background = 'rgba(255,193,7,.15)';
        $resume.pill.style.borderColor = 'rgba(255,193,7,.35)';
        $resume.pill.style.color = 'var(--ink)';
      }
    }
  }

  // listeners résumé (✅ correction: idInscriptions)
  [idFormation, idProspect, idDestinataire, idEntreprise, idInscriptions, idDevise, idStatus, idDate, idRemiseGlobPct, idRemiseGlobEur].forEach(sel=>{
    const el = document.querySelector(sel);
    if (!el) return;
    el.addEventListener('change', refreshResume);
    el.addEventListener('input', refreshResume);
  });

  /* =========================================================
     Modal entreprise (ton code)
  ========================================================= */
  const mount = document.getElementById('entrepriseModalMount');
  const btnAddEntreprise = document.getElementById('btnAddEntreprise');

  async function loadEntrepriseModal() {
    const url = "{{ path('app_administrateur_devis_entreprise_modal', { entite: entite.id }) }}";
    const res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' }});
    const html = await res.text();
    mount.innerHTML = html;
  }
  function showEntrepriseModal() {
    const modalEl = document.getElementById('entrepriseModal');
    const modal = new bootstrap.Modal(modalEl);
    modal.show();
  }
  btnAddEntreprise?.addEventListener('click', async () => {
    await loadEntrepriseModal();
    showEntrepriseModal();
    setTimeout(() => {
      const rs = document.querySelector('#entrepriseModal input[name$="[raisonSociale]"]');
      rs?.focus();
    }, 150);
  });

  document.addEventListener('submit', async (e) => {
    const f = e.target;
    if (!f || f.id !== 'entrepriseModalForm') return;

    console.log('submit modal entreprise intercepté ✅');
    e.preventDefault();
    e.stopPropagation();

    const action = f.getAttribute('action');
    const fd = new FormData(f);

    const res = await fetch(action, {
      method: 'POST',
      body: fd,
      headers: { 'X-Requested-With': 'XMLHttpRequest' }
    });

    const payload = await res.json().catch(() => null);

    if (!payload || payload.ok !== true) {
      if (payload?.html) {
        mount.innerHTML = payload.html;
        showEntrepriseModal();
      } else {
        console.error('Réponse non JSON ou erreur serveur', res.status);
      }
      return;
    }


    const entSelect = document.querySelector(idEntreprise);
    if (entSelect?.tomselect) {
      entSelect.tomselect.addOption({ value: String(payload.id), text: payload.text });
      entSelect.tomselect.setValue(String(payload.id), true);
    } else if (entSelect) {
      const opt = document.createElement('option');
      opt.value = String(payload.id);
      opt.textContent = payload.text;
      opt.selected = true;
      entSelect.appendChild(opt);
    }

    const modalEl = document.getElementById('entrepriseModal');
    const modal = bootstrap.Modal.getInstance(modalEl);
    modal?.hide();

    refreshResume();
  }, true); // <- capture


  /* =========================================================
     INIT
  ========================================================= */
  initFormValidation({ formName: 'devis_form' });

  // calc initial (edit ou non)
  recomputeTotalsFromLines();
  refreshResume();

  // si edit avec formation déjà choisie
  applyFormationAuto();
});
</script>
{% endblock %}
