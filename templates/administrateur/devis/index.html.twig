<script>
$(function () {
  const $statusFilter = $('#devisStatusFilter');

  function nowLabel(){
    const d = new Date();
    return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
  }

  function formatEUR(cents){
    const val = (Number(cents || 0) / 100);
    return val.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' €';
  }

  function setBar($el, pct){
    const p = Math.max(0, Math.min(100, Math.round(pct)));
    $el.css('width', p + '%');
  }

  async function loadDevisKpis(){
    try {
      const url = "{{ path('app_administrateur_devis_kpis', { entite: entite.id }) }}";
      const params = new URLSearchParams({ statusFilter: ($statusFilter.val() || 'all') });

      const res = await fetch(url + '?' + params.toString(), {
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
      });
      if (!res.ok) throw new Error('HTTP ' + res.status);

      const j = await res.json();

      const count = Number(j.count || 0);
      const ttcCents = Number(j.ttcCents || 0);
      const last30Count = Number(j.last30Count || 0);
      const last30TtcCents = Number(j.last30TtcCents || 0);

      $('#kpi-devis-count').text(count.toLocaleString('fr-FR'));
      $('#kpi-devis-ttc').text(formatEUR(ttcCents));
      $('#kpi-devis-30d-count').text(last30Count.toLocaleString('fr-FR'));
      $('#kpi-devis-30d-ttc').text(formatEUR(last30TtcCents));

      // barres: échelle "douce"
      const countMax = Math.max(20, Math.ceil(count / 10) * 10);
      setBar($('#kpi-bar-devis-count'), (count / countMax) * 100);

      const ttcMax = Math.max(10000, ttcCents); // min 100€ en cents => 10000
      setBar($('#kpi-bar-devis-ttc'), (ttcCents / ttcMax) * 100);

      setBar($('#kpi-bar-devis-30d'), (last30TtcCents / ttcMax) * 100);

      $('#hero-last-refresh').text('Maj : ' + nowLabel());
    } catch (e) {
      console.error('KPI devis error:', e);
      $('#hero-last-refresh').text('Maj : —');
    }
  }

  function initTooltips(){
    if (typeof bootstrap === 'undefined' || !bootstrap.Tooltip) return;
    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => {
      bootstrap.Tooltip.getOrCreateInstance(el);
    });
  }

  // ✅ premier chargement KPI
  loadDevisKpis();

  const table = $('#tableauDevis').DataTable({
    processing: true,
    serverSide: true,
    autoWidth: false,
    scrollX: true,
    scrollCollapse: true,
    responsive: false,

    ajax: {
      url: "{{ path('app_administrateur_devis_ajax', { entite: entite.id }) }}",
      type: "POST",
      data: function (d) {
        d.statusFilter = $statusFilter.val() || 'all';
      }
    },

    dom:
      '<"dt-top d-flex flex-wrap gap-2 align-items-center justify-content-between"'
        + '<"dt-actions d-flex gap-2 align-items-center"B>'
        + '<"dt-search"f>'
      + '>'
      + 'rt'
      + '<"dt-bottom-internal d-flex flex-wrap gap-2 align-items-center justify-content-between"lip>',

    buttons: [
      { extend: 'copy',  title: 'Devis', text: 'Copier' },
      { extend: 'csv',   title: 'Devis', text: 'CSV' },
      { extend: 'excel', title: 'Devis', text: 'Excel' },
      { extend: 'pdf',   title: 'Devis', text: 'PDF' },
      { extend: 'print', title: 'Devis', text: 'Imprimer' },
    ],

    lengthMenu: [[10,25,50,100,500],[10,25,50,100,500]],

    columns: [
      { data:'numero' },
      { data:'dest' },
      { data:'ttc' },
      { data:'status' },
      { data:'actions' }
    ],

    columnDefs: [
      { targets:2, className:'text-end', createdCell: function(td){ $(td).addClass('text-end'); } },
      { targets:2, createdRow: function(){ } },
      // ✅ colonnes texte (évite XSS + DT stable)
      { targets:[0,1,2], render: $.fn.dataTable.render.text() },

      // ✅ status/actions = HTML server-side (badges + boutons)
      { targets:[3,4], orderable:false, searchable:false, render: function(data, type){
          // type 'display' -> on affiche le HTML, sinon on renvoie une version texte minimale
          if (type === 'display') return data || '';
          return (data || '').toString().replace(/<[^>]*>/g,'').trim();
        }
      },

      { targets:4, className:'action-column text-end' },
      { targets:2, className:'text-end' },
    ],

    order: [[0,'desc']],
    language: { url:'https://cdn.datatables.net/plug-ins/2.2.2/i18n/fr-FR.json' },
    deferRender: true,

    initComplete: function(){
      const api = this.api();
      const container = api.buttons().container();
      const $btns = $(container).find('button');

      $('#exportMenu').empty();

      $btns.each(function(){
        const $b = $(this);
        const label = $b.text().trim();

        const icon = label === 'Excel' ? 'bi-file-earmark-excel' :
                     label === 'PDF' ? 'bi-file-earmark-pdf' :
                     label === 'CSV' ? 'bi-filetype-csv' :
                     label === 'Imprimer' ? 'bi-printer' :
                     label === 'Copier' ? 'bi-clipboard' : 'bi-download';

        const $item = $(`
          <li>
            <a class="dropdown-item d-flex align-items-center gap-2" href="#">
              <i class="bi ${icon}"></i> <span>${label}</span>
            </a>
          </li>
        `);

        $item.on('click', function(e){
          e.preventDefault();
          $b.trigger('click');
        });

        $('#exportMenu').append($item);
      });

      $(container).hide();
      initTooltips();
    }
  });


  // ✅ Dropdown actions devis : on "flotte" le menu hors du scroll DataTables (sinon il est clippé)
  (function enableDevisActionsFloatingDropdown(){
    document.addEventListener('show.bs.dropdown', function(e){
      const toggle = e.target;
      if (!toggle.closest('.devis-actions')) return;

      const dd = toggle.closest('.dropdown, .btn-group');
      if (!dd) return;

      const menu = dd.querySelector('.dropdown-menu');
      if (!menu) return;

      // mémorise le parent original
      if (!menu.__originalParent) menu.__originalParent = dd;

      // move to body + classe z-index
      document.body.appendChild(menu);
      menu.classList.add('devis-floating-dropdown');

      // positionne le menu sous le toggle
      const rect = toggle.getBoundingClientRect();

      // important : forcer la mesure après appendChild
      menu.style.position = 'absolute';
      menu.style.top = '0px';
      menu.style.left = '0px';
      menu.style.display = 'block'; // au cas où
      const menuRect = menu.getBoundingClientRect();

      const isEnd = menu.classList.contains('dropdown-menu-end') || menu.classList.contains('dropdown-menu-end');
      const top = rect.bottom + window.scrollY + 6;

      let left = isEnd
        ? (rect.right + window.scrollX - menuRect.width)
        : (rect.left + window.scrollX);

      // clamp dans la fenêtre
      left = Math.max(8, Math.min(left, window.scrollX + window.innerWidth - menuRect.width - 8));

      menu.style.top = `${top}px`;
      menu.style.left = `${left}px`;
    }, true);

    document.addEventListener('hidden.bs.dropdown', function(e){
      const toggle = e.target;
      if (!toggle.closest('.devis-actions')) return;

      const dd = toggle.closest('.dropdown, .btn-group');
      if (!dd) return;

      // remettre uniquement le menu lié à ce groupe
      document.querySelectorAll('body .devis-floating-dropdown').forEach(menu => {
        if (menu.__originalParent === dd) {
          dd.appendChild(menu);
          menu.classList.remove('devis-floating-dropdown');
          menu.style.position = '';
          menu.style.top = '';
          menu.style.left = '';
          menu.style.display = '';
        }
      });
    }, true);

    // ✅ si scroll/resize : ferme les menus ouverts
    window.addEventListener('scroll', () => {
      document.querySelectorAll('.devis-actions [aria-expanded="true"][data-bs-toggle="dropdown"]')
        .forEach(btn => btn.click());
    }, true);

    window.addEventListener('resize', () => {
      document.querySelectorAll('.devis-actions [aria-expanded="true"][data-bs-toggle="dropdown"]')
        .forEach(btn => btn.click());
    }, true);
  })();


  table.on('draw.dt', function(){
    initTooltips();
  });

  $statusFilter.on('change', function () {
    table.ajax.reload(null, true);
    loadDevisKpis();
  });

  $('#btnReset').on('click', function () {
    $statusFilter.val('all');
    table.search('');
    table.order([[0, 'desc']]);
    table.ajax.reload(null, true);
    loadDevisKpis();
  });


  /* =========================================================================
   * ✅ MODALE ENVOI EMAIL DEVIS (Prospect)
   * ========================================================================= */

  window.openDevisEmailModal = async function(prospectId, devisId){
    const url = "{{ path('app_administrateur_prospect_devis_modal', { entite: entite.id, prospect: 0, devis: 0 }) }}"
      .replace('/0/devis/0/modal', '/' + prospectId + '/devis/' + devisId + '/modal');

    const res = await fetch(url, { headers: { 'X-Requested-With':'XMLHttpRequest' }});
    const html = await res.text();
    document.getElementById('devisEmailModalHost').innerHTML = html;

    const modalEl = document.getElementById('devisEmailModal');
    const bsModal = new bootstrap.Modal(modalEl);
    bsModal.show();

    const form = modalEl.querySelector('#devisSendForm');
    const previewZone = modalEl.querySelector('#devisPreviewZone');
    const statusEl = modalEl.querySelector('#devisSendStatus');

    async function doPreview(){
      const fd = new URLSearchParams();
      fd.set('to', form.querySelector('[name$="[to]"]').value || '');
      fd.set('subject', form.querySelector('[name$="[subject]"]').value || '');
      fd.set('message', form.querySelector('[name$="[message]"]').value || '');

      const urlPreview = "{{ path('app_administrateur_prospect_devis_preview', { entite: entite.id, prospect: 0, devis: 0 }) }}"
        .replace('/0/devis/0/preview', '/' + prospectId + '/devis/' + devisId + '/preview');

      const r = await fetch(urlPreview, { method:'POST', body: fd, headers:{ 'X-Requested-With':'XMLHttpRequest' }});
      const j = await r.json();

      if(!j.ok){
        previewZone.innerHTML = '<div class="text-danger">Erreur aperçu</div>';
        return;
      }

      // ✅ isolation CSS: l'email est rendu dans un iframe
      previewZone.innerHTML = `
        <iframe
          id="emailPreviewFrame"
          style="width:100%; border:0; border-radius:12px; min-height:420px; background:#fff;"
          sandbox="allow-same-origin"
        ></iframe>
      `;

      const frame = previewZone.querySelector('#emailPreviewFrame');
      frame.srcdoc = j.html;

      // (optionnel) ajuste la hauteur après chargement (simple)
      frame.onload = () => {
        try {
          const h = frame.contentWindow.document.documentElement.scrollHeight;
          frame.style.height = Math.min(Math.max(h, 420), 900) + 'px';
        } catch(e) {
          // si sandbox bloque, on garde min-height
        }
      };
    }


    modalEl.querySelector('#btnDevisPreview')?.addEventListener('click', doPreview);

    let sending = false;
    modalEl.querySelector('#btnDevisSend')?.addEventListener('click', async (e) => {
      if (sending) return;
      sending = true;

      const btn = e.currentTarget;
      btn.disabled = true;
      const old = btn.innerHTML;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Envoi…';
      statusEl.textContent = '';

      try{
        const fd = new URLSearchParams();
        fd.set('to', form.querySelector('[name$="[to]"]').value || '');
        fd.set('subject', form.querySelector('[name$="[subject]"]').value || '');
        fd.set('message', form.querySelector('[name$="[message]"]').value || '');
        fd.set('attachPdf', form.querySelector('[name$="[attachPdf]"]').checked ? '1' : '0');
        fd.set('idemKey', form.querySelector('[name$="[idemKey]"]').value || '');

        const urlSend = "{{ path('app_administrateur_prospect_devis_send', { entite: entite.id, prospect: 0, devis: 0 }) }}"
          .replace('/0/devis/0/send', '/' + prospectId + '/devis/' + devisId + '/send');

        const r = await fetch(urlSend, { method:'POST', body: fd, headers:{ 'X-Requested-With':'XMLHttpRequest' }});
        const j = await r.json();

        if(!j.ok){
          statusEl.textContent = j.error || 'Erreur envoi';
          btn.disabled = false;
          btn.innerHTML = old;
          sending = false;
          return;
        }

        statusEl.textContent = '✅ Devis envoyé.';
        setTimeout(() => bsModal.hide(), 600);
        setTimeout(() => window.location.reload(), 900);
      } catch(err){
        statusEl.textContent = 'Erreur technique.';
        btn.disabled = false;
        btn.innerHTML = old;
        sending = false;
      }
    });

    await doPreview();
  };
});
</script>



<script>
document.addEventListener('DOMContentLoaded', () => {
  const modalEl  = document.getElementById('devisToInvoiceModal');
  if (!modalEl) return;

  const labelEl  = document.getElementById('jsDevisLabel');
  const statusEl = document.getElementById('jsDevisStatus');
  const hiddenId = document.getElementById('jsDevisIdToSubmit');

  const chk      = document.getElementById('confirmDevisToInvoiceCheck');
  const btnOk    = document.getElementById('btnConfirmDevisToInvoice');

  const bsModal = new bootstrap.Modal(modalEl);

  // Ouvre la modale depuis n’importe quel bouton "Transformer"
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('[data-bs-target="#devisToInvoiceModal"]');
    if (!btn) return;

    // si disabled, Bootstrap ne l’ouvrira pas normalement — sécurité
    if (btn.hasAttribute('disabled') || btn.classList.contains('disabled')) return;

    const devisId = btn.getAttribute('data-devis-id') || '';
    const numero  = btn.getAttribute('data-devis-numero') || ('Devis #' + devisId);
    const st      = btn.getAttribute('data-devis-status') || '—';

    hiddenId.value = devisId;
    if (labelEl)  labelEl.textContent  = numero;
    if (statusEl) statusEl.textContent = st;

    // reset checkbox / bouton
    chk.checked = false;
    btnOk.disabled = true;

    bsModal.show();
  });

  // checkbox -> active le bouton
  chk.addEventListener('change', () => {
    btnOk.disabled = !chk.checked;
  });

  // Soumission
  btnOk.addEventListener('click', () => {
    if (btnOk.disabled) return;

    const devisId = hiddenId.value;
    if (!devisId) return;

    const form = document.getElementById('devisToInvoiceForm-' + devisId);
    if (!form) return;

    btnOk.disabled = true;
    btnOk.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Création…';

    form.submit();
  });

  // Reset quand on ferme
  modalEl.addEventListener('hidden.bs.modal', () => {
    chk.checked = false;
    btnOk.disabled = true;
    btnOk.innerHTML = '<i class="bi bi-check2-circle me-1"></i> Créer la facture';
    hiddenId.value = '';
    if (labelEl) labelEl.textContent = 'ce devis';
    if (statusEl) statusEl.textContent = '—';
  });
});
</script>
