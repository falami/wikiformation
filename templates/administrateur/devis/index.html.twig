{# templates/administrateur/devis/index.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}Devis{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }
    
    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;

      /* Ombre douce premium */
      box-shadow: 0 18px 50px rgba(0,0,0,.14);

      /* Fond piloté par les couleurs de l'entité */
      background:
        /* halo clair (tertiaire) */
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        /* halo accent (secondaire) */
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        /* voile subtil (quaternaire) pour la profondeur */
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        /* dégradé principal (principal -> plus clair) */
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    /* léger glass highlight */
    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    /* barre accent = secondaire (et glow basé sur secondaire) */
    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }
    .hero .subtitle{ opacity:.86 }
    /* ===== Chips HERO (comme Sessions) ===== */
    .hero .chip{
      display:inline-flex;
      align-items:center;
      gap:.5rem;
      padding:.32rem .7rem;
      border-radius:999px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(255,255,255,.14);
      backdrop-filter: blur(6px);
      font-size:.82rem;
      color: rgba(255,255,255,.92);
      white-space: nowrap;
    }
    .hero .chip i{ color: var(--theme-color-secondaire); }

    .hero .chip--pill{
      background: color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
      border-color: color-mix(in srgb, var(--theme-color-secondaire) 28%, rgba(255,255,255,.14));
      color:#fff;
    }

    .hero .btn{
      border-radius:14px;
      font-weight:800;
    }
    .hero .subtitle{ opacity:.86; }

    .kpi-card{
      border: 1px solid rgba(0,0,0,.06);
      box-shadow: 0 10px 26px rgba(0,0,0,.06);
      border-radius: 18px;
      overflow:hidden;
      background: #fff;
      position:relative;
    }
    .kpi-card:before{ content:""; position:absolute; inset:0; background: radial-gradient(700px 120px at 20% 0%, rgba(255,193,7,.12), transparent 55%); pointer-events:none; }
    .kpi-ico{
      width:44px; height:44px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }

    .filter-icon{
      width:38px; height:38px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }
    .kpi-label{ color: rgba(0,0,0,.55); font-size:.85rem }
    .kpi-value{ font-weight: 800; font-size: 1.6rem; letter-spacing:-.02em }
    .kpi-sub{ color: rgba(0,0,0,.50); font-size:.82rem }
    .kpi-bar{ height: 6px; border-radius: 999px; background: rgba(0,0,0,.06); overflow:hidden; }
    .kpi-bar > span{ display:block; height:100%; width: 0%; background: var(--theme-color-secondaire); border-radius: 999px; transition: width .35s ease; }

    .toolbar{
      border-radius: 16px; background: #fff;
      border: 1px solid rgba(0,0,0,.06);
      box-shadow: 0 10px 24px rgba(0,0,0,.05);
      padding: .85rem;
    }
    .toolbar .hint{ font-size:.85rem; color: rgba(0,0,0,.55); }
    .chip{
      display:inline-flex; align-items:center; gap:.5rem;
      padding:.35rem .7rem; border-radius:999px;
      background: rgba(0,0,0,.03);
      border: 1px solid rgba(0,0,0,.06);
      font-size:.85rem;
      color: rgba(0,0,0,.65);
    }

    .table-card{
      border-radius: 18px;
      background: #fff;
      border: 1px solid rgba(0,0,0,.06);
      box-shadow: 0 12px 30px rgba(0,0,0,.06);
      overflow:hidden;
    }
    table.dataTable{ margin:0 !important; }
    table.dataTable thead th{
      position: sticky; top: 0; z-index: 2;
      background: #f7f8fa !important;
      border-bottom: 1px solid rgba(0,0,0,.08) !important;
      text-transform: uppercase;
      font-size: .78rem;
      letter-spacing:.06em;
      color: rgba(0,0,0,.55);
      text-align: center;
      vertical-align: middle;
    }
    .dataTables_wrapper .dataTables_filter input{
      border-radius: 999px !important;
      padding: .45rem .85rem !important;
      border: 1px solid rgba(0,0,0,.12) !important;
      outline: none !important;
      box-shadow: none !important;
    }
    .dataTables_wrapper .dataTables_length select{
      border-radius: 999px !important;
      border: 1px solid rgba(0,0,0,.12) !important;
      padding: .35rem .7rem !important;
    }
    .dt-top{ padding: .75rem .85rem; border-bottom: 1px solid rgba(0,0,0,.06); background: #fff; }
    .dt-bottom-internal{ padding: 1rem .85rem !important; background: #fff; border-top: 1px solid rgba(0,0,0,.06); }

    #tableauDevis tbody tr:nth-child(odd) > *{ background-color:#fff !important; }
    #tableauDevis tbody tr:nth-child(even) > *{ background-color: rgba(35,51,66,.035) !important; }
    #tableauDevis tbody tr:hover > *{ background-color: rgba(255,193,7,.08) !important; }
    #tableauDevis tbody td{ padding-top: .75rem !important; padding-bottom: .75rem !important; }

    @media (max-width: 768px){
      table.dataTable td.action-column{
        position: sticky; right:0; background:#fff; z-index:5;
        box-shadow: -12px 0 18px -14px rgba(0,0,0,.22);
      }
      .hero{ border-radius: 16px; }
    }



    /* =========================
   ✅ Actions devis (même design que Dépenses)
   ========================= */

/* largeur mini colonne actions */
#tableauDevis th:last-child,
#tableauDevis td:last-child{
  width: 1% !important;
  min-width: 0 !important;
  white-space: nowrap;
}

/* boutons compacts */
.devis-actions .btn{
  padding: .32rem .55rem;
}

/* bouton principal */
.devis-actions .devis-main{
  background: rgba(255,255,255,.85);
  border-color: rgba(0,0,0,.12);
  box-shadow: 0 10px 22px rgba(0,0,0,.06);
}
.devis-actions .devis-main:hover{
  box-shadow: 0 14px 28px rgba(0,0,0,.10);
  border-color: rgba(0,0,0,.18);
}

/* bouton secondaire (envoyer) */
.devis-actions .devis-secondary{
  background: rgba(255,255,255,.85);
  border-color: rgba(0,0,0,.12);
  box-shadow: 0 10px 22px rgba(0,0,0,.06);
  padding: .40rem .40rem !important;
}
.devis-actions .devis-secondary:hover{
  box-shadow: 0 14px 28px rgba(0,0,0,.10);
  border-color: rgba(0,0,0,.18);
}

/* split */
.devis-actions .devis-split{
  padding-left: .55rem;
  padding-right: .55rem;
  border-color: rgba(0,0,0,.12);
  background: rgba(255,255,255,.85);
}

/* menu dropdown */
.devis-actions .devis-menu{
  border-radius: 16px;
  border: 1px solid rgba(0,0,0,.10);
  box-shadow: 0 18px 46px rgba(0,0,0,.18);
  padding: .55rem;
  background:
    radial-gradient(900px 220px at 10% 0%, rgba(255,193,7,.10), transparent 55%),
    #fff;
  overflow: hidden;
}
.devis-actions .devis-menu .dropdown-item{
  border-radius: 12px;
  padding: .50rem .60rem;
  margin: .10rem 0;
  border: 1px solid transparent;
}
.devis-actions .devis-menu .dropdown-item:hover{
  background: rgba(255,193,7,.10);
  border-color: rgba(255,193,7,.22);
}

/* fusion pill (main + split) */
.devis-actions.btn-group .devis-main{
  border-top-right-radius: 0 !important;
  border-bottom-right-radius: 0 !important;
}
.devis-actions.btn-group .devis-split{
  border-top-left-radius: 0 !important;
  border-bottom-left-radius: 0 !important;
  margin-left: -1px;
  position: relative;
}
.devis-actions.btn-group .devis-split:before{
  content:"";
  position:absolute;
  left:0;
  top:20%;
  bottom:20%;
  width:1px;
  background: rgba(0,0,0,.10);
}

/* si tu as un bouton secondaire, on le “colle” au milieu */
.devis-actions.btn-group .devis-secondary{
  border-radius: 0 !important;
}

/* ne jamais masquer quand dropdown ouvert */
#tableauDevis td.action-column .devis-actions{
  opacity: 1 !important;
  visibility: visible !important;
}
#tableauDevis td.action-column .devis-actions:focus-within{
  opacity: 1 !important;
  visibility: visible !important;
}

/* alignement colonne */
#tableauDevis td.action-column{
  padding-left: 0 !important;
  padding-right: .15rem !important;
  text-align: right;
}


/* ✅ Menu actions "floaté" au-dessus de tout */
body .devis-floating-dropdown{
  z-index: 20000 !important;
}





  </style>

  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/style-table.css') }}">
  <link rel="stylesheet" href="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/datatables.min.css"/>
  <link rel="stylesheet" href="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.css"/>
{% endblock %}

