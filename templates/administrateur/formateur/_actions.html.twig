{# templates/administrateur/formateur/_actions.html.twig #}

<div class="btn-group btn-group-sm formateur-actions" role="group">

  {# ✅ Bouton principal = éditer #}
  <a class="btn btn-light formateur-main"
     data-bs-toggle="tooltip" title="Éditer"
     href="{{ path('app_administrateur_formateur_modifier', { entite: entite.id, id: formateur.id }) }}">
    <i class="bi bi-pencil"></i>
  </a>

  {# ✅ Split dropdown #}
  <button type="button"
          class="btn btn-light dropdown-toggle dropdown-toggle-split formateur-split"
          data-bs-toggle="dropdown" aria-expanded="false">
    <span class="visually-hidden">Actions</span>
  </button>

  <ul class="dropdown-menu dropdown-menu-end formateur-menu">

    <li>
      <a class="dropdown-item d-flex align-items-center"
         href="{{ path('app_administrateur_formateur_modifier', { entite: entite.id, id: formateur.id }) }}">
        <i class="bi bi-pencil me-2"></i> Modifier
      </a>
    </li>

    {# (optionnel) si tu as une page show #}
    {#
    <li>
      <a class="dropdown-item d-flex align-items-center"
         href="{{ path('app_administrateur_formateur_show', { entite: entite.id, id: formateur.id }) }}">
        <i class="bi bi-eye me-2"></i> Ouvrir
      </a>
    </li>
    #}

    <li><hr class="dropdown-divider"></li>

    <li>
      <button type="button"
              class="dropdown-item d-flex align-items-center text-danger delete-btn"
              data-bs-toggle="modal"
              data-bs-target="#deleteModal"
              data-url="{{ path('app_administrateur_formateur_supprimer', { entite: entite.id, id: formateur.id }) }}">
        <i class="bi bi-trash me-2"></i> Supprimer
      </button>
    </li>

  </ul>
</div>
