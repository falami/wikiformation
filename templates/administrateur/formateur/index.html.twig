          <button type="button" class="btn btn-outline-light btn-sm fw-semibold"
                  onclick="document.getElementById('filtersCollapse')?.scrollIntoView({behavior:'smooth'})">
            <i class="bi bi-funnel me-1"></i> Filtres
          </button>
        </div>
      </div>
    </div>
  </div>

  {# KPI (depuis la page DataTables visible) #}
  <div class="row g-3 mb-3">
    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-people fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Formateurs</div>
              <div class="kpi-value" id="kpi-total">—</div>
              <div class="kpi-sub">Total (filtré)</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-calendar3 fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Sessions</div>
              <div class="kpi-value" id="kpi-sessions">—</div>
              <div class="kpi-sub">Somme des sessions</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-award fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Qualifs (moy.)</div>
              <div class="kpi-value" id="kpi-qualifs">—</div>
              <div class="kpi-sub">Engins qualifiés</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-geo-alt fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Sites (moy.)</div>
              <div class="kpi-value" id="kpi-sites">—</div>
              <div class="kpi-sub">Sites préférés</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  {# FILTERBAR #}
  <div class="filterbar mb-3">
    <div class="filterbar__top">
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <div class="filter-icon"><i class="bi bi-funnel"></i></div>
        <div>
          <div class="filterbar__title">Filtres</div>
          <div class="filterbar__hint">Affiner par engin / site + recherche nom.</div>
        </div>
      </div>

      <div class="ms-auto d-flex gap-2 align-items-center">
        <button class="btn btn-outline-secondary btn-sm fw-semibold d-md-none"
                type="button" data-bs-toggle="collapse" data-bs-target="#filtersCollapse">
          <i class="bi bi-sliders"></i> Filtres
        </button>

        <div class="dropdown">
          <button class="btn btn-warning btn-sm fw-semibold dropdown-toggle" data-bs-toggle="dropdown">
            <i class="bi bi-download"></i> Export
          </button>
          <ul class="dropdown-menu dropdown-menu-end" id="exportMenu"></ul>
        </div>
      </div>
    </div>

    <div class="collapse d-md-block" id="filtersCollapse">
      <div class="filterbar__body">
        <div class="filtergrid">

          <div class="filter-control fcol-engin">
            <div class="form-label">Engin qualifié</div>
            <div class="filterbox">
              <div class="filterrow">
                <div class="filter-icon"><i class="bi bi-truck-front"></i></div>
                <select id="enginFilter" class="form-select form-select-sm">
                  <option value="all">Tous</option>
                </select>
              </div>
            </div>
          </div>

          <div class="filter-control fcol-site">
            <div class="form-label">Site préféré</div>
            <div class="filterbox">
              <div class="filterrow">
                <div class="filter-icon"><i class="bi bi-geo-alt"></i></div>
                <select id="siteFilter" class="form-select form-select-sm">
                  <option value="all">Tous</option>
                </select>
              </div>
            </div>
          </div>

          <div class="filter-control fcol-search">
            <div class="form-label">Nom / certifs</div>
            <div class="filterbox">
              <div class="filterrow">
                <div class="filter-icon"><i class="bi bi-search"></i></div>
                <input type="text" id="quickSearch" class="form-control form-control-sm" placeholder="Nom, prénom, certifs…">
              </div>
            </div>
          </div>

          <div class="fcol-actions">
            <div class="form-label">&nbsp;</div>
            <button id="btnReset" type="button" class="resetbox w-100" title="Réinitialiser les filtres">
              <span class="filterrow w-100">
                <span class="filter-icon"><i class="bi bi-arrow-counterclockwise"></i></span>
                <span class="resetbox__text flex-grow-1">Reset</span>
                <span class="resetbox__badge" id="resetCount" style="display:none;">0</span>
              </span>
            </button>
          </div>

        </div>
      </div>
    </div>
  </div>

  {# TABLE #}
  <div class="table-card mb-4 p-3">
    <table id="tableauFormateur" class="table table-hover align-middle mb-0 w-100">
      <thead>
        <tr>
          <th>#</th>
          <th>Nom</th>
          <th>Certifications</th>
          <th>Engins qualifiés</th>
          <th>Sites préférés</th>
          <th>Sessions</th>
          <th class="text-end"></th>
        </tr>
      </thead>
      <tbody></tbody>
    </table>
  </div>


{% include 'partials/_modales_index_generiques.html.twig' %}

<script>
$(function(){
  const $engin = $('#enginFilter');
  const $site  = $('#siteFilter');
  const $q     = $('#quickSearch');

  let tsEngin=null, tsSite=null;

  function nowLabel(){
    const d = new Date();
    return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
  }

  function initTomSelect(){
    const common = {
      create:false,
      allowEmptyOption:true,
      maxItems:1,
      plugins:['clear_button'],
      render:{ no_results: () => '<div class="px-2 py-1 text-muted">Aucun résultat</div>' }
    };
    tsEngin?.destroy(); tsSite?.destroy();
    tsEngin = new TomSelect('#enginFilter', { ...common, placeholder:'Tous' });
    tsSite  = new TomSelect('#siteFilter',  { ...common, placeholder:'Tous' });

    tsEngin.on('change', ()=> refreshAll(true));
    tsSite.on('change', ()=> refreshAll(true));
  }

  function updateResetUi(count){
    const btn = document.getElementById('btnReset');
    const badge = document.getElementById('resetCount');
    if(!btn || !badge) return;

    if(count > 0){
      btn.disabled = false;
      btn.classList.add('is-active');
      badge.style.display = 'inline-flex';
      badge.textContent = String(count);
    } else {
      btn.disabled = true;
      btn.classList.remove('is-active');
      badge.style.display = 'none';
      badge.textContent = '0';
    }
  }

  function countActiveFilters(){
    let c = 0;
    if(($engin.val() || 'all') !== 'all') c++;
    if(($site.val() || 'all') !== 'all') c++;
    if(($q.val() || '').trim() !== '') c++;
    return c;
  }

  function computeKpisFromCurrentRows(api){
    const data = api.rows({ search: 'applied' }).data().toArray();
    const total = data.length;

    let sumSessions = 0;
    let sumQualifs = 0;
    let sumSites = 0;

    data.forEach(r => {
      const ns = parseInt(String(r.nbSessions ?? '').replace(/[^\d]/g,''), 10);
      if(!Number.isNaN(ns)) sumSessions += ns;

      const qual = String(r.enginsQualifies ?? '').trim();
      if(qual && qual !== '—') sumQualifs += qual.split(',').map(x=>x.trim()).filter(Boolean).length;

      const sites = String(r.sitesPreferes ?? '').trim();
      if(sites && sites !== '—') sumSites += sites.split(',').map(x=>x.trim()).filter(Boolean).length;
    });

    const avgQual = total ? (sumQualifs / total) : 0;
    const avgSites = total ? (sumSites / total) : 0;

    $('#kpi-total').text(total);
    $('#kpi-sessions').text(sumSessions);
    $('#kpi-qualifs').text(total ? (Math.round(avgQual*10)/10).toString().replace('.', ',') : '—');
    $('#kpi-sites').text(total ? (Math.round(avgSites*10)/10).toString().replace('.', ',') : '—');
    $('#hero-last-refresh').text('Maj : ' + nowLabel());
  }

  function refreshAll(resetPaging=false){
    table.ajax.reload(null, !resetPaging ? false : true);
  }

  const table = $('#tableauFormateur').DataTable({
    serverSide:true,
    processing:true,
    autoWidth: false,
    scrollX: true,
    scrollCollapse: true,
    responsive: false,

    ajax:{
      url:"{{ path('app_administrateur_formateur_ajax', { entite: entite.id }) }}",
      type:"POST",
      data: function(d){
        // ⚠️ Ces champs seront ignorés tant que ton contrôleur n’applique pas les filtres.
        d.enginFilter = $engin.val() || 'all';
        d.siteFilter  = $site.val() || 'all';
      }
    },

    dom:
      '<"dt-top d-flex flex-wrap gap-2 align-items-center justify-content-between"'
        + '<"dt-actions d-flex gap-2 align-items-center"B>'
        + '<"dt-search d-none"f>'  // on masque la search DataTables, on utilise notre input
      + '>'
      + 'rt'
      + '<"dt-bottom-internal d-flex flex-wrap gap-2 align-items-center justify-content-between"lip>',

    buttons:['copy','csv','excel','pdf','print'],
    lengthMenu:[[10,25,50,500],[10,25,50,500]],

    columns:[
      {data:'id'},
      {data:'nom'},
      {data:'certifications'},
      {data:'enginsQualifies'},
      {data:'sitesPreferes'},
      {data:'nbSessions'},
      {data:'actions'}
    ],

    order:[[0,'desc']],
    language:{ url:'https://cdn.datatables.net/plug-ins/2.2.2/i18n/fr-FR.json' },
    columnDefs:[
      {targets:6, className:'action-column text-end', orderable:false, searchable:false},
      {type:'num', targets:0}
    ],

    initComplete:function(){
      const api = this.api();
      const $btns = $(api.buttons().container()).find('button');

      $('#exportMenu').empty();
      $btns.each(function(){
        const $b=$(this);
        $('<li><a class="dropdown-item" href="#">'+$b.text()+'</a></li>')
          .on('click',e=>{e.preventDefault();$b.click();})
          .appendTo('#exportMenu');
      });
      $(api.buttons().container()).hide();
    }
  });


  // ✅ Dropdown actions formateurs : on "flotte" le menu hors du scroll DataTables (sinon il est clippé)
  (function enableFormateurActionsFloatingDropdown(){
    document.addEventListener('show.bs.dropdown', function(e){
      const toggle = e.target;
      if (!toggle.closest('.formateur-actions')) return;

      const dd = toggle.closest('.dropdown, .btn-group');
      if (!dd) return;

      const menu = dd.querySelector('.dropdown-menu');
      if (!menu) return;

      if (!menu.__originalParent) menu.__originalParent = dd;

      document.body.appendChild(menu);
      menu.classList.add('formateur-floating-dropdown');

      const rect = toggle.getBoundingClientRect();

      menu.style.position = 'absolute';
      menu.style.top = '0px';
      menu.style.left = '0px';
      menu.style.display = 'block';

      const menuRect = menu.getBoundingClientRect();
      const top = rect.bottom + window.scrollY + 6;

      let left = (rect.right + window.scrollX - menuRect.width);
      left = Math.max(8, Math.min(left, window.scrollX + window.innerWidth - menuRect.width - 8));

      menu.style.top = `${top}px`;
      menu.style.left = `${left}px`;
    }, true);

    document.addEventListener('hidden.bs.dropdown', function(e){
      const toggle = e.target;
      if (!toggle.closest('.formateur-actions')) return;

      const dd = toggle.closest('.dropdown, .btn-group');
      if (!dd) return;

      document.querySelectorAll('body .formateur-floating-dropdown').forEach(menu => {
        if (menu.__originalParent === dd) {
          dd.appendChild(menu);
          menu.classList.remove('formateur-floating-dropdown');
          menu.style.position = '';
          menu.style.top = '';
          menu.style.left = '';
          menu.style.display = '';
        }
      });
    }, true);

    // ✅ si scroll/resize : ferme les menus ouverts
    window.addEventListener('scroll', () => {
      document.querySelectorAll('.formateur-actions [aria-expanded="true"][data-bs-toggle="dropdown"]')
        .forEach(btn => btn.click());
    }, true);

    window.addEventListener('resize', () => {
      document.querySelectorAll('.formateur-actions [aria-expanded="true"][data-bs-toggle="dropdown"]')
        .forEach(btn => btn.click());
    }, true);
  })();


  function dtAdjust(){ table.columns.adjust(); }
  table.on('init.dt', function(){ setTimeout(dtAdjust, 50); setTimeout(dtAdjust, 250); });

  table.on('draw.dt', function(){
    dtAdjust();
    computeKpisFromCurrentRows(table);
    updateResetUi(countActiveFilters());
  });

  // Recherche custom => utilise la recherche DataTables serveur (search.value)
  let tSearch=null;
  $q.on('input', function(){
    clearTimeout(tSearch);
    tSearch = setTimeout(function(){
      table.search(($q.val() || '').trim()).draw();
      refreshAll(true);
    }, 300);
  });

  // Reset
  $('#btnReset').on('click', function(){
    tsEngin ? tsEngin.setValue('all', true) : $engin.val('all');
    tsSite  ? tsSite.setValue('all', true)  : $site.val('all');
    $q.val('');
    table.search('').draw();
    refreshAll(true);
  });

  // Modales génériques
  $(document).on('click','.delete-btn',e=>$('#confirmDelete').attr('href', $(e.currentTarget).data('url')));

  // init
  initTomSelect();

  async function loadMeta(){
    const url = "{{ path('app_administrateur_formateur_meta', { entite: entite.id }) }}";
    const res = await fetch(url, { headers: { 'Accept':'application/json' }});
    if(!res.ok) return;

    const json = await res.json();

    const fill = (id, list) => {
      const el = document.querySelector(id);
      if(!el || !el.tomselect) return;
      const ts = el.tomselect;

      ts.clearOptions();
      ts.addOption({ value:'all', text:'Tous' });
      (list || []).forEach(x => ts.addOption({ value:String(x.id), text:x.label }));
      ts.refreshOptions(false);
      ts.setValue('all', true);
    };

    fill('#enginFilter', json.engins);
    fill('#siteFilter',  json.sites);
  }
  loadMeta();



  updateResetUi(0);
  $('#hero-last-refresh').text('Maj : ' + nowLabel());
});
</script>
{% endblock %}
