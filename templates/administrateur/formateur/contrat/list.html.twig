<script>
$(function(){

  const $status = $('#statusFilter');
  const $formateur = $('#formateurFilter');
  const $session = $('#sessionFilter');

  function nowLabel(){
    const d = new Date();
    return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
  }

  let tsStatus=null, tsFormateur=null, tsSession=null;

  function initTomSelect(){
    const common = {
      create:false,
      allowEmptyOption:true,
      maxItems:1,
      plugins:['clear_button'],
      render:{ no_results: () => '<div class="px-2 py-1 text-muted">Aucun résultat</div>' }
    };

    tsStatus?.destroy(); tsFormateur?.destroy(); tsSession?.destroy();
    tsStatus = new TomSelect('#statusFilter', { ...common, placeholder:'Tous' });
    tsFormateur = new TomSelect('#formateurFilter', { ...common, placeholder:'Tous' });
    tsSession = new TomSelect('#sessionFilter', { ...common, placeholder:'Toutes' });

    tsStatus.on('change', ()=>refreshAll(true));
    tsFormateur.on('change', ()=>refreshAll(true));
    tsSession.on('change', ()=>refreshAll(true));
  }

  async function loadMeta(){
    const url = "{{ path('app_administrateur_formateurs_contrats_meta', { entite: entite.id }) }}";
    const res = await fetch(url, { headers:{'Accept':'application/json'} });
    if(!res.ok) return;
    const json = await res.json();

    // statuses
    tsStatus.clearOptions();
    tsStatus.addOption({ value:'all', text:'Tous' });
    (json.statuses || []).forEach(x => tsStatus.addOption({ value:String(x.value), text:String(x.label) }));
    tsStatus.refreshOptions(false);
    tsStatus.setValue('all', true);

    // formateurs
    tsFormateur.clearOptions();
    tsFormateur.addOption({ value:'all', text:'Tous' });
    (json.formateurs || []).forEach(x => tsFormateur.addOption({ value:String(x.id), text:String(x.label) }));
    tsFormateur.refreshOptions(false);
    tsFormateur.setValue('all', true);

    // sessions
    tsSession.clearOptions();
    tsSession.addOption({ value:'all', text:'Toutes' });
    (json.sessions || []).forEach(x => tsSession.addOption({ value:String(x.id), text:String(x.label) }));
    tsSession.refreshOptions(false);
    tsSession.setValue('all', true);
  }

  async function loadKpis(){
    const params = new URLSearchParams();
    params.set('status', $status.val() || 'all');
    params.set('formateur', $formateur.val() || 'all');
    params.set('session', $session.val() || 'all');

    const url = "{{ path('app_administrateur_formateurs_contrats_kpis', { entite: entite.id }) }}?" + params.toString();
    const res = await fetch(url, { headers:{'Accept':'application/json'} });
    if(!res.ok) return;
    const k = await res.json();

    $('#kpi-count').text(k.total ?? '—');

    const by = k.byStatus || {};
    $('#kpi-sent').text(by.ENVOYE ?? 0);
    $('#kpi-signed').text(by.SIGNE ?? 0);
    $('#kpi-archive').text(by.ARCHIVE ?? 0);

    $('#hero-last-refresh').text('Maj : ' + nowLabel());
  }

  function updateResetUi(count){
    const btn = document.getElementById('btnReset');
    const badge = document.getElementById('resetCount');
    if(!btn || !badge) return;

    if(count > 0){
      btn.disabled = false;
      btn.classList.add('is-active');
      badge.style.display = 'inline-flex';
      badge.textContent = String(count);
    } else {
      btn.disabled = true;
      btn.classList.remove('is-active');
      badge.style.display = 'none';
      badge.textContent = '0';
    }
  }

  function buildActiveFilters(){
    const items = [];

    const st = ($status.val() || 'all');
    if(st !== 'all'){
      items.push({ key:'status', label:'Statut', value: $('#statusFilter option:selected').text() });
    }

    const fo = ($formateur.val() || 'all');
    if(fo !== 'all'){
      items.push({ key:'formateur', label:'Formateur', value: $('#formateurFilter option:selected').text() });
    }

    const se = ($session.val() || 'all');
    if(se !== 'all'){
      items.push({ key:'session', label:'Session', value: $('#sessionFilter option:selected').text() });
    }

    const $wrap = $('#activeFilters');
    $wrap.find('.af-badge').remove();

    if(items.length === 0){
      $('#activeFiltersEmpty').show();
      updateResetUi(0);
      return;
    }

    $('#activeFiltersEmpty').hide();
    updateResetUi(items.length);

    items.forEach(it=>{
      const $b = $(`<span class="af-badge" data-key="${it.key}">
        <strong>${it.label} :</strong> ${it.value} <i class="bi bi-x-lg ms-1"></i>
      </span>`);

      $b.on('click', ()=>{
        if(it.key === 'status') tsStatus.setValue('all', true);
        if(it.key === 'formateur') tsFormateur.setValue('all', true);
        if(it.key === 'session') tsSession.setValue('all', true);
        refreshAll(true);
      });

      $wrap.append($b);
    });
  }

  // DataTable
  const table = $('#tableContrats').DataTable({
    serverSide:true,
    processing:true,
    autoWidth:true,

    scrollX:true,
    scrollCollapse:true,
    responsive:false,

    ajax:{
      url:"{{ path('app_administrateur_formateurs_contrats_ajax', { entite: entite.id }) }}",
      type:"POST",
      data: d => {
        d.statusFilter = $status.val() || 'all';
        d.formateurFilter = $formateur.val() || 'all';
        d.sessionFilter = $session.val() || 'all';
      }
    },

    dom:
      '<"dt-top d-flex flex-wrap gap-2 align-items-center justify-content-between"'
        + '<"dt-actions d-flex gap-2 align-items-center"B>'
        + '<"dt-search"f>'
      + '>'
      + 'rt'
      + '<"dt-bottom-internal d-flex flex-wrap gap-2 align-items-center justify-content-between"lip>',

    buttons:['copy','csv','excel','pdf','print'],
    lengthMenu:[[10,25,50,200],[10,25,50,200]],

    order:[[3,'desc']], // date création

    language:{ url:'https://cdn.datatables.net/plug-ins/2.2.2/i18n/fr-FR.json' },

    columns:[
      {data:'numero'},
      {data:'formateur'},
      {data:'session'},
      {data:'dateCreation'},
      {data:'signatureAt'},
      {data:'status'},
      {data:'actions'}
    ],
    columnDefs:[
      {targets:6, className:'action-column text-end', orderable:false, searchable:false},
      {targets:[1,2,4,5], orderable:false}
    ],

    initComplete:function(){
      const api = this.api();
      const $btns = $(api.buttons().container()).find('button');

      $('#exportMenu').empty();
      $btns.each(function(){
        const $b=$(this);
        $('<li><a class="dropdown-item" href="#">'+$b.text()+'</a></li>')
          .on('click',e=>{e.preventDefault();$b.click();})
          .appendTo('#exportMenu');
      });
      $(api.buttons().container()).hide();

      api.columns.adjust();
    }
  });

  function dtAdjust(){ table.columns.adjust(); }

  table.on('init.dt', function(){
    setTimeout(dtAdjust, 50);
    setTimeout(dtAdjust, 250);
  });
  table.on('draw.dt', function(){
    dtAdjust();
    $('#hero-last-refresh').text('Maj : ' + nowLabel());
  });

  // refresh global (DT + KPI + active filters)
  function refreshAll(resetPaging=false){
    table.ajax.reload(null, !resetPaging ? false : true);
    loadKpis();
    buildActiveFilters();
  }


  // ✅ branche la modale delete sur le bouton
  $(document).on('click', '.delete-btn', function(){
    const url = $(this).data('url');
    const token = $(this).data('token');

    $('#deleteForm').attr('action', url);
    $('#deleteToken').val(token || '');
  });


  // Reset
  $('#btnReset').on('click', function(){
    tsStatus.setValue('all', true);
    tsFormateur.setValue('all', true);
    tsSession.setValue('all', true);

    table.search('').draw();
    refreshAll(true);
  });

  // init
  initTomSelect();

  loadMeta().then(()=>{
    loadKpis();
    buildActiveFilters();
  });

    const defaults = {
    cg: {{ (entite.preferences and entite.preferences.contratFormateurConditionsGeneralesDefault ? entite.preferences.contratFormateurConditionsGeneralesDefault : '')|json_encode|raw }},
    cp: {{ (entite.preferences and entite.preferences.contratFormateurConditionsParticulieresDefault ? entite.preferences.contratFormateurConditionsParticulieresDefault : '')|json_encode|raw }},
  };

  if (btnReset) {
    btnReset.addEventListener('click', () => {
      if (inputCg && defaults.cg) inputCg.value = defaults.cg;
      if (inputCp && defaults.cp) inputCp.value = defaults.cp;
    });
  }



});
</script>
{% endblock %}
