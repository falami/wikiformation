{% include 'partials/_modales_index_generiques.html.twig' %}

<script>
$(function(){
  const $roles    = $('#rolesFilter');
  const $verified = $('#verifiedFilter');
  const $locked   = $('#lockedFilter');
  const $search   = $('#searchName');

  function nowLabel(){
    const d = new Date();
    return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
  }

  function escapeHtml(str){
    return String(str).replace(/[&<>"']/g, s => ({
      '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'
    }[s]));
  }

  let tsRoles = null, tsVerified = null, tsLocked = null;
  function initTomSelect(){
    const common = {
      create: false,
      allowEmptyOption: true,
      maxItems: 1,
      plugins: ['clear_button'],
      render: { no_results: () => '<div class="px-2 py-1 text-muted">Aucun résultat</div>' }
    };
    tsRoles?.destroy(); tsVerified?.destroy(); tsLocked?.destroy();
    tsRoles    = new TomSelect('#rolesFilter',    {...common, placeholder:'Tous'});
    tsVerified = new TomSelect('#verifiedFilter', {...common, placeholder:'Tous'});
    tsLocked   = new TomSelect('#lockedFilter',   {...common, placeholder:'Tous'});

    tsRoles.on('change',    () => refreshAll(true));
    tsVerified.on('change', () => refreshAll(true));
    tsLocked.on('change',   () => refreshAll(true));
  }

  function updateResetUi(count){
    const btn = document.getElementById('btnReset');
    const badge = document.getElementById('resetCount');
    if(!btn || !badge) return;

    if(count > 0){
      btn.disabled = false;
      btn.classList.add('is-active');
      badge.style.display = 'inline-flex';
      badge.textContent = String(count);
    } else {
      btn.disabled = true;
      btn.classList.remove('is-active');
      badge.style.display = 'none';
      badge.textContent = '0';
    }
  }

  function buildActiveFilters(){
    const items = [];

    const r = $roles.val();
    if(r && r !== 'all') items.push({ key:'role', label:'Rôle', value: $('#rolesFilter option:selected').text() });

    const v = $verified.val();
    if(v && v !== 'all') items.push({ key:'verified', label:'Vérifié', value: (v === '1' ? 'Oui' : 'Non') });

    const l = $locked.val();
    if(l && l !== 'all') items.push({ key:'locked', label:'Verrouillé', value: (l === '1' ? 'Oui' : 'Non') });

    const s = ($search.val() || '').trim();
    if(s) items.push({ key:'search', label:'Recherche', value: s });

    const $wrap = $('#activeFilters');
    $wrap.find('.af-badge').remove();

    if(items.length === 0){
      $('#activeFiltersEmpty').show();
      updateResetUi(0);
      return;
    }

    $('#activeFiltersEmpty').hide();
    updateResetUi(items.length);

    items.forEach(it=>{
      const $b = $(`<span class="af-badge" data-key="${it.key}">
        <strong>${it.label} :</strong> ${escapeHtml(it.value)} <i class="bi bi-x-lg ms-1"></i>
      </span>`);

      $b.on('click', ()=>{
        switch(it.key){
          case 'role':     tsRoles.setValue('all', true); break;
          case 'verified': tsVerified.setValue('all', true); break;
          case 'locked':   tsLocked.setValue('all', true); break;
          case 'search':   $search.val(''); break;
        }
        refreshAll(true);
      });

      $wrap.append($b);
    });
  }


  // ✅ Dropdown actions users : on "flotte" le menu hors du scroll DataTables (sinon il est clippé)
  (function enableUserActionsFloatingDropdown(){
    document.addEventListener('show.bs.dropdown', function(e){
      const toggle = e.target;
      if (!toggle.closest('.user-actions')) return;

      const dd = toggle.closest('.dropdown, .btn-group');
      if (!dd) return;

      const menu = dd.querySelector('.dropdown-menu');
      if (!menu) return;

      if (!menu.__originalParent) menu.__originalParent = dd;

      document.body.appendChild(menu);
      menu.classList.add('user-floating-dropdown');

      const rect = toggle.getBoundingClientRect();

      menu.style.position = 'absolute';
      menu.style.top = '0px';
      menu.style.left = '0px';
      menu.style.display = 'block';
      const menuRect = menu.getBoundingClientRect();

      const isEnd = menu.classList.contains('dropdown-menu-end') || menu.classList.contains('dropdown-menu-end');
      const top = rect.bottom + window.scrollY + 6;

      let left = isEnd
        ? (rect.right + window.scrollX - menuRect.width)
        : (rect.left + window.scrollX);

      left = Math.max(8, Math.min(left, window.scrollX + window.innerWidth - menuRect.width - 8));

      menu.style.top = `${top}px`;
      menu.style.left = `${left}px`;
    }, true);

    document.addEventListener('hidden.bs.dropdown', function(e){
      const toggle = e.target;
      if (!toggle.closest('.user-actions')) return;

      const dd = toggle.closest('.dropdown, .btn-group');
      if (!dd) return;

      document.querySelectorAll('body .user-floating-dropdown').forEach(menu => {
        if (menu.__originalParent === dd) {
          dd.appendChild(menu);
          menu.classList.remove('user-floating-dropdown');
          menu.style.position = '';
          menu.style.top = '';
          menu.style.left = '';
          menu.style.display = '';
        }
      });
    }, true);

    // ferme les menus ouverts si scroll/resize
    window.addEventListener('scroll', () => {
      document.querySelectorAll('.user-actions [aria-expanded="true"][data-bs-toggle="dropdown"]')
        .forEach(btn => btn.click());
    }, true);

    window.addEventListener('resize', () => {
      document.querySelectorAll('.user-actions [aria-expanded="true"][data-bs-toggle="dropdown"]')
        .forEach(btn => btn.click());
    }, true);
  })();


  const table = $('#tableauUtilisateur').DataTable({
    serverSide:true,
    processing:true,
    autoWidth: false,
    scrollX: true,
    scrollCollapse: true,
    responsive: false,

    ajax:{
      url:"{{ path('app_administrateur_utilisateur_ajax', { entite: entite.id }) }}",
      type:"POST",
      data: d => {
        d.rolesFilter    = $roles.val() || 'all';
        d.verifiedFilter = $verified.val() || 'all';
        d.lockedFilter   = $locked.val() || 'all';
        d.searchName     = $search.val() || '';
      }
    },

    dom:
      '<"dt-top d-flex flex-wrap gap-2 align-items-center justify-content-between"'
        + '<"dt-actions d-flex gap-2 align-items-center"B>'
        + '<"dt-search"f>'
      + '>'
      + 'rt'
      + '<"dt-bottom-internal d-flex flex-wrap gap-2 align-items-center justify-content-between"lip>',

    buttons:['copy','csv','excel','pdf','print'],
    lengthMenu:[[10,25,50,500],[10,25,50,500]],

    columns:[
      {data:'id', name:'id'},
      {data:'nom', name:'nom'},
      {data:'prenom', name:'prenom'},
      {data:'email', name:'email'},
      {
        data:'roles',
        name:'roles',
        orderable:false,
        render: function(data, type, row){
          if(type !== 'display') return data || '';

          const raw = (data || '').split(',').map(s => s.trim()).filter(Boolean);

          const map = {
            'TENANT_STAGIAIRE':  { label:'Stagiaire',              cls:'rb-stagiaire',  icon:'bi-mortarboard',    prio: 10 },
            'TENANT_FORMATEUR':  { label:'Formateur',              cls:'rb-formateur',  icon:'bi-easel2',         prio: 20 },
            'TENANT_ADMIN':      { label:'Administrateur',         cls:'rb-admin',      icon:'bi-shield-check',   prio: 30 },
            'TENANT_ENTREPRISE': { label:'Entreprise',             cls:'rb-entreprise', icon:'bi-building',       prio: 15 },
            'TENANT_OF':         { label:'Organisme de formation', cls:'rb-entreprise', icon:'bi-building',       prio: 15 },
            'TENANT_OPCO':       { label:'OPCO',                   cls:'rb-entreprise', icon:'bi-building',       prio: 15 },
            'TENANT_COMMERCIAL': { label:'Commercial',             cls:'rb-commercial', icon:'bi-graph-up-arrow', prio: 25 },
            'TENANT_DIRIGEANT':  { label:'Dirigeant',              cls:'rb-admin',      icon:'bi-award',          prio: 28 },
          };

          const picked = raw
            .map(r => map[r] ? ({ code:r, ...map[r] }) : ({ code:r, label:r.replace('ROLE_',''), cls:'', icon:'bi-person', prio: 1 }))
            .filter(x => x.code !== 'ROLE_USER')
            .sort((a,b)=> b.prio - a.prio);

          if (!picked.length) return '<span class="text-muted">—</span>';

          const badges = picked.map(r =>
            `<span class="role-badge ${r.cls}"><i class="bi ${r.icon}"></i>${escapeHtml(r.label)}</span>`
          ).join('');

          return `<div class="role-badges">${badges}</div>`;
        }
      },
      {data:'inscriptions', name:'inscriptions'},
      {data:'verified', name:'verified'},
      {data:'locked', name:'locked'},
      {data:'actions', name:'actions'}
    ],

    columnDefs:[
      {targets:8, className:'action-column text-end', orderable:false, searchable:false},
      {targets:[6,7], visible:false},
      {targets:[1,2,3,4,5], className:'text-center'}
    ],

    order:[[0,'desc']],
    language:{ url:'https://cdn.datatables.net/plug-ins/2.2.2/i18n/fr-FR.json' },

    initComplete:function(){
      const api = this.api();
      const $btns = $(api.buttons().container()).find('button');

      $('#exportMenu').empty();
      $btns.each(function(){
        const $b=$(this);
        $('<li><a class="dropdown-item" href="#">'+$b.text()+'</a></li>')
          .on('click',e=>{e.preventDefault();$b.click();})
          .appendTo('#exportMenu');
      });
      $(api.buttons().container()).hide();
      api.columns.adjust();
    }
  });

  function refreshAll(resetPaging=false){
    table.ajax.reload(null, !resetPaging ? false : true);
    buildActiveFilters();
    $('#hero-last-refresh').text('Maj : ' + nowLabel());
  }

  function dtAdjust(){ table.columns.adjust(); }
  table.on('init.dt', () => setTimeout(dtAdjust, 60));
  table.on('draw.dt', () => dtAdjust());
  window.addEventListener('resize', () => setTimeout(dtAdjust, 150));

  // Search debounce (filtre “Recherche” local)
  let tSearch = null;
  $search.on('input', ()=>{
    clearTimeout(tSearch);
    tSearch = setTimeout(()=>refreshAll(true), 300);
  });

  // Reset
  $('#btnReset').on('click', function(){
    tsRoles.setValue('all', true);
    tsVerified.setValue('all', true);
    tsLocked.setValue('all', true);
    $search.val('');
    table.search('');
    refreshAll(true);
  });

  // Delete modal
  $(document).on('click', '.delete-btn', function () {
    const url   = $(this).data('url');
    const token = $(this).data('token');

    $('#deleteForm').attr('action', url);
    $('#deleteToken').val(token);
  });


  // Init
  initTomSelect();
  buildActiveFilters();
  $('#hero-last-refresh').text('Maj : ' + nowLabel());





  // ✅ Helper anti double-clic + loading pour une modal "submit"
  function bindConfirmModal({
    modalId,
    triggerSelector,
    labelId,
    checkId,
    btnId,
    formId,
    tokenId,
    lockedText,     // ex: "Envoi..."
    lockedIconHtml  // ex: '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>'
  }) {
    const modalEl = document.getElementById(modalId);
    if (!modalEl) return;

    const label = document.getElementById(labelId);
    const chk   = document.getElementById(checkId);
    const btn   = document.getElementById(btnId);
    const form  = document.getElementById(formId);
    const token = document.getElementById(tokenId);

    let submitting = false;
    let originalBtnHtml = btn ? btn.innerHTML : '';

    const closeBtn = modalEl.querySelector('.btn-close');

    function lockUI() {
      submitting = true;

      if (btn) {
        btn.disabled = true;
        btn.setAttribute('aria-busy', 'true');
        btn.innerHTML = (lockedIconHtml || '') + (lockedText || 'Traitement...');
      }

      // optionnel : éviter fermeture pendant l'envoi
      if (closeBtn) closeBtn.disabled = true;

      // optionnel : empêcher backdrop/esc
      const instance = bootstrap.Modal.getInstance(modalEl);
      if (instance) {
        modalEl.setAttribute('data-bs-backdrop', 'static');
        modalEl.setAttribute('data-bs-keyboard', 'false');
      }
    }

    function unlockUI() {
      submitting = false;

      if (btn) {
        btn.disabled = !(chk && chk.checked);
        btn.removeAttribute('aria-busy');
        btn.innerHTML = originalBtnHtml;
      }
      if (closeBtn) closeBtn.disabled = false;

      modalEl.removeAttribute('data-bs-backdrop');
      modalEl.removeAttribute('data-bs-keyboard');
    }

    function resetState() {
      submitting = false;
      if (label) label.textContent = '—';
      if (chk) chk.checked = false;
      if (btn) {
        btn.disabled = true;
        btn.removeAttribute('aria-busy');
        btn.innerHTML = originalBtnHtml;
      }
      if (form) form.setAttribute('action', '#');
      if (token) token.value = '';
      if (closeBtn) closeBtn.disabled = false;
    }

    // Remplissage depuis le trigger
    document.addEventListener('click', function (e) {
      const trigger = e.target.closest(triggerSelector);
      if (!trigger) return;

      const user = trigger.getAttribute('data-user') || trigger.dataset.user || '—';
      const url  = trigger.getAttribute('data-url')  || trigger.dataset.url  || '#';
      const csrf = trigger.getAttribute('data-token')|| trigger.dataset.token|| '';

      if (label) label.textContent = user;
      if (form)  form.setAttribute('action', url);
      if (token) token.value = csrf;

      // reset checkbox / bouton à l'ouverture
      if (chk) chk.checked = false;
      if (btn) btn.disabled = true;
      unlockUI();
    });

    // Checkbox => active/désactive le bouton
    chk?.addEventListener('change', () => {
      if (!btn) return;
      if (submitting) { btn.disabled = true; return; }
      btn.disabled = !chk.checked;
    });

    // Click confirmer => lock + submit
    btn?.addEventListener('click', () => {
      if (submitting) return;
      if (!chk || !chk.checked) return;

      lockUI();

      // 🔒 sécurité ultime : empêche double submit même si submit appelé ailleurs
      if (form && !form.dataset.submitted) {
        form.dataset.submitted = '1';
        form.submit();
      }
    });

    // Empêche Enter de resoumettre si quelqu'un focus un champ (ici il n'y en a pas, mais safe)
    form?.addEventListener('submit', (e) => {
      if (submitting) return;
      // si un submit "manuel" arrive, on lock quand même
      lockUI();
    });

    // Reset à la fermeture
    modalEl.addEventListener('hidden.bs.modal', () => {
      if (form) delete form.dataset.submitted;
      resetState();
    });
  }


  // ✅ Bind 1 : activation
  bindConfirmModal({
    modalId: 'activationModal',
    triggerSelector: '.js-open-activation-modal',
    labelId: 'activationUserLabel',
    checkId: 'confirmActivationCheck',
    btnId: 'btnConfirmActivation',
    formId: 'activationForm',
    tokenId: 'activationToken',
    lockedText: 'Envoi...',
    lockedIconHtml: '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>'
  });

  // ✅ Bind 2 : reset password
  bindConfirmModal({
    modalId: 'resetPasswordModal',
    triggerSelector: '.js-open-reset-modal',
    labelId: 'resetUserLabel',
    checkId: 'confirmResetCheck',
    btnId: 'btnConfirmReset',
    formId: 'resetPasswordForm',
    tokenId: 'resetPasswordToken',
    lockedText: 'Génération...',
    lockedIconHtml: '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>'
  });





});
</script>
