{% extends 'base_admin.html.twig' %}
{% block title %}Modifier interaction #{{ interaction.id }}{% endblock %}


{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css">
  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }

  </style>
{% endblock %}

{% block body %}
<div class="container-fluid px-3 px-lg-4">
  {% include 'flagMessage.html.twig' %}

  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <div class="small text-muted">Utilisateur #{{ u.id }}</div>
      <div class="fw-bold">{{ u.prenom }} {{ u.nom|upper }}</div>
    </div>

    <a class="btn btn-outline-secondary btn-sm"
       href="{{ path('app_administrateur_utilisateur_show', { entite: entite.id, id: u.id }) }}">
      <i class="bi bi-arrow-left"></i> Retour
    </a>
  </div>

  <div class="card">
    <div class="card-header fw-bold">Modifier interaction</div>
    <div class="card-body">
      {{ form_start(form) }}
        {{ form_widget(form) }}
        <div class="mt-3 d-flex gap-2 justify-content-end">
          <a class="btn btn-light"
             href="{{ path('app_administrateur_utilisateur_show', { entite: entite.id, id: u.id }) }}">Annuler</a>
          <button class="btn btn-primary">Enregistrer</button>
        </div>
      {{ form_end(form) }}
    </div>
  </div>
</div>
{% endblock %}
