{# templates/administrateur/utilisateur/_actions.html.twig #}

<div class="btn-group btn-group-sm user-actions" role="group">

  {# ✅ Bouton principal = Modifier #}
  <a class="btn btn-light user-main"
     data-bs-toggle="tooltip" title="Modifier"
     href="{{ path('app_administrateur_utilisateur_modifier', { id: utilisateur.id, entite: entite.id }) }}">
    <i class="bi bi-pencil"></i>
  </a>

  {# ✅ Split dropdown #}
  <button type="button"
          class="btn btn-light dropdown-toggle dropdown-toggle-split user-split"
          data-bs-toggle="dropdown"
          data-bs-auto-close="outside"
          aria-expanded="false">
    <span class="visually-hidden">Actions</span>
  </button>

  <ul class="dropdown-menu dropdown-menu-end user-menu">

    {# Ouvrir #}
    <li>
      <a class="dropdown-item d-flex align-items-center"
         href="{{ path('app_administrateur_utilisateur_show', { id: utilisateur.id, entite: entite.id }) }}">
        <i class="bi bi-eye me-2"></i> Ouvrir
      </a>
    </li>

    <li><hr class="dropdown-divider"></li>

    {# ✅ Activation email (modal) #}
    <li>
      <button type="button"
              class="dropdown-item d-flex align-items-center text-success js-open-activation-modal"
              data-bs-toggle="modal"
              data-bs-target="#activationModal"
              data-user="{{ utilisateur.prenom ~ ' ' ~ utilisateur.nom|upper }}"
              data-url="{{ path('app_administrateur_utilisateur_send_activation', { id: utilisateur.id, entite: entite.id }) }}"
              data-token="{{ csrf_token('send_activation_' ~ utilisateur.id) }}">
        <i class="bi bi-envelope-check me-2"></i> Envoyer email d’activation
      </button>
    </li>

    {# ✅ Reset password (modal) #}
    <li>
      <button type="button"
              class="dropdown-item d-flex align-items-center text-primary js-open-reset-modal"
              data-bs-toggle="modal"
              data-bs-target="#resetPasswordModal"
              data-user="{{ utilisateur.prenom ~ ' ' ~ utilisateur.nom|upper }}"
              data-url="{{ path('app_administrateur_utilisateur_reset_password', { id: utilisateur.id, entite: entite.id }) }}"
              data-token="{{ csrf_token('reset_password_' ~ utilisateur.id) }}">
        <i class="bi bi-key me-2"></i> Reset mot de passe
      </button>
    </li>

    <li><hr class="dropdown-divider"></li>

    {# Supprimer / Lock #}
    <li>
      {% if not locked %}
        <button type="button"
                class="dropdown-item d-flex align-items-center text-danger delete-btn"
                data-bs-toggle="modal" data-bs-target="#deleteModal"
                data-url="{{ path('app_administrateur_utilisateur_supprimer', { id: utilisateur.id, entite: entite.id }) }}"
                data-token="{{ csrf_token('delete_user_' ~ utilisateur.id) }}">
          <i class="bi bi-trash me-2"></i> Supprimer
        </button>
      {% else %}
        <span class="dropdown-item d-flex align-items-center text-muted disabled">
          <i class="bi bi-lock me-2"></i> Utilisateur identifié
        </span>
      {% endif %}
    </li>

  </ul>
</div>
