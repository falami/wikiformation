{# templates/administrateur/utilisateur/_doc_email_modal.html.twig #}
<div class="modal fade modal-premium"
     id="userDocEmailModal"
     tabindex="-1"
     aria-hidden="true"
     data-preview-url="{{ previewUrl }}"
     data-send-url="{{ sendUrl }}">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content" style="border-radius:18px; overflow:hidden;">
      <div class="modal-header">
        <div>
          <h5 class="modal-title mb-0">Envoyer {{ docLabel|lower }}</h5>
          <div class="text-muted small">
            {{ docLabel }} <strong>{{ docNumber }}</strong> — Utilisateur :
            <strong>{{ (u.prenom ~ ' ' ~ u.nom)|trim }}</strong>
          </div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
      </div>

      <div class="modal-body">
        <form id="userDocSendForm">
          <input type="hidden" name="idemKey" value="{{ idemKey }}">
          <input type="hidden" name="docType" value="{{ docType }}">

          <div class="row g-3">
            <div class="col-12 col-md-6">
              <label class="form-label fw-semibold">Destinataire</label>
              <input class="form-control" name="to" value="{{ to }}" placeholder="email@exemple.com">
              <div class="form-text">Email de l’utilisateur (modifiable).</div>
            </div>

            <div class="col-12 col-md-6">
              <label class="form-label fw-semibold">Objet</label>
              <input class="form-control" name="subject" value="{{ subject }}" maxlength="160">
            </div>

            <div class="col-12">
              <label class="form-label fw-semibold">Message</label>
              <textarea class="form-control" name="message" rows="7"
                        placeholder="Bonjour {{ u.prenom }}, ...">{{ defaultMessage|default('') }}</textarea>
              <div class="form-text">
                Variables Twig dispo : <code>{{ '{{ utilisateur.prenom }}' }}</code>,
                <code>{{ '{{ entite.nom }}' }}</code>,
                <code>{{ '{{ devis.numero }}' }}</code> / <code>{{ '{{ facture.numero }}' }}</code> (selon le doc).
              </div>
            </div>

            <div class="col-12">
              <div class="d-flex flex-wrap gap-3 align-items-center">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="attachPdf"
                         name="attachPdf" value="1" {% if attachPdfDefault %}checked{% endif %}>
                  <label class="form-check-label" for="attachPdf">
                    Joindre le PDF
                  </label>
                </div>
              </div>
            </div>

            <div class="col-12">
              <div class="d-flex gap-2 justify-content-end">
                <button type="button" class="btn btn-outline-secondary" id="btnUserDocPreview">
                  <i class="bi bi-eye"></i> Aperçu
                </button>
                <button type="button" class="btn btn-warning fw-semibold" id="btnUserDocSend">
                  <i class="bi bi-send"></i> Envoyer
                </button>
              </div>
              <div class="small mt-2" id="userDocSendStatus" style="color:#0a7a2f;"></div>
            </div>
          </div>
        </form>

        <hr class="my-3">

        <div>
          <div class="d-flex align-items-center justify-content-between mb-2">
            <div class="fw-semibold">Aperçu email</div>
            <div class="text-muted small">Rendu HTML final</div>
          </div>

          <div id="userDocPreviewZone"
               style="border:1px solid rgba(0,0,0,.08); border-radius:14px; padding:12px; background:#fff;">
            <div class="text-muted small">Clique sur “Aperçu” pour générer le rendu.</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
