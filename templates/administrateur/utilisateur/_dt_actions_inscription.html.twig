{# templates/administrateur/utilisateur/_dt_actions_inscription.html.twig #}
<div class="btn-group dt-actions-compact" role="group">
  {# adapte selon tes routes existantes #}
  <a class="btn btn-outline-primary btn-sm"
     href="{{ path('app_administrateur_inscription_edit', { entite: entite.id, id: inscription.id }) }}"
     title="Ouvrir">
    <i class="bi bi-pencil"></i>
  </a>

  {% if inscription.session %}
    <a class="btn btn-outline-secondary btn-sm"
       href="{{ path('app_administrateur_session_edit', { entite: entite.id, id: inscription.session.id }) }}"
       title="Session">
      <i class="bi bi-mortarboard"></i>
    </a>
  {% endif %}
</div>
