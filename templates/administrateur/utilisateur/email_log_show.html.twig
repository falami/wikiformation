{# templates/administrateur/utilisateur/email_log_show.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Email #{{ log.id }} — {{ u.prenom }} {{ u.nom|upper }}{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
      --line: rgba(15,35,54,.10);
      --radius: 18px;
      --shadow: 0 18px 50px rgba(0,0,0,.08);
    }

    /* Dans une modale (iframe), on évite le padding énorme du layout */
    .pageWrap{
      padding: 14px;
    }

    .content {
        margin-left: 0px !important;
    }

    .cardX{
      background: var(--bs-body-bg);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow: hidden;
    }
    .cardX-h{
      padding: 14px 16px;
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap: 10px;
      border-bottom: 1px solid var(--line);
      background: linear-gradient(135deg, rgba(35,51,66,.98), rgba(15,35,54,.86));
      color: #fff;
    }
    .cardX-b{ padding: 16px; }

    .metaGrid{
      display:grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 10px;
      margin-bottom: 12px;
    }
    .metaBox{
      grid-column: span 6;
      padding: 10px 12px;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: rgba(255,255,255,.6);
    }
    .metaLabel{ font-size: 12px; opacity: .75; }
    .metaValue{ font-weight: 800; }

    @media (max-width: 992px){
      .metaBox{ grid-column: span 12; }
    }

    .htmlFrame{
      border: 1px solid var(--line);
      border-radius: 14px;
      overflow: hidden;
      background: #fff;
      min-height: 70vh;
    }

    .badge-soft{
      border: 1px solid rgba(255,255,255,.20);
      background: rgba(255,255,255,.10);
      color: #fff;
      border-radius: 999px;
      padding: 6px 10px;
      font-weight: 800;
      font-size: 12px;
      white-space: nowrap;
    }

    .btn-ghost{
      background: rgba(255,255,255,.10) !important;
      border: 1px solid rgba(255,255,255,.18) !important;
      color: #fff !important;
      border-radius: 14px !important;
      font-weight: 800;
    }
  </style>
{% endblock %}

{% block body %}
  <div class="container-fluid pageWrap">

    <div class="cardX mb-3">

      <div class="cardX-b">

        <div class="metaGrid">
          <div class="metaBox">
            <div class="metaLabel">Sujet</div>
            <div class="metaValue">{{ log.subject|default('—') }}</div>
          </div>

          <div class="metaBox">
            <div class="metaLabel">Template</div>
            <div class="metaValue">
              {% if log.template is defined and log.template %}
                {{ log.template.name|default(log.template.code|default('—')) }}
              {% else %}
                —
              {% endif %}
            </div>
          </div>

          <div class="metaBox">
            <div class="metaLabel">Envoyé le</div>
            <div class="metaValue">
              {% if log.sentAt is defined and log.sentAt %}
                {{ log.sentAt|date('d/m/Y H:i') }}
              {% else %}
                —
              {% endif %}
            </div>
          </div>

          <div class="metaBox">
            <div class="metaLabel">Clé idempotence</div>
            <div class="metaValue">{{ log.idemKey|default('—') }}</div>
          </div>

          {% if log.errorMessage is defined and log.errorMessage %}
            <div class="metaBox" style="grid-column: span 12; border-color: rgba(220,53,69,.35);">
              <div class="metaLabel">Erreur</div>
              <div class="metaValue" style="color: var(--bs-danger);">
                {{ log.errorMessage }}
              </div>
            </div>
          {% endif %}
        </div>

        {# Aperçu HTML #}
        <div class="htmlFrame">
          {% if log.bodyHtmlSnapshot is defined and log.bodyHtmlSnapshot %}
            {# On affiche le HTML dans une iframe sandboxée via srcdoc #}
            <iframe
              style="width:100%; height:70vh; border:0;"
              sandbox="allow-same-origin"
              srcdoc="{{ log.bodyHtmlSnapshot|e('html_attr') }}"
            ></iframe>
          {% else %}
            <div class="p-3 text-muted">Aucun contenu HTML sauvegardé.</div>
          {% endif %}
        </div>

        {# Optionnel : version texte #}
        {% if log.bodyTextSnapshot is defined and log.bodyTextSnapshot %}
          <details class="mt-3">
            <summary class="fw-semibold">Voir la version texte</summary>
            <pre class="mt-2 p-3" style="white-space:pre-wrap; border:1px solid var(--line); border-radius:14px; background: rgba(255,255,255,.6);">{{ log.bodyTextSnapshot }}</pre>
          </details>
        {% endif %}

      </div>
    </div>

  </div>
{% endblock %}
