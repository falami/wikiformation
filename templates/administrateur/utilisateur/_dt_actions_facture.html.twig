{# templates/administrateur/utilisateur/_dt_actions_facture.html.twig #}
<div class="btn-group dt-actions-compact" role="group">
  <a class="btn btn-outline-primary btn-sm"
     href="{{ path('app_administrateur_facture_edit', { entite: entite.id, id: facture.id }) }}"
     title="Ouvrir">
    <i class="bi bi-pencil"></i>
  </a>

  <button type="button"
          class="btn btn-outline-success btn-sm"
          title="Envoyer par email"
          onclick="window.openUserFactureEmailModal({{ facture.id }})">
    <i class="bi bi-envelope"></i>
  </button>

  <a class="btn btn-outline-dark btn-sm"
     href="{{ path('app_administrateur_facture_pdf', { entite: entite.id, id: facture.id }) }}"
     target="_blank"
     title="PDF">
    <i class="bi bi-filetype-pdf"></i>
  </a>
</div>
