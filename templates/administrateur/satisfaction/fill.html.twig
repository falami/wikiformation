{# templates/administrateur/satisfaction/fill.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}Satisfaction — Remplir{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }
    .cardx{ background:#fff; border-radius:18px; border:1px solid rgba(0,0,0,.06); box-shadow:0 12px 30px rgba(0,0,0,.06); overflow:hidden; }
    .chapter{ border:1px dashed rgba(0,0,0,.15); border-radius:16px; padding:12px; background:rgba(0,0,0,.015); }
    .qitem{ border:1px solid rgba(0,0,0,.06); border-radius:14px; padding:10px 12px; background:#fff; }
  </style>
{% endblock %}

{% block body %}
<div class="container-fluid px-3">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h2 class="fw-bold mb-0">Questionnaire de satisfaction</h2>
      <div class="text-muted">
        Session : <strong>{{ assignment.session.code ?? ('Session #' ~ assignment.session.id) }}</strong>
        — Template : <strong>{{ template.title ?? '—' }}</strong>
      </div>
    </div>
    <a class="btn btn-outline-secondary fw-semibold"
       href="{{ path('app_stagiaire_satisfaction_index', { entite: entite.id }) }}">
      <i class="bi bi-arrow-left"></i> Retour
    </a>
  </div>

  {% include 'flagMessage.html.twig' %}

  {% set locked = attempt.submittedAt is not null %}
  {% set existing = attempt.answers ?? {} %}

  <form method="post">
    <div class="row g-3">
      <div class="col-12 col-xl-8">
        <div class="cardx">
          <div class="p-3 border-bottom fw-bold">
            <i class="bi bi-ui-checks"></i> Questions
            {% if locked %}
              <span class="badge bg-success ms-2">Soumis le {{ attempt.submittedAt|date('d/m/Y H:i') }}</span>
            {% endif %}
          </div>

          <div class="p-3">
            {% for ch in template.chapters %}
              <div class="chapter mb-3">
                <div class="fw-bold mb-2">
                  <span class="badge bg-light text-dark border me-2">{{ ch.position ?? loop.index }}</span>
                  {{ ch.title ?? 'Chapitre' }}
                </div>

                <div class="d-grid gap-2">
                  {% for q in ch.questions %}
                    {% set key = q.id|default(loop.index) %}
                    {% set keyStr = key ~ '' %}
                    {% set value = existing[keyStr]|default(existing[key]|default('')) %}

                    <div class="qitem">
                      <div class="fw-semibold mb-2">{{ q.label ?? ('Question #' ~ key) }}</div>

                      {# Version générique : textarea (tu pourras remplacer par radios/notes selon ton modèle) #}
                      <textarea
                        name="answers[{{ key }}]"
                        class="form-control"
                        rows="3"
                        {% if locked %}disabled{% endif %}
                        placeholder="Votre réponse…"
                      >{{ value }}</textarea>

                      {% if q.help is defined and q.help %}
                        <div class="text-muted small mt-2">{{ q.help }}</div>
                      {% endif %}
                    </div>
                  {% else %}
                    <div class="text-muted small">Aucune question dans ce chapitre.</div>
                  {% endfor %}
                </div>
              </div>
            {% else %}
              <div class="text-muted">Aucun chapitre dans ce template.</div>
            {% endfor %}
          </div>
        </div>
      </div>

      <div class="col-12 col-xl-4">
        <div class="cardx">
          <div class="p-3 border-bottom fw-bold"><i class="bi bi-save2"></i> Actions</div>
          <div class="p-3">
            {% if locked %}
              <div class="alert alert-success mb-3">
                Questionnaire déjà soumis. Vous pouvez consulter vos réponses.
              </div>
            {% else %}
              <div class="alert alert-warning mb-3">
                Pensez à enregistrer puis soumettre quand c’est terminé.
              </div>

              <button class="btn btn-outline-primary w-100 fw-semibold mb-2" type="submit">
                <i class="bi bi-cloud-arrow-up"></i> Enregistrer
              </button>

              <button class="btn btn-warning w-100 fw-semibold" type="submit" name="submit" value="1"
                      onclick="return confirm('Soumettre définitivement ?');">
                <i class="bi bi-send-check"></i> Soumettre
              </button>
            {% endif %}
          </div>
        </div>

        <div class="cardx mt-3">
          <div class="p-3 border-bottom fw-bold"><i class="bi bi-info-circle"></i> Infos</div>
          <div class="p-3">
            <div class="text-muted small">Début :</div>
            <div class="fw-semibold mb-2">{{ assignment.session.dateDebut ? assignment.session.dateDebut|date('d/m/Y H:i') : '—' }}</div>

            <div class="text-muted small">Fin :</div>
            <div class="fw-semibold">{{ assignment.session.dateFin ? assignment.session.dateFin|date('d/m/Y H:i') : '—' }}</div>
          </div>
        </div>

      </div>
    </div>
  </form>
</div>
{% endblock %}
