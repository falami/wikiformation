{# templates/administrateur/satisfaction/show.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}Satisfaction — Consultation{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
{% endblock %}

{% block body %}
<div class="container-fluid px-3">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h2 class="fw-bold mb-0">Satisfaction — Tentative #{{ attempt.id }}</h2>
      <div class="text-muted">
        Session : <strong>{{ assignment.session.code ?? ('Session #' ~ assignment.session.id) }}</strong>
        — Stagiaire : <strong>{{ assignment.stagiaire.prenom ?? '' }} {{ assignment.stagiaire.nom ?? '' }}</strong>
      </div>
    </div>
    <a class="btn btn-outline-secondary fw-semibold" href="{{ path('app_administrateur_satisfaction_template_index', { entite: entite.id }) }}">
      <i class="bi bi-arrow-left"></i> Retour
    </a>
  </div>

  <div class="card p-3">
    <div class="mb-2">
      <span class="badge bg-light text-dark border">Démarré : {{ attempt.startedAt ? attempt.startedAt|date('d/m/Y H:i') : '—' }}</span>
      <span class="badge bg-success ms-2">Soumis : {{ attempt.submittedAt ? attempt.submittedAt|date('d/m/Y H:i') : '—' }}</span>
    </div>

    <hr>

    {% set answers = attempt.answers ?? {} %}

    {% for ch in template.chapters %}
      <h5 class="fw-bold mt-3">{{ ch.title ?? 'Chapitre' }}</h5>
      <div class="table-responsive">
        <table class="table table-sm align-middle">
          <thead class="table-light">
            <tr><th>Question</th><th>Réponse</th></tr>
          </thead>
          <tbody>
          {% for q in ch.questions %}
            {% set key = q.id|default(loop.index) %}
            <tr>
              <td class="fw-semibold">{{ q.label ?? ('Question #' ~ key) }}</td>
              <td>{{ answers[key|string]|default('—')|nl2br }}</td>
            </tr>
          {% else %}
            <tr><td colspan="2" class="text-muted">Aucune question.</td></tr>
          {% endfor %}
          </tbody>
        </table>
      </div>
    {% else %}
      <div class="text-muted">Aucun chapitre.</div>
    {% endfor %}
  </div>
</div>
{% endblock %}
