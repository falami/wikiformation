{# templates/administrateur/formation/index.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}Formations{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }

    /* HERO */
    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;

      /* Ombre douce premium */
      box-shadow: 0 18px 50px rgba(0,0,0,.14);

      /* Fond piloté par les couleurs de l'entité */
      background:
        /* halo clair (tertiaire) */
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        /* halo accent (secondaire) */
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        /* voile subtil (quaternaire) pour la profondeur */
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        /* dégradé principal (principal -> plus clair) */
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    /* léger glass highlight */
    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    /* barre accent = secondaire (et glow basé sur secondaire) */
    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }
    .chip{
      display:inline-flex;
      align-items:center;
      gap:.45rem;
      padding:.28rem .65rem;
      border-radius:999px;
      background: rgba(255,255,255,.10);
      border:1px solid rgba(255,255,255,.14);
      font-size:.82rem;
      color: rgba(255,255,255,.92);
      white-space: nowrap;
    }
    .chip i{ color: var(--theme-color-secondaire); }
    .hero .btn{
      border-radius: 14px;
      font-weight: 800;
    }
    .hero .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .hero .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }

    /* KPI */
    .kpi-card{
      border: 1px solid rgba(0,0,0,.06);
      box-shadow: 0 10px 26px rgba(0,0,0,.06);
      border-radius: 18px;
      overflow:hidden;
      background:#fff;
      position:relative;
    }
    .kpi-label{ color: rgba(0,0,0,.55); font-size:.85rem }
    .kpi-value{ font-weight:800; font-size:1.6rem; letter-spacing:-.02em }
    .kpi-sub{ color: rgba(0,0,0,.50); font-size:.82rem }

    /* FILTERBAR */
    .filterbar{
      background:#fff;
      border-radius:18px;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 10px 24px rgba(0,0,0,.05);
      overflow: visible;
    }
    .filterbar__top{
      padding: .9rem 1rem;
      border-bottom:1px solid rgba(0,0,0,.06);
      background: linear-gradient(180deg, rgba(0,0,0,.015), transparent);
      display:flex;
      align-items:center;
      gap:.75rem;
    }
    .filterbar__title{
      font-weight:800;
      letter-spacing:-.01em;
      margin:0;
      font-size:1rem;
    }
    .filterbar__hint{
      color: rgba(0,0,0,.55);
      font-size:.85rem;
      margin-left:.25rem;
    }
    .filterbar__body{ padding: 1rem; }

    .filtergrid{
      display:grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: .75rem;
      align-items:end;
    }
    .fcol-engin{ grid-column: span 3; }
    .fcol-niveau{ grid-column: span 2; }
    .fcol-range{ grid-column: span 3; }
    .fcol-actions{ grid-column: span 2; text-align:left; }

    @media (max-width: 1200px){
      .fcol-engin{ grid-column: span 6; }
      .fcol-niveau{ grid-column: span 6; }
      .fcol-range{ grid-column: span 8; }
      .fcol-actions{ grid-column: span 4; }
    }
    @media (max-width: 768px){
      .filterbar__body{ padding:.85rem; }
      .fcol-engin, .fcol-niveau, .fcol-range, .fcol-actions{ grid-column: span 12; }
    }

    .filter-control .form-label{
      font-size:.78rem;
      font-weight:700;
      color: rgba(0,0,0,.55);
      text-transform:uppercase;
      letter-spacing:.06em;
      margin-bottom:.25rem;
    }
    .filterbox{
      border:1px solid rgba(0,0,0,.08);
      border-radius:14px;
      padding:.55rem .6rem;
      background:#fff;
      box-shadow: 0 8px 18px rgba(0,0,0,.04);
    }
    .filterbox:focus-within{
      border-color: rgba(255,193,7,.55);
      box-shadow: 0 0 0 .2rem rgba(255,193,7,.18), 0 10px 18px rgba(0,0,0,.06);
    }
    .filterbox .form-select,
    .filterbox .form-control{
      border:0 !important;
      box-shadow:none !important;
      padding-left:0 !important;
      padding-right:0 !important;
      background:transparent !important;
    }

    .kpi-ico{
      width:44px; height:44px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }

    .filter-icon{
      width:38px; height:38px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }
    .filterrow{ display:flex; gap:.6rem; align-items:center; }

    /* Reset façon filterbox */
    .resetbox{
      border: 1px solid rgba(0,0,0,.08);
      border-radius: 14px;
      padding: .55rem .6rem;
      background: #fff;
      box-shadow: 0 8px 18px rgba(0,0,0,.04);

      display:flex;
      align-items:center;
      justify-content:flex-start;

      cursor:pointer;
      user-select:none;
      transition: box-shadow .15s ease, border-color .15s ease, transform .15s ease, background .15s ease;
    }
    .resetbox__text{
      font-size: .9rem;
      font-weight: 700;
      color: rgba(0,0,0,.65);
      white-space: nowrap;
    }
    .resetbox__badge{
      min-width: 28px;
      height: 22px;
      padding: 0 .5rem;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: .78rem;
      font-weight: 800;
      background: rgba(0,0,0,.06);
      color: rgba(0,0,0,.65);
      border: 1px solid rgba(0,0,0,.08);
    }
    .resetbox:hover{
      border-color: rgba(255,193,7,.35);
      background: rgba(255,193,7,.06);
    }
    .resetbox:active{ transform: translateY(1px); }
    .resetbox:focus,
    .resetbox:focus-visible{
      outline:none;
      border-color: rgba(255,193,7,.55);
      box-shadow: 0 0 0 .2rem rgba(255,193,7,.18), 0 10px 18px rgba(0,0,0,.06);
    }
    .resetbox.is-active{
      border-color: rgba(255,193,7,.35);
      background: rgba(255,193,7,.06);
    }
    .resetbox.is-active .resetbox__badge{
      background: rgba(255,193,7,.22);
      border-color: rgba(255,193,7,.30);
      color: rgba(0,0,0,.75);
    }
    .resetbox:disabled{
      cursor: default;
      opacity: .55;
      transform: none !important;
      background:#fff;
    }
    .fcol-actions .resetbox{ justify-content: center; }

    /* DATATABLE CARD */
    .table-card{
      background:#fff;
      border-radius:18px;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 12px 30px rgba(0,0,0,.06);
      overflow: visible;
    }
    table.dataTable{ margin:0 !important; }
    table.dataTable thead th{
      background:#f7f8fa!important;
      border-bottom:1px solid rgba(0,0,0,.08)!important;
      font-size:.78rem;
      text-transform:uppercase;
      letter-spacing:.05em;
      color: rgba(0,0,0,.55);
      text-align:center !important;
    }
    #tableauFormation tbody td{ text-align:center !important; vertical-align: middle; }

    .dt-top{
      padding:.75rem .85rem;
      border-bottom:1px solid rgba(0,0,0,.06);
      background:#fff;
    }
    .dt-bottom-internal{
      padding:1rem .85rem!important;
      border-top:1px solid rgba(0,0,0,.06);
      background:#fff;
      margin-top:.75rem!important;
    }

    /* Zebra + hover */
    #tableauFormation tbody tr:nth-child(even) > *{
      background:rgba(35,51,66,.035)!important;
    }
    #tableauFormation tbody tr:hover > *{
      background:rgba(255,193,7,.08)!important;
    }
    #tableauFormation tbody td{
      padding-top:.65rem!important;
      padding-bottom:.65rem!important;
    }

    /* Hover actions */
    td.action-column{
      position:relative;
      padding-right:110px !important;
      overflow: visible !important;
      white-space: nowrap;
      min-width: 140px;
    }
    .hover-actions{
      position:absolute;
      top:50%;
      right:.65rem;
      transform:translateY(-50%) translateX(8px);
      opacity:0;
      pointer-events:none;
      transition: all .18s ease;
      z-index:50;
    }
    #tableauFormation tbody tr:hover .hover-actions{
      opacity:1;
      transform:translateY(-50%) translateX(0);
      pointer-events:auto;
    }

    /* Mobile: actions visibles + sticky colonne */
    @media (max-width:768px){
      td.action-column{
        position: sticky;
        right:0;
        background:#fff !important;
        z-index:5;
        box-shadow:-12px 0 18px -14px rgba(0,0,0,.22);
        padding-right:.75rem !important;
      }
      .hover-actions{
        position:static;
        transform:none;
        opacity:1;
        pointer-events:auto;
      }
      .hero{ border-radius:16px; }
    }

    /* TomSelect bootstrap5 */
    .filterbar .ts-dropdown{ z-index:2000 !important; }
    .filterbox .ts-wrapper{ width:100%; }
    .filterbox .ts-control{
      border:0 !important; box-shadow:none !important; padding:0 !important;
      background:transparent !important; min-height:auto !important;
    }
    .filterbox .ts-dropdown{
      border-radius: 14px;
      border: 1px solid rgba(0,0,0,.10);
      box-shadow: 0 14px 30px rgba(0,0,0,.10);
      overflow:hidden;
    }
    .filterbox .ts-dropdown .active{ background: rgba(255,193,7,.16) !important; }




    /* =========================
      ✅ Actions formation (même design que Devis)
      ========================= */

    /* colonne actions compacte */
    #tableauFormation th:last-child,
    #tableauFormation td:last-child{
      width: 1% !important;
      min-width: 0 !important;
      white-space: nowrap;
    }

    /* boutons compacts */
    .formation-actions .btn{
      padding: .32rem .55rem;
    }

    /* bouton principal */
    .formation-actions .formation-main{
      background: rgba(255,255,255,.85);
      border-color: rgba(0,0,0,.12);
      box-shadow: 0 10px 22px rgba(0,0,0,.06);
    }
    .formation-actions .formation-main:hover{
      box-shadow: 0 14px 28px rgba(0,0,0,.10);
      border-color: rgba(0,0,0,.18);
    }

    /* split */
    .formation-actions .formation-split{
      padding-left: .55rem;
      padding-right: .55rem;
      border-color: rgba(0,0,0,.12);
      background: rgba(255,255,255,.85);
    }

    /* fusion pill (main + split) */
    .formation-actions.btn-group .formation-main{
      border-top-right-radius: 0 !important;
      border-bottom-right-radius: 0 !important;
    }
    .formation-actions.btn-group .formation-split{
      border-top-left-radius: 0 !important;
      border-bottom-left-radius: 0 !important;
      margin-left: -1px;
      position: relative;
    }
    .formation-actions.btn-group .formation-split:before{
      content:"";
      position:absolute;
      left:0;
      top:20%;
      bottom:20%;
      width:1px;
      background: rgba(0,0,0,.10);
    }

    /* menu dropdown */
    .formation-actions .formation-menu{
      border-radius: 16px;
      border: 1px solid rgba(0,0,0,.10);
      box-shadow: 0 18px 46px rgba(0,0,0,.18);
      padding: .55rem;
      background:
        radial-gradient(900px 220px at 10% 0%, rgba(255,193,7,.10), transparent 55%),
        #fff;
      overflow: hidden;
    }
    .formation-actions .formation-menu .dropdown-item{
      border-radius: 12px;
      padding: .50rem .60rem;
      margin: .10rem 0;
      border: 1px solid transparent;
    }
    .formation-actions .formation-menu .dropdown-item:hover{
      background: rgba(255,193,7,.10);
      border-color: rgba(255,193,7,.22);
    }

    /* ne jamais masquer quand dropdown ouvert (important avec hover-actions) */
    #tableauFormation td.action-column .formation-actions{
      opacity: 1 !important;
      visibility: visible !important;
    }
    #tableauFormation td.action-column .formation-actions:focus-within{
      opacity: 1 !important;
      visibility: visible !important;
    }

    /* alignement colonne */
    #tableauFormation td.action-column{
      padding-left: 0 !important;
      padding-right: .15rem !important;
      text-align: right;
    }

    /* ✅ Menu actions "floaté" au-dessus de tout */
    body .formation-floating-dropdown{
      z-index: 20000 !important;
    }


    /* ✅ Actions toujours visibles (comme Devis) */
    #tableauFormation td.action-column{
      padding-right: .15rem !important; /* plus besoin de réserver 110px */
    }

    /* on annule le mode "hover only" */
    #tableauFormation td.action-column .hover-actions{
      position: static !important;
      top: auto !important;
      right: auto !important;
      transform: none !important;
      opacity: 1 !important;
      pointer-events: auto !important;
      transition: none !important;
    }

    /* sécurité : même si une règle hover traîne */
    #tableauFormation tbody tr:hover .hover-actions{
      opacity: 1 !important;
      transform: none !important;
      pointer-events: auto !important;
    }


  </style>

  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/style-table.css') }}">
  <link rel="stylesheet" href="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.css"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css">
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
  <script src="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
{% endblock %}

{% block body %}

  {# HERO #}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>

    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-mortarboard me-2" style="color:var(--theme-color-secondaire)"></i>
            Formations
          </h2>

          <div class="opacity-75 mt-1">
            Catalogue, niveaux, prix et suivi des sessions.
          </div>

          <div class="d-flex gap-2 flex-wrap mt-3">
            <span class="chip"><i class="bi bi-collection"></i> Catalogue</span>
            <span class="chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
            <span class="chip"><i class="bi bi-clock-history"></i> <span id="hero-last-refresh">—</span></span>
          </div>
        </div>

        <div class="d-flex gap-2">
          <a class="btn btn-light btn-sm fw-semibold"
            href="{{ path('app_administrateur_formation_ajouter', { entite: entite.id }) }}">
            <i class="bi bi-plus-circle me-1"></i> Nouvelle formation
          </a>

          <button type="button" class="btn btn-outline-light btn-sm fw-semibold"
                  onclick="document.querySelector('.filterbar')?.scrollIntoView({behavior:'smooth'})">
            <i class="bi bi-funnel me-1"></i> Filtres
          </button>
        </div>
      </div>
    </div>
  </div>

  {# KPI (calculés depuis la page DataTables) #}
  <div class="row g-3 mb-3">
    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-collection fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Formations</div>
              <div class="kpi-value" id="kpi-total">—</div>
              <div class="kpi-sub">Total (filtré)</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-calendar3 fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Sessions</div>
              <div class="kpi-value" id="kpi-sessions">—</div>
              <div class="kpi-sub">Somme des sessions</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-cash-coin fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Prix moyen</div>
              <div class="kpi-value" id="kpi-prix-moyen">—</div>
              <div class="kpi-sub">Sur le listing</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-hourglass-split fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Durée moyenne</div>
              <div class="kpi-value" id="kpi-duree-moyenne">—</div>
              <div class="kpi-sub">En jours</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  {# FILTERBAR #}
  <div class="filterbar mb-3">
    <div class="filterbar__top">
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <div class="filter-icon"><i class="bi bi-funnel"></i></div>
        <div>
          <div class="filterbar__title">Filtres</div>
          <div class="filterbar__hint">Affiner le catalogue (engin, niveau, prix…)</div>
        </div>
      </div>

      <div class="ms-auto d-flex gap-2 align-items-center">
        <button class="btn btn-outline-secondary btn-sm fw-semibold d-md-none"
                type="button" data-bs-toggle="collapse" data-bs-target="#filtersCollapse">
          <i class="bi bi-sliders"></i> Filtres
        </button>

        <div class="dropdown">
          <button class="btn btn-warning btn-sm fw-semibold dropdown-toggle" data-bs-toggle="dropdown">
            <i class="bi bi-download"></i> Export
          </button>
          <ul class="dropdown-menu dropdown-menu-end" id="exportMenu"></ul>
        </div>
      </div>
    </div>

    <div class="collapse d-md-block" id="filtersCollapse">
      <div class="filterbar__body">
        <div class="filtergrid">

          <div class="filter-control fcol-engin">
            <div class="form-label">Catégorie</div>
            <div class="filterbox">
              <div class="filterrow">
                <div class="filter-icon"><i class="bi bi-folder"></i></div>
                <select id="categorieFilter" class="form-select form-select-sm">
                  <option value="all">Toutes</option>
                </select>
              </div>
            </div>
          </div>

          <div class="filter-control fcol-niveau">
            <div class="form-label">Sous-catégorie</div>
            <div class="filterbox">
              <div class="filterrow">
                <div class="filter-icon"><i class="bi bi-diagram-3"></i></div>
                <select id="sousCategorieFilter" class="form-select form-select-sm" disabled>
                  <option value="all">Toutes</option>
                </select>
              </div>
            </div>
          </div>

          <div class="filter-control fcol-niveau">
            <div class="form-label">Niveau</div>
            <div class="filterbox">
              <div class="filterrow">
                <div class="filter-icon"><i class="bi bi-award"></i></div>
                <select id="niveauFilter" class="form-select form-select-sm">
                  <option value="all">Tous</option>
                </select>
              </div>
            </div>
          </div>

          <div class="filter-control fcol-range">
            <div class="form-label">Prix (min / max)</div>
            <div class="filterbox">
              <div class="filterrow">
                <div class="filter-icon"><i class="bi bi-currency-euro"></i></div>
                <input type="number" class="form-control form-control-sm" id="prixMin" placeholder="Min" min="0" step="1">
                <span class="text-muted small">—</span>
                <input type="number" class="form-control form-control-sm" id="prixMax" placeholder="Max" min="0" step="1">
              </div>
            </div>
          </div>

          <div class="fcol-actions">
            <div class="form-label">&nbsp;</div>
            <button id="btnReset" type="button" class="resetbox w-100" title="Réinitialiser les filtres">
              <span class="filterrow w-100">
                <span class="filter-icon"><i class="bi bi-arrow-counterclockwise"></i></span>
                <span class="resetbox__text flex-grow-1">Reset</span>
                <span class="resetbox__badge" id="resetCount" style="display:none;">0</span>
              </span>
            </button>
          </div>

        </div>
      </div>
    </div>
  </div>

  {# TABLE #}
  <div class="table-card p-3">
    <table id="tableauFormation" class="table table-hover align-middle mb-0 w-100">
      <thead>
        <tr>
          <th>#</th>
          <th>Titre</th>
          <th>Catégorie</th>
          <th>Sous-catégorie</th>
          <th>Niveau</th>
          <th>Prix base</th>
          <th>Durée</th>
          <th>Sessions</th>
          <th class="text-end"></th>
        </tr>
      </thead>

      <tbody></tbody>
    </table>
  </div>


{% include 'partials/_modales_index_generiques.html.twig' %}

<script>
$(function(){
  const $categorie = $('#categorieFilter');
  const $sousCat   = $('#sousCategorieFilter');
  const $niveau    = $('#niveauFilter'); // si tu le gardes
  const $prixMin   = $('#prixMin');
  const $prixMax   = $('#prixMax');

  let tsCategorie = null, tsSousCat = null, tsNiveau = null;

  // stock client
  let subcatsByParent = {}; // { "12": [ {id,label}, ... ] }


  function nowLabel(){
    const d = new Date();
    return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
  }

  function initTomSelect(){
    const common = {
      create: false,
      allowEmptyOption: true,
      maxItems: 1,
      plugins: ['clear_button'],
      render: { no_results: () => '<div class="px-2 py-1 text-muted">Aucun résultat</div>' }
    };

    tsCategorie?.destroy();
    tsSousCat?.destroy();
    tsNiveau?.destroy();

    tsCategorie = new TomSelect('#categorieFilter', { ...common, placeholder: 'Toutes' });
    tsSousCat   = new TomSelect('#sousCategorieFilter', { ...common, placeholder: 'Toutes' });

    // si tu gardes NiveauFormation
    if (document.querySelector('#niveauFilter')) {
      tsNiveau = new TomSelect('#niveauFilter', { ...common, placeholder: 'Tous' });
      tsNiveau.on('change', () => refreshAll(true));
    }

    tsCategorie.on('change', () => {
      // quand on change de catégorie => rebuild sous-catégories + reload table
      rebuildSousCategories();
      refreshAll(true);
    });

    tsSousCat.on('change', () => refreshAll(true));
  }

  function rebuildSousCategories(){
    const catId = $categorie.val() || 'all';
    const items = (catId !== 'all' && subcatsByParent[String(catId)]) ? subcatsByParent[String(catId)] : [];

    const ts = document.querySelector('#sousCategorieFilter')?.tomselect;
    if(!ts) return;

    ts.clear(true);
    ts.clearOptions();

    ts.addOption({ value:'all', text:'Toutes' });
    items.forEach(sc => ts.addOption({ value:String(sc.id), text: sc.label }));

    ts.refreshOptions(false);

    // enable/disable
    const has = items.length > 0;
    ts.input.disabled = !has;
    $('#sousCategorieFilter').prop('disabled', !has);

    ts.setValue('all', true);
  }


  function updateResetUi(count){
    const btn = document.getElementById('btnReset');
    const badge = document.getElementById('resetCount');
    if(!btn || !badge) return;

    if(count > 0){
      btn.disabled = false;
      btn.classList.add('is-active');
      badge.style.display = 'inline-flex';
      badge.textContent = String(count);
    } else {
      btn.disabled = true;
      btn.classList.remove('is-active');
      badge.style.display = 'none';
      badge.textContent = '0';
    }
  }

  function computeKpisFromCurrentRows(api){
    const data = api.rows({ search: 'applied' }).data().toArray();

    const total = data.length;
    let sumSessions = 0;
    let sumPrix = 0, countPrix = 0;
    let sumDuree = 0, countDuree = 0;

    data.forEach(r => {
      const ns = parseInt(String(r.nbSessions ?? r.sessions ?? '').replace(/[^\d]/g,''), 10);
      if(!Number.isNaN(ns)) sumSessions += ns;

      const prixStr = String(r.prixBase ?? '').replace(/\s/g,'').replace('€','').replace(',', '.');
      const prix = parseFloat(prixStr);
      if(!Number.isNaN(prix) && prix > 0){ sumPrix += prix; countPrix++; }

      const dureeStr = String(r.duree ?? '').replace(/[^\d]/g,'');
      const duree = parseInt(dureeStr, 10);
      if(!Number.isNaN(duree) && duree > 0){ sumDuree += duree; countDuree++; }
    });

    const prixMoyen = countPrix ? (sumPrix / countPrix) : 0;
    const dureeMoy = countDuree ? (sumDuree / countDuree) : 0;

    $('#kpi-total').text(total);
    $('#kpi-sessions').text(sumSessions);
    $('#kpi-prix-moyen').text(prixMoyen ? prixMoyen.toFixed(2).replace('.', ',') + ' €' : '—');
    $('#kpi-duree-moyenne').text(dureeMoy ? (Math.round(dureeMoy*10)/10).toString().replace('.', ',') + ' j' : '—');
    $('#hero-last-refresh').text('Maj : ' + nowLabel());
  }

  function countActiveFilters(){
    let c = 0;
    if(($categorie.val() || 'all') !== 'all') c++;
    if(($sousCat.val() || 'all') !== 'all') c++;
    if(($niveau.val() || 'all') !== 'all') c++;
    if(($prixMin.val() || '').trim() !== '') c++;
    if(($prixMax.val() || '').trim() !== '') c++;
    return c;
  }


  function refreshAll(resetPaging=false){
    table.ajax.reload(null, !resetPaging ? false : true);
  }

  const table = $('#tableauFormation').DataTable({
    serverSide:true,
    processing:true,
    autoWidth: false,
    scrollX: true,
    scrollCollapse: true,
    responsive: false,

    ajax:{
      url:"{{ path('app_administrateur_formation_ajax', { entite: entite.id }) }}",
      type:"POST",
      data: function(d){
        d.categorieFilter     = $categorie.val() || 'all';
        d.sousCategorieFilter = $sousCat.val() || 'all';

        // si tu gardes niveau
        d.niveauFilter = ($('#niveauFilter').val() || 'all');

        d.prixMin = ($prixMin.val() || '').trim();
        d.prixMax = ($prixMax.val() || '').trim();
      }

    },

    dom:
      '<"dt-top d-flex flex-wrap gap-2 align-items-center justify-content-between"'
        + '<"dt-actions d-flex gap-2 align-items-center"B>'
        + '<"dt-search"f>'
      + '>'
      + 'rt'
      + '<"dt-bottom-internal d-flex flex-wrap gap-2 align-items-center justify-content-between"lip>',

    buttons:['copy','csv','excel','pdf','print'],
    lengthMenu:[[10,25,50,500],[10,25,50,500]],

    columns:[
      {data:'id', name:'id'},
      {data:'titre', name:'titre'},
      {data:'categorie', name:'categorie'},
      {data:'sousCategorie', name:'sousCategorie'},
      {data:'niveau', name:'niveau'},
      {data:'prixBase', name:'prixBase'},
      {data:'duree', name:'duree'},
      {data:'nbSessions', name:'nbSessions'},
      {data:'actions', name:'actions'}
    ],
    columnDefs:[
      {targets:8, className:"action-column text-end", orderable:false, searchable:false},
      {type:"num", targets:0}
    ],


    order:[[0,'desc']],
    language:{ url:'https://cdn.datatables.net/plug-ins/2.2.2/i18n/fr-FR.json' },


    initComplete:function(){
      const api = this.api();
      const $btns = $(api.buttons().container()).find('button');

      $('#exportMenu').empty();
      $btns.each(function(){
        const $b=$(this);
        $('<li><a class="dropdown-item" href="#">'+$b.text()+'</a></li>')
          .on('click',e=>{e.preventDefault();$b.click();})
          .appendTo('#exportMenu');
      });
      $(api.buttons().container()).hide();
    }
  });


  // ✅ Dropdown actions formation : on "flotte" le menu hors du scroll DataTables (sinon il est clippé)
  (function enableFormationActionsFloatingDropdown(){
    document.addEventListener('show.bs.dropdown', function(e){
      const toggle = e.target;
      if (!toggle.closest('.formation-actions')) return;

      const dd = toggle.closest('.dropdown, .btn-group');
      if (!dd) return;

      const menu = dd.querySelector('.dropdown-menu');
      if (!menu) return;

      if (!menu.__originalParent) menu.__originalParent = dd;

      document.body.appendChild(menu);
      menu.classList.add('formation-floating-dropdown');

      const rect = toggle.getBoundingClientRect();

      menu.style.position = 'absolute';
      menu.style.top = '0px';
      menu.style.left = '0px';
      menu.style.display = 'block';

      const menuRect = menu.getBoundingClientRect();
      const isEnd = menu.classList.contains('dropdown-menu-end');
      const top = rect.bottom + window.scrollY + 6;

      let left = isEnd
        ? (rect.right + window.scrollX - menuRect.width)
        : (rect.left + window.scrollX);

      left = Math.max(8, Math.min(left, window.scrollX + window.innerWidth - menuRect.width - 8));

      menu.style.top = `${top}px`;
      menu.style.left = `${left}px`;
    }, true);

    document.addEventListener('hidden.bs.dropdown', function(e){
      const toggle = e.target;
      if (!toggle.closest('.formation-actions')) return;

      const dd = toggle.closest('.dropdown, .btn-group');
      if (!dd) return;

      document.querySelectorAll('body .formation-floating-dropdown').forEach(menu => {
        if (menu.__originalParent === dd) {
          dd.appendChild(menu);
          menu.classList.remove('formation-floating-dropdown');
          menu.style.position = '';
          menu.style.top = '';
          menu.style.left = '';
          menu.style.display = '';
        }
      });
    }, true);

    // ✅ si scroll/resize : ferme les menus ouverts
    window.addEventListener('scroll', () => {
      document.querySelectorAll('.formation-actions [aria-expanded="true"][data-bs-toggle="dropdown"]')
        .forEach(btn => btn.click());
    }, true);

    window.addEventListener('resize', () => {
      document.querySelectorAll('.formation-actions [aria-expanded="true"][data-bs-toggle="dropdown"]')
        .forEach(btn => btn.click());
    }, true);
  })();


  function dtAdjust(){ table.columns.adjust(); }
  table.on('init.dt', function(){ setTimeout(dtAdjust, 50); setTimeout(dtAdjust, 250); });
  table.on('draw.dt', function(){
    dtAdjust();

    const api = table;
    computeKpisFromCurrentRows(api);

    const n = countActiveFilters();
    updateResetUi(n);
  });



  async function loadMeta(){
    const url = "{{ path('app_administrateur_formation_meta', { entite: entite.id }) }}";
    const res = await fetch(url, { headers: { 'Accept':'application/json' }});
    if(!res.ok) return;
    const json = await res.json();

    subcatsByParent = json.subCategoriesByParent || {};

    // Catégories (parents)
    const tsCat = document.querySelector('#categorieFilter')?.tomselect;
    if (tsCat) {
      tsCat.clearOptions();
      tsCat.addOption({ value: 'all', text: 'Toutes' });
      (json.categoriesParents || []).forEach(c => tsCat.addOption({ value: String(c.id), text: c.label }));
      tsCat.refreshOptions(false);
      tsCat.setValue('all', true);
    }

    // Sous-catégorie: vide au départ
    rebuildSousCategories();

    // NiveauFormation si tu le gardes
    const tsN = document.querySelector('#niveauFilter')?.tomselect;
    if (tsN && json.niveaux) {
      tsN.clearOptions();
      tsN.addOption({ value: 'all', text: 'Tous' });
      (json.niveaux || []).forEach(n => tsN.addOption({ value: String(n.value), text: n.label }));
      tsN.refreshOptions(false);
      tsN.setValue('all', true);
    }
  }



  // Debounce sur prix
  let tPrix=null;
  function debouncePrix(){
    clearTimeout(tPrix);
    tPrix = setTimeout(()=>refreshAll(true), 350);
  }
  $prixMin.on('input', debouncePrix);
  $prixMax.on('input', debouncePrix);

  // Reset
  $('#btnReset').on('click', function(){
    tsCategorie ? tsCategorie.setValue('all', true) : $categorie.val('all');
    rebuildSousCategories(); // reset sous-cat + disable

    // si tu gardes niveau
    if(tsNiveau) tsNiveau.setValue('all', true);
    else $('#niveauFilter').val('all');

    $prixMin.val(''); $prixMax.val('');
    table.search('').draw();
    refreshAll(true);
  });


  // Modale suppression
  $(document).on('click', '.delete-btn', function () {
    const url = $(this).data('url');
    const token = $(this).data('token');
    const name = $(this).data('name') || 'cet élément';

    $('#deleteForm').attr('action', url);
    $('#deleteToken').val(token);
    $('#deleteItemName').text(name);
  });


  // init TomSelect
  initTomSelect();
  loadMeta().then(()=> refreshAll(true));


  // Premier update UI (désactive reset)
  updateResetUi(0);
  $('#hero-last-refresh').text('Maj : ' + nowLabel());

});
</script>
{% endblock %}
