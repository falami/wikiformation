  {% include 'partials/_modales_index_generiques.html.twig' %}

  <script>
    $(function(){
      const $status = $('#statusFilter');
      const $module = $('#moduleFilter');
      const $q = $('#quickSearch');

      let tsStatus = null;
      let tsModule = null;

      function nowLabel(){
        const d = new Date();
        return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
      }

      function initTomSelect(){
        const common = {
          create:false,
          allowEmptyOption:true,
          maxItems:1,
          plugins:['clear_button'],
          render:{ no_results: () => '<div class="px-2 py-1 text-muted">Aucun résultat</div>' }
        };

        tsStatus?.destroy();
        tsModule?.destroy();

        tsStatus = new TomSelect('#statusFilter', { ...common, placeholder:'Tous' });
        tsModule = new TomSelect('#moduleFilter', { ...common, placeholder:'Tous' });

        tsStatus.on('change', ()=> refreshAll(true));
        tsModule.on('change', ()=> refreshAll(true));
      }

      function updateResetUi(count){
        const btn = document.getElementById('btnReset');
        const badge = document.getElementById('resetCount');
        if(!btn || !badge) return;

        if(count > 0){
          btn.disabled = false;
          btn.classList.add('is-active');
          badge.style.display = 'inline-flex';
          badge.textContent = String(count);
        } else {
          btn.disabled = true;
          btn.classList.remove('is-active');
          badge.style.display = 'none';
          badge.textContent = '0';
        }
      }

      function countActiveFilters(){
        let c = 0;
        if(($status.val() || 'all') !== 'all') c++;
        if(($module.val() || 'all') !== 'all') c++;
        if(($q.val() || '').trim() !== '') c++;
        return c;
      }

      function refreshAll(resetPaging=false){
        table.ajax.reload(null, !resetPaging ? false : true);
      }

      function computeKpisFromCurrentRows(api){
        const data = api.rows({ search: 'applied' }).data().toArray();

        const total = data.length;
        let actifs = 0;
        let formations = 0;
        let modulesOn = 0;

        data.forEach(r => {
          if (parseInt(r.isActiveRaw ?? 0, 10) === 1) {
            actifs++;
          }

          const nbForm = parseInt(r.formationsCountRaw ?? 0, 10);
          if (!Number.isNaN(nbForm)) {
            formations += nbForm;
          }

          modulesOn += parseInt(r.catalogueEnabledRaw ?? 0, 10);
          modulesOn += parseInt(r.calendarEnabledRaw ?? 0, 10);
          modulesOn += parseInt(r.elearningEnabledRaw ?? 0, 10);
          modulesOn += parseInt(r.shopEnabledRaw ?? 0, 10);
        });

        $('#kpi-total').text(total);
        $('#kpi-actifs').text(actifs);
        $('#kpi-formations').text(formations);
        $('#kpi-modules').text(modulesOn);
        $('#hero-last-refresh').text('Maj : ' + nowLabel());
      }

      const table = $('#tableauHosts').DataTable({
        serverSide: true,
        processing: true,
        autoWidth: false,
        scrollX: true,
        scrollCollapse: true,
        responsive: false,

        ajax:{
          url: "{{ path('app_super_public_host_ajax') }}",
          type: "POST",
          data: function(d){
            d.statusFilter = $status.val() || 'all';
            d.moduleFilter = $module.val() || 'all';
          }
        },

        dom:
          '<"dt-top d-flex flex-wrap gap-2 align-items-center justify-content-between"'
            + '<"dt-actions d-flex gap-2 align-items-center"B>'
            + '<"dt-search d-none"f>'
          + '>'
          + 'rt'
          + '<"dt-bottom-internal d-flex flex-wrap gap-2 align-items-center justify-content-between"lip>',

        buttons:['copy','csv','excel','pdf','print'],
        lengthMenu:[[10,25,50,100],[10,25,50,100]],

        columns:[
          {data:'id'},
          {data:'name'},
          {data:'entite'},
          {data:'host'},
          {data:'isActive'},
          {data:'catalogueEnabled'},
          {data:'calendarEnabled'},
          {data:'elearningEnabled'},
          {data:'shopEnabled'},
          {data:'restrictToAssignedFormations'},
          {data:'formationsCount'},
          {data:'actions'}
        ],

        order:[[0,'desc']],
        language:{ url:'https://cdn.datatables.net/plug-ins/2.2.2/i18n/fr-FR.json' },

        columnDefs:[
          {targets:11, className:'action-column text-end', orderable:false, searchable:false},
          {targets:[4,5,6,7,8,9,10], className:'text-center'},
          {type:'num', targets:[0,10]}
        ],

        initComplete:function(){
          const api = this.api();
          const $btns = $(api.buttons().container()).find('button');

          $('#exportMenu').empty();
          $btns.each(function(){
            const $b = $(this);
            $('<li><a class="dropdown-item" href="#">'+$b.text()+'</a></li>')
              .on('click', e => { e.preventDefault(); $b.click(); })
              .appendTo('#exportMenu');
          });
          $(api.buttons().container()).hide();
        }
      });

      function dtAdjust(){
        table.columns.adjust();
      }

      table.on('init.dt', function(){
        setTimeout(dtAdjust, 50);
        setTimeout(dtAdjust, 250);
      });

      table.on('draw.dt', function(){
        dtAdjust();
        computeKpisFromCurrentRows(table);
        updateResetUi(countActiveFilters());
      });

      let tSearch = null;
      $q.on('input', function(){
        clearTimeout(tSearch);
        tSearch = setTimeout(function(){
          table.search(($q.val() || '').trim()).draw();
        }, 300);
      });

      $('#btnReset').on('click', function(){
        tsStatus ? tsStatus.setValue('all', true) : $status.val('all');
        tsModule ? tsModule.setValue('all', true) : $module.val('all');
        $q.val('');
        table.search('').draw();
        refreshAll(true);
      });

      $(document).on('click', '.delete-btn', function(e){
        const btn = $(e.currentTarget);
        const url = btn.data('url');
        const token = btn.data('token');

        const form = document.querySelector('#deleteModal form');
        if (!form) return;

        form.setAttribute('action', url);

        const tokenInput = form.querySelector('input[name="_token"]');
        if (tokenInput) {
            tokenInput.value = token;
        }
        });

      initTomSelect();
      updateResetUi(0);
      $('#hero-last-refresh').text('Maj : ' + nowLabel());





        (function enableHostActionsFloatingDropdown(){
            document.addEventListener('show.bs.dropdown', function(e){
                const toggle = e.target;
                if (!toggle.closest('.host-actions')) return;

                const dd = toggle.closest('.dropdown, .btn-group');
                if (!dd) return;

                const menu = dd.querySelector('.dropdown-menu');
                if (!menu) return;

                if (!menu.__originalParent) menu.__originalParent = dd;

                document.body.appendChild(menu);
                menu.classList.add('host-floating-dropdown');

                const rect = toggle.getBoundingClientRect();

                menu.style.position = 'absolute';
                menu.style.top = '0px';
                menu.style.left = '0px';
                menu.style.display = 'block';

                const menuRect = menu.getBoundingClientRect();
                const top = rect.bottom + window.scrollY + 6;

                let left = (rect.right + window.scrollX - menuRect.width);
                left = Math.max(8, Math.min(left, window.scrollX + window.innerWidth - menuRect.width - 8));

                menu.style.top = `${top}px`;
                menu.style.left = `${left}px`;
            }, true);

            document.addEventListener('hidden.bs.dropdown', function(e){
                const toggle = e.target;
                if (!toggle.closest('.host-actions')) return;

                const dd = toggle.closest('.dropdown, .btn-group');
                if (!dd) return;

                document.querySelectorAll('body .host-floating-dropdown').forEach(menu => {
                if (menu.__originalParent === dd) {
                    dd.appendChild(menu);
                    menu.classList.remove('host-floating-dropdown');
                    menu.style.position = '';
                    menu.style.top = '';
                    menu.style.left = '';
                    menu.style.display = '';
                }
                });
            }, true);

            window.addEventListener('scroll', () => {
                document.querySelectorAll('.host-actions [aria-expanded="true"][data-bs-toggle="dropdown"]')
                .forEach(btn => btn.click());
            }, true);

            window.addEventListener('resize', () => {
                document.querySelectorAll('.host-actions [aria-expanded="true"][data-bs-toggle="dropdown"]')
                .forEach(btn => btn.click());
            }, true);
            })();



    });




  </script>
{% endblock %}