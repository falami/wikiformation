{% extends 'base_admin.html.twig' %}
{% block title %}Hosts publics{% endblock %}

{% block stylesheets %}
  {{ parent() }}

  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/style-table.css') }}">
  <link rel="stylesheet" href="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.css"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css">

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite is defined and entite ? entite.couleurPrincipal : '#233342') }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite is defined and entite ? entite.couleurSecondaire : '#ffc107') }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite is defined and entite ? entite.couleurTertiaire : '#F0F0F0') }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite is defined and entite ? entite.couleurQuaternaire : '#000000') }};
    }

    body{
      background:#f5f7fb;
    }

    /* HERO */
    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;
      box-shadow: 0 18px 50px rgba(0,0,0,.14);
      background:
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }

    .chip{
      display:inline-flex; align-items:center; gap:.45rem;
      padding:.28rem .65rem; border-radius:999px; font-size:.82rem;
      background: rgba(255,255,255,.10);
      border:1px solid rgba(255,255,255,.14);
      color: rgba(255,255,255,.92);
      white-space: nowrap;
    }
    .chip i{ color: var(--theme-color-secondaire); }

    .hero .btn{
      border-radius: 14px;
      font-weight: 800;
    }
    .hero .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .hero .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }

    /* KPI */
    .kpi-card{
      border: 1px solid rgba(0,0,0,.06);
      box-shadow: 0 10px 26px rgba(0,0,0,.06);
      border-radius: 18px;
      overflow:hidden;
      background:#fff;
      position:relative;
    }
    .kpi-label{ color: rgba(0,0,0,.55); font-size:.85rem; }
    .kpi-value{ font-weight:800; font-size:1.6rem; letter-spacing:-.02em; }
    .kpi-sub{ color: rgba(0,0,0,.50); font-size:.82rem; }

    .kpi-ico{
      width:44px; height:44px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }

    /* FILTERBAR */
    .filterbar{
      background:#fff;
      border-radius:18px;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 10px 24px rgba(0,0,0,.05);
      overflow: visible;
    }
    .filterbar__top{
      padding: .9rem 1rem;
      border-bottom:1px solid rgba(0,0,0,.06);
      background: linear-gradient(180deg, rgba(0,0,0,.015), transparent);
      display:flex;
      align-items:center;
      gap:.75rem;
    }
    .filterbar__title{ font-weight:800; letter-spacing:-.01em; margin:0; font-size:1rem; }
    .filterbar__hint{ color: rgba(0,0,0,.55); font-size:.85rem; margin-left:.25rem; }
    .filterbar__body{ padding: 1rem; }

    .filtergrid{
      display:grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: .75rem;
      align-items:end;
    }
    .fcol-status{ grid-column: span 3; }
    .fcol-module{ grid-column: span 3; }
    .fcol-search{ grid-column: span 4; }
    .fcol-actions{ grid-column: span 2; text-align:left; }

    @media (max-width: 1200px){
      .fcol-status{ grid-column: span 6; }
      .fcol-module{ grid-column: span 6; }
      .fcol-search{ grid-column: span 8; }
      .fcol-actions{ grid-column: span 4; }
    }
    @media (max-width: 768px){
      .filterbar__body{ padding:.85rem; }
      .fcol-status, .fcol-module, .fcol-search, .fcol-actions{ grid-column: span 12; }
      .hero{ border-radius:16px; }
    }

    .filter-control .form-label{
      font-size:.78rem;
      font-weight:700;
      color: rgba(0,0,0,.55);
      text-transform:uppercase;
      letter-spacing:.06em;
      margin-bottom:.25rem;
    }

    .filterbox{
      border:1px solid rgba(0,0,0,.08);
      border-radius:14px;
      padding:.55rem .6rem;
      background:#fff;
      box-shadow: 0 8px 18px rgba(0,0,0,.04);
    }
    .filterbox:focus-within{
      border-color: rgba(255,193,7,.55);
      box-shadow: 0 0 0 .2rem rgba(255,193,7,.18), 0 10px 18px rgba(0,0,0,.06);
    }
    .filterbox .form-select,
    .filterbox .form-control{
      border:0 !important;
      box-shadow:none !important;
      padding-left:0 !important;
      padding-right:0 !important;
      background:transparent !important;
    }

    .filter-icon{
      width:38px; height:38px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }
    .filterrow{ display:flex; gap:.6rem; align-items:center; }

    .resetbox{
      border: 1px solid rgba(0,0,0,.08);
      border-radius: 14px;
      padding: .55rem .6rem;
      background: #fff;
      box-shadow: 0 8px 18px rgba(0,0,0,.04);
      display:flex;
      align-items:center;
      justify-content:flex-start;
      cursor:pointer;
      user-select:none;
      transition: box-shadow .15s ease, border-color .15s ease, transform .15s ease, background .15s ease;
    }
    .resetbox__text{ font-size: .9rem; font-weight: 700; color: rgba(0,0,0,.65); white-space: nowrap; }
    .resetbox__badge{
      min-width: 28px;
      height: 22px;
      padding: 0 .5rem;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: .78rem;
      font-weight: 800;
      background: rgba(0,0,0,.06);
      color: rgba(0,0,0,.65);
      border: 1px solid rgba(0,0,0,.08);
    }
    .resetbox:hover{ border-color: rgba(255,193,7,.35); background: rgba(255,193,7,.06); }
    .resetbox:active{ transform: translateY(1px); }
    .resetbox:focus,
    .resetbox:focus-visible{
      outline:none;
      border-color: rgba(255,193,7,.55);
      box-shadow: 0 0 0 .2rem rgba(255,193,7,.18), 0 10px 18px rgba(0,0,0,.06);
    }
    .resetbox.is-active{ border-color: rgba(255,193,7,.35); background: rgba(255,193,7,.06); }
    .resetbox.is-active .resetbox__badge{
      background: rgba(255,193,7,.22);
      border-color: rgba(255,193,7,.30);
      color: rgba(0,0,0,.75);
    }
    .resetbox:disabled{ cursor: default; opacity:.55; transform:none !important; background:#fff; }
    .fcol-actions .resetbox{ justify-content:center; }

    /* DATATABLE CARD */
    .table-card{
      background:#fff;
      border-radius:18px;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 12px 30px rgba(0,0,0,.06);
      overflow: visible;
    }

    table.dataTable{ margin:0 !important; }
    table.dataTable thead th{
      background:#f7f8fa!important;
      border-bottom:1px solid rgba(0,0,0,.08)!important;
      font-size:.78rem;
      text-transform:uppercase;
      letter-spacing:.05em;
      color: rgba(0,0,0,.55);
      text-align:center !important;
      vertical-align: middle;
    }

    #tableauHosts tbody td{
      text-align:center !important;
      vertical-align: middle;
      padding-top:.7rem!important;
      padding-bottom:.7rem!important;
    }

    .dt-top{
      padding:.75rem .85rem;
      border-bottom:1px solid rgba(0,0,0,.06);
      background:#fff;
    }
    .dt-bottom-internal{
      padding:1rem .85rem!important;
      border-top:1px solid rgba(0,0,0,.06);
      background:#fff;
      margin-top:.75rem!important;
    }

    #tableauHosts tbody tr:nth-child(even) > *{ background:rgba(35,51,66,.035)!important; }
    #tableauHosts tbody tr:hover > *{ background:rgba(255,193,7,.08)!important; }

    .host-name{
      font-weight:800;
      color:#0f172a;
    }

    .host-code{
      display:inline-flex;
      align-items:center;
      gap:.45rem;
      padding:.35rem .7rem;
      border-radius:999px;
      background:rgba(15,23,42,.05);
      border:1px solid rgba(15,23,42,.08);
      font-size:.84rem;
      white-space:nowrap;
    }

    .tiny-badge{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width: 34px;
      padding:.3rem .55rem;
      border-radius:999px;
      font-size:.78rem;
      font-weight:700;
      border:1px solid rgba(0,0,0,.08);
      white-space: nowrap;
    }
    .tiny-badge.yes{
      background: rgba(25,135,84,.12);
      color: #146c43;
      border-color: rgba(25,135,84,.20);
    }
    .tiny-badge.no{
      background: rgba(108,117,125,.10);
      color: #495057;
      border-color: rgba(108,117,125,.18);
    }

    .host-count{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width: 40px;
      height: 34px;
      border-radius: 12px;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      font-weight: 800;
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
    }


   td.action-column{
        white-space: nowrap;
        text-align:right !important;
        overflow: visible !important;
    }

    @media (max-width:768px){
        td.action-column{
            position: sticky;
            right:0;
            background:#fff !important;
            z-index:5;
            box-shadow:-12px 0 18px -14px rgba(0,0,0,.22);
            padding-right:.75rem !important;
        }
        .hero{ border-radius:16px; }
    }

    .filterbar .ts-dropdown{ z-index:2000 !important; }
    .filterbox .ts-wrapper{ width:100%; }
    .filterbox .ts-control{
      border:0 !important;
      box-shadow:none !important;
      padding:0 !important;
      background:transparent !important;
      min-height:auto !important;
    }
    .filterbox .ts-dropdown{
      border-radius: 14px;
      border: 1px solid rgba(0,0,0,.10);
      box-shadow: 0 14px 30px rgba(0,0,0,.10);
      overflow:hidden;
    }
    .filterbox .ts-dropdown .active{ background: rgba(255,193,7,.16) !important; }




    /* =========================
   Actions hosts (même design que formateurs)
   ========================= */

#tableauHosts th:last-child,
#tableauHosts td.action-column{
  width: 1% !important;
  min-width: 0 !important;
  white-space: nowrap;
}

#tableauHosts td.action-column{
  padding-left: 0 !important;
  padding-right: .15rem !important;
  text-align: right !important;
  overflow: visible !important;
}

.host-actions .btn{
  padding: .32rem .55rem;
}

.host-actions .host-main{
  background: rgba(255,255,255,.85);
  border-color: rgba(0,0,0,.12);
  box-shadow: 0 10px 22px rgba(0,0,0,.06);
}
.host-actions .host-main:hover{
  box-shadow: 0 14px 28px rgba(0,0,0,.10);
  border-color: rgba(0,0,0,.18);
}

.host-actions .host-split{
  padding-left: .55rem;
  padding-right: .55rem;
  border-color: rgba(0,0,0,.12);
  background: rgba(255,255,255,.85);
}

.host-actions.btn-group .host-main{
  border-top-right-radius: 0 !important;
  border-bottom-right-radius: 0 !important;
}
.host-actions.btn-group .host-split{
  border-top-left-radius: 0 !important;
  border-bottom-left-radius: 0 !important;
  margin-left: -1px;
  position: relative;
}
.host-actions.btn-group .host-split:before{
  content:"";
  position:absolute;
  left:0;
  top:20%;
  bottom:20%;
  width:1px;
  background: rgba(0,0,0,.10);
}

.host-actions .host-menu{
  border-radius: 16px;
  border: 1px solid rgba(0,0,0,.10);
  box-shadow: 0 18px 46px rgba(0,0,0,.18);
  padding: .55rem;
  background:
    radial-gradient(900px 220px at 10% 0%, rgba(255,193,7,.10), transparent 55%),
    #fff;
  overflow: hidden;
}
.host-actions .host-menu .dropdown-item{
  border-radius: 12px;
  padding: .50rem .60rem;
  margin: .10rem 0;
  border: 1px solid transparent;
}
.host-actions .host-menu .dropdown-item:hover{
  background: rgba(255,193,7,.10);
  border-color: rgba(255,193,7,.22);
}

body .host-floating-dropdown{
  z-index: 20000 !important;
}
  </style>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
  <script src="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
{% endblock %}

{% block body %}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>

    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-globe2 me-2" style="color:var(--theme-color-secondaire)"></i>
            Hosts white-label
          </h2>

          <div class="opacity-75 mt-1">
            Gestion des domaines publics externes et des modules exposés.
          </div>

          <div class="d-flex gap-2 flex-wrap mt-3">
            <span class="chip"><i class="bi bi-diagram-3"></i> White-label</span>
            <span class="chip"><i class="bi bi-hdd-network"></i> Routage public</span>
            <span class="chip"><i class="bi bi-clock-history"></i> <span id="hero-last-refresh">—</span></span>
          </div>
        </div>

        <div class="d-flex gap-2">
          <a href="{{ path('app_super_public_host_ajouter') }}" class="btn btn-light btn-sm fw-semibold">
            <i class="bi bi-plus-circle me-1"></i> Nouveau host
          </a>

          <button type="button" class="btn btn-outline-theme btn-sm fw-semibold"
                  onclick="document.getElementById('filtersCollapse')?.scrollIntoView({behavior:'smooth'})">
            <i class="bi bi-funnel me-1"></i> Filtres
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-3">
    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-globe2 fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Hosts</div>
              <div class="kpi-value" id="kpi-total">—</div>
              <div class="kpi-sub">Total filtré</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-check-circle fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Actifs</div>
              <div class="kpi-value" id="kpi-actifs">—</div>
              <div class="kpi-sub">Hosts actifs</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-journal-text fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Formations</div>
              <div class="kpi-value" id="kpi-formations">—</div>
              <div class="kpi-sub">Affectations visibles</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
      <div class="kpi-card h-100">
        <div class="p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="kpi-ico"><i class="bi bi-grid-1x2 fs-4"></i></div>
            <div class="flex-grow-1">
              <div class="kpi-label">Modules ON</div>
              <div class="kpi-value" id="kpi-modules">—</div>
              <div class="kpi-sub">Somme des activations</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  <div class="filterbar mb-3">
    <div class="filterbar__top">
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <div class="filter-icon"><i class="bi bi-funnel"></i></div>
        <div>
          <div class="filterbar__title">Filtres</div>
          <div class="filterbar__hint">Affiner par statut, module et recherche libre.</div>
        </div>
      </div>

      <div class="ms-auto d-flex gap-2 align-items-center">
        <button class="btn btn-outline-secondary btn-sm fw-semibold d-md-none"
                type="button" data-bs-toggle="collapse" data-bs-target="#filtersCollapse">
          <i class="bi bi-sliders"></i> Filtres
        </button>

        <div class="dropdown">
          <button class="btn btn-warning btn-sm fw-semibold dropdown-toggle" data-bs-toggle="dropdown">
            <i class="bi bi-download"></i> Export
          </button>
          <ul class="dropdown-menu dropdown-menu-end" id="exportMenu"></ul>
        </div>
      </div>
    </div>

    <div class="collapse d-md-block" id="filtersCollapse">
      <div class="filterbar__body">
        <div class="filtergrid">

          <div class="filter-control fcol-status">
            <div class="form-label">Statut</div>
            <div class="filterbox">
              <div class="filterrow">
                <div class="filter-icon"><i class="bi bi-toggle-on"></i></div>
                <select id="statusFilter" class="form-select form-select-sm">
                  <option value="all">Tous</option>
                  <option value="active">Actifs</option>
                  <option value="inactive">Inactifs</option>
                </select>
              </div>
            </div>
          </div>

          <div class="filter-control fcol-module">
            <div class="form-label">Module</div>
            <div class="filterbox">
              <div class="filterrow">
                <div class="filter-icon"><i class="bi bi-grid-1x2"></i></div>
                <select id="moduleFilter" class="form-select form-select-sm">
                  <option value="all">Tous</option>
                  <option value="catalogue">Catalogue</option>
                  <option value="calendar">Calendrier</option>
                  <option value="elearning">E-learning</option>
                  <option value="shop">Shop</option>
                  <option value="restricted">Restriction formations</option>
                </select>
              </div>
            </div>
          </div>

          <div class="filter-control fcol-search">
            <div class="form-label">Recherche</div>
            <div class="filterbox">
              <div class="filterrow">
                <div class="filter-icon"><i class="bi bi-search"></i></div>
                <input type="text" id="quickSearch" class="form-control form-control-sm" placeholder="Nom, host, domaine…">
              </div>
            </div>
          </div>

          <div class="fcol-actions">
            <div class="form-label">&nbsp;</div>
            <button id="btnReset" type="button" class="resetbox w-100" title="Réinitialiser les filtres">
              <span class="filterrow w-100">
                <span class="filter-icon"><i class="bi bi-arrow-counterclockwise"></i></span>
                <span class="resetbox__text flex-grow-1">Reset</span>
                <span class="resetbox__badge" id="resetCount" style="display:none;">0</span>
              </span>
            </button>
          </div>

        </div>
      </div>
    </div>
  </div>

  <div class="table-card mb-4 p-3">
    <table id="tableauHosts" class="table table-hover align-middle mb-0 w-100">
      <thead>
        <tr>
          <th>#</th>
          <th>Nom</th>
          <th>Entité</th>
          <th>Host</th>
          <th>Actif</th>
          <th>Catalogue</th>
          <th>Calendrier</th>
          <th>E-learning</th>
          <th>Shop</th>
          <th>Restriction</th>
          <th>Formations</th>
          <th class="text-end"></th>
        </tr>
      </thead>
      <tbody></tbody>
    </table>
