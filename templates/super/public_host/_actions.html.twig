<div class="btn-group btn-group-sm host-actions" role="group">

  {# Bouton principal = modifier #}
  <a class="btn btn-light host-main"
     data-bs-toggle="tooltip"
     title="Modifier"
     href="{{ path('app_super_public_host_modifier', { id: host.id }) }}">
    <i class="bi bi-pencil"></i>
  </a>

  {# Split dropdown #}
  <button type="button"
          class="btn btn-light dropdown-toggle dropdown-toggle-split host-split"
          data-bs-toggle="dropdown"
          aria-expanded="false">
    <span class="visually-hidden">Actions</span>
  </button>

  <ul class="dropdown-menu dropdown-menu-end host-menu">
    <li>
      <a class="dropdown-item d-flex align-items-center"
         href="{{ path('app_super_public_host_modifier', { id: host.id }) }}">
        <i class="bi bi-pencil me-2"></i> Modifier
      </a>
    </li>

    <li>
      <a class="dropdown-item d-flex align-items-center"
         href="{{ path('app_super_public_host_show', { id: host.id }) }}">
        <i class="bi bi-eye me-2"></i> Voir
      </a>
    </li>

    <li><hr class="dropdown-divider"></li>

    <li>
      <button type="button"
              class="dropdown-item d-flex align-items-center text-danger delete-btn"
              data-bs-toggle="modal"
              data-bs-target="#deleteModal"
              data-url="{{ path('app_super_public_host_supprimer', { id: host.id }) }}"
              data-token="{{ csrf_token('delete_public_host_' ~ host.id) }}">
        <i class="bi bi-trash me-2"></i> Supprimer
      </button>
    </li>
  </ul>
</div>