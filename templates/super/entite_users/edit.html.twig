{% extends 'base_admin.html.twig' %}
{% block title %}Super — {{ isNew ? 'Ajouter' : 'Éditer' }} compte — {{ entite.nom }}{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --ink:#0f2336;
    }
    .wrap{ max-width: 980px; margin:0 auto; }
    .panel{
      border-radius:18px; background:#fff;
      border:1px solid rgba(0,0,0,.06);
      box-shadow: 0 12px 30px rgba(0,0,0,.06);
      overflow:hidden;
    }
    .panel .head{
      padding:1rem 1rem;
      border-bottom:1px solid rgba(0,0,0,.06);
      background: radial-gradient(900px 180px at 15% 0%, rgba(255,193,7,.10), transparent 55%), #fff;
    }
  </style>
{% endblock %}

{% block body %}
<div class="wrap py-4">

  <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <div>
      <div class="text-muted small">SUPER / {{ entite.nom }}</div>
      <h1 class="h4 mb-0">{{ isNew ? 'Ajouter un utilisateur à l’entité' : 'Éditer le rattachement' }}</h1>
    </div>
    <a class="btn btn-outline-secondary" href="{{ path('app_super_entite_users_index', { entite: entite.id }) }}">
      <i class="bi bi-arrow-left"></i> Retour
    </a>
  </div>

  {% include 'flagMessage.html.twig' %}

  <div class="panel">
    <div class="head d-flex justify-content-between align-items-center">
      <div class="fw-bold">Paramètres</div>
      <span class="badge text-bg-warning">Super</span>
    </div>

    <div class="p-3">
      {{ form_start(form) }}
        {{ form_widget(form) }}

        <div class="d-flex flex-wrap gap-2 mt-3">
          <button class="btn btn-warning fw-semibold" type="submit">
            <i class="bi bi-check2-circle"></i> Enregistrer
          </button>
          <a class="btn btn-outline-secondary" href="{{ path('app_super_entite_users_index', { entite: entite.id }) }}">
            Annuler
          </a>
        </div>
      {{ form_end(form) }}
    </div>
  </div>

</div>
{% endblock %}
