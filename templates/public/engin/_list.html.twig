{# templates/public/engin/_list.html.twig #}

{# COMPTEUR #}
<div id="results-count" class="results-count">
  {{ engins|length }} résultats
</div>

{# LISTE #}
<div id="results" class="vstack gap-4 pb-5">
  {% for b in engins %}
    {% set cover =
      (b.photoBanniere ? asset('uploads/photos/engin/' ~ b.photoBanniere) :
       (b.photoCouverture ? asset('uploads/photos/engin/' ~ b.photoCouverture) :
        asset('dist/img/vitrine/voile.webp')))
    %}

    <div class="session-card">
      <div class="row g-0">
        {# Visuel #}
        <div class="col-12 col-lg-3">
          <div class="session-media h-100 w-100" style="--cover:url('{{ cover|e('html_attr') }}');"></div>
        </div>

        {# Corps #}
        <div class="col-12 col-lg-6">
          <div class="session-body py-3">
            {# Badges compacts #}
            <div class="d-flex align-items-center flex-wrap gap-2 mb-2">
              {% if b.type is defined and b.type %}
                <span class="chip-soft">
                  <i class="bi bi-life-preserver me-1"></i>{{ b.type.value ?? b.type.name ?? b.type }}
                </span>
              {% endif %}
              {% if b.site %}
                <span class="chip-soft">
                  <i class="bi bi-geo-alt me-1"></i>{{ b.site.nom }}
                </span>
              {% endif %}
              {% set nbFormateurs = b.formateurQualifications|length %}
              {% if nbFormateurs > 0 %}
                <span class="chip-soft">
                  <i class="bi bi-person-badge-fill me-1"></i>{{ nbFormateurs }} formateur{% if nbFormateurs>1 %}s{% endif %} qualifié{% if nbFormateurs>1 %}s{% endif %}
                </span>
              {% endif %}
            </div>

            {# Titre #}
            <h3 class="session-title mb-2 fw-bold">{{ b.nom }}</h3>

            {# Infos rapides (chips) — protégées si attributs inexistants #}
            <div class="d-flex flex-wrap gap-2 mb-2">
              {% if b.annee        is defined and b.annee        %}<span class="chip-soft">Année {{ b.annee }}</span>{% endif %}
              {% if b.personnes    is defined and b.personnes    %}<span class="chip-soft">{{ b.personnes }} pers.</span>{% endif %}
              {% if b.cabinesDoubles is defined and b.cabinesDoubles %}<span class="chip-soft">{{ b.cabinesDoubles }} cab. doubles</span>{% endif %}
              {% if b.couchagesRecommandes is defined and b.couchagesRecommandes %}<span class="chip-soft">{{ b.couchagesRecommandes }} couch. recommandés</span>{% endif %}
              {% if b.couchagesCarres is defined and b.couchagesCarres is not null %}<span class="chip-soft">{{ b.couchagesCarres }} couch. carré</span>{% endif %}
            </div>

            {# Specs principales en grille compacte #}
            <div class="d-flex flex-wrap gap-3 small mt-2">
              <div class="spec-item">
                <i class="bi bi-people-fill me-1"></i>
                <span class="text-white-50">Capacité :</span>
                <strong>{{ b.capacite ?? '—' }}</strong>
              </div>
              <div class="spec-item">
                <i class="fa-solid fa-bed me-1"></i>
                <span class="text-white-50">Couchages :</span>
                <strong>{{ b.capaciteCouchage ?? '—' }}</strong>
              </div>
              {% if b.cabine %}
                <div class="spec-item">
                  <i class="bi bi-door-open-fill me-1"></i>
                  <span class="text-white-50">Cabines :</span>
                  <strong>{{ b.cabine }}</strong>
                </div>
              {% endif %}
              {% if b.douche %}
                <div class="spec-item">
                  <i class="fa-solid fa-shower me-1"></i>
                  <span class="text-white-50">Douches :</span>
                  <strong>{{ b.douche }}</strong>
                </div>
              {% endif %}
            </div>

            {# Dimensions / réservoirs (chips) #}
            {% set hasDims =
              (b.longueurHt     is defined and b.longueurHt) or
              (b.largeurMax     is defined and b.largeurMax) or
              (b.tirantEau      is defined and b.tirantEau)  or
              (b.reservoirFuel  is defined and b.reservoirFuel) or
              (b.reservoirEau   is defined and b.reservoirEau)
            %}
            {% if hasDims %}
              <div class="d-flex flex-wrap gap-2 mt-2">
                {% if b.longueurHt    is defined and b.longueurHt %}<span class="chip-soft">LHT {{ b.longueurHt }} m</span>{% endif %}
                {% if b.largeurMax    is defined and b.largeurMax %}<span class="chip-soft">Largeur {{ b.largeurMax }} m</span>{% endif %}
                {% if b.tirantEau     is defined and b.tirantEau  %}<span class="chip-soft">TE {{ b.tirantEau }} m</span>{% endif %}
                {% if b.reservoirFuel is defined and b.reservoirFuel %}<span class="chip-soft">Fuel {{ b.reservoirFuel }}</span>{% endif %}
                {% if b.reservoirEau  is defined and b.reservoirEau  %}<span class="chip-soft">Eau {{ b.reservoirEau }}</span>{% endif %}
              </div>
            {% endif %}

            {# Équipements (chips) #}
            {% set hasEquip =
              (b.dessalinisateur   is defined and b.dessalinisateur) or
              (b.panneauxSolaires  is defined and b.panneauxSolaires) or
              (b.refrigerateur     is defined and b.refrigerateur) or
              (b.prise             is defined and b.prise) or
              (b.propulseurEtrave  is defined and b.propulseurEtrave) or
              (b.gps               is defined and b.gps)
            %}
            {% if hasEquip %}
              <div class="d-flex flex-wrap gap-2 mt-2">
                {% if b.dessalinisateur  is defined and b.dessalinisateur  %}<span class="chip-soft">Dessalinisateur</span>{% endif %}
                {% if b.panneauxSolaires is defined and b.panneauxSolaires %}<span class="chip-soft">Panneaux solaires</span>{% endif %}
                {% if b.refrigerateur    is defined and b.refrigerateur    %}<span class="chip-soft">Réfrigérateur</span>{% endif %}
                {% if b.prise            is defined and b.prise            %}<span class="chip-soft">Prise</span>{% endif %}
                {% if b.propulseurEtrave is defined and b.propulseurEtrave %}<span class="chip-soft">Propulseur d’étrave</span>{% endif %}
                {% if b.gps              is defined and b.gps              %}<span class="chip-soft">GPS</span>{% endif %}
              </div>
            {% endif %}

            {# Extrait description #}
            {% if b.caracteristique %}
              <p class="text-white-50 mt-2 mb-0 small lh-sm">
                {{ (b.caracteristique|striptags|slice(0,160) ~ (b.caracteristique|length > 160 ? '…' : '')) }}
              </p>
            {% endif %}
          </div>
        </div>

        {# Panneau droit #}
        <div class="col-12 col-lg-3">
          <div class="price-panel text-center">
            <div class="price-from text-uppercase">Capacité max</div>
            <div class="price-value">
              {{ (b.capacite ?? 0)|number_format(0, ',', ' ') }}<span class="fs-6 align-top"> pers.</span>
            </div>
            <div class="text-white-50 mb-3">Couchages {{ b.capaciteCouchage ?? '—' }}</div>
            <a class="btn cta w-100" href="{{ path('app_public_engin_show', {id: b.id}) }}">Voir le engin</a>
          </div>
        </div>
      </div>
    </div>
  {% else %}
    <div class="empty-state text-center text-dark py-5">
      <i class="bi bi-emoji-frown fs-1 d-block mb-3"></i>
      <h3 class="h5 text-dark mb-2">Aucun engin trouvé</h3>
      <p class="mb-4">Essayez d’élargir les filtres (site, type, capacités).</p>
      <div class="d-flex gap-2 justify-content-center">
        <button type="button" id="btn-reset-filters" class="btn btn-secondary">
          <i class="bi bi-arrow-counterclockwise me-2"></i>Réinitialiser les filtres
        </button>
        <a href="{{ path('app_public_engin') }}" class="btn btn-warning text-dark">Voir toute la flotte</a>
      </div>
    </div>
  {% endfor %}
</div>
