{% block javascripts %}
{{ parent() }}
<script>

/* ===== HOME PRICING (Stripe-driven) ===== */

function formatEurFromCents(cents){
  const v = Number(cents || 0) / 100;
  return v > 0
    ? v.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + '€'
    : '—';
}

function homeRenderPrices(interval){
  // ✅ bon input hidden
  const intervalInput = document.getElementById('home-interval');
  if (intervalInput) intervalInput.value = interval;

  // ✅ bons sélecteurs
  document.querySelectorAll('.home-js-interval-main').forEach(el => el.textContent = 'mois');
  document.querySelectorAll('.home-js-interval-sub').forEach(el => {
    el.textContent = (interval === 'year') ? '(avec engagement annuel)' : '(sans engagement)';
  });

  // ✅ affichage depuis data-*
  document.querySelectorAll('.priceValue').forEach(el => {
    let cents = Number(el.dataset[interval] || 0);

    // ⚠️ data-year = prix annuel Stripe => on l’affiche au mois
    if (interval === 'year' && cents > 0) {
      cents = Math.round(cents / 12);
    }

    el.textContent = formatEurFromCents(cents);
  });
}

function getPlanCents(planUpper, interval){
  const el = document.querySelector(`.priceValue[data-plan-code="${planUpper}"]`);
  if (!el) return null;

  let cents = Number(el.dataset[interval] || 0);
  if (cents <= 0) return null;

  // ⚠️ data-year = annuel Stripe -> on renvoie un mensuel affichable
  if (interval === 'year') {
    cents = Math.round(cents / 12);
  }
  return cents;
}

function homeRefreshBillingModalIfOpen(){
  const modalEl = document.getElementById('homeBillingConfirmModal');
  if (!modalEl || !modalEl.classList.contains('show')) return;

  const planUpper = document.getElementById('home-selectedPlan')?.value || '';
  if (!planUpper) return;

  const interval = document.getElementById('home-interval')?.value || 'year';

  const intervalLabel = document.getElementById('homeBillingIntervalLabel');
  if (intervalLabel) {
    intervalLabel.textContent = (interval === 'month')
      ? 'Mensuel (sans engagement)'
      : 'Annuel (engagement annuel)';
  }

  const addonsLabel = document.getElementById('homeBillingAddonsLabel');
  if (addonsLabel) {
    const checked = Array.from(document.querySelectorAll('#pricing input[name="addons[]"]:checked'));
    addonsLabel.textContent = !checked.length ? 'Aucune' : (checked.length === 1 ? '1 option' : (checked.length + ' options'));
  }

  const cents = getPlanCents(planUpper, interval);

  const priceMain = document.getElementById('homeBillingPriceMain');
  const priceSub  = document.getElementById('homeBillingPriceSub');
  const totalYearWrap = document.getElementById('homeBillingTotalYearWrap');
  const totalYear = document.getElementById('homeBillingTotalYear');
  const priceUnit = document.getElementById('homeBillingPriceUnit');

  if (!cents) {
    if (priceMain) priceMain.textContent = '—';
    if (priceSub)  priceSub.textContent = 'Prix indisponible';
    if (priceUnit) priceUnit.textContent = 'mois';
    totalYearWrap?.classList.add('d-none');
    return;
  }

  if (priceMain) priceMain.textContent = formatEurFromCents(cents);
  if (priceUnit) priceUnit.textContent = 'mois';

  if (interval === 'year') {
    if (priceSub) priceSub.textContent = '(avec engagement annuel)';
    if (totalYear) totalYear.textContent = formatEurFromCents(cents * 12);
    totalYearWrap?.classList.remove('d-none');
  } else {
    if (priceSub) priceSub.textContent = '(sans engagement)';
    totalYearWrap?.classList.add('d-none');
  }
}



function homeUpdateBillingModal(planUpper){
  if (!planUpper) return;

  const interval = document.getElementById('home-interval')?.value || 'year';

  const intervalLabel = document.getElementById('homeBillingIntervalLabel');
  if (intervalLabel) {
    intervalLabel.textContent = (interval === 'month')
      ? 'Mensuel (sans engagement)'
      : 'Annuel (engagement annuel)';
  }

  const addonsLabel = document.getElementById('homeBillingAddonsLabel');
  if (addonsLabel) {
    const checked = Array.from(document.querySelectorAll('#pricing input[name="addons[]"]:checked'));
    addonsLabel.textContent = !checked.length ? 'Aucune' : (checked.length === 1 ? '1 option' : (checked.length + ' options'));
  }

  const cents = getPlanCents(planUpper, interval);

  const priceMain = document.getElementById('homeBillingPriceMain');
  const priceSub  = document.getElementById('homeBillingPriceSub');
  const totalYearWrap = document.getElementById('homeBillingTotalYearWrap');
  const totalYear = document.getElementById('homeBillingTotalYear');
  const priceUnit = document.getElementById('homeBillingPriceUnit');

  if (!cents) {
    if (priceMain) priceMain.textContent = '—';
    if (priceSub)  priceSub.textContent = 'Prix indisponible';
    if (priceUnit) priceUnit.textContent = 'mois';
    totalYearWrap?.classList.add('d-none');
    return;
  }

  if (priceMain) priceMain.textContent = formatEurFromCents(cents);
  if (priceUnit) priceUnit.textContent = 'mois';

  if (interval === 'year') {
    if (priceSub) priceSub.textContent = '(avec engagement annuel)';
    if (totalYear) totalYear.textContent = formatEurFromCents(cents * 12);
    totalYearWrap?.classList.remove('d-none');
  } else {
    if (priceSub) priceSub.textContent = '(sans engagement)';
    totalYearWrap?.classList.add('d-none');
  }
}

// Switch buttons
const homeBtnM = document.getElementById('home-btn-month');
const homeBtnY = document.getElementById('home-btn-year');

homeBtnM?.addEventListener('click', ()=>{
  homeBtnM.style.background = 'var(--accent)';
  homeBtnM.style.color = '#fff';
  homeBtnY.style.background = 'transparent';
  homeBtnY.style.color = 'inherit';
  homeRenderPrices('month');
  homeRefreshBillingModalIfOpen();
});

homeBtnY?.addEventListener('click', ()=>{
  homeBtnY.style.background = 'var(--accent)';
  homeBtnY.style.color = '#fff';
  homeBtnM.style.background = 'transparent';
  homeBtnM.style.color = 'inherit';
  homeRenderPrices('year');
  homeRefreshBillingModalIfOpen();
});

// Init
homeRenderPrices('year');


// ===== HOME: remplir le hidden "plan" au submit (trial) =====
(function bindHomeTrialSubmit(){
  const form = document.getElementById('homePricingForm');
  const planHidden = document.getElementById('home-selectedPlan');
  if (!form || !planHidden) return;

  form.addEventListener('submit', (e) => {
    const submitter = e.submitter;

    // Trial : plan depuis bouton "Essayer"
    if (submitter && submitter.classList.contains('js-home-trial-submit')) {
      const p = (submitter.dataset.plan || '').toUpperCase();
      if (p) planHidden.value = p;
      return;
    }

    // Checkout : plan doit déjà être dans le hidden
    const action = form.getAttribute('action') || '';
    if (action.includes('billing') || action.includes('checkout')) {
      planHidden.value = (planHidden.value || '').trim(); // ✅ pas de upper
    }
  });
})();

// Collapse “Voir le détail”
document.querySelectorAll('.toggle-details-home').forEach(btn => {
  const selector = btn.getAttribute('data-bs-target');
  const target = document.querySelector(selector);
  const label = btn.querySelector('.label-text');
  const icon  = btn.querySelector('.chevron');
  if (!target) return;

  const collapse = bootstrap.Collapse.getOrCreateInstance(target, { toggle: false });

  btn.addEventListener('click', (e) => {
    e.preventDefault();
    collapse.toggle();
  });

  target.addEventListener('shown.bs.collapse', () => {
    btn.setAttribute('aria-expanded', 'true');
    if (label) label.textContent = 'Réduire';
    if (icon)  icon.textContent = '−';
  });

  target.addEventListener('hidden.bs.collapse', () => {
    btn.setAttribute('aria-expanded', 'false');
    if (label) label.textContent = 'Voir le détail';
    if (icon)  icon.textContent = '+';
  });
});

// Update modal if addons change
document.addEventListener('change', (e) => {
  if (e.target && e.target.matches('#pricing input[name="addons[]"]')) {
    homeRefreshBillingModalIfOpen();
  }
});

// Modal binding (HOME)
(function bindHomeBillingConfirmModal(){
  const modalEl = document.getElementById('homeBillingConfirmModal');
  if (!modalEl) return;

  const form   = document.getElementById('homePricingForm');
  const planIn = document.getElementById('home-selectedPlan');

  const labelPlan     = document.getElementById('homeBillingPlanLabel');
  const labelInterval = document.getElementById('homeBillingIntervalLabel');
  const labelAddons   = document.getElementById('homeBillingAddonsLabel');

  const priceUnit = document.getElementById('homeBillingPriceUnit');

  const chk = document.getElementById('homeConfirmBillingCheck');
  const btn = document.getElementById('homeBtnConfirmBilling');


  form?.addEventListener('submit', () => {
    const fd = new FormData(form);
    console.log('[HOME SUBMIT] action=', form.getAttribute('action'));
    console.log('[HOME SUBMIT] payload=', Array.from(fd.entries()));
  });

  let submitting = false;
  let originalBtnHtml = btn ? btn.innerHTML : '';
  const closeBtn = modalEl.querySelector('.btn-close');

  function getIntervalLabel(){
    const v = document.getElementById('home-interval')?.value || 'year';
    return v === 'month' ? 'Mensuel (sans engagement)' : 'Annuel (engagement annuel)';
  }
  function getAddonsLabel(){
    const checked = Array.from(document.querySelectorAll('#pricing input[name="addons[]"]:checked'));
    if (!checked.length) return 'Aucune';
    return checked.length === 1 ? '1 option' : (checked.length + ' options');
  }
  function lockUI(){
    submitting = true;
    if (btn){
      btn.disabled = true;
      btn.setAttribute('aria-busy','true');
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Redirection...';
    }
    if (closeBtn) closeBtn.disabled = true;
  }
  function unlockUI(){
    submitting = false;
    if (btn){
      btn.removeAttribute('aria-busy');
      btn.innerHTML = originalBtnHtml;
      btn.disabled = !(chk && chk.checked);
    }
    if (closeBtn) closeBtn.disabled = false;
  }
  function resetState(){
    submitting = false;
    if (chk) chk.checked = false;
    if (btn){
      btn.disabled = true;
      btn.removeAttribute('aria-busy');
      btn.innerHTML = originalBtnHtml;
    }
    if (labelPlan) labelPlan.textContent = '—';
    if (labelInterval) labelInterval.textContent = '—';
    if (labelAddons) labelAddons.textContent = '—';
    if (form) form.setAttribute('action', "{{ path('app_pricing_start_trial') }}");
    if (planIn) planIn.value = '';
    if (closeBtn) closeBtn.disabled = false;
    const tokenInput = document.getElementById('home-form-token');
    if (tokenInput) {
      tokenInput.value = modalEl.dataset.csrfTrial || '';
    }
  }

  document.addEventListener('click', function(e){
    const trigger = e.target.closest('.js-open-home-billing-confirm');
    if (!trigger) return;

    const action = trigger.dataset.action || '#';
    const plan   = trigger.dataset.plan || '';
    const planName = trigger.dataset.planName || plan || '—';
    const cta = trigger.dataset.cta || 'Continuer';

    modalEl.dataset.plan = plan;

    if (priceUnit) priceUnit.textContent = 'mois';

    // set form action + plan
    if (form) form.setAttribute('action', action);

    // ✅ swap CSRF selon l'action
    const tokenInput = document.getElementById('home-form-token');
    if (tokenInput) {
      const isCheckout = action.includes('billing') || action.includes('checkout');
      tokenInput.value = isCheckout ? (modalEl.dataset.csrfCheckout || '') : (modalEl.dataset.csrfTrial || '');
    }


    if (planIn) planIn.value = String(plan || '');

    if (labelPlan) labelPlan.textContent = planName;
    if (labelInterval) labelInterval.textContent = getIntervalLabel();
    if (labelAddons) labelAddons.textContent = getAddonsLabel();


    if (btn){
      btn.innerHTML = '<i class="bi bi-arrow-right-circle me-1"></i> ' + cta;
      originalBtnHtml = btn.innerHTML;
    }

    if (chk) chk.checked = false;
    if (btn) btn.disabled = true;
    // ✅ plan sûr (si jamais le hidden a été vidé)
    if (planIn && (!planIn.value || !planIn.value.trim())) {
      planIn.value = modalEl.dataset.plan || '';
    }
    unlockUI();

    homeUpdateBillingModal((planIn?.value || '').toUpperCase());
    const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
    modal.show();
  });

  chk?.addEventListener('change', ()=>{
    if (!btn) return;
    if (submitting){ btn.disabled = true; return; }
    btn.disabled = !chk.checked;
  });

  // Remplacez la partie finale de bindHomeBillingConfirmModal par ceci :
  btn?.addEventListener('click', () => {
      if (submitting) return;
      if (!chk || !chk.checked) return;

      // SÉCURITÉ : On s'assure que le champ hidden est bien rempli avant de partir
      const planIn = document.getElementById('home-selectedPlan');
      if (modalEl.dataset.plan) {
          planIn.value = modalEl.dataset.plan;
      }

      lockUI();

      if (form && !form.dataset.submitted) {
          form.dataset.submitted = '1';
          // Désactiver Turbo pour cette soumission pour éviter les conflits de redirection
          form.setAttribute('data-turbo', 'false'); 
          form.submit(); // Soumission standard plus fiable pour Stripe
      }
  });

  modalEl.addEventListener('hidden.bs.modal', ()=>{
    if (form) delete form.dataset.submitted;
    resetState();
  });

  modalEl.addEventListener('shown.bs.modal', () => {
    const planUpper = document.getElementById('home-selectedPlan')?.value || '';
    homeUpdateBillingModal(planUpper);
  });
})();
</script>

{# ===== ton JS existant (FAQ + animations) peut rester après ou avant, peu importe ===== #}
<script>
function toggleFaq(btn) {
  const item = btn.closest('.faq-item');
  const isOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(el => el.classList.remove('open'));
  if (!isOpen) item.classList.add('open');
}

/* Scroll-triggered fade-in */
const obs = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.style.opacity = 1;
      e.target.style.transform = 'translateY(0)';
    }
  });
}, { threshold: .1 });

document.querySelectorAll('.mod-cell, .step-card, .testi-card, .price-card, .value-cell, .faq-item, .compare-row').forEach((el, i) => {
  el.style.opacity = 0;
  el.style.transform = 'translateY(18px)';
  el.style.transition = `opacity .55s ease ${(i % 4) * .08}s, transform .55s ease ${(i % 4) * .08}s`;
  obs.observe(el);
});
</script>
{% endblock %}