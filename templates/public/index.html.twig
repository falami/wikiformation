{# templates/public/index.html.twig #}
{% extends 'base_public.html.twig' %}

{% block title %}Wikiformation - La plateforme tout-en-un pour piloter votre organisme, simplement{% endblock %}
{% block meta_description %}Sessions, documents, Qualiopi, e-learning, évaluations, extranet, facturation, tableaux de bord. Wikiformation centralise et automatise votre quotidien pour gagner du temps et sécuriser votre conformité.{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Geist:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>
/* ═══════════════════════════════════════════
   TOKENS (Ultra premium + dark ready)
═══════════════════════════════════════════ */
:root {
  /* Backgrounds */
  --bg-base:    #faf9f7;
  --bg-warm:    #f4f1ec;
  --bg-card:    #ffffff;
  --bg-muted:   #f0ede8;

  /* Ink */
  --ink-1:      #1a1916;
  --ink-2:      #3d3b37;
  --ink-3:      #7a786f;
  --ink-4:      #aaa89f;

  /* Accent - bleu ardoise */
  --accent:     #2563a8;
  --accent-lt:  #dbeafe;
  --accent-mid: #93bbf0;

  /* Accent 2 - vert sauge */
  --sage:       #4a7c59;
  --sage-lt:    #d6ead9;
  --sage-mid:   #8dbf9c;

  /* Accent 3 - terre cuite (CTA) */
  --terra:      #c25d3b;
  --terra-lt:   #fceee8;
  --terra-mid:  #e8967a;

  /* Borders */
  --border:     rgba(26,25,22,.09);
  --border2:    rgba(26,25,22,.15);
  --border3:    rgba(26,25,22,.05);

  /* Shadows */
  --shadow-sm:  0 1px 4px rgba(26,25,22,.07), 0 10px 24px rgba(26,25,22,.04);
  --shadow-md:  0 2px 10px rgba(26,25,22,.07), 0 20px 56px rgba(26,25,22,.08);
  --shadow-lg:  0 6px 18px rgba(26,25,22,.08), 0 30px 84px rgba(26,25,22,.12);

  /* Radii */
  --r-2xl: 30px;
  --r-xl:  22px;
  --r-lg:  16px;
  --r-md:  12px;

  /* Fonts */
  --font-display: 'Lora', Georgia, serif;
  --font-body:    'Geist', system-ui, sans-serif;

  /* Motion */
  --ease: cubic-bezier(.22,.68,0,1);
  --t: 220ms var(--ease);

  /* Hero colors */
  --hero-ink: #ffffff;
  --hero-muted: rgba(255,255,255,.72);
  --hero-stroke: rgba(255,255,255,.12);
  --hero-glass: rgba(255,255,255,.08);

  /* Focus */
  --focus: 0 0 0 4px rgba(37,99,168,.22);
}

/* Dark mode (auto) */
@media (prefers-color-scheme: dark) {
  :root{
    --bg-base:  #0b0f14;
    --bg-warm:  #0e141c;
    --bg-card:  #0f1722;
    --bg-muted: #101a26;

    --ink-1: #e9eef6;
    --ink-2: rgba(233,238,246,.86);
    --ink-3: rgba(233,238,246,.64);
    --ink-4: rgba(233,238,246,.45);

    --border:  rgba(233,238,246,.10);
    --border2: rgba(233,238,246,.16);
    --border3: rgba(233,238,246,.06);

    --shadow-sm:  0 1px 6px rgba(0,0,0,.30);
    --shadow-md:  0 10px 40px rgba(0,0,0,.40);
    --shadow-lg:  0 18px 70px rgba(0,0,0,.55);

    --hero-ink: #ffffff;
    --hero-muted: rgba(255,255,255,.72);
    --hero-stroke: rgba(255,255,255,.12);
    --hero-glass: rgba(255,255,255,.07);
    --focus: 0 0 0 4px rgba(147,187,240,.25);
  }
}

/* ═══════════════════════════════════════════
   BASE
═══════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: var(--font-body);
  background: var(--bg-base);
  color: var(--ink-1);
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  text-rendering: geometricPrecision;
}
a { text-decoration: none; color: inherit; }
img { max-width: 100%; display: block; }

:where(a, button) { outline: none; }
:where(a, button):focus-visible { box-shadow: var(--focus); border-radius: 14px; }


.w-max { max-width: 1240px; margin-inline: auto; padding-inline: 1.5rem; }

/* Subtle dot-grid texture (softer) */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: -1; /* ✅ IMPORTANT : derrière tout */
  background-image: radial-gradient(circle, rgba(26,25,22,.055) 1px, transparent 1px);
  background-size: 30px 30px;
  opacity: .45;
}

@media (prefers-color-scheme: dark) {
  body::before {
    background-image: radial-gradient(circle, rgba(255,255,255,.06) 1px, transparent 1px);
    opacity: .22;
  }
}

/* ═══════════════════════════════════════════
   ORNAMENT (crisper)
═══════════════════════════════════════════ */
.ornament { display: flex; align-items: center; gap: 1rem; max-width: 340px; margin: 0 auto; }
.ornament-line {
  flex: 1; height: 1px;
  background: linear-gradient(90deg, transparent, var(--border2), transparent);
}
.ornament-gem {
  width: 8px; height: 8px;
  background: linear-gradient(135deg, var(--terra), var(--accent));
  rotate: 45deg;
  box-shadow: 0 0 14px rgba(194,93,59,.22);
}

/* ═══════════════════════════════════════════
   LABELS (glassier)
═══════════════════════════════════════════ */
.label {
  display: inline-flex; align-items: center; gap: .45rem;
  padding: .32rem .75rem;
  border-radius: 999px;
  border: 1px solid var(--border2);
  background: color-mix(in srgb, var(--bg-card) 80%, transparent);
  color: var(--ink-2);
  font-size: .75rem; font-weight: 700;
  letter-spacing: .05em; text-transform: uppercase;
  box-shadow: var(--shadow-sm);
  backdrop-filter: blur(8px);
}
.label i { opacity: .95; }

.label.accent { background: color-mix(in srgb, var(--accent-lt) 75%, transparent); border-color: var(--accent-mid); color: var(--accent); }
.label.sage   { background: color-mix(in srgb, var(--sage-lt) 75%, transparent);   border-color: var(--sage-mid);   color: var(--sage); }
.label.terra  { background: color-mix(in srgb, var(--terra-lt) 75%, transparent);  border-color: var(--terra-mid);  color: var(--terra); }

/* ═══════════════════════════════════════════
   BUTTONS (premium, tactile)
═══════════════════════════════════════════ */
.btn-prime, .btn-outline, .btn-accent {
  display: inline-flex; align-items: center; gap: .55rem;
  padding: .88rem 1.55rem;
  border-radius: var(--r-lg);
  font-family: var(--font-body);
  font-size: .95rem;
  cursor: pointer;
  white-space: nowrap;
  transition: transform var(--t), box-shadow var(--t), background var(--t), border-color var(--t), color var(--t), opacity var(--t);
  will-change: transform;
  user-select: none;
}
.btn-prime:active, .btn-outline:active, .btn-accent:active { transform: translateY(0); }

.btn-prime {
  border: 0; color: #fff;
  background: linear-gradient(135deg, #c25d3b, #b04f30);
  box-shadow: 0 10px 28px rgba(194,93,59,.28), 0 2px 6px rgba(0,0,0,.10);
}
.btn-prime:hover {
  transform: translateY(-2px);
  box-shadow: 0 16px 44px rgba(194,93,59,.32), 0 8px 18px rgba(0,0,0,.12);
  color: #fff;
}

.btn-outline {
  border: 1.5px solid var(--border2);
  background: color-mix(in srgb, var(--bg-card) 85%, transparent);
  color: var(--ink-2);
  box-shadow: var(--shadow-sm);
  backdrop-filter: blur(10px);
}
.btn-outline:hover {
  border-color: color-mix(in srgb, var(--accent) 55%, var(--border2));
  background: color-mix(in srgb, var(--accent-lt) 45%, var(--bg-card));
  color: var(--accent);
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}

.btn-accent {
  border: 0; color: #fff;
  background: linear-gradient(135deg, #2563a8, #1d4f89);
  box-shadow: 0 10px 30px rgba(37,99,168,.25);
}
.btn-accent:hover {
  transform: translateY(-2px);
  box-shadow: 0 18px 52px rgba(37,99,168,.30);
  color:#fff;
}

.btn-prime i, .btn-outline i, .btn-accent i { transform: translateY(.5px); }

/* ═══════════════════════════════════════════
   SECTION CHROME
═══════════════════════════════════════════ */
.section { padding: 5.2rem 0; position: relative; }
.section-header { text-align: center; margin-bottom: 3.6rem; }
.section-title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 3.4vw, 2.95rem);
  font-weight: 600;
  line-height: 1.16; color: var(--ink-1);
  letter-spacing: -.012em;
  margin: .95rem 0 .85rem;
}
.section-title em { font-style: italic; color: var(--terra); font-weight: 400; }
.section-lead {
  font-size: 1.05rem; line-height: 1.78;
  color: var(--ink-3); max-width: 70ch;
  margin-inline: auto;
}
.divider { border: 0; height: 1px; background: var(--border); margin: 0; }

/* ═══════════════════════════════════════════
   HERO (cinematic mesh + vignette)
═══════════════════════════════════════════ */
.hero {
  padding: 6.2rem 0 4rem;
  position: relative;
  overflow: hidden;
  isolation: isolate;
}
/* Main cinematic background */
.hero::before{
  content:'';
  position:absolute; inset:-2px;
  z-index:-2;
  background:
    radial-gradient(1200px 700px at 15% 10%, rgba(37,99,168,.55), transparent 60%),
    radial-gradient(900px 520px at 85% 20%, rgba(194,93,59,.45), transparent 60%),
    radial-gradient(820px 520px at 55% 95%, rgba(74,124,89,.35), transparent 62%),
    linear-gradient(180deg, #09111b 0%, #0b0f14 70%, color-mix(in srgb, var(--bg-base) 30%, #0b0f14) 100%);
}
/* Vignette + subtle noise-like sheen */
.hero::after{
  content:'';
  position:absolute; inset:0;
  z-index:-1;
  background:
    radial-gradient(circle at 30% 20%, rgba(255,255,255,.10), transparent 40%),
    radial-gradient(circle at 70% 10%, rgba(255,255,255,.08), transparent 45%),
    radial-gradient(circle at 50% 85%, rgba(255,255,255,.06), transparent 48%),
    linear-gradient(180deg, rgba(0,0,0,.35), rgba(0,0,0,.55));
  mix-blend-mode: soft-light;
  pointer-events:none;
}

/* Subtle “light streak” */
.hero-streak{
  position:absolute; inset:auto -20% 10% -20%;
  height: 220px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,.10), transparent);
  transform: rotate(-8deg);
  filter: blur(8px);
  opacity: .6;
  z-index: -1;
}

.hero-inner {
  display: grid;
  grid-template-columns: 1.05fr .95fr;
  gap: 4rem;
  align-items: center;
}
@media (max-width: 960px) {
  .hero-inner { grid-template-columns: 1fr; gap: 2.6rem; }
  .hero { padding: 4.2rem 0 3rem; }
}

.hero-eyebrow { display: flex; flex-wrap: wrap; gap: .5rem; margin-bottom: 1.45rem; }

.hero-title {
  font-family: var(--font-display);
  font-size: clamp(2.55rem, 5.2vw, 3.35rem);
  font-weight: 600; line-height: 1.06;
  letter-spacing: -.02em;
  margin-bottom: 1.25rem;
  color: var(--hero-ink);
  text-shadow: 0 18px 55px rgba(0,0,0,.45);
}
.hero-title em { font-style: italic; color: #ffd2c2; font-weight: 400; }

.hero-sub {
  font-size: 1.08rem; line-height: 1.78;
  color: var(--hero-muted);
  max-width: 56ch;
  margin-bottom: 2.1rem;
}

.hero-ctas { display: flex; gap: .75rem; flex-wrap: wrap; margin-bottom: 2rem; }

/* Trust chips in hero (glass) */
.hero-trust { display: flex; flex-wrap: wrap; gap: .55rem; }
.hero-trust .label{
  background: var(--hero-glass);
  border-color: var(--hero-stroke);
  color: rgba(255,255,255,.82);
  box-shadow: 0 10px 30px rgba(0,0,0,.18);
}
.hero-trust .label i{ opacity:.9; }

/* ═══════════════════════════════════════════
   LIVE CARD (glass SaaS)
═══════════════════════════════════════════ */
.live-card {
  border-radius: var(--r-2xl);
  border: 1px solid rgba(255,255,255,.14);
  background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,.06));
  box-shadow: 0 30px 90px rgba(0,0,0,.45);
  overflow: hidden;
  position: relative;
  backdrop-filter: blur(14px);
  transform: translateZ(0);
}
.live-card::before{
  content:'';
  position:absolute; inset:0;
  background:
    radial-gradient(700px 420px at 20% 10%, rgba(255,255,255,.16), transparent 60%),
    radial-gradient(720px 420px at 85% 35%, rgba(255,255,255,.10), transparent 60%);
  pointer-events:none;
}
.live-card::after {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: linear-gradient(90deg, var(--terra), var(--accent), var(--sage));
}

.lc-header {
  padding: 1rem 1.2rem;
  background: rgba(10,14,20,.30);
  border-bottom: 1px solid rgba(255,255,255,.10);
  display: flex; align-items: center; justify-content: space-between;
}
.lc-dots { display: flex; gap: .35rem; }
.lc-dot  { width: .55rem; height: .55rem; border-radius: 50%; filter: saturate(1.2); }
.lc-dot.r { background: #ff5f5a; } .lc-dot.y { background: #febc2e; } .lc-dot.g { background: #28c840; }

.lc-title-bar {
  font-size: .82rem; font-weight: 700;
  color: rgba(255,255,255,.72);
  display: flex; align-items: center; gap: .45rem;
}
.lc-live {
  display: inline-flex; align-items: center; gap: .4rem;
  font-size: .72rem; font-weight: 800;
  color: #bff2cf;
  letter-spacing: .08em; text-transform: uppercase;
}
.lc-live::before {
  content: ''; width: 6px; height: 6px; border-radius: 50%;
  background: #77f0a7;
  box-shadow: 0 0 10px rgba(119,240,167,.65);
  animation: livepulse 1.4s infinite;
}
@keyframes livepulse { 0%,100%{opacity:1} 50%{opacity:.25} }

.lc-body { padding: 1.15rem; }

.lc-stat-row {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: .7rem; margin-bottom: 1rem;
}
.lc-stat {
  border-radius: 18px;
  border: 1px solid rgba(255,255,255,.12);
  background: rgba(10,14,20,.22);
  padding: .85rem .65rem; text-align: center;
}
.lc-stat-n {
  font-family: var(--font-display);
  font-size: 1.55rem; font-weight: 600;
  color: #ffd2c2;
  line-height: 1; margin-bottom: .2rem;
}
.lc-stat-l {
  font-size: .68rem; font-weight: 700;
  color: rgba(255,255,255,.58);
  letter-spacing: .08em; text-transform: uppercase;
}

.lc-item {
  display: flex; align-items: center; gap: .85rem;
  padding: .85rem .95rem;
  border-radius: 18px;
  border: 1px solid rgba(255,255,255,.12);
  background: rgba(10,14,20,.18);
  margin-bottom: .6rem;
  transition: transform var(--t), background var(--t), border-color var(--t);
}
.lc-item:last-child { margin-bottom: 0; }
.lc-item:hover {
  background: rgba(255,255,255,.10);
  border-color: rgba(255,255,255,.18);
  transform: translateY(-2px);
}

.lc-icon {
  width: 40px; height: 40px; border-radius: 14px;
  display: grid; place-items: center;
  flex-shrink: 0; font-size: .98rem;
  border: 1px solid rgba(255,255,255,.16);
  background: rgba(255,255,255,.10);
  color: #fff;
}
.ico-terra  { background: rgba(194,93,59,.18); }
.ico-accent { background: rgba(37,99,168,.20); }
.ico-sage   { background: rgba(74,124,89,.20); }
.ico-warm   { background: rgba(254,188,46,.16); }

.lc-item-text { flex: 1; min-width: 0; }
.lc-item-name { font-size: .9rem; font-weight: 800; color: rgba(255,255,255,.92); }
.lc-item-desc { font-size: .77rem; color: rgba(255,255,255,.62); margin-top: .08rem; }

.lc-badge {
  font-size: .7rem; font-weight: 900;
  padding: .26rem .58rem; border-radius: 999px;
  white-space: nowrap; letter-spacing: .04em;
  border: 1px solid rgba(255,255,255,.16);
  background: rgba(255,255,255,.10);
  color: rgba(255,255,255,.86);
}

.lc-footer {
  padding: .9rem 1.15rem;
  background: rgba(10,14,20,.28);
  border-top: 1px solid rgba(255,255,255,.10);
  display: flex; align-items: center; justify-content: space-between; gap: 1rem;
}
.lc-footer-text { font-size: .8rem; color: rgba(255,255,255,.70); font-weight: 700; }

/* ═══════════════════════════════════════════
   INDUSTRIES ROW
═══════════════════════════════════════════ */
.industries-row {
  display: flex; flex-wrap: wrap; gap: .55rem; justify-content: center;
  margin-top: 1.1rem;
}
.industries-row .label{
  background: rgba(255,255,255,.08);
  border-color: rgba(255,255,255,.12);
  color: rgba(255,255,255,.78);
}

/* ═══════════════════════════════════════════
   VALUE STRIP (premium top gradient)
═══════════════════════════════════════════ */
.value-strip {
  border-radius: var(--r-2xl);
  border: 1px solid var(--border2);
  background: var(--bg-card);
  box-shadow: var(--shadow-md);
  overflow: hidden;
  position: relative;
}
.value-strip::before{
  content:'';
  position:absolute; left:0; right:0; top:0; height:2px;
  background: linear-gradient(90deg, var(--terra), var(--accent), var(--sage));
}
.value-grid { display: grid; grid-template-columns: repeat(3, 1fr); }
@media (max-width: 768px) { .value-grid { grid-template-columns: 1fr; } }
.value-cell { padding: 2.05rem 1.8rem; border-right: 1px solid var(--border); position: relative; }
.value-cell:last-child { border-right: 0; }
@media (max-width: 768px) {
  .value-cell { border-right: 0; border-bottom: 1px solid var(--border); }
  .value-cell:last-child { border-bottom: 0; }
}
.value-cell.mid { background: linear-gradient(180deg, var(--bg-warm), var(--bg-card)); }
.value-icon {
  width: 46px; height: 46px; border-radius: 14px;
  display: grid; place-items: center;
  margin-bottom: 1rem; font-size: 1.1rem;
  box-shadow: 0 12px 28px rgba(0,0,0,.08);
}
.value-cell-title { font-weight: 800; font-size: .98rem; color: var(--ink-1); margin-bottom: .55rem; display: flex; align-items: center; gap: .45rem; }
.value-cell-text { font-size: .9rem; line-height: 1.72; color: var(--ink-3); }

/* ═══════════════════════════════════════════
   MODULES GRID (hover glow)
═══════════════════════════════════════════ */
.modules-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 1px; border: 1px solid var(--border2);
  border-radius: var(--r-2xl); overflow: hidden;
  background: var(--border);
  box-shadow: var(--shadow-md);
}
@media (max-width: 960px) { .modules-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 560px) { .modules-grid { grid-template-columns: 1fr; } }

.mod-cell {
  background: var(--bg-card);
  padding: 1.75rem 1.6rem;
  transition: transform var(--t), background var(--t);
  position: relative; overflow: hidden;
}
.mod-cell::before{
  content:'';
  position:absolute; inset:0;
  background: radial-gradient(420px 220px at 25% 10%, rgba(37,99,168,.10), transparent 60%);
  opacity:0;
  transition: opacity var(--t);
}
.mod-cell::after {
  content: '';
  position: absolute; bottom: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, var(--terra), var(--accent), var(--sage));
  transform: scaleX(0); transform-origin: left;
  transition: transform 320ms var(--ease);
}
.mod-cell:hover { background: color-mix(in srgb, var(--bg-warm) 65%, var(--bg-card)); transform: translateY(-2px); }
.mod-cell:hover::after { transform: scaleX(1); }
.mod-cell:hover::before{ opacity:1; }

.mod-ico {
  width: 48px; height: 48px; border-radius: 16px;
  display: grid; place-items: center;
  font-size: 1.15rem; margin-bottom: 1.05rem;
  transition: transform var(--t);
  box-shadow: 0 14px 30px rgba(0,0,0,.08);
}
.mod-cell:hover .mod-ico { transform: scale(1.06); }

.mod-ico-terra  { background: var(--terra-lt);  border: 1px solid var(--terra-mid);  color: var(--terra); }
.mod-ico-accent { background: var(--accent-lt); border: 1px solid var(--accent-mid); color: var(--accent); }
.mod-ico-sage   { background: var(--sage-lt);   border: 1px solid var(--sage-mid);   color: var(--sage); }
.mod-ico-warm   { background: #fef9e7; border: 1px solid #f0d080; color: #a07820; }
.mod-ico-pink   { background: #fce7f3; border: 1px solid #f0a0c0; color: #a02060; }
.mod-ico-slate  { background: #e8eef7; border: 1px solid #b0c0d8; color: #3a5070; }

.mod-name { font-weight: 800; font-size: .99rem; color: var(--ink-1); margin-bottom: .48rem; }
.mod-desc { font-size: .86rem; line-height: 1.65; color: var(--ink-3); margin-bottom: .9rem; }
.mod-tags { display: flex; flex-wrap: wrap; gap: .35rem; }
.mod-tag {
  font-size: .68rem; font-weight: 700;
  padding: .2rem .52rem; border-radius: 999px;
  background: color-mix(in srgb, var(--bg-muted) 85%, transparent);
  border: 1px solid var(--border2);
  color: var(--ink-4);
  letter-spacing: .04em;
}

/* ═══════════════════════════════════════════
   STEPS
═══════════════════════════════════════════ */
.steps-wrap { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; position: relative; }
.steps-connector {
  position: absolute; top: 28px; left: 16%; right: 16%;
  height: 1px; background: linear-gradient(90deg, var(--terra-mid), var(--accent-mid));
  opacity: .45;
}
@media (max-width: 768px) { .steps-wrap { grid-template-columns: 1fr; } .steps-connector { display: none; } }

.step-card {
  border-radius: var(--r-xl); border: 1px solid var(--border);
  background: var(--bg-card); padding: 1.65rem 1.45rem;
  box-shadow: var(--shadow-sm);
  transition: transform var(--t), box-shadow var(--t), border-color var(--t);
}
.step-card:hover { border-color: var(--border2); transform: translateY(-4px); box-shadow: var(--shadow-md); }
.step-num {
  width: 42px; height: 42px; border-radius: 50%;
  display: grid; place-items: center;
  font-weight: 900; font-size: .86rem;
  background: linear-gradient(135deg, var(--terra), #b04f30);
  color: #fff;
  margin-bottom: 1.15rem;
  box-shadow: 0 14px 30px rgba(194,93,59,.25);
}
.step-title { font-weight: 800; font-size: .98rem; color: var(--ink-1); margin-bottom: .55rem; }
.step-text  { font-size: .88rem; line-height: 1.7; color: var(--ink-3); }

/* ═══════════════════════════════════════════
   COMPARE TABLE
═══════════════════════════════════════════ */
.compare-wrap {
  border-radius: var(--r-2xl);
  border: 1px solid var(--border2);
  overflow: hidden;
  box-shadow: var(--shadow-md);
  position: relative;
}
.compare-wrap::before{
  content:'';
  position:absolute; left:0; right:0; top:0; height:2px;
  background: linear-gradient(90deg, var(--terra), var(--accent), var(--sage));
}
.compare-head { display: grid; grid-template-columns: 1.2fr 1fr 1fr; background: var(--bg-warm); border-bottom: 1px solid var(--border2); }
@media (max-width: 768px) { .compare-head, .compare-row { grid-template-columns: 1fr; } }
.compare-head-cell {
  padding: 1.08rem 1.25rem; font-weight: 800; font-size: .87rem;
  color: var(--ink-3); border-right: 1px solid var(--border);
}
.compare-head-cell:last-child { border-right: 0; }
.compare-head-cell.highlight { background: var(--accent-lt); color: var(--accent); border-color: var(--accent-mid); }
.compare-row { display: grid; grid-template-columns: 1.2fr 1fr 1fr; border-top: 1px solid var(--border); background: var(--bg-card); transition: background var(--t); }
.compare-row:hover { background: color-mix(in srgb, var(--bg-warm) 65%, var(--bg-card)); }
.compare-cell {
  padding: 1rem 1.25rem; font-size: .88rem; line-height: 1.66;
  color: var(--ink-3); border-right: 1px solid var(--border);
}
.compare-cell:last-child { border-right: 0; }
.compare-cell.key { font-weight: 800; color: var(--ink-1); }
.compare-cell.bad { color: var(--ink-4); font-style: italic; }
.compare-cell.good { color: var(--sage); background: color-mix(in srgb, var(--sage-lt) 75%, transparent); font-weight: 700; }

/* ═══════════════════════════════════════════
   TESTIMONIALS
═══════════════════════════════════════════ */
.testi-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
@media (max-width: 768px) { .testi-grid { grid-template-columns: 1fr; } }
.testi-card {
  border-radius: var(--r-xl); border: 1px solid var(--border);
  background: var(--bg-card); padding: 1.75rem;
  box-shadow: var(--shadow-sm);
  transition: transform var(--t), box-shadow var(--t), border-color var(--t);
  position: relative; overflow: hidden;
}
.testi-card::before {
  content: '';
  position: absolute; top: 0; left: 0; width: 3px; height: 100%;
  background: linear-gradient(180deg, var(--terra), var(--accent), var(--sage));
}
.testi-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); border-color: var(--border2); }
.testi-quote-mark { font-family: var(--font-display); font-size: 3rem; line-height: .7; color: var(--terra); opacity: .35; margin-bottom: .65rem; display: block; }
.testi-text { font-size: .94rem; line-height: 1.75; color: var(--ink-2); font-style: italic; margin-bottom: 1.15rem; }
.testi-author { font-weight: 800; color: var(--ink-1); font-size: .88rem; }
.testi-role   { font-size: .78rem; color: var(--ink-4); margin-top: .12rem; }

/* ═══════════════════════════════════════════
   PRICING
═══════════════════════════════════════════ */

/* PRICING GRID: 4 colonnes */
.pricing-grid{
  display:grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
}

/* Écran moyen -> 2 colonnes */
@media (max-width: 1100px){
  .pricing-grid{ grid-template-columns: repeat(2, 1fr); }
}

/* Mobile -> 1 colonne */
@media (max-width: 768px){
  .pricing-grid{ grid-template-columns: 1fr; }
}

.price-card {
  border-radius: var(--r-xl);
  border: 1px solid var(--border2);
  background: var(--bg-card);
  padding: 1.85rem 1.55rem;
  box-shadow: var(--shadow-sm);
  position: relative; overflow: hidden;
  transition: transform var(--t), box-shadow var(--t), border-color var(--t);
}
.price-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); border-color: var(--border2); }
.price-card.featured {
  border-color: var(--accent-mid);
  background: linear-gradient(160deg, color-mix(in srgb, var(--accent-lt) 70%, transparent), var(--bg-card));
  box-shadow: var(--shadow-lg), 0 0 0 2px color-mix(in srgb, var(--accent-lt) 55%, transparent);
}
.price-card.featured::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: linear-gradient(90deg, var(--accent), var(--sage), var(--terra));
}
.price-tier { font-size: .72rem; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; color: var(--ink-4); margin-bottom: .48rem; }
.price-name { font-family: var(--font-display); font-size: 1.62rem; font-weight: 600; color: var(--ink-1); }
.price-sub  { font-size: .82rem; color: var(--ink-4); margin-top: .18rem; }
.price-amount {
  font-size: 2.05rem; font-weight: 900; color: var(--ink-1);
  margin: .9rem 0 .25rem; letter-spacing: -.02em;
}
.price-amount sup { font-size: .95rem; font-weight: 700; vertical-align: top; margin-top: .35rem; }
.price-amount span { font-size: .86rem; font-weight: 500; color: var(--ink-4); }
.price-divider { height: 1px; background: var(--border); margin: 1.15rem 0; }
.price-features { list-style: none; display: flex; flex-direction: column; gap: .55rem; margin-bottom: 1.5rem; }
.price-features li { font-size: .88rem; color: var(--ink-2); display: flex; align-items: flex-start; gap: .55rem; }
.price-features li::before { content: '✦'; color: var(--terra); font-size: .62rem; margin-top: .22rem; flex-shrink: 0; }

/* ═══════════════════════════════════════════
   FAQ (accessible)
═══════════════════════════════════════════ */
.faq-list { display: flex; flex-direction: column; gap: .6rem; }
.faq-item {
  border-radius: var(--r-lg); border: 1px solid var(--border);
  background: var(--bg-card); overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: border-color var(--t), box-shadow var(--t);
}
.faq-item:hover { border-color: var(--border2); box-shadow: var(--shadow-md); }
.faq-item.open  { border-color: var(--accent-mid); }

.faq-q {
  width: 100%;
  background: none; border: 0;
  padding: 1.08rem 1.2rem;
  display: flex; align-items: center; justify-content: space-between; gap: 1rem;
  cursor: pointer; text-align: left;
  font-family: var(--font-body);
  font-size: .95rem; font-weight: 800; color: var(--ink-1);
}
.faq-arrow {
  flex-shrink: 0; width: 26px; height: 26px; border-radius: 999px;
  border: 1px solid var(--border2);
  background: var(--bg-warm);
  display: grid; place-items: center;
  color: var(--terra);
  font-size: .72rem;
  transition: transform var(--t), background var(--t), border-color var(--t);
}
.faq-item.open .faq-arrow {
  background: var(--terra-lt);
  border-color: var(--terra-mid);
  transform: rotate(45deg);
}
.faq-a {
  max-height: 0; overflow: hidden;
  transition: max-height 360ms var(--ease), padding var(--t);
  padding: 0 1.2rem;
  font-size: .9rem; line-height: 1.75; color: var(--ink-3);
}
.faq-item.open .faq-a { max-height: 320px; padding: 0 1.2rem 1.1rem; }

/* ═══════════════════════════════════════════
   FINAL CTA
═══════════════════════════════════════════ */
.final-cta-wrap {
  border-radius: var(--r-2xl);
  border: 1px solid var(--border2);
  background: linear-gradient(135deg, #fdf6f1, #f0edf9, #eef5f0);
  box-shadow: var(--shadow-lg);
  padding: 4.7rem 2rem; text-align: center;
  position: relative; overflow: hidden;
}
.final-cta-wrap::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, var(--terra), var(--accent), var(--sage));
}
.final-cta-wrap::after {
  content: '';
  position: absolute; bottom: -180px; right: -180px;
  width: 520px; height: 520px; border-radius: 50%;
  background: radial-gradient(circle, rgba(37,99,168,.08), transparent 70%);
  pointer-events: none;
}
.final-cta-title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 3.6vw, 3.05rem);
  font-weight: 600; color: var(--ink-1);
  margin: .8rem 0 1.05rem; line-height: 1.14;
}
.final-cta-title em { font-style: italic; color: var(--terra); font-weight: 400; }
.final-cta-sub {
  font-size: 1.05rem; color: var(--ink-3); max-width: 60ch;
  margin: 0 auto 2.1rem; line-height: 1.75;
}
.final-cta-actions { display: flex; gap: .75rem; justify-content: center; flex-wrap: wrap; }

/* ═══════════════════════════════════════════
   ENTRY ANIMATIONS (respect reduced motion)
═══════════════════════════════════════════ */
@keyframes fadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
.anim { opacity: 0; animation: fadeUp .7s var(--ease) forwards; }
.anim-d1 { animation-delay: .08s; }
.anim-d2 { animation-delay: .18s; }
.anim-d3 { animation-delay: .30s; }
.anim-d4 { animation-delay: .42s; }
.anim-d5 { animation-delay: .54s; }

@media (prefers-reduced-motion: reduce) {
  html { scroll-behavior: auto; }
  .anim { animation: none; opacity: 1; transform: none; }
  .live-card, .mod-cell, .step-card, .testi-card, .price-card { transition: none !important; }
}

/* ═══════════════════════════════════════════
   HELPERS
═══════════════════════════════════════════ */
.text-center { text-align: center; }




/* ═══════════════════════════════════════════
   COMPARE — MOBILE ONLY IMPROVEMENTS
   (Ne change rien sur desktop)
═══════════════════════════════════════════ */
@media (max-width: 768px){

  /* Un peu plus de respiration dans la section */
  #compare.section { padding: 4rem 0; }
  #compare .section-header { margin-bottom: 2.2rem; }
  #compare .w-max { padding-inline: 1.1rem; }

  /* Le “header” du tableau devient une barre de titre compacte */
  #compare .compare-head{
    display: block; /* écrase le grid mobile existant */
    padding: .9rem 1rem;
    background: var(--bg-warm);
    border-bottom: 1px solid var(--border2);
  }
  #compare .compare-head-cell{
    border-right: 0;
    padding: 0;
    font-size: .86rem;
    color: var(--ink-3);
  }
  /* On garde uniquement le libellé “Avant / Après” en une ligne */
  #compare .compare-head-cell:nth-child(1){ display:none; }
  #compare .compare-head-cell:nth-child(2),
  #compare .compare-head-cell:nth-child(3){
    display: inline-flex;
    align-items: center;
    gap: .45rem;
    padding: .35rem .65rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg-card) 85%, transparent);
    margin-right: .5rem;
    font-weight: 800;
  }
  #compare .compare-head-cell:nth-child(2){
    border-color: rgba(185,28,28,.22);
    background: color-mix(in srgb, #fef2f2 75%, var(--bg-card));
    color: #b91c1c;
  }
  #compare .compare-head-cell:nth-child(3){
    border-color: var(--accent-mid);
    background: color-mix(in srgb, var(--accent-lt) 65%, var(--bg-card));
    color: var(--accent);
  }

  /* Chaque ligne devient une “carte” (plus lisible sur téléphone) */
  #compare .compare-row{
    display: block;            /* annule le grid sur mobile */
    padding: 0;
    border-top: 0;
    background: transparent;
    margin-top: .85rem;
  }

  /* Carte container: on utilise les cellules existantes */
  #compare .compare-row .compare-cell{
    border-right: 0;
    background: var(--bg-card);
    padding: .95rem 1rem;
  }

  /* Titre de la carte */
  #compare .compare-row .compare-cell.key{
    border: 1px solid var(--border2);
    border-bottom: 0;
    border-radius: 18px 18px 0 0;
    font-size: .98rem;
    line-height: 1.25;
    display:flex;
    align-items:center;
    gap:.6rem;
  }
  #compare .compare-row .compare-cell.key::before{
    content:'';
    width: 10px; height: 10px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--terra), var(--accent));
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--bg-warm) 70%, transparent);
    flex-shrink:0;
  }

  /* Cellule “Sans” devient un bloc avec label */
  #compare .compare-row .compare-cell.bad{
    border-left: 1px solid var(--border2);
    border-right: 1px solid var(--border2);
    border-top: 1px solid var(--border);
    font-style: normal;
    color: var(--ink-2);
    position: relative;
    padding-top: 2.2rem;
  }
  #compare .compare-row .compare-cell.bad::before{
    content: "Sans Wikiformation";
    position: absolute;
    top: .75rem; left: 1rem;
    font-size: .72rem;
    font-weight: 900;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: #b91c1c;
    background: color-mix(in srgb, #fef2f2 70%, var(--bg-card));
    border: 1px solid rgba(185,28,28,.20);
    padding: .25rem .55rem;
    border-radius: 999px;
  }

  /* Cellule “Avec” devient un bloc avec label + fond doux */
  #compare .compare-row .compare-cell.good{
    border: 1px solid var(--border2);
    border-top: 1px solid var(--border);
    border-radius: 0 0 18px 18px;
    position: relative;
    padding-top: 2.2rem;
    background: color-mix(in srgb, var(--sage-lt) 55%, var(--bg-card));
    color: color-mix(in srgb, var(--sage) 80%, var(--ink-1));
    font-weight: 800;
  }
  #compare .compare-row .compare-cell.good::before{
    content: "✦ Avec Wikiformation";
    position: absolute;
    top: .75rem; left: 1rem;
    font-size: .72rem;
    font-weight: 900;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent-lt) 65%, var(--bg-card));
    border: 1px solid color-mix(in srgb, var(--accent-mid) 70%, var(--border2));
    padding: .25rem .55rem;
    border-radius: 999px;
  }

  /* Micro-optimisations lisibilité */
  #compare .compare-row .compare-cell.bad,
  #compare .compare-row .compare-cell.good{
    line-height: 1.6;
    font-size: .92rem;
  }

  /* Sur mobile, le hover ne sert pas -> on neutralise l'effet de survol */
  #compare .compare-row:hover{ background: transparent; }
}



.btn-stack{
  flex-direction: column;
  gap: .15rem;
  white-space: normal;
  text-align: center;
}
.btn-stack i{ margin-bottom:.15rem; }
.btn-stack .t2{ opacity:.9; font-weight:700; font-size:.85em; }
</style>
{% endblock %}

