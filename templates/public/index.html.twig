{# ════════════════════════════════════
   PRICING (FUNCTIONAL)
════════════════════════════════════ #}
<section class="section" id="pricing" style="background:var(--bg-warm);">
  <div class="w-max">
    <div class="section-header">
      <div class="ornament" style="margin-bottom:1.1rem;">
        <span class="ornament-line"></span><span class="ornament-gem"></span><span class="ornament-line"></span>
      </div>
      <h2 class="section-title">Des tarifs simples,<br><em>une montée en puissance naturelle</em></h2>
      <p class="section-lead">Commencez au bon niveau, puis activez les modules quand vous en avez besoin.</p>
    </div>

    {# ✅ Switch interval (mensuel/annuel) #}
    <div class="flex-center" style="margin:-.5rem 0 2rem;">
      <div class="switch-pill" style="
          border-radius:999px; padding:6px; background:rgba(26,25,22,.06);
          display:inline-flex; gap:6px; border:1px solid var(--border); box-shadow: var(--shadow-sm);
        ">
        <button class="btn btn-sm" type="button" data-interval="month" id="home-btn-month"
                style="border-radius:999px; border:0; padding:.45rem .9rem; font-weight:700; background:transparent;">
          Mensuel
        </button>
        <button class="btn btn-sm" type="button" data-interval="year" id="home-btn-year"
                style="border-radius:999px; border:0; padding:.45rem .9rem; font-weight:800; background:var(--accent); color:#fff;">
          Annuel <span style="margin-left:.45rem; font-size:.72rem; font-weight:900; background:rgba(255,193,7,.9); color:#1a1916; padding:.18rem .45rem; border-radius:999px;">-20%</span>
        </button>
      </div>
    </div>

    {% for msg in app.flashes('billing_expired') %}
      <div class="w-max" style="max-width:900px;margin:0 auto 1rem;">
        <div class="alert alert-danger d-flex align-items-center gap-2" role="alert"
             style="border-radius:16px; box-shadow: var(--shadow-sm); border:1px solid rgba(185,28,28,.18);">
          <i class="bi bi-exclamation-triangle-fill"></i>
          <div>{{ msg }}</div>
        </div>
      </div>
    {% endfor %}

    {# ✅ On ne garde que 4 plans #}
    {% set allowedCodes = ['ESSENTIEL','PROFESSIONNEL','EXPERT','EXCELLENCE'] %}
    {% set filteredPlans = plans|filter(p => (p.code|upper) in allowedCodes) %}

    <form method="post"
      action="{{ path('app_pricing_start_trial') }}"
      data-turbo="false"
      class="pricing-grid"
      id="homePricingForm">
    <input type="hidden" name="_token" id="home-form-token" value="{{ csrf_token('start_trial') }}">
    <input type="hidden" name="interval" id="home-interval" value="year"/>
    <input type="hidden" name="plan" id="home-selectedPlan" value=""/>
    <button type="submit"
            id="homeHiddenSubmit"
            class="d-none"
            aria-hidden="true"
            tabindex="-1">
      submit
    </button>


      {% for plan in filteredPlans %}
        {# accents par plan #}
        {% set accent = plan.code == 'ESSENTIEL'
          ? '#f59e0b'
          : (plan.code == 'PROFESSIONNEL'
            ? '#10b981'
            : (plan.code == 'EXPERT'
              ? '#8b5cf6'
              : '#fb7185'
            )
          )
        %}

        {# featured => PROFESSIONNEL #}
        {% set featured = (plan.code == 'PROFESSIONNEL') %}

        <div class="price-card {{ featured ? 'featured' : '' }}" style="--plan-accent: {{ accent }}; position:relative;">
          {# top accent line #}
          <div style="position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--plan-accent), var(--accent));"></div>

          {% if featured %}
            <span class="label accent" style="position:absolute; top:14px; right:14px; box-shadow: var(--shadow-sm);">
              <i class="bi bi-stars"></i> Le plus choisi
            </span>
          {% endif %}

          <div class="price-tier">Offre {{ loop.index|format('%02d') }}</div>
          <div class="price-name">{{ plan.name }}</div>

          <div class="price-sub" style="margin-top:.25rem;">
            <span style="color: var(--plan-accent); font-weight:800;">
              {{ plan.maxApprenantsAn == 0 ? 'Apprenants illimités' : plan.maxApprenantsAn ~ ' apprenants/an' }}
            </span>
            <div style="margin-top:.35rem; color: var(--ink-4); font-size:.82rem;">
              • {{ plan.maxUtilisateurs == 0 ? 'Utilisateurs illimités' : plan.maxUtilisateurs ~ ' utilisateurs' }}<br>
              • {{ plan.maxFormateurs == 0 ? 'Formateurs illimités' : plan.maxFormateurs ~ ' formateurs' }}<br>
              • {{ plan.maxEntreprises == 0 ? 'Entreprises illimitées' : plan.maxEntreprises ~ ' entreprises' }}<br>
              • {{ plan.maxProspects == 0 ? 'Prospects illimités' : plan.maxProspects ~ ' prospects' }}
            </div>
          </div>

          <div class="price-amount" style="display:flex; align-items:baseline; gap:.55rem;">
            
            {% set p = planPrices[plan.code|upper]|default(null) %}
            <div class="plan-price priceValue"
              data-plan-code="{{ plan.code|upper }}"
              data-month="{{ p ? (p.month ?? 0) : 0 }}"
              data-year="{{ p ? (p.year  ?? 0) : 0 }}">—</div>
            <span style="font-size:.85rem; font-weight:500; color: var(--ink-4);">HT / <span class="home-js-interval-main">mois</span></span>
          </div>

          <div class="price-sub home-js-interval-sub" style="margin-top:.15rem;">
            (avec engagement annuel)
          </div>

          <div class="price-divider"></div>

          {# Mini features “preview” (tu peux customiser selon plan.code) #}
          <ul class="price-features">
            <li>Gestion sessions & stagiaires</li>
            <li>Documents & conformité</li>
            <li>Suivi qualité / indicateurs</li>
            {#{% if plan.code in ['EXPERT','EXCELLENCE'] %}
              <li>E-learning & progression</li>
            {% endif %}
            {% if plan.code == 'EXCELLENCE' %}
              <li>Automatisations avancées</li>
            {% endif %}#}
          </ul>

          {# CTA logique (copie de la page tarifs) #}
          {% set isLogged = app.user is not null %}
          {% set isAdmin = isLogged and is_granted('ENTITE_ADMIN', entite) %}

          {% if not isLogged %}
            <a href="{{ path('app_login', {'_target_path': path('app_public') ~ '#pricing'}) }}"
               class="btn-outline"
               style="width:100%; justify-content:center; border-color: rgba(26,25,22,.16);">
              <i class="bi bi-person-check"></i> Essayer gratuitement <br>(3 mois)
            </a>
          {% else %}
            {% if trialConsumed %}
              {% if isAdmin %}
                <button type="button"
                        class="btn-accent js-open-home-billing-confirm"
                        data-action="{{ path('app_billing_checkout') }}"
                        data-plan="{{ plan.code|upper }}"
                        data-plan-name="{{ plan.name }}"
                        data-cta="Souscrire maintenant"
                        style="width:100%; justify-content:center; background: var(--plan-accent);">
                  <i class="bi bi-credit-card"></i> Souscrire maintenant
                </button>
              {% else %}
                <div class="label" style="width:100%; justify-content:center; background:#fff7ed; border-color:#fed7aa; color:#9a3412;">
                  <i class="bi bi-shield-lock"></i> Seul un administrateur peut souscrire.
                </div>
              {% endif %}
            {% else %}
              {% if isAdmin %}
                <button type="submit"
                  class="btn-prime btn-stack js-home-trial-submit"
                  data-plan="{{ plan.code|upper }}"
                  style="width:100%; justify-content:center; background: var(--terra);">
                  <span class="t1"><i class="bi bi-rocket-takeoff"></i> Essayer gratuitement</span>
                  <span class="t2">(3 mois)</span>
                </button>
              {% else %}
                <div class="label" style="width:100%; justify-content:center; background:#fff7ed; border-color:#fed7aa; color:#9a3412;">
                  <i class="bi bi-shield-lock"></i> Seul un administrateur peut démarrer l’essai.
                </div>
              {% endif %}
            {% endif %}
          {% endif %}

          {# Détail + Addons (collapse) #}
          <div class="text-center" style="margin-top:.75rem;">
            <button type="button"
                    class="btn btn-link small toggle-details-home d-inline-flex align-items-center gap-1"
                    style="color: var(--ink-3); text-decoration:none;"
                    data-bs-target="#home-details-{{ plan.code }}"
                    aria-controls="home-details-{{ plan.code }}"
                    aria-expanded="false">
              <span class="label-text">Voir le détail</span>
              <span class="chevron" style="font-weight:900;">+</span>
            </button>
          </div>

          <div class="collapse" id="home-details-{{ plan.code }}">
            <div style="padding-top:.65rem;">
              <ul class="price-features" style="margin-bottom:1rem;">
                <li>Espace apprenant / formateur / entreprise</li>
                <li>Exports & traçabilité</li>
                <li>Relances & automatisations</li>
                <li>PDF homogènes</li>
              </ul>

              {% if addons is defined and addons|length %}
                <div style="border-top:1px solid var(--border); padding-top:1rem;">
                  <div style="font-weight:800; margin-bottom:.65rem;">Options</div>

                  {% for addon in addons %}
                    <label style="display:flex; align-items:flex-start; gap:.55rem; margin-bottom:.55rem;">
                      <input class="form-check-input mt-1" type="checkbox" name="addons[]" value="{{ addon.code }}">
                      <span style="min-width:0;">
                        <span style="font-weight:800;">{{ addon.name }}</span>
                        <span style="display:block; color: var(--ink-4); font-size:.82rem; line-height:1.5;">
                          {{ addon.description }}
                        </span>
                      </span>
                    </label>
                  {% endfor %}

                  <div style="color: var(--ink-4); font-size:.82rem;">
                    Les options seront ajoutées à l’abonnement (Stripe).
                  </div>
                </div>
              {% endif %}
            </div>
          </div>

        </div>
      {% endfor %}
    </form>

    <div class="text-center" style="margin-top:2rem;">
      <a class="btn-outline" href="{{ path('app_public_pricing') }}">
        <i class="bi bi-tags"></i> Comparer toutes les offres
      </a>
    </div>
  </div>
</section>

{# Modal : Confirmation souscription / essai (HOME) #}
<div class="modal fade modal-premium"
     id="homeBillingConfirmModal"
     tabindex="-1"
     aria-hidden="true"
     data-csrf-trial="{{ csrf_token('start_trial') }}"
     data-csrf-checkout="{{ csrf_token('billing_checkout') }}">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="border-radius:22px; overflow:hidden;">
      <div class="modal-header" style="background:var(--bg-warm); border-bottom:1px solid var(--border);">
        <h5 class="modal-title">
          <i class="bi bi-shield-check me-2"></i> Confirmation
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
      </div>

      <div class="modal-body">
        <div class="d-flex gap-3 align-items-start">
