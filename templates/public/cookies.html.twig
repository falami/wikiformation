{# templates/public/politique_cookies.html.twig #}
{% extends 'base_public.html.twig' %}

{% block title %}WikiFormation — Politique de cookies{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">

    <style>
        /* ── TOKENS ─────────────────────────────────────────────── */
        :root {
            --ink:        #0a0a0f;
            --ink-80:     rgba(10,10,15,.80);
            --ink-40:     rgba(10,10,15,.40);
            --ink-10:     rgba(10,10,15,.07);
            --gold:       #c9a84c;
            --gold-light: #e8d49a;
            --gold-faint: rgba(201,168,76,.10);
            --cream:      #faf8f3;
            --white:      #ffffff;
            --rule:       rgba(10,10,15,.08);

            --r-xl: 28px;
            --r-lg: 20px;
            --r-md: 14px;

            --shadow-card: 0 12px 36px rgba(10,10,15,.07), 0 2px 6px rgba(10,10,15,.04);

            --serif: 'Cormorant Garamond', Georgia, serif;
            --sans:  'DM Sans', sans-serif;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }

        body {
            font-family: var(--sans);
            background-color: var(--cream);
            color: var(--ink);
            overflow-x: hidden;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
            pointer-events: none;
            z-index: 9999;
            opacity: .6;
        }

        .pg-wrap { min-height: 100vh; }

        /* ══ HERO ══════════════════════════════════════════════════ */
        .hero {
            position: relative;
            background: #0f1b28;
            overflow: hidden;
            padding: 5rem 0 5rem;
        }

        .hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background: repeating-linear-gradient(
                90deg,
                rgba(255,255,255,.025) 0px,
                rgba(255,255,255,.025) 1px,
                transparent 1px,
                transparent 72px
            );
            pointer-events: none;
        }

        /* warm amber orb — cookie palette */
        .hero-orb-amber {
            position: absolute;
            left: -80px;
            top: -80px;
            width: 360px;
            height: 360px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(245,158,11,.14) 0%, transparent 65%);
            pointer-events: none;
        }

        .hero-orb-gold {
            position: absolute;
            right: -120px;
            bottom: -120px;
            width: 440px;
            height: 440px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(201,168,76,.20) 0%, transparent 65%);
            pointer-events: none;
        }

        .hero-inner {
            position: relative;
            z-index: 2;
            padding: 0 2rem;
        }

        .hero-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: .6rem;
            font-size: .72rem;
            font-weight: 500;
            letter-spacing: .16em;
            text-transform: uppercase;
            color: var(--gold-light);
            margin-bottom: 2rem;
            padding: .45rem .9rem;
            border: 1px solid rgba(201,168,76,.25);
            border-radius: 999px;
        }

        .hero h1 {
            font-family: var(--serif);
            font-size: clamp(3rem, 6vw, 5.4rem);
            font-weight: 300;
            letter-spacing: -.02em;
            line-height: 1.08;
            color: #fff;
            margin-bottom: 2rem;
        }

        .hero h1 em {
            font-style: italic;
            color: var(--gold-light);
        }

        .hero-intro {
            font-size: 1.05rem;
            line-height: 1.85;
            color: rgba(255,255,255,.60);
            font-weight: 300;
            max-width: 580px;
            padding-left: 1.4rem;
            border-left: 2px solid rgba(201,168,76,.35);
        }

        .hero-pills {
            display: flex;
            flex-wrap: wrap;
            gap: .75rem;
            margin-top: 3rem;
        }

        .hero-pill {
            display: inline-flex;
            align-items: center;
            gap: .55rem;
            padding: .55rem 1.1rem;
            border-radius: 999px;
            background: rgba(255,255,255,.06);
            border: 1px solid rgba(255,255,255,.10);
            color: rgba(255,255,255,.72);
            font-size: .85rem;
        }

        .hero-pill i { color: var(--gold); font-size: .9rem; }

        .hero-wave {
            display: block;
            width: 100%;
            line-height: 0;
            margin-top: -1px;
        }

        /* ══ LAYOUT ════════════════════════════════════════════════ */
        .doc-layout {
            display: grid;
            grid-template-columns: 260px 1fr;
            max-width: 1200px;
            margin: 0 auto;
            padding: 3.5rem 1.5rem 6rem;
            align-items: start;
        }

        /* ── SIDEBAR ───────────────────────────────────────────── */
        .sidebar {
            position: sticky;
            top: 2.5rem;
            padding-right: 2.5rem;
        }

        .sidebar-label {
            font-size: .68rem;
            font-weight: 500;
            letter-spacing: .14em;
            text-transform: uppercase;
            color: var(--ink-40);
            margin-bottom: 1.2rem;
        }

        .toc { list-style: none; border-left: 1px solid var(--rule); }

        .toc li a {
            display: flex;
            align-items: baseline;
            gap: .65rem;
            padding: .6rem 0 .6rem 1.2rem;
            text-decoration: none;
            color: var(--ink-40);
            font-size: .85rem;
            line-height: 1.45;
            transition: color .2s, border-color .2s;
            border-left: 2px solid transparent;
            margin-left: -1px;
        }

        .toc li a .num {
            font-family: var(--serif);
            font-size: .8rem;
            color: var(--gold);
            flex-shrink: 0;
        }

        .toc li a:hover  { color: var(--ink); border-left-color: var(--gold); }
        .toc li a.active { color: var(--ink); font-weight: 500; border-left-color: var(--gold); }

        .sidebar-updated {
            margin-top: 2.5rem;
            padding: .9rem 1rem;
            background: var(--gold-faint);
            border: 1px solid rgba(201,168,76,.18);
            border-radius: var(--r-md);
            font-size: .8rem;
            color: var(--ink-80);
            line-height: 1.6;
        }

        .sidebar-updated strong { color: var(--gold); }

        /* ── MAIN ──────────────────────────────────────────────── */
        .doc-main { min-width: 0; }

        /* ── SECTION ───────────────────────────────────────────── */
        .doc-section {
            margin-bottom: 1.75rem;
            background: var(--white);
            border: 1px solid var(--rule);
            border-radius: var(--r-xl);
            overflow: hidden;
            box-shadow: var(--shadow-card);
            opacity: 0;
            transform: translateY(22px);
            transition: opacity .55s cubic-bezier(.22,.68,0,1.2), transform .55s cubic-bezier(.22,.68,0,1.2);
        }

        .doc-section.visible { opacity: 1; transform: translateY(0); }

        .section-head {
            display: flex;
            align-items: flex-start;
            gap: 1.25rem;
            padding: 1.75rem 2rem 1.5rem;
            border-bottom: 1px solid var(--rule);
        }

        .section-num {
            font-family: var(--serif);
            font-size: 2.6rem;
            font-weight: 300;
            line-height: 1;
            color: var(--gold);
            flex-shrink: 0;
            min-width: 42px;
        }

        .section-title-wrap { flex: 1; }

        .section-category {
            font-size: .68rem;
            font-weight: 500;
            letter-spacing: .13em;
            text-transform: uppercase;
            color: var(--ink-40);
            margin-bottom: .3rem;
        }

        .section-title {
            font-family: var(--serif);
            font-size: 1.65rem;
            font-weight: 600;
            letter-spacing: -.02em;
            color: var(--ink);
            line-height: 1.2;
        }

        .section-icon {
            width: 44px;
            height: 44px;
            border-radius: var(--r-md);
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--gold-faint);
            border: 1px solid rgba(201,168,76,.15);
            color: var(--gold);
            font-size: 1.1rem;
            flex-shrink: 0;
        }

        .section-body { padding: 1.75rem 2rem; }

        .section-body p {
            font-size: .975rem;
            line-height: 1.85;
            color: var(--ink-80);
            margin-bottom: 1rem;
        }

        .section-body p:last-child { margin-bottom: 0; }

        /* ── SUMMARY GRID ──────────────────────────────────────── */
        .summary-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1rem;
            padding: 1.75rem 2rem;
            border-bottom: 1px solid var(--rule);
        }

        .sum-card {
            padding: 1.3rem;
            border: 1px solid var(--rule);
            border-radius: var(--r-lg);
            background: var(--cream);
            transition: box-shadow .2s, transform .2s, border-color .2s;
            cursor: default;
        }

        .sum-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-card);
            border-color: rgba(201,168,76,.3);
        }

        .sum-icon {
            width: 42px;
            height: 42px;
            border-radius: 13px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--ink);
            color: var(--gold);
            font-size: 1rem;
            margin-bottom: 1rem;
        }

        .sum-card h3 {
            font-family: var(--serif);
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--ink);
            margin-bottom: .4rem;
        }

        .sum-card p {
            font-size: .84rem;
            color: var(--ink-40);
            line-height: 1.65;
            margin: 0;
        }

        /* ── COOKIE TYPE CARDS (3-col) ─────────────────────────── */
        .cookie-types {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
        }

        .cookie-card {
            border: 1px solid var(--rule);
            border-radius: var(--r-lg);
            overflow: hidden;
            background: var(--cream);
            transition: box-shadow .2s, transform .2s, border-color .2s;
        }

        .cookie-card:hover {
            box-shadow: var(--shadow-card);
            transform: translateY(-3px);
            border-color: rgba(201,168,76,.28);
        }

        .cookie-card-head {
            padding: 1.1rem 1.25rem .9rem;
            background: white;
            border-bottom: 1px solid var(--rule);
            display: flex;
            align-items: center;
            gap: .8rem;
        }

        .cookie-card-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .cookie-card-dot.green  { background: #10b981; box-shadow: 0 0 0 3px rgba(16,185,129,.15); }
        .cookie-card-dot.amber  { background: #f59e0b; box-shadow: 0 0 0 3px rgba(245,158,11,.15); }
        .cookie-card-dot.blue   { background: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,.15); }
        .cookie-card-dot.purple { background: #8b5cf6; box-shadow: 0 0 0 3px rgba(139,92,246,.15); }

        .cookie-card-title {
            font-family: var(--serif);
            font-size: 1.05rem;
            font-weight: 600;
            color: var(--ink);
            flex: 1;
        }

        .cookie-card-badge {
            font-size: .68rem;
            font-weight: 500;
            letter-spacing: .08em;
            text-transform: uppercase;
            padding: .25rem .6rem;
            border-radius: 999px;
        }

        .badge-required { background: rgba(16,185,129,.12); color: #059669; border: 1px solid rgba(16,185,129,.2); }
        .badge-optional  { background: rgba(245,158,11,.10); color: #b45309; border: 1px solid rgba(245,158,11,.2); }

        .cookie-card-body {
            padding: 1rem 1.25rem;
            font-size: .88rem;
            color: var(--ink-80);
            line-height: 1.75;
        }

        /* ── CHECK LIST ────────────────────────────────────────── */
        .check-list { list-style: none; display: grid; gap: .55rem; }

        .check-list li {
            display: flex;
            gap: .85rem;
            align-items: flex-start;
            font-size: .935rem;
            line-height: 1.7;
            color: var(--ink-80);
            padding: .7rem .9rem;
            border-radius: var(--r-md);
            transition: background .2s;
        }

        .check-list li:hover { background: var(--ink-10); }

        .check-list li::before {
            content: '';
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: rgba(16,185,129,.12);
            border: 1px solid rgba(16,185,129,.25);
            flex-shrink: 0;
            margin-top: .15rem;
            background-image: url("data:image/svg+xml,%3Csvg width='10' height='8' viewBox='0 0 10 8' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 4l3 3 5-6' stroke='%2310b981' stroke-width='1.5' fill='none' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
            background-repeat: no-repeat;
            background-position: center;
        }

        /* ── DURATION TABLE ────────────────────────────────────── */
        .duration-list { display: grid; gap: .85rem; }

        .duration-row {
            display: flex;
            align-items: center;
            gap: 1rem;
            border: 1px solid var(--rule);
            border-radius: var(--r-lg);
            background: var(--cream);
            padding: 1rem 1.25rem;
            transition: border-color .2s, box-shadow .2s;
        }

        .duration-row:hover {
            border-color: rgba(201,168,76,.28);
            box-shadow: 0 4px 20px rgba(201,168,76,.06);
        }

        .duration-icon {
            width: 38px;
            height: 38px;
            border-radius: 11px;
            background: var(--ink);
            color: var(--gold);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .9rem;
            flex-shrink: 0;
        }

        .duration-info { flex: 1; }

        .duration-name {
            font-family: var(--serif);
            font-size: 1rem;
            font-weight: 600;
            color: var(--ink);
            margin-bottom: .18rem;
        }

        .duration-desc {
            font-size: .85rem;
            color: var(--ink-80);
            line-height: 1.6;
        }

        .duration-badge {
            font-size: .75rem;
            font-weight: 500;
            padding: .3rem .75rem;
            border-radius: 999px;
            background: var(--gold-faint);
            border: 1px solid rgba(201,168,76,.2);
            color: #92670a;
            white-space: nowrap;
            flex-shrink: 0;
        }

        /* ── MANAGE BLOCK ──────────────────────────────────────── */
        .manage-options {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .manage-card {
            border: 1px solid var(--rule);
            border-radius: var(--r-lg);
            background: var(--cream);
            padding: 1.2rem 1.25rem;
            display: flex;
            gap: 1rem;
            align-items: flex-start;
            transition: box-shadow .2s, border-color .2s, transform .2s;
        }

        .manage-card:hover {
            box-shadow: var(--shadow-card);
            border-color: rgba(201,168,76,.28);
            transform: translateY(-2px);
        }

        .manage-card-icon {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: var(--ink);
            color: var(--gold);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .95rem;
            flex-shrink: 0;
        }

        .manage-card-body strong {
            display: block;
            font-family: var(--serif);
            font-size: 1.05rem;
            font-weight: 600;
            color: var(--ink);
            margin-bottom: .3rem;
        }

        .manage-card-body p {
            font-size: .85rem;
            color: var(--ink-40);
            line-height: 1.65;
            margin: 0;
        }

        /* ── CALLOUT BLOCKS ────────────────────────────────────── */
        .callout {
            border-radius: var(--r-lg);
            padding: 1.2rem 1.4rem;
            display: flex;
            gap: 1rem;
            align-items: flex-start;
            margin-top: 1.2rem;
        }

        .callout-icon {
            width: 34px;
            height: 34px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .95rem;
            flex-shrink: 0;
        }

        .callout-body { flex: 1; }
        .callout-body p { margin: 0; font-size: .9rem; line-height: 1.75; color: var(--ink-80); }
        .callout-body a { color: var(--gold); text-decoration: none; }

        .callout-info   { background: rgba(59,130,246,.06);  border: 1px solid rgba(59,130,246,.12); }
        .callout-info .callout-icon { background: rgba(59,130,246,.10); color: #3b82f6; }

        .callout-warn   { background: rgba(245,158,11,.06);  border: 1px solid rgba(245,158,11,.14); }
        .callout-warn .callout-icon { background: rgba(245,158,11,.12); color: #d97706; }

        .callout-gold   { background: rgba(201,168,76,.07);  border: 1px solid rgba(201,168,76,.18); }
        .callout-gold .callout-icon { background: rgba(201,168,76,.14); color: var(--gold); }

        /* ── FOOTER ────────────────────────────────────────────── */
        .doc-footer {
            text-align: center;
            padding: 2rem;
            font-size: .85rem;
            color: var(--ink-40);
        }

        .doc-footer a { color: var(--gold); text-decoration: none; }

        /* ══ RESPONSIVE ════════════════════════════════════════════ */
        @media (max-width: 991px) {
            .doc-layout { grid-template-columns: 1fr; }
            .sidebar { position: static; padding-right: 0; margin-bottom: 2rem; }
            .toc { display: flex; flex-wrap: wrap; gap: .4rem; border-left: none; }
            .toc li a {
                border: 1px solid var(--rule);
                border-radius: 999px;
                border-left: 1px solid var(--rule);
                padding: .45rem .9rem;
                font-size: .78rem;
            }
            .toc li a:hover { border-color: var(--gold); }
            .summary-grid  { grid-template-columns: repeat(2, 1fr); }
            .cookie-types  { grid-template-columns: 1fr; }
            .manage-options{ grid-template-columns: 1fr; }
        }

        @media (max-width: 767px) {
            .hero { padding: 4rem 0 5rem; }
            .hero h1 { font-size: 2.8rem; }
            .summary-grid { grid-template-columns: 1fr; }
            .section-head { padding: 1.25rem; }
            .section-body { padding: 1.25rem; }
            .section-num  { font-size: 2rem; }
            .hero-pills   { display: none; }
            .duration-row { flex-wrap: wrap; }
            .duration-badge { width: 100%; text-align: center; }
        }
    </style>
{% endblock %}

{% block body %}
    {% include 'header_public.html.twig' %}

    <main class="pg-wrap">

        <!-- ══ HERO ══════════════════════════════════════════════ -->
        <section class="hero">
            <div class="hero-orb-amber"></div>
            <div class="hero-orb-gold"></div>
            <div class="container">
                <div class="hero-inner">
                    <span class="hero-eyebrow">
                        <i class="bi bi-cookie"></i>
                        Fonctionnement &amp; gestion des traceurs · WikiFormation
                    </span>
                    <h1>Politique de<br><em>cookies</em></h1>
                    <p class="hero-intro">
                        Cette page vous explique quels cookies sont utilisés sur WikiFormation,
                        pourquoi ils sont déposés et comment vous pouvez gérer vos préférences
                        à tout moment.
                    </p>
                    <div class="hero-pills">
                        <span class="hero-pill"><i class="bi bi-toggles"></i> Cookies nécessaires</span>
                        <span class="hero-pill"><i class="bi bi-bar-chart-line"></i> Mesure d'audience</span>
                        <span class="hero-pill"><i class="bi bi-sliders"></i> Vos préférences</span>
                        <span class="hero-pill"><i class="bi bi-clock-history"></i> Durées encadrées</span>
                    </div>
                </div>
            </div>
        </section>

        <svg class="hero-wave" viewBox="0 0 1440 52" fill="none" xmlns="http://www.w3.org/2000/svg" style="background:#0f1b28;">
            <path d="M0 0C360 52 1080 52 1440 0V52H0V0Z" fill="#faf8f3"/>
        </svg>

        <!-- ══ DOC LAYOUT ═════════════════════════════════════════ -->
        <div class="doc-layout">

            <!-- sidebar -->
            <aside class="sidebar">
                <p class="sidebar-label">Sommaire</p>
                <ul class="toc" id="toc">
                    <li><a href="#s1"><span class="num">01</span> Qu'est-ce qu'un cookie ?</a></li>
                    <li><a href="#s2"><span class="num">02</span> Catégories de cookies</a></li>
                    <li><a href="#s3"><span class="num">03</span> Finalités d'utilisation</a></li>
                    <li><a href="#s4"><span class="num">04</span> Durées de conservation</a></li>
                    <li><a href="#s5"><span class="num">05</span> Gérer vos préférences</a></li>
                    <li><a href="#s6"><span class="num">06</span> Cookies tiers</a></li>
                    <li><a href="#s7"><span class="num">07</span> Mise à jour</a></li>
                </ul>
                <div class="sidebar-updated">
                    <strong>Dernière mise à jour</strong><br>
                    {{ "now"|date("d/m/Y") }}
                </div>
            </aside>

            <!-- main -->
            <div class="doc-main">

                <!-- Summary -->
                <article class="doc-section visible" style="opacity:1;transform:none;">
                    <div class="summary-grid">
                        <div class="sum-card">
                            <div class="sum-icon"><i class="bi bi-toggles"></i></div>
                            <h3>Nécessaires</h3>
                            <p>Certains cookies sont indispensables au fonctionnement du service et déposés sans consentement.</p>
                        </div>
                        <div class="sum-card">
                            <div class="sum-icon"><i class="bi bi-hand-thumbs-up"></i></div>
                            <h3>Consentement</h3>
                            <p>Les cookies non essentiels ne sont déposés qu'après votre accord explicite via la bannière.</p>
                        </div>
                        <div class="sum-card">
                            <div class="sum-icon"><i class="bi bi-sliders"></i></div>
                            <h3>Contrôle total</h3>
                            <p>Vous pouvez modifier vos préférences à tout moment depuis la bannière ou votre navigateur.</p>
                        </div>
                        <div class="sum-card">
                            <div class="sum-icon"><i class="bi bi-clock-history"></i></div>
                            <h3>Durées limitées</h3>
                            <p>Chaque cookie a une durée de vie définie, adaptée à sa finalité et à la réglementation.</p>
                        </div>
                    </div>
                </article>

                <!-- 1. Qu'est-ce qu'un cookie -->
                <article class="doc-section" id="s1">
                    <div class="section-head">
                        <span class="section-num">01</span>
                        <div class="section-title-wrap">
                            <p class="section-category">Définition</p>
                            <h2 class="section-title">Qu'est-ce qu'un cookie ?</h2>
                        </div>
                        <div class="section-icon"><i class="bi bi-question-circle"></i></div>
                    </div>
                    <div class="section-body">
                        <p>Un cookie est un petit fichier texte déposé sur votre terminal (ordinateur, tablette, smartphone) lors de votre visite sur un site web. Il permet au site de mémoriser certaines informations relatives à votre navigation afin d'améliorer votre expérience et d'assurer le bon fonctionnement des services.</p>
                        <p>Les cookies ne peuvent pas exécuter de programmes ni transmettre de virus. Ils sont propres à chaque site et ne peuvent être lus que par le serveur qui les a émis.</p>
                        <div class="callout callout-info">
                            <div class="callout-icon"><i class="bi bi-info-lg"></i></div>
                            <div class="callout-body">
                                <p>Conformément aux recommandations de la CNIL et à la réglementation ePrivacy, les cookies nécessitant votre consentement ne sont déposés qu'après votre accord explicite.</p>
                            </div>
                        </div>
                    </div>
                </article>

                <!-- 2. Catégories -->
                <article class="doc-section" id="s2">
                    <div class="section-head">
                        <span class="section-num">02</span>
                        <div class="section-title-wrap">
                            <p class="section-category">Typologie</p>
                            <h2 class="section-title">Catégories de cookies utilisées</h2>
                        </div>
                        <div class="section-icon"><i class="bi bi-layers"></i></div>
                    </div>
                    <div class="section-body">
                        <div class="cookie-types">
                            <div class="cookie-card">
                                <div class="cookie-card-head">
                                    <span class="cookie-card-dot green"></span>
                                    <span class="cookie-card-title">Strictement nécessaires</span>
                                    <span class="cookie-card-badge badge-required">Requis</span>
                                </div>
                                <div class="cookie-card-body">
                                    Indispensables au fonctionnement du site : session utilisateur, sécurité, mémorisation des préférences de consentement. Déposés sans accord préalable.
                                </div>
                            </div>
                            <div class="cookie-card">
                                <div class="cookie-card-head">
                                    <span class="cookie-card-dot amber"></span>
                                    <span class="cookie-card-title">Mesure d'audience</span>
                                    <span class="cookie-card-badge badge-optional">Optionnel</span>
                                </div>
                                <div class="cookie-card-body">
                                    Permettent de mesurer le trafic, les pages consultées et le comportement des visiteurs (ex. Google Analytics). Soumis à consentement.
                                </div>
                            </div>
                            <div class="cookie-card">
                                <div class="cookie-card-head">
                                    <span class="cookie-card-dot blue"></span>
                                    <span class="cookie-card-title">Fonctionnels</span>
                                    <span class="cookie-card-badge badge-optional">Optionnel</span>
                                </div>
                                <div class="cookie-card-body">
                                    Mémorisent vos préférences d'affichage, de langue ou d'interface pour personnaliser votre expérience lors de visites ultérieures.
                                </div>
                            </div>
                        </div>
                    </div>
                </article>

                <!-- 3. Finalités -->
                <article class="doc-section" id="s3">
                    <div class="section-head">
                        <span class="section-num">03</span>
                        <div class="section-title-wrap">
                            <p class="section-category">Objectifs</p>
                            <h2 class="section-title">Finalités d'utilisation</h2>
                        </div>
                        <div class="section-icon"><i class="bi bi-bullseye"></i></div>
                    </div>
                    <div class="section-body">
                        <p>Les cookies déposés sur WikiFormation poursuivent les finalités suivantes :</p>
                        <ul class="check-list mt-3">
                            <li>mémoriser vos préférences utilisateur et paramètres d'interface ;</li>
                            <li>assurer la sécurité de la session et l'authentification sur la plateforme ;</li>
                            <li>améliorer la performance, la stabilité et l'ergonomie du site ;</li>
                            <li>mesurer l'audience via des outils analytiques (avec votre consentement) ;</li>
                            <li>mémoriser votre choix relatif aux cookies lors de la visite initiale ;</li>
                            <li>assurer le bon fonctionnement des intégrations techniques nécessaires au service.</li>
                        </ul>
                    </div>
                </article>

                <!-- 4. Durées -->
                <article class="doc-section" id="s4">
                    <div class="section-head">
                        <span class="section-num">04</span>
                        <div class="section-title-wrap">
                            <p class="section-category">Rétention</p>
                            <h2 class="section-title">Durées de conservation</h2>
                        </div>
                        <div class="section-icon"><i class="bi bi-clock-history"></i></div>
                    </div>
                    <div class="section-body">
                        <p>La durée de vie de chaque cookie est adaptée à sa finalité et encadrée par la réglementation applicable.</p>
                        <div class="duration-list mt-3">
                            <div class="duration-row">
                                <div class="duration-icon"><i class="bi bi-shield-check"></i></div>
                                <div class="duration-info">
                                    <p class="duration-name">Cookies de session</p>
                                    <p class="duration-desc">Supprimés automatiquement à la fermeture du navigateur.</p>
                                </div>
                                <span class="duration-badge">Session</span>
                            </div>
                            <div class="duration-row">
                                <div class="duration-icon"><i class="bi bi-toggles"></i></div>
                                <div class="duration-info">
                                    <p class="duration-name">Préférences de consentement</p>
                                    <p class="duration-desc">Mémorisent votre choix relatif aux cookies pour éviter de vous le redemander.</p>
                                </div>
                                <span class="duration-badge">13 mois max</span>
                            </div>
                            <div class="duration-row">
                                <div class="duration-icon"><i class="bi bi-bar-chart-line"></i></div>
                                <div class="duration-info">
                                    <p class="duration-name">Cookies analytiques</p>
                                    <p class="duration-desc">Mesure d'audience — durée conforme aux recommandations de la CNIL.</p>
                                </div>
                                <span class="duration-badge">13 mois max</span>
                            </div>
                            <div class="duration-row">
                                <div class="duration-icon"><i class="bi bi-sliders"></i></div>
                                <div class="duration-info">
                                    <p class="duration-name">Cookies fonctionnels</p>
                                    <p class="duration-desc">Mémorisation des préférences d'interface et paramètres personnalisés.</p>
                                </div>
                                <span class="duration-badge">6 à 12 mois</span>
                            </div>
                        </div>
                    </div>
                </article>

                <!-- 5. Gérer préférences -->
                <article class="doc-section" id="s5">
                    <div class="section-head">
                        <span class="section-num">05</span>
                        <div class="section-title-wrap">
                            <p class="section-category">Contrôle</p>
                            <h2 class="section-title">Gérer vos préférences</h2>
                        </div>
                        <div class="section-icon"><i class="bi bi-sliders"></i></div>
                    </div>
                    <div class="section-body">
                        <p>Vous disposez à tout moment de plusieurs moyens pour gérer les cookies déposés sur votre terminal :</p>
                        <div class="manage-options mt-3">
                            <div class="manage-card">
                                <div class="manage-card-icon"><i class="bi bi-ui-checks"></i></div>
                                <div class="manage-card-body">
                                    <strong>Bannière de consentement</strong>
                                    <p>Acceptez, refusez ou paramétrez les catégories de cookies depuis la bannière affichée lors de votre première visite ou via le lien de gestion des cookies.</p>
                                </div>
                            </div>
                            <div class="manage-card">
                                <div class="manage-card-icon"><i class="bi bi-browser-chrome"></i></div>
                                <div class="manage-card-body">
                                    <strong>Paramètres du navigateur</strong>
                                    <p>Vous pouvez configurer votre navigateur pour bloquer ou supprimer les cookies. Notez que certaines fonctionnalités du site pourraient ne plus être accessibles.</p>
                                </div>
                            </div>
                            <div class="manage-card">
                                <div class="manage-card-icon"><i class="bi bi-bar-chart-line"></i></div>
                                <div class="manage-card-body">
                                    <strong>Opt-out analytique</strong>
                                    <p>Si vous utilisez Google Analytics, vous pouvez vous y opposer via le module complémentaire de désactivation disponible depuis Google.</p>
                                </div>
                            </div>
                            <div class="manage-card">
                                <div class="manage-card-icon"><i class="bi bi-arrow-counterclockwise"></i></div>
                                <div class="manage-card-body">
                                    <strong>Retrait du consentement</strong>
                                    <p>Votre consentement peut être retiré à tout moment avec effet pour l'avenir, sans que cela ne remette en cause les traitements déjà effectués.</p>
                                </div>
                            </div>
                        </div>
                        <div class="callout callout-warn mt-4">
                            <div class="callout-icon"><i class="bi bi-exclamation-lg"></i></div>
                            <div class="callout-body">
                                <p>Le refus ou la suppression des cookies strictement nécessaires peut empêcher l'accès à certaines fonctionnalités de la plateforme, notamment l'authentification.</p>
                            </div>
                        </div>
                    </div>
                </article>

                <!-- 6. Cookies tiers -->
                <article class="doc-section" id="s6">
                    <div class="section-head">
                        <span class="section-num">06</span>
                        <div class="section-title-wrap">
                            <p class="section-category">Partenaires</p>
                            <h2 class="section-title">Cookies tiers</h2>
                        </div>
                        <div class="section-icon"><i class="bi bi-diagram-2"></i></div>
                    </div>
                    <div class="section-body">
                        <p>Certains services intégrés à WikiFormation peuvent déposer leurs propres cookies sur votre terminal. Ces cookies sont soumis aux politiques de confidentialité des tiers concernés, sur lesquels WikiFormation n'a pas de contrôle direct.</p>
                        <ul class="check-list mt-3">
                            <li>Google Analytics — mesure d'audience et statistiques de navigation (soumis à consentement) ;</li>
                            <li>Stripe — traitement sécurisé des paiements (cookies techniques nécessaires à la transaction) ;</li>
                            <li>tout autre service tiers mentionné dans la politique de confidentialité.</li>
                        </ul>
                        <div class="callout callout-gold">
                            <div class="callout-icon"><i class="bi bi-link-45deg"></i></div>
                            <div class="callout-body">
                                <p>Pour en savoir plus sur les traitements effectués par ces tiers, consultez leurs politiques de confidentialité respectives disponibles sur leurs sites officiels.</p>
                            </div>
                        </div>
                    </div>
                </article>

                <!-- 7. Mise à jour -->
                <article class="doc-section" id="s7">
                    <div class="section-head">
                        <span class="section-num">07</span>
                        <div class="section-title-wrap">
                            <p class="section-category">Évolution</p>
                            <h2 class="section-title">Mise à jour de la politique</h2>
                        </div>
                        <div class="section-icon"><i class="bi bi-arrow-repeat"></i></div>
                    </div>
                    <div class="section-body">
                        <p>La présente politique de cookies peut être modifiée à tout moment pour refléter une évolution des services, des outils utilisés ou de la réglementation applicable. La date de dernière mise à jour figure ci-dessous ainsi que dans le sommaire latéral.</p>
                        <p>En cas de modification substantielle, un nouveau recueil de consentement sera effectué si nécessaire.</p>
                    </div>
                </article>

                <!-- Footer -->
                <p class="doc-footer">
                    Dernière mise à jour : <strong>{{ "now"|date("d/m/Y") }}</strong> &nbsp;·&nbsp;
                    <a href="{{ path('app_public_cgu') }}">CGU</a> &nbsp;·&nbsp;
                    <a href="{{ path('app_public_cgv') }}">CGV</a> &nbsp;·&nbsp;
                    <a href="{{ path('app_public_mentions_legales') }}">Mentions légales</a> &nbsp;·&nbsp;
                    <a href="{{ path('app_public_politique_confidentialite') }}">Confidentialité</a>
                </p>

            </div><!-- /doc-main -->
        </div><!-- /doc-layout -->

    </main>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
    (() => {
        const sections = document.querySelectorAll('.doc-section');
        const obs = new IntersectionObserver((entries) => {
            entries.forEach((e, i) => {
                if (e.isIntersecting) {
                    setTimeout(() => e.target.classList.add('visible'), i * 60);
                    obs.unobserve(e.target);
                }
            });
        }, { threshold: 0.07 });
        sections.forEach(s => obs.observe(s));

        const anchors = document.querySelectorAll('.doc-section[id]');
        const links   = document.querySelectorAll('.toc a');
        const scrollObs = new IntersectionObserver((entries) => {
            entries.forEach(e => {
                if (e.isIntersecting) {
                    links.forEach(l => l.classList.remove('active'));
                    const active = document.querySelector(`.toc a[href="#${e.target.id}"]`);
                    if (active) active.classList.add('active');
                }
            });
        }, { rootMargin: '-30% 0px -65% 0px' });
        anchors.forEach(a => scrollObs.observe(a));
    })();
    </script>
{% endblock %}
