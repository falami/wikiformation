{# templates/public/catalogue.html.twig #}
{% extends 'base_public.html.twig' %}
{% set brand = public_branding() %}

{% block title %}Catalogue de nos formations{% endblock %}
{% block meta_description %}Consultez l’ensemble de nos formations (même sans dates planifiées) et demandez l’ouverture d’une session.{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    :root{
      --bg:#0e2a3b;
      --panel:#0e2433;
      --panel-2:#112a3b;
      --glow:#1c4a66;
      --field:#0f2230;
      --field-border:#1e3e54;
      --ink:#eaf6ff;
      --muted:#a8c9da;
      --cta:#e73d45;
      --cta-ink:#fff;
      --chip:#153448;
      --chip-ink:#cfe6f3;
      --ring: 0 0 0 3px rgba(58,160,255,.25), 0 10px 30px rgba(0,0,0,.25);
    }

    body{ overflow-x:hidden; color:var(--ink); }

    .hero-cover{
      position:relative; color:#000;
    }
    .hero-cover::after{ content:""; position:absolute; inset:0; }
    .hero-inner{ position:relative; z-index:2; padding:1rem 0 1rem; }

    .catalog-wrap{ max-width: 1400px; margin: 0 auto; }

    /* top bar */
    .catalog-top{
      display:flex; align-items:flex-end; justify-content:space-between;
      gap:1rem; margin-top: 1.25rem; margin-bottom: .75rem;
    }
    .results-count{ color:var(--muted); font-weight:600; }
    .hint{ color: rgba(255,255,255,.65); }

    /* cards = identiques home */
    .session-card{
      background:#0f1b28; border:0; border-radius:18px; overflow:hidden;
      box-shadow:0 15px 35px rgba(0,0,0,.35);
    }
    .session-media{
      position: relative;
      min-height: 160px;
      background: radial-gradient(120% 120% at 0% 0%, rgba(255,255,255,.05), transparent 60%),
                  var(--cover, url('')) center/cover no-repeat;
      border-top-left-radius: 18px;
      border-bottom-left-radius: 18px;
      -webkit-mask-image: linear-gradient(to right, rgba(0,0,0,1) 72%, rgba(0,0,0,0) 100%);
              mask-image: linear-gradient(to right, rgba(0,0,0,1) 72%, rgba(0,0,0,0) 100%);
    }
    @media (max-width: 991.98px){
      .session-media{
        min-height: 180px;
        -webkit-mask-image: linear-gradient(to right, rgba(0,0,0,1) 84%, rgba(0,0,0,0) 100%);
                mask-image: linear-gradient(to right, rgba(0,0,0,1) 84%, rgba(0,0,0,0) 100%);
        border-radius: 18px 18px 0 0;
      }
    }

    .session-body{ padding:1rem 1.4rem !important; }
    .session-title{ color:#fff; font-weight:700; font-size:1.25rem; margin-bottom:.4rem !important; }
    .session-meta{ color:var(--muted); }

    /* timeline */
    .session-meta{
      --tl-pad: 1.5rem;
      --dot: .6rem;
      --line: 2px;
      position: relative;
      padding-left: var(--tl-pad);
    }
    .dot{ width:.6rem; height:.6rem; border-radius:50%; display:inline-block; margin-right:.45rem; vertical-align:middle; }
    .dot-red{ background:#ff445a; }
    .dot-blue{ background:#3aa0ff; }
    .dot-green{ background:#51cb1c; }

    .chip-soft{
      background: rgba(255,255,255,.08);
      border: 1px solid rgba(255,255,255,.12);
      color: #fff;
      border-radius: 999px;
      padding: .25rem .6rem;
      font-size: .8rem;
      line-height: 1;
    }

    .price-panel{
      background:#0d1622; color:#cfe6f3; height:100%;
      display:flex; flex-direction:column; justify-content:center;
      border-left:1px solid #1f2a3a; padding:1.4rem;
    }
    @media (max-width: 991.98px){
      .price-panel{ border-left:0; border-top:1px solid #1f2a3a; }
    }
    .price-from{ color:var(--muted); font-size:.9rem; }
    .price-value{ color:#fff; font-weight:300; font-size:2.2rem; line-height:1; }
    .price-value-reduit{ color:#888b93; font-weight:900; font-size:1rem; line-height:1; }

    .cta{
      background:var(--cta); border:0; color:#fff; font-weight:700;
      border-radius:12px; padding:.9rem 1.1rem;
    }
    .cta:hover{ filter:brightness(1.05); background: var(--cta-ink) !important; color: var(--cta); }

    .btn-outline-light{
      border-radius: 12px;
    }

    .empty-state{
      background: rgba(255,255,255,.06);
      border: 1px solid rgba(255,255,255,.10);
      border-radius: 18px;
      padding: 2.5rem 1.5rem;
    }
  </style>
{% endblock %}

{% block body %}
  {% include 'header_public.html.twig' %}

  <header class="hero bg-light text-center">
      <div class="container">
          <img class="mb-1"
            src="{{ asset(brand.logo) }}"
            alt="Logo {{ brand.name }}"
            class="img-fluid"
            width="200">
          <h1 class="fw-bold fs-sm-2 fs-md-3 fs-lg-5 mt-5">{{ 'home.hero.h1'|trans }}</h1>
      </div>
  </header>
  

  <section class="hero-cover d-flex align-items-end">
    <div class="container hero-inner text-center text-lg-start">
      <h1 class="display-6 display-lg-4 mb-2">Catalogue de nos formations</h1>
      <p class="mb-0">Toutes les formations disponibles.</p>
    </div>
  </section>

  <div class="container catalog-wrap pb-5">

    <div class="catalog-top">
      <div>
        <div class="results-count" id="results-count">{{ formations|length }} résultat{% if formations|length > 1 %}s{% endif %}</div>
        <div class="hint small">Clique sur “Voir la formation” pour les détails et faire une demande.</div>
      </div>

      <a class="btn btn-outline-light" href="{{ path('app_public') }}">
        <i class="bi bi-calendar3 me-2"></i>Voir le calendrier
      </a>
    </div>

    <div id="results" class="vstack gap-4">
      {% for item in formations %}
        {% set f = item.formation %}
        {% set s = item.nextSession %}

        {% set cover =
          (f is defined and f.photoBanniere ? asset('uploads/photos/formation/' ~ f.photoBanniere) :
          asset('dist/img/vitrine/voile.webp'))
        %}

        <div class="session-card">
          <div class="row g-0">
            <div class="col-12 col-lg-3">
              <div class="session-media h-100 w-100" style="--cover:url('{{ cover|e('html_attr') }}');"></div>
            </div>

            <div class="col-12 col-lg-6">
              <div class="session-body">
                <div class="session-badges d-flex align-items-center flex-wrap gap-2 mb-1">
                  {% if f and f.niveau is defined %}
                    {% set _niv_key = 'formation.niveau.' ~ (f.niveau.value ?? f.niveau.name) %}
                    <span class="chip-soft"><i class="bi bi-tags-fill me-2"></i>{{ _niv_key|lower|trans }}</span>
                  {% endif %}
                  {% if f and f.codeQualiopi %}
                    <span class="badge badge-qualio rounded-pill bg-success-subtle text-success">Qualiopi {{ f.codeQualiopi }}</span>

                  {% endif %}

                  {% if not s %}
                    <span class="badge rounded-pill bg-warning-subtle text-warning">
                      <i class="bi bi-lightning-charge me-1"></i>Sur demande
                    </span>
                  {% endif %}
                </div>

                <div class="session-title">
                  {{ f.titre ?? 'Formation' }}
                  {% if f.duree is defined and f.duree %}
                    ({{ f.duree }} jour{% if f.duree > 1 %}s{% endif %})
                  {% endif %}
                </div>

                
                  {% if s %}
                    <div class="small session-meta mt-2">
                    <div class="mb-1">
                      {{ s.dateDebut ? s.dateDebut|date('d/m/Y H:i') : 'Date à définir' }}
                    </div>
                    <div>
                      {% if s.dateFin %}{{ s.dateFin|date('d/m/Y H:i') }}{% else %}{{ f.duree ? f.duree ~ ' jours' : '' }}{% endif %}
                    </div>
                    </div>
                  {% else %}
                    <div class="small mt-2">
                    <div class="mb-1">
                      Prochaine session : <strong>sur demande</strong>
                    </div>
                    <div class="text-white-50">Tu peux demander une date, un lieu, et un devis.</div>
                    </div>
                  {% endif %}
                

                {% if f.description %}
                  <p class="text-white-50 mt-3 mb-0">
                    {{ (f.description|striptags|slice(0,180)|nl2br ~ (f.description|length > 180 ? '…' : ''))|raw }}
                  </p>
                {% endif %}
              </div>
            </div>

            <div class="col-12 col-lg-3">
              <div class="price-panel text-center">
                <div class="price-from text-uppercase">À partir de</div>

                {% set prixReduit = f.prixReduitEuros %}
                {% if prixReduit is not null %}
                  <div class="price-value">{{ (prixReduit ?? 0)|number_format(0, ',', ' ') }}<span class="fs-6 align-top"> €</span></div>
                  <div class="text-white-50">HT / pers.</div>
                  <div class="price-value-reduit mb-3">
                    Au lieu de {{ f.prixBaseEuros|number_format(0, ',', ' ') }}<span class="fs-6 align-top"> €</span>
                  </div>
                {% else %}
                  <div class="price-value">{{ (f.prixBaseEuros ?? 0)|number_format(0, ',', ' ') }}<span class="fs-6 align-top"> €</span></div>
                  <div class="text-white-50 mb-3">HT / pers.</div>
                {% endif %}

                <a class="btn cta w-100" href="{{ path('app_public_show', {slug: f.slug}) }}">
                  Voir la formation
                </a>

                {% if not s %}
                  <a class="btn btn-outline-light w-100 mt-2" href="{{ path('app_public_show', {slug: f.slug}) }}#demande-session">
                    <i class="bi bi-envelope me-2"></i>Demander une session
                  </a>
                {% endif %}
              </div>
            </div>
          </div>
        </div>

      {% else %}
        <div class="empty-state text-center">
          <i class="bi bi-journal-x fs-1 d-block mb-3 text-white"></i>
          <h3 class="h5 text-white mb-2">Aucune formation disponible</h3>
          <p class="mb-0 text-white-50">Active “Visible public” sur au moins une formation.</p>
        </div>
      {% endfor %}
    </div>

  </div>
{% endblock %}
