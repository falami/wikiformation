    <main class="pg-wrap">

        <!-- ══ HERO ══════════════════════════════════════════════ -->
        <section class="hero">
            <div class="hero-orb-indigo"></div>
            <div class="hero-orb-gold"></div>
            <div class="container">
                <div class="hero-inner">
                    <span class="hero-eyebrow">
