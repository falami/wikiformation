{# templates/public/cgv.html.twig #}
{% extends 'base_public.html.twig' %}

{% block title %}WikiFormation — Conditions Générales de Vente{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">

    <style>
        /* ── TOKENS ─────────────────────────────────────────────── */
        :root {
            --ink:        #0a0a0f;
            --ink-80:     rgba(10,10,15,.80);
            --ink-40:     rgba(10,10,15,.40);
            --ink-10:     rgba(10,10,15,.07);
            --gold:       #c9a84c;
            --gold-light: #e8d49a;
            --gold-faint: rgba(201,168,76,.10);
            --cream:      #faf8f3;
            --white:      #ffffff;
            --rule:       rgba(10,10,15,.08);

            --r-xl: 28px;
            --r-lg: 20px;
            --r-md: 14px;

            --shadow-card: 0 12px 36px rgba(10,10,15,.07), 0 2px 6px rgba(10,10,15,.04);
            --shadow-plan: 0 20px 60px rgba(10,10,15,.10), 0 4px 12px rgba(10,10,15,.05);

            --serif: 'Cormorant Garamond', Georgia, serif;
            --sans:  'DM Sans', sans-serif;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }

        body {
            font-family: var(--sans);
            background-color: var(--cream);
            color: var(--ink);
            overflow-x: hidden;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
            pointer-events: none;
            z-index: 9999;
            opacity: .6;
        }

        .pg-wrap { min-height: 100vh; }

        /* ══ HERO ══════════════════════════════════════════════════ */
        .hero {
            position: relative;
            background: #0f1b28;
            overflow: hidden;
            padding: 5rem 0 5rem;
        }

        .hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background: repeating-linear-gradient(
                90deg,
                rgba(255,255,255,.025) 0px,
                rgba(255,255,255,.025) 1px,
                transparent 1px,
                transparent 72px
            );
            pointer-events: none;
        }

        /* indigo orb — commerce / SaaS feel */
        .hero-orb-indigo {
            position: absolute;
            left: -100px;
            top: -100px;
            width: 380px;
            height: 380px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(99,102,241,.13) 0%, transparent 65%);
            pointer-events: none;
        }

        .hero-orb-gold {
            position: absolute;
            right: -120px;
            bottom: -120px;
            width: 440px;
            height: 440px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(201,168,76,.20) 0%, transparent 65%);
            pointer-events: none;
        }

        .hero-inner {
            position: relative;
            z-index: 2;
            padding: 0 2rem;
        }

        .hero-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: .6rem;
            font-size: .72rem;
            font-weight: 500;
            letter-spacing: .16em;
            text-transform: uppercase;
            color: var(--gold-light);
            margin-bottom: 2rem;
            padding: .45rem .9rem;
            border: 1px solid rgba(201,168,76,.25);
            border-radius: 999px;
        }

        .hero h1 {
            font-family: var(--serif);
            font-size: clamp(3rem, 6vw, 5.4rem);
            font-weight: 300;
            letter-spacing: -.02em;
            line-height: 1.08;
            color: #fff;
            margin-bottom: 2rem;
        }

        .hero h1 em {
            font-style: italic;
            color: var(--gold-light);
        }

        .hero-intro {
            font-size: 1.05rem;
            line-height: 1.85;
            color: rgba(255,255,255,.60);
            font-weight: 300;
            max-width: 580px;
            padding-left: 1.4rem;
            border-left: 2px solid rgba(201,168,76,.35);
        }

        .hero-pills {
            display: flex;
            flex-wrap: wrap;
            gap: .75rem;
            margin-top: 3rem;
        }

        .hero-pill {
            display: inline-flex;
            align-items: center;
            gap: .55rem;
            padding: .55rem 1.1rem;
            border-radius: 999px;
            background: rgba(255,255,255,.06);
            border: 1px solid rgba(255,255,255,.10);
            color: rgba(255,255,255,.72);
            font-size: .85rem;
        }

        .hero-pill i { color: var(--gold); font-size: .9rem; }

        .hero-wave {
            display: block;
            width: 100%;
            line-height: 0;
            margin-top: -1px;
        }

        /* ══ LAYOUT ════════════════════════════════════════════════ */
        .doc-layout {
            display: grid;
            grid-template-columns: 260px 1fr;
            max-width: 1200px;
            margin: 0 auto;
            padding: 3.5rem 1.5rem 6rem;
            align-items: start;
        }

        /* ── SIDEBAR ───────────────────────────────────────────── */
        .sidebar {
            position: sticky;
            top: 2.5rem;
            padding-right: 2.5rem;
        }

        .sidebar-label {
            font-size: .68rem;
            font-weight: 500;
            letter-spacing: .14em;
            text-transform: uppercase;
            color: var(--ink-40);
            margin-bottom: 1.2rem;
        }

        .toc { list-style: none; border-left: 1px solid var(--rule); }

        .toc li a {
            display: flex;
            align-items: baseline;
            gap: .65rem;
            padding: .6rem 0 .6rem 1.2rem;
            text-decoration: none;
            color: var(--ink-40);
            font-size: .85rem;
            line-height: 1.45;
            transition: color .2s, border-color .2s;
            border-left: 2px solid transparent;
            margin-left: -1px;
        }

        .toc li a .num {
            font-family: var(--serif);
            font-size: .8rem;
            color: var(--gold);
            flex-shrink: 0;
        }

        .toc li a:hover  { color: var(--ink); border-left-color: var(--gold); }
        .toc li a.active { color: var(--ink); font-weight: 500; border-left-color: var(--gold); }

        .sidebar-updated {
            margin-top: 2.5rem;
            padding: .9rem 1rem;
            background: var(--gold-faint);
            border: 1px solid rgba(201,168,76,.18);
            border-radius: var(--r-md);
            font-size: .8rem;
            color: var(--ink-80);
            line-height: 1.6;
        }

        .sidebar-updated strong { color: var(--gold); }

        /* ── MAIN ──────────────────────────────────────────────── */
        .doc-main { min-width: 0; }

        /* ── SECTION ───────────────────────────────────────────── */
        .doc-section {
            margin-bottom: 1.75rem;
            background: var(--white);
            border: 1px solid var(--rule);
            border-radius: var(--r-xl);
            overflow: hidden;
            box-shadow: var(--shadow-card);
            opacity: 0;
            transform: translateY(22px);
            transition: opacity .55s cubic-bezier(.22,.68,0,1.2), transform .55s cubic-bezier(.22,.68,0,1.2);
        }

        .doc-section.visible { opacity: 1; transform: translateY(0); }

        .section-head {
            display: flex;
            align-items: flex-start;
            gap: 1.25rem;
            padding: 1.75rem 2rem 1.5rem;
            border-bottom: 1px solid var(--rule);
        }

        .section-num {
            font-family: var(--serif);
            font-size: 2.6rem;
            font-weight: 300;
            line-height: 1;
            color: var(--gold);
            flex-shrink: 0;
            min-width: 42px;
        }

        .section-title-wrap { flex: 1; }

        .section-category {
            font-size: .68rem;
            font-weight: 500;
            letter-spacing: .13em;
            text-transform: uppercase;
            color: var(--ink-40);
            margin-bottom: .3rem;
        }

        .section-title {
            font-family: var(--serif);
            font-size: 1.65rem;
            font-weight: 600;
            letter-spacing: -.02em;
            color: var(--ink);
            line-height: 1.2;
        }

        .section-icon {
            width: 44px;
            height: 44px;
            border-radius: var(--r-md);
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--gold-faint);
            border: 1px solid rgba(201,168,76,.15);
            color: var(--gold);
            font-size: 1.1rem;
            flex-shrink: 0;
        }

        .section-body { padding: 1.75rem 2rem; }

        .section-body p {
            font-size: .975rem;
            line-height: 1.85;
            color: var(--ink-80);
            margin-bottom: 1rem;
        }

        .section-body p:last-child { margin-bottom: 0; }

        /* ── SUMMARY GRID ──────────────────────────────────────── */
        .summary-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1rem;
            padding: 1.75rem 2rem;
            border-bottom: 1px solid var(--rule);
        }

        .sum-card {
            padding: 1.3rem;
            border: 1px solid var(--rule);
            border-radius: var(--r-lg);
            background: var(--cream);
            transition: box-shadow .2s, transform .2s, border-color .2s;
            cursor: default;
        }

        .sum-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-card);
            border-color: rgba(201,168,76,.3);
        }

        .sum-icon {
            width: 42px;
            height: 42px;
            border-radius: 13px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--ink);
            color: var(--gold);
            font-size: 1rem;
            margin-bottom: 1rem;
        }

        .sum-card h3 {
            font-family: var(--serif);
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--ink);
            margin-bottom: .4rem;
        }

        .sum-card p {
            font-size: .84rem;
            color: var(--ink-40);
            line-height: 1.65;
            margin: 0;
        }

        /* ══ PLAN CARDS ════════════════════════════════════════════ */
        .plans-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.25rem;
        }

        .plan-card {
            position: relative;
            border-radius: var(--r-lg);
            overflow: hidden;
            border: 1px solid var(--rule);
            background: var(--white);
            box-shadow: var(--shadow-card);
            transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
        }

        .plan-card:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow-plan);
            border-color: rgba(10,10,15,.12);
        }

        .plan-card.featured {
            border-color: rgba(201,168,76,.35);
        }

        /* colored top bar */
        .plan-topbar {
            height: 4px;
            width: 100%;
        }

        .plan-header {
            padding: 1.5rem 1.5rem 1rem;
            display: flex;
            align-items: flex-start;
            gap: 1rem;
        }

        .plan-icon {
            width: 52px;
            height: 52px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            color: var(--white);
            flex-shrink: 0;
        }

        .plan-meta { flex: 1; }

        .plan-name {
            font-family: var(--serif);
            font-size: 1.4rem;
            font-weight: 600;
            color: var(--ink);
            line-height: 1.1;
            margin-bottom: .3rem;
        }

        .plan-subtitle {
            font-size: .85rem;
            color: var(--ink-40);
            line-height: 1.55;
            margin-bottom: .6rem;
        }

        .plan-badge {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            padding: .28rem .7rem;
            border-radius: 999px;
            font-size: .72rem;
            font-weight: 500;
            letter-spacing: .06em;
            text-transform: uppercase;
            background: rgba(201,168,76,.12);
            border: 1px solid rgba(201,168,76,.25);
            color: #92670a;
        }

        .plan-pricing {
            padding: 0 1.5rem 1rem;
            display: flex;
            align-items: baseline;
            gap: .5rem;
        }

        .plan-price {
            font-family: var(--serif);
            font-size: 2.4rem;
            font-weight: 600;
            letter-spacing: -.03em;
            color: var(--ink);
            line-height: 1;
        }

        .plan-period {
            font-size: .85rem;
            color: var(--ink-40);
        }

        .plan-annual {
            padding: 0 1.5rem .9rem;
            font-size: .8rem;
            color: var(--ink-40);
        }

        .plan-divider {
            height: 1px;
            background: var(--rule);
            margin: 0 1.5rem;
        }

        .plan-features {
            list-style: none;
            padding: 1rem 1.5rem 1.5rem;
        }

        .plan-features li {
            display: flex;
            align-items: flex-start;
            gap: .75rem;
            padding: .65rem 0;
            border-top: 1px solid var(--rule);
            font-size: .88rem;
            color: var(--ink-80);
            line-height: 1.6;
        }

        .plan-features li:first-child { border-top: none; padding-top: 0; }

        .plan-features li::before {
            content: '';
            width: 16px;
            height: 16px;
            border-radius: 50%;
            flex-shrink: 0;
            margin-top: .15rem;
            background: rgba(16,185,129,.12);
            border: 1px solid rgba(16,185,129,.25);
            background-image: url("data:image/svg+xml,%3Csvg width='8' height='7' viewBox='0 0 8 7' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 3.5l2.2 2.2 4-4.4' stroke='%2310b981' stroke-width='1.4' fill='none' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
            background-repeat: no-repeat;
            background-position: center;
        }

        /* ── LEGAL ITEMS LIST ──────────────────────────────────── */
        .legal-list { display: grid; gap: .85rem; }

        .legal-item {
            display: flex;
            gap: 1rem;
            align-items: flex-start;
            border: 1px solid var(--rule);
            border-radius: var(--r-lg);
            background: var(--cream);
            padding: 1rem 1.25rem;
            transition: border-color .2s, box-shadow .2s;
        }

        .legal-item:hover {
            border-color: rgba(201,168,76,.28);
            box-shadow: 0 4px 20px rgba(201,168,76,.06);
        }

        .legal-item-num {
            font-family: var(--serif);
            font-size: 1.3rem;
            font-weight: 300;
            color: var(--gold);
            line-height: 1;
            flex-shrink: 0;
            min-width: 24px;
            margin-top: .1rem;
        }

        .legal-item p {
            font-size: .92rem;
            color: var(--ink-80);
            line-height: 1.75;
            margin: 0;
        }

        /* ── CHECK LIST ────────────────────────────────────────── */
        .check-list { list-style: none; display: grid; gap: .55rem; }

        .check-list li {
            display: flex;
            gap: .85rem;
            align-items: flex-start;
            font-size: .935rem;
            line-height: 1.7;
            color: var(--ink-80);
            padding: .7rem .9rem;
            border-radius: var(--r-md);
            transition: background .2s;
        }

        .check-list li:hover { background: var(--ink-10); }

        .check-list li::before {
            content: '';
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: rgba(16,185,129,.12);
            border: 1px solid rgba(16,185,129,.25);
            flex-shrink: 0;
            margin-top: .15rem;
            background-image: url("data:image/svg+xml,%3Csvg width='10' height='8' viewBox='0 0 10 8' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 4l3 3 5-6' stroke='%2310b981' stroke-width='1.5' fill='none' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
            background-repeat: no-repeat;
            background-position: center;
        }

        /* ── CALLOUT BLOCKS ────────────────────────────────────── */
        .callout {
            border-radius: var(--r-lg);
            padding: 1.2rem 1.4rem;
            display: flex;
            gap: 1rem;
            align-items: flex-start;
            margin-top: 1.2rem;
        }

        .callout-icon {
            width: 34px;
            height: 34px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .95rem;
            flex-shrink: 0;
        }

        .callout-body { flex: 1; }
        .callout-body p { margin: 0; font-size: .9rem; line-height: 1.75; color: var(--ink-80); }
        .callout-body strong { color: var(--ink); }

        .callout-info { background: rgba(59,130,246,.06); border: 1px solid rgba(59,130,246,.12); }
        .callout-info .callout-icon { background: rgba(59,130,246,.10); color: #3b82f6; }

        .callout-gold { background: rgba(201,168,76,.07); border: 1px solid rgba(201,168,76,.18); }
        .callout-gold .callout-icon { background: rgba(201,168,76,.14); color: var(--gold); }

        .callout-warn { background: rgba(245,158,11,.06); border: 1px solid rgba(245,158,11,.14); }
        .callout-warn .callout-icon { background: rgba(245,158,11,.12); color: #d97706; }

        /* ── FOOTER ────────────────────────────────────────────── */
        .doc-footer {
            text-align: center;
            padding: 2rem;
            font-size: .85rem;
            color: var(--ink-40);
        }

        .doc-footer a { color: var(--gold); text-decoration: none; }

        /* ══ RESPONSIVE ════════════════════════════════════════════ */
        @media (max-width: 991px) {
            .doc-layout { grid-template-columns: 1fr; }
            .sidebar { position: static; padding-right: 0; margin-bottom: 2rem; }
            .toc { display: flex; flex-wrap: wrap; gap: .4rem; border-left: none; }
            .toc li a {
                border: 1px solid var(--rule);
                border-radius: 999px;
                border-left: 1px solid var(--rule);
                padding: .45rem .9rem;
                font-size: .78rem;
            }
            .toc li a:hover { border-color: var(--gold); }
            .summary-grid { grid-template-columns: repeat(2, 1fr); }
            .plans-grid   { grid-template-columns: 1fr; }
        }

        @media (max-width: 767px) {
            .hero { padding: 4rem 0 5rem; }
            .hero h1 { font-size: 2.8rem; }
            .summary-grid { grid-template-columns: 1fr; }
            .section-head { padding: 1.25rem; }
            .section-body { padding: 1.25rem; }
            .section-num  { font-size: 2rem; }
            .hero-pills   { display: none; }
        }
    </style>
{% endblock %}

