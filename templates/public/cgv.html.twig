{% extends 'base_public.html.twig' %}

{% block title %}Wiki Formation - Conditions Générales de Vente{% endblock %}

{% block stylesheets %}{% endblock %}
{% block javascripts %}{% endblock %}

{% block body %}
    {% include 'header_public.html.twig' %}

    <div class="container py-5 mt-5">
        <div class="bg-white shadow rounded p-4 p-md-5">
            <div class="text-center mb-5">
                <h1 class="display-5 fw-bold text-primary">Conditions Générales de Vente</h1>
                <p class="lead text-muted">Informations contractuelles relatives à la souscription d’un abonnement sur Wiki Formation</p>
            </div>

            {% set abonnements = [
                {'type': 'Premium', 'icon': 'gem'},
                {'type': 'Administrateur', 'icon': 'person-gear'},
                {'type': 'Utilisateur', 'icon': 'person'}
            ] %}

            {% for abonnement in abonnements %}
                <div class="card mb-4 border-0 shadow-sm">
                    <div class="card-header bg-theme text-white d-flex align-items-center">
                        <i class="bi bi-{{ abonnement.icon }} me-2 fs-4"></i>
                        <h5 class="mb-0">Abonnement {{ abonnement.type }}</h5>
                    </div>
                    <div class="card-body">
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item"><strong>Produits :</strong> Abonnements {{ abonnement.type|lower }}.</li>
                            <li class="list-group-item"><strong>Prix :</strong> Affichés TTC sur la page d'accueil une fois connecté.</li>
                            <li class="list-group-item"><strong>Paiement :</strong> Par Stripe via une plateforme 100% sécurisée.</li>
                            <li class="list-group-item"><strong>Rétractation :</strong> Pas de droit de rétractation après souscription. Vous pouvez néanmoins annuler à tout moment.</li>
                            <li class="list-group-item"><strong>Résiliation :</strong> Possible à tout moment via votre espace personnel.</li>
                            <li class="list-group-item"><strong>Litiges :</strong> Possibilité de recours à un médiateur de la consommation.</li>
                        </ul>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
