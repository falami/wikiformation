                            </div>

                            <div class="hero-contract-grid">
                                <div class="hero-contract-item">
                                    <span>Dernière mise à jour</span>
                                    <strong>{{ "now"|date("d/m/Y") }}</strong>
                                </div>
                                <div class="hero-contract-item">
                                    <span>Champ d’application</span>
                                    <strong>Site & plateforme</strong>
                                </div>
                                <div class="hero-contract-item">
                                    <span>Accès</span>
                                    <strong>Public et authentifié</strong>
                                </div>
                                <div class="hero-contract-item">
                                    <span>Cadre</span>
