                    </section>

                    <article class="doc-section" id="s1">
                        <div class="section-head">
                            <span class="section-num">01</span>
                            <div class="section-title-wrap">
                                <p class="section-category">Fondements</p>
                                <h2 class="section-title">Objet des CGU</h2>
