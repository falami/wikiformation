                    </article>

                    <article class="doc-section" id="s12">
                        <div class="section-head">
                            <span class="section-num">12</span>
                            <div class="section-title-wrap">
                                <p class="section-category">Juridique</p>
                                <h2 class="section-title">Droit applicable</h2>
                            </div>
                            <div class="section-icon"><i class="bi bi-bank"></i></div>
                        </div>
