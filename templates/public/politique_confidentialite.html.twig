{% extends 'base_public.html.twig' %}

{% block title %}Wiki Formation -  du club - Politique de confidentialité{% endblock %}


{% block stylesheets %}
{% endblock %}

{% block javascripts %}
{% endblock %}


{% block body %}
    
    
    {% include 'header_public.html.twig' %}



    <div class="container p-5 mt-5">
        <h1 class="mb-4">Politique de confidentialité</h1>
        <p class="lead">Chez <strong>Wiki Formation</strong>, nous accordons une grande importance à la protection de vos données personnelles. Cette page vous explique de manière transparente comment vos données sont collectées, utilisées et protégées.</p>

        <div class="accordion" id="privacyAccordion">

            <!-- Responsable -->
            <div class="accordion-item">
                <h2 class="accordion-header" id="heading1">
                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapse1" aria-expanded="true">
                        1. Responsable du traitement
                    </button>
                </h2>
                <div id="collapse1" class="accordion-collapse collapse show" data-bs-parent="#privacyAccordion">
                    <div class="accordion-body">
                        Le responsable du traitement est :<br>
                        <strong>Wiki Formation</strong><br>
                        Email : <a href="mailto:contact@wikiformation.fr">contact@wikiformation.fr</a>
                    </div>
                </div>
            </div>

            <!-- Données collectées -->
            <div class="accordion-item">
                <h2 class="accordion-header" id="heading2">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse2">
                        2. Données collectées
                    </button>
                </h2>
                <div id="collapse2" class="accordion-collapse collapse" data-bs-parent="#privacyAccordion">
                    <div class="accordion-body">
                        <ul>
                            <li>Données d'identification : nom, prénom, adresse e-mail, téléphone, etc.</li>
                            <li>Données de compte : mot de passe, préférences, abonnements</li>
                            <li>Données de navigation : adresse IP, type de navigateur, pages visitées, etc.</li>
                            <li>Données de géolocalisation (si activée dans votre profil)</li>
                            <li>Historique des sorties, évaluations, interactions sur la plateforme</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Finalités -->
            <div class="accordion-item">
                <h2 class="accordion-header" id="heading3">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse3">
                        3. Finalités de la collecte
                    </button>
                </h2>
                <div id="collapse3" class="accordion-collapse collapse" data-bs-parent="#privacyAccordion">
                    <div class="accordion-body">
                        <ul>
                            <li>Fourniture des services proposés (création de compte, gestion des sorties, messagerie)</li>
                            <li>Communication avec les utilisateurs (emails, notifications)</li>
                            <li>Amélioration de l’expérience utilisateur et du site</li>
                            <li>Analyse de l’utilisation du site à des fins statistiques</li>
                            <li>Respect des obligations légales et réglementaires</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Cookies -->
            <div class="accordion-item">
                <h2 class="accordion-header" id="heading4">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse4">
                        4. Utilisation des cookies
                    </button>
                </h2>
                <div id="collapse4" class="accordion-collapse collapse" data-bs-parent="#privacyAccordion">
                    <div class="accordion-body">
                        Nous utilisons des cookies pour :
                        <ul>
                            <li>Mémoriser vos préférences de navigation</li>
                            <li>Établir des statistiques d’audience (via Google Analytics ou Matomo – uniquement avec votre consentement)</li>
                            <li>Améliorer les performances du site</li>
                        </ul>
                        Vous pouvez gérer vos préférences à tout moment via la bannière ou les paramètres de votre navigateur.
                    </div>
                </div>
            </div>

            <!-- Consentement -->
            <div class="accordion-item">
                <h2 class="accordion-header" id="heading5">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse5">
                        5. Consentement
                    </button>
                </h2>
                <div id="collapse5" class="accordion-collapse collapse" data-bs-parent="#privacyAccordion">
                    <div class="accordion-body">
                        Lors de votre première visite, vous êtes invité à accepter ou refuser les cookies. Certains services nécessitent votre consentement explicite (ex : newsletter, contact, Google Maps, etc.).
                    </div>
                </div>
            </div>

            <!-- Sécurité des données -->
            <div class="accordion-item">
                <h2 class="accordion-header" id="heading6">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse6">
                        6. Sécurité des données
                    </button>
                </h2>
                <div id="collapse6" class="accordion-collapse collapse" data-bs-parent="#privacyAccordion">
                    <div class="accordion-body">
                        Nous utilisons des protocoles sécurisés (HTTPS), une base de données protégée, un contrôle d’accès et des sauvegardes régulières. Les mots de passe sont chiffrés.
                    </div>
                </div>
            </div>

            <!-- Destinataires -->
            <div class="accordion-item">
                <h2 class="accordion-header" id="heading7">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse7">
                        7. Destinataires des données
                    </button>
                </h2>
                <div id="collapse7" class="accordion-collapse collapse" data-bs-parent="#privacyAccordion">
                    <div class="accordion-body">
                        Les données sont traitées uniquement par les administrateurs autorisés. Aucun transfert n’est effectué vers des tiers sans votre consentement, sauf obligation légale.
                    </div>
                </div>
            </div>

            <!-- Conservation -->
            <div class="accordion-item">
                <h2 class="accordion-header" id="heading8">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse8">
                        8. Durée de conservation
                    </button>
                </h2>
                <div id="collapse8" class="accordion-collapse collapse" data-bs-parent="#privacyAccordion">
                    <div class="accordion-body">
                        Vos données sont conservées aussi longtemps que votre compte est actif, et jusqu’à 3 ans après la dernière activité. Les données fiscales ou comptables peuvent être conservées plus longtemps conformément à la loi.
                    </div>
                </div>
            </div>

            <!-- Droits -->
            <div class="accordion-item">
                <h2 class="accordion-header" id="heading9">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse9">
                        9. Vos droits
                    </button>
                </h2>
                <div id="collapse9" class="accordion-collapse collapse" data-bs-parent="#privacyAccordion">
                    <div class="accordion-body">
                        Vous pouvez à tout moment exercer vos droits :
                        <ul>
                            <li>Droit d'accès</li>
                            <li>Droit de rectification</li>
                            <li>Droit à l'effacement</li>
                            <li>Droit à la limitation</li>
                            <li>Droit à la portabilité</li>
                            <li>Droit d’opposition</li>
                        </ul>
                        Contact : <a href="mailto:contact@wikiformation.fr">contact@wikiformation.fr</a>
                    </div>
                </div>
            </div>

            <!-- Mise à jour -->
            <div class="accordion-item">
                <h2 class="accordion-header" id="heading10">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse10">
                        10. Mise à jour de la politique
                    </button>
                </h2>
                <div id="collapse10" class="accordion-collapse collapse" data-bs-parent="#privacyAccordion">
                    <div class="accordion-body">
                        Cette politique peut être modifiée à tout moment. Dernière mise à jour : <strong>{{ "now"|date("d/m/Y") }}</strong>.
                    </div>
                </div>
            </div>

        </div>
    </div>
{% endblock %}


