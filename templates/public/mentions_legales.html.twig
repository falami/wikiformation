{# templates/public/mentions_legales.html.twig #}
{% extends 'base_public.html.twig' %}

{% block title %}WikiFormation - Mentions légales{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">

    <style>
        :root{
            --wf-bg: #f6f2ea;
            --wf-bg-soft: #fbf8f2;
            --wf-panel: rgba(255,255,255,.72);
            --wf-panel-strong: rgba(255,255,255,.92);
            --wf-white: #ffffff;

            --wf-ink: #0d1320;
            --wf-ink-2: #1a2233;
            --wf-muted: #667085;
            --wf-muted-2: rgba(13,19,32,.58);
            --wf-line: rgba(15,23,42,.08);
            --wf-line-strong: rgba(15,23,42,.14);

            --wf-gold: #c7a552;
            --wf-gold-2: #e8d29a;
            --wf-gold-soft: rgba(199,165,82,.12);

            --wf-navy: #0d1727;
            --wf-navy-2: #122034;
            --wf-blue: #3b82f6;
            --wf-indigo: #5b67f1;
            --wf-emerald: #10b981;
            --wf-red: #ef4444;
            --wf-amber: #f59e0b;

            --wf-shadow-xs: 0 1px 2px rgba(2,6,23,.04);
            --wf-shadow-sm: 0 10px 30px rgba(15,23,42,.06);
            --wf-shadow-md: 0 20px 60px rgba(15,23,42,.10);
            --wf-shadow-lg: 0 30px 90px rgba(15,23,42,.14);

            --wf-r-xs: 12px;
            --wf-r-sm: 16px;
            --wf-r-md: 22px;
            --wf-r-lg: 28px;
            --wf-r-xl: 34px;
            --wf-r-pill: 999px;

            --wf-serif: 'Cormorant Garamond', Georgia, serif;
            --wf-sans: 'DM Sans', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }

        *,
        *::before,
        *::after {
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }


        .legal-page {
            position: relative;
            isolation: isolate;
        }

        .legal-page::before{
            content:'';
            position:absolute;
            left:50%;
            top:520px;
            transform:translateX(-50%);
            width:min(1200px, 86vw);
            height:500px;
            border-radius:50%;
            background: radial-gradient(circle, rgba(59,130,246,.10), transparent 65%);
            filter: blur(30px);
            z-index:-1;
            pointer-events:none;
        }

        /* HERO */
        .legal-hero {
            position: relative;
            overflow: hidden;
            background: #0f1b28;
            padding: 5.75rem 0 6.5rem;
        }

        .legal-hero::before {
            content: '';
            position: absolute;
            inset: -2px;
            z-index: -2;
            background:
                radial-gradient(1200px 700px at 15% 10%, rgba(59,130,246,.32), transparent 60%),
                radial-gradient(900px 520px at 85% 20%, rgba(91,103,241,.26), transparent 60%),
                radial-gradient(820px 520px at 55% 95%, rgba(199,165,82,.22), transparent 62%),
                linear-gradient(180deg, #09111b 0%, #0b0f14 70%, #0b0f14 100%);
        }

        .hero-orb-line{
            position:absolute;
            inset:0;
            background:
                radial-gradient(circle at 15% 22%, rgba(255,255,255,.08) 0 2px, transparent 2px),
                radial-gradient(circle at 82% 38%, rgba(255,255,255,.06) 0 2px, transparent 2px),
                radial-gradient(circle at 66% 72%, rgba(255,255,255,.05) 0 2px, transparent 2px);
            pointer-events:none;
        }

        .hero-shell{
            position:relative;
            z-index:2;
        }

        .hero-grid{
            display:grid;
            grid-template-columns: minmax(0, 1.15fr) minmax(320px, .85fr);
            gap: 2rem;
            align-items:end;
        }

        .hero-badge{
            display:inline-flex;
            align-items:center;
            gap:.7rem;
            padding:.6rem 1rem;
            border-radius: var(--wf-r-pill);
            border: 1px solid rgba(231,213,160,.22);
            background: rgba(255,255,255,.05);
            backdrop-filter: blur(8px);
            color: var(--wf-gold-2);
            font-size: .76rem;
            letter-spacing: .16em;
            text-transform: uppercase;
            font-weight: 600;
            margin-bottom: 1.6rem;
        }

        .hero-badge i{
            font-size: .9rem;
            color: var(--wf-gold);
        }

        .hero-title{
            margin:0 0 1.4rem;
            font-family: var(--wf-serif);
            font-size: clamp(3rem, 6vw, 5.65rem);
            line-height: .95;
            font-weight: 500;
            letter-spacing: -.04em;
            color: #fff;
        }

        .hero-title .accent{
            color: #cfe0ff;
            font-style: italic;
            font-weight: 400;
        }

        .hero-lead{
            max-width: 720px;
            margin: 0;
            color: rgba(255,255,255,.72);
            font-size: 1.05rem;
            line-height: 1.95;
            padding-left: 1.2rem;
            border-left: 2px solid rgba(207,224,255,.26);
        }

        .hero-pills{
            display:flex;
            flex-wrap:wrap;
            gap:.8rem;
            margin-top: 2rem;
        }

        .hero-pill{
            display:inline-flex;
            align-items:center;
            gap:.55rem;
            padding:.75rem 1rem;
            border-radius: var(--wf-r-pill);
            background: rgba(255,255,255,.06);
            border: 1px solid rgba(255,255,255,.10);
            color: rgba(255,255,255,.78);
            font-size: .88rem;
            backdrop-filter: blur(8px);
            box-shadow: inset 0 1px 0 rgba(255,255,255,.04);
        }

        .hero-pill i{
            color: var(--wf-gold);
        }

        .hero-aside{
            position:relative;
        }

        .hero-card{
            position:relative;
            overflow:hidden;
            padding: 1.4rem;
            border-radius: 26px;
            background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,.05));
            border: 1px solid rgba(255,255,255,.10);
            backdrop-filter: blur(18px);
            box-shadow: 0 20px 70px rgba(0,0,0,.22);
        }

        .hero-card::before{
            content:'';
            position:absolute;
            inset:0;
            background: radial-gradient(circle at top right, rgba(59,130,246,.16), transparent 35%);
            pointer-events:none;
        }

        .hero-card-top{
            display:flex;
            align-items:center;
            justify-content:space-between;
            gap:1rem;
            margin-bottom: 1.1rem;
        }

        .hero-card-label{
            color: rgba(255,255,255,.58);
            font-size: .78rem;
            text-transform: uppercase;
            letter-spacing: .14em;
        }

        .hero-card-status{
            display:inline-flex;
            align-items:center;
            gap:.45rem;
            color:#dbeafe;
            font-size:.8rem;
            padding:.42rem .7rem;
            border-radius:999px;
            background: rgba(59,130,246,.12);
            border:1px solid rgba(59,130,246,.22);
        }

        .hero-card-status::before{
            content:'';
            width:8px;
            height:8px;
            border-radius:50%;
            background:#3b82f6;
            box-shadow:0 0 0 6px rgba(59,130,246,.13);
        }

        .hero-contract-grid{
            display:grid;
            grid-template-columns: repeat(2, 1fr);
            gap:.9rem;
        }

        .hero-contract-item{
            padding: 1rem;
            border-radius: 18px;
            background: rgba(255,255,255,.05);
            border: 1px solid rgba(255,255,255,.08);
        }

        .hero-contract-item span{
            display:block;
            font-size:.76rem;
            color: rgba(255,255,255,.54);
            margin-bottom:.35rem;
            letter-spacing:.06em;
            text-transform:uppercase;
        }

        .hero-contract-item strong{
            display:block;
            font-size:.98rem;
            font-weight:600;
            color:#fff;
            line-height:1.45;
        }

        .hero-wave{
            display:block;
            width:100%;
            line-height:0;
            margin-top:-1px;
        }

        /* TRUST BAR */
        .trust-strip-wrap{
            margin-top: -2.8rem;
            position: relative;
            z-index: 4;
        }

        .trust-strip{
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 1rem;
        }

        .trust-strip-inner{
            display:grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1rem;
            padding: 1rem;
            border-radius: 24px;
            border: 1px solid rgba(255,255,255,.55);
            background: rgba(255,255,255,.72);
            backdrop-filter: blur(18px);
            box-shadow: var(--wf-shadow-md);
        }

        .trust-item{
            display:flex;
            align-items:flex-start;
            gap:.9rem;
            padding: 1rem 1.05rem;
            border-radius: 18px;
            background: rgba(255,255,255,.72);
            border: 1px solid rgba(15,23,42,.05);
        }

        .trust-icon{
            width: 46px;
            height: 46px;
            border-radius: 14px;
            display:flex;
            align-items:center;
            justify-content:center;
            background: linear-gradient(180deg, #111827, #1f2937);
            color: var(--wf-gold);
            font-size: 1rem;
            box-shadow: inset 0 1px 0 rgba(255,255,255,.08);
            flex-shrink:0;
        }

        .trust-item strong{
            display:block;
            font-size:.98rem;
            color: var(--wf-ink);
            margin-bottom:.2rem;
        }

        .trust-item span{
            display:block;
            color: var(--wf-muted);
            font-size:.84rem;
            line-height:1.65;
        }

        /* LAYOUT */
        .doc-shell{
            max-width: 1320px;
            margin: 0 auto;
            padding: 3rem 1.25rem 6rem;
        }

        .doc-layout{
            display:grid;
            grid-template-columns: 290px minmax(0, 1fr);
            gap: 2rem;
            align-items:start;
        }

        /* SIDEBAR */
        .doc-sidebar{
            position: sticky;
            top: 2rem;
        }

        .sidebar-card{
            position: relative;
            overflow:hidden;
            background: rgba(255,255,255,.72);
            border: 1px solid rgba(255,255,255,.7);
            border-radius: 26px;
            box-shadow: var(--wf-shadow-sm);
            backdrop-filter: blur(16px);
            padding: 1.25rem;
        }

        .sidebar-card::before{
            content:'';
            position:absolute;
            inset:0 auto auto 0;
            width:100%;
            height:4px;
            background: linear-gradient(90deg, var(--wf-gold), rgba(59,130,246,.24), transparent);
        }

        .sidebar-kicker{
            display:flex;
            align-items:center;
            gap:.6rem;
            margin-bottom: .85rem;
            font-size: .72rem;
            letter-spacing: .14em;
            text-transform: uppercase;
            font-weight: 700;
            color: var(--wf-muted);
        }

        .sidebar-title{
            font-family: var(--wf-serif);
            font-size: 1.5rem;
            line-height: 1.05;
            color: var(--wf-ink);
            margin-bottom: .35rem;
        }

        .sidebar-text{
            font-size: .9rem;
            line-height: 1.7;
            color: var(--wf-muted);
            margin-bottom: 1.2rem;
        }

        .toc{
            list-style:none;
            margin:0;
            padding:0;
            display:grid;
            gap:.35rem;
        }

        .toc a{
            display:flex;
            align-items:flex-start;
            gap:.8rem;
            text-decoration:none;
            border:1px solid transparent;
            border-radius:16px;
            padding:.8rem .9rem;
            color: var(--wf-muted);
            transition: .2s ease;
        }

        .toc a:hover{
            background: rgba(255,255,255,.7);
            border-color: rgba(59,130,246,.18);
            color: var(--wf-ink);
            transform: translateX(3px);
        }

        .toc a.active{
            background: linear-gradient(180deg, rgba(199,165,82,.14), rgba(59,130,246,.05));
            border-color: rgba(59,130,246,.18);
            color: var(--wf-ink);
            box-shadow: inset 0 1px 0 rgba(255,255,255,.5);
        }

        .toc .num{
            min-width: 28px;
            font-family: var(--wf-serif);
            font-size: .94rem;
            color: var(--wf-gold);
            line-height: 1.4;
        }

        .sidebar-meta{
            margin-top: 1.2rem;
            padding: 1rem;
            border-radius: 18px;
            background: linear-gradient(180deg, rgba(13,23,39,.98), rgba(20,33,53,.98));
            color: rgba(255,255,255,.76);
            box-shadow: inset 0 1px 0 rgba(255,255,255,.05);
        }

        .sidebar-meta-label{
            display:block;
            color: rgba(255,255,255,.52);
            font-size: .72rem;
            text-transform: uppercase;
            letter-spacing: .12em;
            margin-bottom: .25rem;
        }

        .sidebar-meta strong{
            color: #fff;
            font-size: .95rem;
        }

        /* MAIN */
        .doc-main{
            min-width:0;
        }

        .overview{
            margin-bottom: 1.4rem;
            padding: 1.15rem;
            border-radius: 28px;
            background: rgba(255,255,255,.68);
            backdrop-filter: blur(14px);
            border: 1px solid rgba(255,255,255,.68);
            box-shadow: var(--wf-shadow-sm);
        }

        .overview-grid{
            display:grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1rem;
        }

        .overview-card{
            position:relative;
            overflow:hidden;
            padding: 1.25rem;
            border-radius: 22px;
            background: linear-gradient(180deg, rgba(255,255,255,.94), rgba(255,255,255,.82));
            border: 1px solid rgba(15,23,42,.06);
            box-shadow: var(--wf-shadow-xs);
            transition: transform .22s ease, box-shadow .22s ease, border-color .22s ease;
        }

        .overview-card:hover{
            transform: translateY(-4px);
            box-shadow: var(--wf-shadow-sm);
            border-color: rgba(59,130,246,.18);
        }

        .overview-icon{
            width: 46px;
            height: 46px;
            border-radius: 14px;
            display:flex;
            align-items:center;
            justify-content:center;
            background: #0f1b28;
            color: #cfe0ff;
            font-size: 1rem;
            margin-bottom: .95rem;
        }

        .overview-card h3{
            font-family: var(--wf-serif);
            font-size: 1.18rem;
            font-weight: 600;
            color: var(--wf-ink);
            margin-bottom: .35rem;
        }

        .overview-card p{
            margin:0;
            color: var(--wf-muted);
            font-size: .86rem;
            line-height: 1.7;
        }

        /* SECTION */
        .doc-section{
            position:relative;
            overflow:hidden;
            margin-bottom: 1.4rem;
            background: rgba(255,255,255,.78);
            border: 1px solid rgba(255,255,255,.82);
            border-radius: 30px;
            box-shadow: var(--wf-shadow-sm);
            backdrop-filter: blur(16px);
            opacity: 0;
            transform: translateY(24px);
            transition: opacity .55s ease, transform .55s ease;
        }

        .doc-section.visible{
            opacity: 1;
            transform: translateY(0);
        }

        .doc-section::before{
            content:'';
            position:absolute;
            inset:0 auto auto 0;
            width:100%;
            height:1px;
            background: linear-gradient(90deg, rgba(59,130,246,.36), rgba(199,165,82,.12), transparent);
            pointer-events:none;
        }

        .section-head{
            display:flex;
            align-items:flex-start;
            gap: 1.15rem;
            padding: 1.6rem 1.75rem 1.3rem;
            border-bottom: 1px solid var(--wf-line);
            background: linear-gradient(180deg, rgba(255,255,255,.5), rgba(255,255,255,0));
        }

        .section-num{
            width: 62px;
            height: 62px;
            border-radius: 18px;
            display:flex;
            align-items:center;
            justify-content:center;
            flex-shrink:0;
            font-family: var(--wf-serif);
            font-size: 1.6rem;
            font-weight: 600;
            color: var(--wf-gold);
            background: linear-gradient(180deg, rgba(199,165,82,.14), rgba(199,165,82,.06));
            border: 1px solid rgba(199,165,82,.18);
            box-shadow: inset 0 1px 0 rgba(255,255,255,.55);
        }

        .section-title-wrap{
            flex:1;
            min-width:0;
        }

        .section-category{
            margin: 0 0 .28rem;
            font-size: .72rem;
            letter-spacing: .15em;
            text-transform: uppercase;
            font-weight: 700;
            color: var(--wf-muted);
        }

        .section-title{
            margin:0;
            font-family: var(--wf-serif);
            font-size: 1.95rem;
            line-height: 1.08;
            letter-spacing: -.025em;
            color: var(--wf-ink);
        }

        .section-icon{
            width: 50px;
            height: 50px;
            border-radius: 16px;
            display:flex;
            align-items:center;
            justify-content:center;
            flex-shrink:0;
            background: linear-gradient(180deg, #111827, #1f2937);
            color: #cfe0ff;
            font-size: 1.05rem;
            box-shadow: inset 0 1px 0 rgba(255,255,255,.06);
        }

        .section-body{
            padding: 1.55rem 1.75rem 1.8rem;
        }

        .section-body p{
            margin: 0 0 1rem;
            font-size: .98rem;
            line-height: 1.9;
            color: rgba(13,19,32,.82);
        }

        .section-body p:last-child{
            margin-bottom:0;
        }

        /* CARDS */
        .cards-2col{
            display:grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .info-card{
            border: 1px solid rgba(15,23,42,.07);
            border-radius: 22px;
            overflow:hidden;
            background: linear-gradient(180deg, rgba(255,255,255,.94), rgba(250,248,244,.95));
            transition: box-shadow .2s, transform .2s, border-color .2s;
        }

        .info-card:hover{
            box-shadow: var(--wf-shadow-sm);
            transform: translateY(-2px);
            border-color: rgba(59,130,246,.18);
        }

        .info-card-head{
            display:flex;
            align-items:center;
            gap:.85rem;
            padding: 1.1rem 1.25rem .9rem;
            background: rgba(255,255,255,.86);
            border-bottom: 1px solid var(--wf-line);
        }

        .info-card-icon{
            width: 38px;
            height: 38px;
            border-radius: 12px;
            background: rgba(15,23,42,.06);
            display:flex;
            align-items:center;
            justify-content:center;
            color: var(--wf-ink);
            font-size: 1rem;
            flex-shrink:0;
        }

        .info-card-title{
            font-family: var(--wf-serif);
            font-size: 1.12rem;
            font-weight: 600;
            color: var(--wf-ink);
        }

        .info-card-body{
            padding: 1rem 1.25rem 1.2rem;
            font-size: .92rem;
            color: rgba(13,19,32,.82);
            line-height: 1.8;
        }

        /* DATA LIST */
        .data-list{
            list-style:none;
            margin:0;
            padding:0;
        }

        .data-list li{
            display:flex;
            gap:.75rem;
            align-items:flex-start;
            padding:.8rem 0;
            border-top: 1px solid var(--wf-line);
        }

        .data-list li:first-child{
            border-top:none;
            padding-top:0;
        }

        .data-list-dot{
            width:7px;
            height:7px;
            border-radius:50%;
            background: var(--wf-gold);
            flex-shrink:0;
            margin-top:.42rem;
        }

        .data-list-content{
            flex:1;
        }

        .data-label{
            display:block;
            font-size:.7rem;
            font-weight:700;
            letter-spacing:.10em;
            text-transform:uppercase;
            color: var(--wf-muted);
            margin-bottom:.18rem;
        }

        .data-value{
            font-size:.93rem;
            color: var(--wf-ink);
            font-weight:500;
            line-height:1.5;
        }

        .data-value a{
            color: #9a731f;
            text-decoration:none;
        }

        .data-value a:hover{
            text-decoration:underline;
        }

        /* LINK CARDS */
        .link-cards{
            display:grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
        }

        .link-card{
            display:flex;
            align-items:flex-start;
            gap:.9rem;
            text-decoration:none;
            border: 1px solid rgba(15,23,42,.07);
            border-radius: 22px;
            padding: 1.15rem 1.1rem;
            background: linear-gradient(180deg, rgba(255,255,255,.94), rgba(250,248,244,.95));
            color: inherit;
            transition: transform .2s, box-shadow .2s, border-color .2s;
        }

        .link-card:hover{
            transform: translateY(-3px);
            box-shadow: var(--wf-shadow-sm);
            border-color: rgba(59,130,246,.18);
            text-decoration:none;
            color: inherit;
        }

        .link-card-icon{
            width: 42px;
            height: 42px;
            border-radius: 13px;
            display:flex;
            align-items:center;
            justify-content:center;
            background: #0f1b28;
            color: #cfe0ff;
            font-size: 1rem;
            flex-shrink:0;
        }

        .link-card-body strong{
            display:block;
            font-family: var(--wf-serif);
            font-size: 1.05rem;
            font-weight: 600;
            color: var(--wf-ink);
            margin-bottom:.25rem;
        }

        .link-card-body span{
            font-size:.82rem;
            color: var(--wf-muted);
            line-height:1.55;
        }

        /* CALLOUTS */
        .callout{
            display:flex;
            gap:1rem;
            align-items:flex-start;
            margin-top: 1.25rem;
            padding: 1.05rem 1.1rem;
            border-radius: 20px;
            border:1px solid transparent;
        }

        .callout-icon{
            width: 38px;
            height: 38px;
            border-radius: 12px;
            display:flex;
            align-items:center;
            justify-content:center;
            flex-shrink:0;
            font-size:.95rem;
        }

        .callout-body{
            flex:1;
        }

        .callout-body p{
            margin:0;
            font-size:.92rem;
            line-height:1.8;
            color: rgba(13,19,32,.82);
        }

        .callout-body strong{
            color: var(--wf-ink);
        }

        .callout-body p a{
            color:#9a731f;
            text-decoration:none;
        }

        .callout-body p a:hover{
            text-decoration:underline;
        }

        .callout-info{
            background: rgba(59,130,246,.06);
            border-color: rgba(59,130,246,.12);
        }

        .callout-info .callout-icon{
            color: #3b82f6;
            background: rgba(59,130,246,.11);
        }

        .callout-danger{
            background: rgba(220,38,38,.05);
            border-color: rgba(220,38,38,.12);
        }

        .callout-danger .callout-icon{
            color: #dc2626;
            background: rgba(220,38,38,.10);
        }

        .callout-gold{
            background: rgba(199,165,82,.08);
            border-color: rgba(199,165,82,.16);
        }

        .callout-gold .callout-icon{
            color: #a57a18;
            background: rgba(199,165,82,.15);
        }

        /* FOOTER */
        .doc-footer{
            text-align:center;
            padding: 1.8rem 1rem .4rem;
            color: var(--wf-muted);
            font-size: .88rem;
        }

        .doc-footer a{
            color: #9a731f;
            text-decoration:none;
            transition: color .2s ease;
        }

        .doc-footer a:hover{
            color: var(--wf-ink);
        }

        /* RESPONSIVE */
        @media (max-width: 1199px){
            .hero-grid{
                grid-template-columns: 1fr;
                gap: 1.6rem;
            }

            .hero-card{
                max-width: 520px;
            }

            .trust-strip-inner,
            .overview-grid{
                grid-template-columns: repeat(2, 1fr);
            }

            .doc-layout{
                grid-template-columns: 1fr;
            }

            .doc-sidebar{
                position: static;
            }
        }

        @media (max-width: 991px){
            .cards-2col,
            .link-cards{
                grid-template-columns: 1fr;
            }

            .toc{
                grid-template-columns: repeat(2, minmax(0,1fr));
            }
        }

        @media (max-width: 767px){
            .legal-hero{
                padding: 4.6rem 0 5.5rem;
            }

            .hero-title{
                font-size: 2.9rem;
            }

            .hero-lead{
                font-size: .98rem;
                line-height: 1.85;
            }

            .hero-pills{
                display:none;
            }

            .hero-contract-grid,
            .trust-strip-inner,
            .overview-grid,
            .toc{
                grid-template-columns: 1fr;
            }

            .section-head,
            .section-body{
                padding-left: 1.15rem;
                padding-right: 1.15rem;
            }

            .section-head{
                gap:.9rem;
            }

            .section-title{
                font-size: 1.55rem;
            }

            .section-num{
                width: 54px;
                height: 54px;
                font-size: 1.35rem;
            }

            .section-icon{
                display:none;
            }

            .overview{
                padding:.9rem;
            }

            .sidebar-card{
                padding: 1rem;
            }
        }
    </style>
{% endblock %}

