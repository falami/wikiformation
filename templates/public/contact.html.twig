{# templates/public/contact.html.twig #}
{% extends 'base_public.html.twig' %}

{% block title %}{{ 'contact.meta.title'|trans }}{% endblock %}
{% block meta_description %}{{ 'contact.meta.description'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">

    <style>
        :root{
            --bg: #07111d;
            --bg-2: #0d1726;
            --bg-3: #101f33;
            --surface: rgba(255,255,255,.72);
            --surface-strong: rgba(255,255,255,.88);
            --surface-dark: rgba(8,17,30,.78);

            --text: #0f1724;
            --text-soft: rgba(15,23,36,.70);
            --text-muted: rgba(15,23,36,.52);

            --white: #ffffff;
            --line: rgba(15,23,36,.08);
            --line-strong: rgba(255,255,255,.10);

            --gold: #d6b25e;
            --gold-2: #f0ddb0;
            --gold-soft: rgba(214,178,94,.14);

            --violet: #7c3aed;
            --cyan: #54c6eb;
            --success: #16a34a;
            --danger: #dc2626;

            --shadow-xs: 0 4px 14px rgba(7,17,29,.06);
            --shadow-sm: 0 12px 30px rgba(7,17,29,.08);
            --shadow-md: 0 22px 60px rgba(7,17,29,.12);
            --shadow-xl: 0 40px 100px rgba(7,17,29,.18);

            --radius-sm: 16px;
            --radius-md: 22px;
            --radius-lg: 30px;
            --radius-xl: 38px;

            --serif: 'Cormorant Garamond', serif;
            --sans: 'Inter', sans-serif;
        }

        * { box-sizing: border-box; }
        html { scroll-behavior: smooth; }


        .contact-page{
            position:relative;
            min-height:100vh;
        }

        /* ================= HERO ================= */
        .contact-hero{
            position:relative;
            overflow:hidden;
            background:
                radial-gradient(circle at 15% 20%, rgba(124,58,237,.18), transparent 22%),
                radial-gradient(circle at 85% 25%, rgba(214,178,94,.16), transparent 20%),
                radial-gradient(circle at 50% 120%, rgba(84,198,235,.10), transparent 30%),
                linear-gradient(135deg, #07111d 0%, #0c1827 45%, #112238 100%);
            padding: 5rem 0 11rem;
        }

        .contact-hero::before{
            content:"";
            position:absolute;
            inset:0;
            background:
                linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
            background-size: 64px 64px;
            mask-image: linear-gradient(to bottom, rgba(0,0,0,.9), rgba(0,0,0,.25));
            pointer-events:none;
        }

        .hero-glow-a,
        .hero-glow-b,
        .hero-glow-c{
            position:absolute;
            border-radius:50%;
            filter: blur(18px);
            pointer-events:none;
        }

        .hero-glow-a{
            width:420px;
            height:420px;
            left:-120px;
            top:-90px;
            background:radial-gradient(circle, rgba(124,58,237,.22) 0%, transparent 68%);
        }

        .hero-glow-b{
            width:520px;
            height:520px;
            right:-140px;
            top:-40px;
            background:radial-gradient(circle, rgba(214,178,94,.20) 0%, transparent 68%);
        }

        .hero-glow-c{
            width:380px;
            height:380px;
            left:50%;
            bottom:-180px;
            transform:translateX(-50%);
            background:radial-gradient(circle, rgba(84,198,235,.16) 0%, transparent 70%);
        }

        .hero-inner{
            position:relative;
            z-index:2;
            max-width: 980px;
            margin: 0 auto;
            text-align:center;
            padding: 0 1.25rem;
        }

        .hero-badge{
            display:inline-flex;
            align-items:center;
            gap:.65rem;
            padding:.7rem 1.1rem;
            border-radius:999px;
            color: var(--gold-2);
            background: rgba(255,255,255,.05);
            border:1px solid rgba(255,255,255,.12);
            box-shadow: inset 0 1px 0 rgba(255,255,255,.08);
            font-size:.78rem;
            font-weight:600;
            letter-spacing:.12em;
            text-transform:uppercase;
            backdrop-filter: blur(10px);
            margin-bottom: 1.5rem;
        }

        .hero-badge i{
            color: var(--gold);
            font-size:.95rem;
        }

        .hero-title{
            font-family: var(--serif);
            font-size: clamp(3.2rem, 7vw, 6rem);
            line-height: .98;
            font-weight: 500;
            letter-spacing: -.03em;
            color: #fff;
            margin: 0 0 1.25rem;
        }

        .hero-title .accent{
            color: var(--gold-2);
            font-style: italic;
        }

        .hero-subtitle{
            max-width: 760px;
            margin: 0 auto 2rem;
            color: rgba(255,255,255,.72);
            font-size: 1.08rem;
            line-height: 1.9;
            font-weight: 400;
        }

        .hero-kpis{
            display:flex;
            justify-content:center;
            flex-wrap:wrap;
            gap:.9rem;
            margin-top: 2.1rem;
        }

        .hero-kpi{
            display:inline-flex;
            align-items:center;
            gap:.65rem;
            padding:.8rem 1rem;
            border-radius:999px;
            background: rgba(255,255,255,.06);
            border:1px solid rgba(255,255,255,.10);
            color: rgba(255,255,255,.86);
            font-size:.9rem;
            backdrop-filter: blur(12px);
        }

        .hero-kpi i{
            color: var(--gold);
        }

        .hero-divider{
            position:absolute;
            left:0;
            right:0;
            bottom:0;
            z-index:1;
            line-height:0;
        }

        /* ================= CONTENT ================= */
        .contact-shell{
            position:relative;
            z-index:3;
            max-width: 1320px;
            margin: -110px auto 0;
        }

        .contact-grid{
            display:grid;
            grid-template-columns: minmax(0, 1.25fr) minmax(320px, .75fr);
            gap: 1.5rem;
            align-items:start;
        }

        /* ================= MAIN CARD ================= */
        .main-card{
            position:relative;
            overflow:hidden;
            border-radius: var(--radius-xl);
            background: rgba(255,255,255,.76);
            border: 1px solid rgba(255,255,255,.55);
            box-shadow: var(--shadow-xl);
            backdrop-filter: blur(20px);
        }

        .main-card::before{
            content:"";
            position:absolute;
            inset:0;
            background:
                linear-gradient(135deg, rgba(255,255,255,.45), transparent 36%),
                radial-gradient(circle at top right, rgba(214,178,94,.10), transparent 22%);
            pointer-events:none;
        }

        .main-card-head{
            position:relative;
            z-index:2;
            padding: 2.15rem 2.15rem 1.35rem;
            border-bottom:1px solid var(--line);
            display:flex;
            align-items:flex-start;
            justify-content:space-between;
            gap:1rem;
            flex-wrap:wrap;
        }

        .main-head-left{
            display:flex;
            gap:1rem;
            align-items:flex-start;
        }

        .main-icon{
            width:58px;
            height:58px;
            border-radius:18px;
            background:
                linear-gradient(135deg, #0d1726 0%, #17283f 100%);
            color: var(--gold);
            display:flex;
            align-items:center;
            justify-content:center;
            font-size:1.2rem;
            box-shadow:
                inset 0 1px 0 rgba(255,255,255,.08),
                0 12px 24px rgba(7,17,29,.18);
            flex-shrink:0;
        }

        .main-title{
            margin:0 0 .35rem;
            font-family: var(--serif);
            font-size: 2rem;
            font-weight: 600;
            line-height: 1.02;
            letter-spacing: -.02em;
            color: var(--text);
        }

        .main-subtitle{
            margin:0;
            color: var(--text-soft);
            line-height: 1.75;
            font-size: .96rem;
            max-width: 680px;
        }

        .response-chip{
            display:inline-flex;
            align-items:center;
            gap:.55rem;
            padding:.8rem 1rem;
            border-radius:999px;
            background: rgba(214,178,94,.10);
            border: 1px solid rgba(214,178,94,.20);
            color:#72561d;
            font-size:.84rem;
            font-weight:600;
            white-space:nowrap;
        }

        .main-card-body{
            position:relative;
            z-index:2;
            padding: 2rem 2.15rem 2.2rem;
        }

        .flash-wrap{
            margin-bottom: 1.35rem;
        }

        /* ================= FORM ================= */
        .form-section-label{
            display:flex;
            align-items:center;
            gap:.55rem;
            margin-bottom: 1rem;
            font-size: .8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .12em;
            color: var(--text-muted);
        }

        .form-grid{
            display:grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .field{
            position:relative;
        }

        .field-icon{
            position:absolute;
            left:1rem;
            top:1.1rem;
            color: rgba(15,23,36,.42);
            font-size: .95rem;
            z-index:5;
            pointer-events:none;
        }

        .field-icon.center{
            top:50%;
            transform:translateY(-50%);
        }

        .field-card{
            position:relative;
            border-radius: 20px;
        }

        .form-floating > .form-control,
        .form-floating > .form-select{
            min-height: 62px;
            border-radius: 20px;
            border: 1px solid rgba(15,23,36,.10);
            background: rgba(255,255,255,.70);
            box-shadow: inset 0 1px 0 rgba(255,255,255,.45);
            color: var(--text);
            font-size: .95rem;
            padding-left: 2.9rem;
            transition: .22s ease;
        }

        .form-floating > textarea.form-control{
            min-height: 190px;
            height: 190px;
            resize: vertical;
            padding-top: 1.45rem;
            padding-left: 2.9rem;
        }

        .form-floating > label{
            left: 2.9rem;
            color: #fff;
            font-size: .88rem;
        }

        .form-floating > .form-control:focus,
        .form-floating > .form-select:focus{
            border-color: rgba(214,178,94,.7);
            background: rgba(255,255,255,.96);
            box-shadow:
                0 0 0 4px rgba(214,178,94,.12),
                0 18px 36px rgba(214,178,94,.08);
        }

        .form-errors,
        .invalid-feedback,
        .form-error{
            margin-top: .45rem;
            padding-left: .15rem;
            color: var(--danger);
            font-size: .82rem;
        }

        .textarea-wrap .field-icon{
            top: 1.15rem;
            transform:none;
        }

        .meta-row{
            display:grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin: 1.2rem 0 0;
        }

        .mini-panel{
            border-radius: 20px;
            background: linear-gradient(180deg, rgba(255,255,255,.74), rgba(248,250,252,.86));
            border:1px solid rgba(15,23,36,.08);
            padding: 1rem 1rem;
            box-shadow: var(--shadow-xs);
        }

        .mini-panel-title{
            display:flex;
            align-items:center;
            gap:.55rem;
            font-size:.82rem;
            font-weight:700;
            color: var(--text);
            margin-bottom:.35rem;
        }

        .mini-panel-text{
            font-size:.86rem;
            color: var(--text-soft);
            line-height:1.65;
            margin:0;
        }

        .hp-row{
            position:absolute;
            left:-10000px;
            width:1px;
            height:1px;
            overflow:hidden;
        }

        .submit-area{
            display:flex;
            align-items:center;
            justify-content:space-between;
            gap:1rem;
            flex-wrap:wrap;
            margin-top: 1.6rem;
            padding-top: 1.5rem;
            border-top:1px solid var(--line);
        }

        .submit-left{
            display:flex;
            align-items:center;
            gap:.9rem;
            flex-wrap:wrap;
        }

        .btn-ultra{
            position:relative;
            overflow:hidden;
            display:inline-flex;
            align-items:center;
            justify-content:center;
            gap:.7rem;
            min-height:56px;
            padding: 0 1.45rem;
            border:none;
            border-radius:999px;
            color:#fff;
            font-weight:700;
            font-size:.94rem;
            letter-spacing:.01em;
            background:
                linear-gradient(135deg, #091220 0%, #12233b 48%, #1a3150 100%);
            box-shadow:
                inset 0 1px 0 rgba(255,255,255,.10),
                0 20px 35px rgba(9,18,32,.22);
            transition: transform .18s ease, box-shadow .22s ease, opacity .2s ease;
        }

        .btn-ultra::before{
            content:"";
            position:absolute;
            inset:0;
            background: linear-gradient(135deg, rgba(214,178,94,.32), transparent 55%);
            opacity:.95;
        }

        .btn-ultra > *{
            position:relative;
            z-index:2;
        }

        .btn-ultra:hover{
            transform: translateY(-2px);
            box-shadow:
                inset 0 1px 0 rgba(255,255,255,.12),
                0 26px 42px rgba(9,18,32,.28);
        }

        .btn-ultra:disabled{
            opacity:.7;
            cursor:not-allowed;
            transform:none;
        }

        .privacy-note{
            display:inline-flex;
            align-items:center;
            gap:.5rem;
            color: var(--text-soft);
            font-size: .85rem;
        }

        .privacy-note i{
            color: var(--success);
        }

        /* ================= SIDEBAR ================= */
        .side-stack{
            display:grid;
            gap:1.2rem;
            position:sticky;
            top:1.5rem;
        }

        .side-card{
            position:relative;
            overflow:hidden;
            border-radius: var(--radius-lg);
            background:
                linear-gradient(180deg, rgba(8,17,30,.94), rgba(12,24,40,.96));
            color:#fff;
            box-shadow: var(--shadow-md);
            border:1px solid rgba(255,255,255,.06);
        }

        .side-card::before{
            content:"";
            position:absolute;
            inset:0;
            background:
                radial-gradient(circle at top right, rgba(214,178,94,.14), transparent 24%),
                linear-gradient(180deg, rgba(255,255,255,.03), transparent);
            pointer-events:none;
        }

        .side-card-body{
            position:relative;
            z-index:2;
            padding: 1.7rem;
        }

        .side-title{
            display:flex;
            align-items:center;
            gap:.65rem;
            margin:0 0 1.2rem;
            font-family: var(--serif);
            font-size: 1.65rem;
            font-weight: 600;
            color:#fff;
            letter-spacing:-.02em;
        }

        .side-title i{
            color: var(--gold);
        }

        .contact-points{
            display:grid;
            gap:.9rem;
        }

        .contact-point{
            display:flex;
            gap:.8rem;
            align-items:flex-start;
            padding:.95rem;
            border-radius:18px;
            background: rgba(255,255,255,.04);
            border:1px solid rgba(255,255,255,.06);
        }

        .contact-point-icon{
            width:42px;
            height:42px;
            border-radius:14px;
            display:flex;
            align-items:center;
            justify-content:center;
            flex-shrink:0;
            color: var(--gold);
            background: rgba(255,255,255,.06);
            border:1px solid rgba(255,255,255,.08);
        }

        .contact-point-label{
            margin:0 0 .15rem;
            font-size:.72rem;
            font-weight:700;
            letter-spacing:.12em;
            text-transform:uppercase;
            color: rgba(255,255,255,.42);
        }

        .contact-point-value{
            margin:0;
            color: rgba(255,255,255,.82);
            line-height:1.65;
            font-size:.92rem;
        }

        .contact-point-value a{
            color: rgba(255,255,255,.88);
            text-decoration:none;
        }

        .contact-point-value a:hover{
            color: var(--gold-2);
        }

        .feature-list{
            list-style:none;
            margin:0;
            padding:0;
            display:grid;
            gap:.75rem;
        }

        .feature-list li{
            display:flex;
            gap:.7rem;
            align-items:flex-start;
            color: rgba(255,255,255,.74);
            line-height:1.65;
            font-size:.9rem;
        }

        .feature-list li i{
            color: var(--gold);
            margin-top:.15rem;
        }

        .side-chips{
            display:flex;
            flex-wrap:wrap;
            gap:.6rem;
            margin-top: 1rem;
        }

        .side-chip{
            display:inline-flex;
            align-items:center;
            gap:.45rem;
            padding:.5rem .85rem;
            border-radius:999px;
            background: rgba(255,255,255,.06);
            border:1px solid rgba(255,255,255,.09);
            color: rgba(255,255,255,.78);
            font-size:.8rem;
        }

        .side-chip i{
            color: var(--gold);
        }

        /* ================= TRUST SECTION ================= */
        .trust-band{
            margin-top: 1.6rem;
            border-radius: var(--radius-xl);
            background: linear-gradient(180deg, rgba(255,255,255,.76), rgba(255,255,255,.64));
            border:1px solid rgba(255,255,255,.62);
            backdrop-filter: blur(18px);
            box-shadow: var(--shadow-sm);
            padding: 1.15rem 1.25rem;
        }

        .trust-grid{
            display:grid;
            grid-template-columns: repeat(3, 1fr);
            gap:1rem;
        }

        .trust-item{
            display:flex;
            align-items:flex-start;
            gap:.75rem;
            padding:.7rem;
        }

        .trust-icon{
            width:42px;
            height:42px;
            border-radius:14px;
            display:flex;
            align-items:center;
            justify-content:center;
            flex-shrink:0;
            background: var(--gold-soft);
            color: #8a6826;
        }

        .trust-title{
            margin:0 0 .2rem;
            font-size:.92rem;
            font-weight:700;
            color: var(--text);
        }

        .trust-text{
            margin:0;
            font-size:.84rem;
            line-height:1.6;
            color: var(--text-soft);
        }

        .bottom-note{
            display:flex;
            align-items:center;
            justify-content:center;
            gap:.55rem;
            text-align:center;
            margin-top: 1.8rem;
            color: var(--text-soft);
            font-size: .88rem;
        }

        .bottom-note i{
            color: #8a6826;
        }

        @media (max-width: 1199px){
            .contact-grid{
                grid-template-columns: 1fr 360px;
            }
        }

        @media (max-width: 991px){
            .contact-shell{
                margin-top:-75px;
            }

            .contact-grid{
                grid-template-columns: 1fr;
            }

            .side-stack{
                position:static;
            }

            .trust-grid{
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 767px){
            .contact-hero{
                padding: 5rem 0 8.5rem;
            }

            .hero-title{
                font-size: 2.8rem;
            }

            .hero-subtitle{
                font-size: .98rem;
                line-height: 1.75;
            }

            .contact-shell{
                padding: 0 1rem 4rem;
                margin-top:-55px;
            }

            .main-card-head,
            .main-card-body,
            .side-card-body{
                padding-left:1.25rem;
                padding-right:1.25rem;
            }

            .main-card-head{
                padding-top:1.4rem;
                padding-bottom:1.2rem;
            }

            .main-card-body{
                padding-top:1.4rem;
                padding-bottom:1.5rem;
            }

            .main-title{
                font-size:1.6rem;
            }

            .form-grid,
            .meta-row{
                grid-template-columns: 1fr;
            }

            .submit-area{
                align-items:flex-start;
            }

            .hero-kpis{
                gap:.65rem;
            }

            .hero-kpi{
                font-size:.82rem;
            }
        }

    </style>
{% endblock %}

{% block body %}
    {% include 'header_public.html.twig' %}

    <main class="contact-page">

        <section class="contact-hero">
            <div class="hero-glow-a"></div>
            <div class="hero-glow-b"></div>
            <div class="hero-glow-c"></div>

            <div class="hero-inner">
                <span class="hero-badge">
                    <i class="bi bi-stars"></i>
                    {{ 'contact.hero.chip'|trans }}
                </span>

                <h1 class="hero-title">
                    {{ 'contact.hero.title'|trans|raw|replace({'WikiFormation': '<span class="accent">WikiFormation</span>'}) }}
                </h1>

                <p class="hero-subtitle">
                    {{ 'contact.hero.subtitle'|trans }}
                </p>

                <div class="hero-kpis">
                    <span class="hero-kpi">
                        <i class="bi bi-lightning-charge"></i>
                        {{ 'contact.chips.fast'|trans }}
                    </span>
                    <span class="hero-kpi">
                        <i class="bi bi-shield-check"></i>
                        {{ 'contact.form.privacy'|trans }}
                    </span>
                    <span class="hero-kpi">
                        <i class="bi bi-headset"></i>
                        {{ 'contact.chips.support'|trans }}
                    </span>
                </div>
            </div>

            <div class="hero-divider">
                <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" style="display:block;width:100%;height:auto;">
                    <path d="M0 42L60 49C120 56 240 70 360 74C480 77 600 70 720 60C840 49 960 35 1080 33C1200 30 1320 39 1380 44L1440 49V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0V42Z" fill="#f7f9fc"/>
                </svg>
            </div>
        </section>

        <div class="contact-shell">
            <div class="contact-grid">

                <section class="main-card">
                    <div class="main-card-head">
                        <div class="main-head-left">
                            <div class="main-icon">
                                <i class="bi bi-send"></i>
                            </div>

                            <div>
                                <h2 class="main-title">{{ 'contact.form.title'|trans }}</h2>
                                <p class="main-subtitle">{{ 'contact.form.subtitle'|trans }}</p>
                            </div>
                        </div>

                        <span class="response-chip">
                            <i class="bi bi-clock-history"></i>
                            {{ 'contact.info.hours'|trans }}
                        </span>
                    </div>

                    <div class="main-card-body">
                        <div class="flash-wrap">
                            {% include 'flagMessage.html.twig' %}
                        </div>

                        {{ form_start(form, {
                            attr: {
                                novalidate: 'novalidate',
                                name: 'contact',
                                class: 'needs-validation'
                            }
                        }) }}

