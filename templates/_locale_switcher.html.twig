{# templates/_locale_switcher.html.twig #}
{# — Utilisation: place ce partial DANS un <li class="nav-item dropdown"> de ta navbar — #}

{% set currentRoute  = app.request.attributes.get('_route') ?: 'app_public' %}
{% set currentParams = app.request.attributes.get('_route_params') ?? {} %}
{% set currentLocale = app.request.locale|default('fr') %}

{# Libellés & drapeaux #}
{% set locales = {
  'fr': {'name':'Français', 'flag':'🇫🇷', 'title':'Français'},
  'en': {'name':'English',  'flag':'🇬🇧', 'title':'English'}
} %}

{# Liste des locales disponibles (ordre) #}
{% set order = ['fr','en'] %}

{# Bouton dropdown (affiche la locale courante) #}
<a class="nav-link dropdown-toggle d-flex align-items-center gap-1"
   href="#"
   id="langDrop"
   role="button"
   data-bs-toggle="dropdown"
   aria-expanded="false"
   aria-label="Language selector">
  <i class="bi bi-translate" aria-hidden="true"></i>
  <span class="d-none d-md-inline">
    {{ locales[currentLocale].flag }} {{ currentLocale|upper }}
  </span>
  <span class="d-inline d-md-none">{{ currentLocale|upper }}</span>
</a>

{# Menu #}
<ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark shadow" aria-labelledby="langDrop">
  {% for code in order %}
    {% set params = currentParams|merge({'_locale': code}) %}
    {% set url = path(currentRoute, params) %}
    <li>
      <a class="dropdown-item d-flex align-items-center gap-2 {{ currentLocale == code ? 'active' : '' }}"
         hreflang="{{ code }}"
         rel="alternate"
         aria-current="{{ currentLocale == code ? 'true' : 'false' }}"
         href="{{ url }}">
        <span style="font-size:1.05rem">{{ locales[code].flag }}</span>
        <span>{{ locales[code].name }}</span>
        {% if currentLocale == code %}
          <i class="bi bi-check2 ms-auto" aria-hidden="true"></i>
        {% endif %}
      </a>
    </li>
  {% endfor %}
</ul>
