{# templates/stagiaire/_actions_session.html.twig #}
<div class="d-flex justify-content-end gap-1">
  <a class="btn btn-sm btn-outline-primary"
     href="{{ path('app_stagiaire_session_show', { entite: entite.id, id: s.id }) }}"
     title="Détails de la session">
    <i class="bi bi-folder2-open"></i> Ouvrir
  </a>

  {# Ouverture modale signature stagiaire pour la date du jour #}
  <button type="button"
          class="btn btn-sm btn-outline-success js-open-sign"
          data-session-id="{{ s.id }}"
          title="Signer ma présence">
    <i class="bi bi-pencil-square"></i> Signer
  </button>
</div>