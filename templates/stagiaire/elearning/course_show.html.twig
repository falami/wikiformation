  <script>
  // Scroll doux vers l’ancre + offset (évite que le titre colle sous un header)
  const SCROLL_OFFSET = 96;

  function smoothScrollTo(id){
    const el = document.getElementById(id);
    if(!el) return;
    const y = el.getBoundingClientRect().top + window.scrollY - SCROLL_OFFSET;
    window.scrollTo({ top: y, behavior: 'smooth' });
  }


  // Intercepte les liens du sommaire (data-scrollto)
  document.addEventListener('click', (e) => {
    const a = e.target.closest('a[data-scrollto]');
    if(!a) return;
    const id = a.getAttribute('data-scrollto');
    if(!id) return;
    e.preventDefault();
    history.replaceState(null, '', '#' + id);
    smoothScrollTo(id);
  });

  // Ouvre l'accordéon correspondant au hash #node-XX au chargement
  function openAccordionForHash(){
    const hash = (location.hash || '').replace('#','');
    if(!hash.startsWith('node-')) return;
    const nodeId = hash.replace('node-','');
    // Cherche le bouton d'accordéon qui pointe vers toc-coll-ID du chapitre parent
    // Ici on utilise une astuce: on ouvre tous les accordéons qui contiennent un lien vers ce node
    const link = document.querySelector('.toc-acc a[data-scrollto="'+hash+'"]');
    if(!link) return;
    const collapse = link.closest('.accordion-collapse');
    if(!collapse) return;

    // Bootstrap 5 collapse
    const bs = bootstrap.Collapse.getOrCreateInstance(collapse, { toggle: false });
    bs.show();
  }
  document.addEventListener('DOMContentLoaded', openAccordionForHash);
  window.addEventListener('hashchange', openAccordionForHash);





  // ✅ Le chevron ne doit jamais déclencher un scroll (au cas où clic/drag)
  document.addEventListener('click', (e) => {
    const tgl = e.target.closest('.toc-toggle');
    if (!tgl) return;
    e.stopPropagation();
  }, true);

  // ✅ Sync classe .collapsed sur le chevron selon l'état du collapse (Bootstrap events)
  document.querySelectorAll('.toc-acc .accordion-collapse').forEach((collapseEl) => {
    const btn = document.querySelector('[data-bs-target="#' + collapseEl.id + '"]');
    if(!btn) return;

    collapseEl.addEventListener('show.bs.collapse', () => btn.classList.remove('collapsed'));
    collapseEl.addEventListener('hide.bs.collapse', () => btn.classList.add('collapsed'));
  });

</script>



<script>
  // ===== ACTIVE LINK STABLE (scroll position based) =====
  const tocLinks = Array.from(document.querySelectorAll('.toc-acc a[data-scrollto]'));
  const nodes = tocLinks
    .map(a => {
      const id = a.getAttribute('data-scrollto');
      return { id, el: document.getElementById(id), link: a };
    })
    .filter(x => x.el);

  const OFFSET = 96; // doit matcher ton smoothScrollTo (-84). Mets 96 pour être large.

  function setActive(id){
    tocLinks.forEach(a => a.classList.toggle('active', a.getAttribute('data-scrollto') === id));

    // Ouvre l'accordéon si besoin
    const activeLink = tocLinks.find(a => a.getAttribute('data-scrollto') === id);
    const collapse = activeLink?.closest('.accordion-collapse');
    if(collapse){
      const bs = bootstrap.Collapse.getOrCreateInstance(collapse, { toggle: false });
      bs.show();
    }
  }

  function getCurrentNodeId(){
    // Le node "actif" = le dernier node dont le top est <= OFFSET
    const y = window.scrollY + OFFSET;

    let current = nodes[0]?.id || null;
    for(const n of nodes){
      const top = n.el.getBoundingClientRect().top + window.scrollY;
      if(top <= y) current = n.id;
      else break; // comme ils sont dans l'ordre DOM, on peut break
    }
    return current;
  }

  // throttle via requestAnimationFrame
  let ticking = false;
  function onScroll(){
    if(ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      ticking = false;
      const id = getCurrentNodeId();
      if(id) setActive(id);
    });
  }

  // Initial + events
  document.addEventListener('DOMContentLoaded', () => {
    onScroll();
  });
  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', onScroll);

  // Quand on clique dans le sommaire, on force l'active immédiatement
  document.addEventListener('click', (e) => {
    const a = e.target.closest('a[data-scrollto]');
    if(!a) return;
    const id = a.getAttribute('data-scrollto');
    if(id) setActive(id);
  });
</script>



<script>
