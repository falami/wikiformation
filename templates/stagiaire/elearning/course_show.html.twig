</script>

<script>
  // ✅ Correction instantanée + bouton "Réessayer"
  document.addEventListener('change', (e) => {
    const input = e.target.closest('.quiz-panel input[type="radio"]');
    if(!input) return;

    const choice = input.closest('.quiz-choice');
    if(!choice) return;

    const qCard = choice.closest('.quiz-q');
    if(!qCard) return;

    // Empêche de répondre 2 fois tant qu'on n'a pas "Réessayer"
    if(qCard.dataset.answered === '1') return;

    const allChoices = Array.from(qCard.querySelectorAll('.quiz-choice'));
    const fb = qCard.querySelector('.quiz-feedback');
    const retryBtn = qCard.querySelector('[data-quiz-retry]');

    // Vérifie si le choix cliqué est correct
    const pickedCorrect = choice.getAttribute('data-correct') === '1';

    if(pickedCorrect){
      choice.classList.add('is-correct');
      if(fb){
        fb.classList.remove('d-none', 'ko');
        fb.classList.add('ok');
        fb.innerHTML = '✅ Bonne réponse';
      }
    }else{
      choice.classList.add('is-wrong');

      // Met en évidence la bonne réponse
      const good = allChoices.find(el => el.getAttribute('data-correct') === '1');
      if(good) good.classList.add('is-correct');

      if(fb){
        fb.classList.remove('d-none', 'ok');
        fb.classList.add('ko');
        fb.innerHTML = '❌ Mauvaise réponse';
      }
    }

    // Désactive la question après réponse
    allChoices.forEach(el => el.classList.add('is-disabled'));
    qCard.dataset.answered = '1';

    // Affiche "Réessayer"
    if(retryBtn) retryBtn.classList.remove('d-none');
  });

  // ✅ Réessayer : reset une question
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('[data-quiz-retry]');
    if(!btn) return;

    const qCard = btn.closest('.quiz-q');
    if(!qCard) return;

    const allChoices = Array.from(qCard.querySelectorAll('.quiz-choice'));
    const inputs = Array.from(qCard.querySelectorAll('input[type="radio"]'));
    const fb = qCard.querySelector('.quiz-feedback');

    // reset radios
    inputs.forEach(i => { i.checked = false; });

    // reset styles
    allChoices.forEach(el => {
      el.classList.remove('is-correct', 'is-wrong', 'is-disabled');
    });

    // reset feedback
    if(fb){
      fb.classList.add('d-none');
      fb.classList.remove('ok', 'ko');
      fb.innerHTML = '';
    }

    // reset state
    delete qCard.dataset.answered;

    // cache le bouton
    btn.classList.add('d-none');
  });
</script>


<script>
document.addEventListener('click', async (e) => {
  const btn = e.target.closest('[data-node-toggle]');
  if(!btn) return;

  const nodeId = btn.getAttribute('data-node-toggle');
  const url = btn.getAttribute('data-url');
  const token = btn.getAttribute('data-token');

  btn.disabled = true;

  try {
    const body = new URLSearchParams();
    body.set('_token', token);

    const res = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
      body: body.toString()
    });

    const json = await res.json();
    if(!json.ok) throw new Error(json.message || 'Erreur');

    // Update bouton + chip statut
    const completed = !!json.completed;

    btn.classList.toggle('btn-success', completed);
    btn.classList.toggle('btn-outline-success', !completed);
    btn.innerHTML = completed
      ? '<i class="bi bi-check2-circle"></i> Terminé'
      : '<i class="bi bi-check2-circle"></i> Marquer terminé';

    const statusChip = document.querySelector('[data-node-status="' + nodeId + '"]');
    if(statusChip){
      statusChip.innerHTML = completed
        ? '<i class="bi bi-check2-circle"></i> Terminé'
        : '<i class="bi bi-hourglass-split"></i> En cours';
    }

    // Update progression hero
    const pct = parseInt(json.progressPct || 0, 10);
    const pctEl = document.getElementById('progressPctValue');
    const barEl = document.getElementById('progressBarSpan');
    if(pctEl) pctEl.textContent = pct + '%';
    if(barEl) barEl.style.setProperty('--w', pct + '%');

  } catch(err){
    alert(err.message || 'Erreur');
  } finally {
    btn.disabled = false;
  }
});
</script>


{% endblock %}
