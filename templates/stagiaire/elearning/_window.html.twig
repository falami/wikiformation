<div class="small fw-semibold text-muted">
  {% if startsAt and endsAt %}
    <div><i class="bi bi-calendar-event"></i> {{ startsAt ? startsAt|date('d/m/Y H:i') : '—' }}</div>
    <div><i class="bi bi-calendar-x"></i> {{ endsAt ? endsAt|date('d/m/Y H:i') : '—' }}</div>
  {% else %}
    <div><i class="bi bi-clock"></i> Illimité</div>
  {% endif %}
</div>
