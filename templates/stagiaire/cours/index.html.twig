{% extends 'base_admin.html.twig' %}
{% block title %}Mes cours — Formations suivies{% endblock %}


{% block stylesheets %}
  {{ parent() }}
  <style>
    :root{
      --bg:#0e2a3b;
      --panel:#0e2433;
      --stroke:rgba(255,255,255,.10);
      --ink:#eaf6ff;
      --muted:#a8c9da;
      --amber:#ffc107;
      --radius:22px;
      --shadow: 0 18px 55px rgba(0,0,0,.35);
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
      --ink:#0f2336; --muted:#6f8897;
    }

    .wrap{ max-width:1200px; margin:0 auto; padding: 0 12px; }
    .hero{
      position:relative; border-radius: var(--radius); overflow:hidden;
      border:1px solid var(--stroke); box-shadow: var(--shadow);
      background: linear-gradient(135deg, rgba(17,42,59,.92), rgba(15,27,40,.92));
      padding: 1.25rem 1.25rem 1.05rem;
    }
    .hero h1{ font-weight:950; letter-spacing:-.02em; margin:.15rem 0 .35rem; color:var(--ink); }
    .hero p{ margin:0; color: rgba(255,255,255,.74); }
    .kpis{ margin-top:.9rem; display:flex; gap:.5rem; flex-wrap:wrap; }
    .kpi{ display:inline-flex; align-items:center; gap:.5rem; padding:.45rem .7rem; border-radius:14px;
      background: rgba(13,22,34,.55); border:1px solid rgba(255,255,255,.10); color: rgba(255,255,255,.84); font-size:.92rem; }
    .kpi i{ color: rgba(255,193,7,.95); }

    .grid{ display:grid; grid-template-columns: repeat(12, minmax(0,1fr)); gap:1rem; margin-top:1.1rem; }
    .tile{
      grid-column: span 4; min-height: 220px;
      position:relative; border-radius: 20px; overflow:hidden;
      border:1px solid rgba(255,255,255,.10);
      box-shadow: 0 14px 40px rgba(0,0,0,.30);
      text-decoration:none; color:#fff;
      background:
        radial-gradient(120% 120% at 0% 0%, rgba(255,255,255,.07), transparent 60%),
        var(--bgimg) center/cover no-repeat;
      transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
    }
    .tile:hover{ transform: translateY(-3px); box-shadow: 0 20px 60px rgba(0,0,0,.42); border-color: rgba(255,193,7,.26); }
    .tile::after{ content:""; position:absolute; inset:0; background: linear-gradient(180deg, rgba(0,0,0,.10) 0%, rgba(0,0,0,.72) 100%); }
    .tile__content{ position:absolute; inset:0; z-index:2; padding:1rem; display:flex; flex-direction:column; justify-content:flex-end; gap:.5rem; }
    .tile__chip{ align-self:flex-start; display:inline-flex; gap:.45rem; align-items:center; padding:.28rem .6rem; border-radius:999px;
      background: rgba(255,255,255,.10); border:1px solid rgba(255,255,255,.14); font-size:.80rem; }
    .tile__title{ font-weight:950; margin:0; font-size:1.15rem; line-height:1.15; }
    .tile__sub{ color: rgba(255,255,255,.78); font-size:.92rem; display:flex; align-items:center; gap:.4rem; }
    .tile__arrow{ width: 34px; height:34px; border-radius: 12px; display:inline-flex; align-items:center; justify-content:center;
      background: rgba(255,193,7,.18); border: 1px solid rgba(255,193,7,.25); }

    @media (max-width: 992px){ .tile{ grid-column: span 6; min-height: 200px; } }
    @media (max-width: 576px){ .tile{ grid-column: span 12; min-height: 180px; } }


    /* ===== HERO (copie du style Sessions, adapté tokens entité) ===== */
.hero{
  border-radius:22px;
  background:
    radial-gradient(1200px 400px at 15% 0%, rgba(255,255,255,.12), transparent 60%),
    radial-gradient(900px 350px at 85% 10%, rgba(255,193,7,.18), transparent 55%),
    linear-gradient(135deg,
      color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
      color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%)
    );
  color:#fff;
  box-shadow:0 18px 50px rgba(0,0,0,.14);
  overflow:hidden;
  position:relative;
  border: 1px solid rgba(255,255,255,.10);
}

.hero .accent{
  width:12px;
  background: var(--theme-color-secondaire);
  border-radius:999px;
  box-shadow:0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
}

/* Chips meta */
.meta-chip{
  display:inline-flex;
  align-items:center;
  gap:.45rem;
  padding:.35rem .65rem;
  border-radius:999px;
  background:rgba(255,255,255,.12);
  border:1px solid rgba(255,255,255,.14);
  font-size:.82rem;
  backdrop-filter: blur(6px);
}

/* KPI chips (version dark, cohérente hero) */
.kpis{ display:flex; gap:.5rem; flex-wrap:wrap; }
.kpi{
  display:inline-flex;
  align-items:center;
  gap:.5rem;
  padding:.45rem .7rem;
  border-radius:14px;
  background: rgba(255,255,255,.10);
  border:1px solid rgba(255,255,255,.14);
  color: rgba(255,255,255,.90);
  font-size:.92rem;
}
.kpi i{ color: var(--theme-color-secondaire); }

/* Mobile */
@media (max-width: 768px){
  .hero{ border-radius:16px; }
}

  </style>


  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/style-table.css') }}">
{% endblock %}

{% block body %}


  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>

    <div class="flex-grow-1">
      <div class="d-flex flex-wrap gap-2 mb-2">
        <span class="meta-chip"><i class="bi bi-mortarboard"></i> Mes cours</span>
        <span class="meta-chip"><i class="bi bi-person-badge"></i> Espace stagiaire</span>
        <span class="meta-chip"><i class="bi bi-shield-check"></i> Accès sécurisé</span>
      </div>

      <div class="d-flex flex-wrap align-items-end gap-2">
        <div class="me-auto">
          <h2 class="fw-bold mb-1">Mes cours</h2>
          <div class="opacity-75">Retrouvez uniquement les formations que vous avez suivies et payées.</div>

          <div class="kpis mt-3">
            <div class="kpi"><i class="bi bi-mortarboard"></i> {{ countFormations }} formation{% if countFormations > 1 %}s{% endif %}</div>
            <div class="kpi"><i class="bi bi-folder"></i> {{ categories|length }} catégorie{% if categories|length > 1 %}s{% endif %}</div>
            <div class="kpi"><i class="bi bi-lightning-charge"></i> Navigation rapide</div>
          </div>
        </div>

        {# Optionnel : petit bouton à droite comme sur Sessions #}
        {# <a class="btn btn-light btn-sm fw-semibold" href="{{ path('app_stagiaire_dashboard', {entite: entite.id}) }}">
          <i class="bi bi-arrow-left-circle"></i> Tableau de bord
        </a> #}
      </div>
    </div>
  </div>


  <div class="grid">
    {% for c in categories %}
      {% set cover = c.photo ? asset('uploads/photos/categorie/' ~ c.photo) : asset('dist/img/placeholder-cat.png') %}
      <a class="tile"
         href="{{ path('app_stagiaire_cours_categorie', {entite: entite.id, slug: c.slug}) }}"
         style="--bgimg:url('{{ cover|e('html_attr') }}');">
        <div class="tile__content">
          <div class="tile__chip"><i class="bi bi-folder2-open"></i> Catégorie</div>
          <p class="tile__title">{{ c.nom }}</p>
          <div class="tile__sub">
            <span class="tile__arrow"><i class="bi bi-arrow-right"></i></span>
            Voir mes formations
          </div>
        </div>
      </a>
    {% else %}
      <div class="text-white-50">
        Aucune formation suivie pour le moment.
      </div>
    {% endfor %}
  </div>

{% endblock %}
