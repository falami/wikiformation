{% extends 'base_admin.html.twig' %}
{% block title %}Mes cours — {{ categorie.nom }}{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  {# Tu peux reprendre quasiment le CSS de ta page publique show.html.twig,
     je te mets une version allégée mais identique dans l’esprit #}
  <style>
    :root{
      --bg:#0e2a3b; --panel:#0e2433; --panel-2:#112a3b;
      --stroke:rgba(255,255,255,.10);
      --ink:#eaf6ff; --muted:#a8c9da;
      --amber:#ffc107; --shadow: 0 18px 55px rgba(0,0,0,.35);
      --radius:22px;
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
      --ink:#0f2336; --muted:#6f8897;
    }
    .hero{ position:relative; border-radius: var(--radius); overflow:hidden; border:1px solid var(--stroke); box-shadow: var(--shadow);
      background: linear-gradient(135deg, rgba(17,42,59,.92), rgba(15,27,40,.92)); }
    .hero-media{ position:absolute; inset:0; background:
      linear-gradient(90deg, rgba(15,27,40,.96) 0%, rgba(15,27,40,.75) 55%, rgba(15,27,40,.15) 100%),
      var(--hero-cover) center/cover no-repeat; opacity:.95; }
    .hero-inner{ position:relative; z-index:2; padding: 1.25rem 1.25rem 1.05rem; }
    .hero-title{ font-weight:950; letter-spacing:-.02em; margin:.55rem 0 .2rem; color:rgba(255,255,255,.74); }
    .hero-sub{ margin:0; color: rgba(255,255,255,.74); }
    .btn-ghost{ border-radius: 14px; border:1px solid rgba(255,255,255,.18); background: rgba(255,255,255,.06); color:#fff; font-weight:800; padding:.55rem .9rem; }
    .btn-amber{ border-radius: 14px; border:0; background: var(--amber); color:#0b1a24; font-weight:900; padding:.55rem .9rem; }

    .formation-row{
      border-radius: 18px;
      border:1px solid rgba(255,255,255,.10);
      background: rgba(15,27,40,.55);
      box-shadow: 0 10px 28px rgba(0,0,0,.25);
      padding: 1rem 1.1rem;
    }
    .formation-row a{ color: var(--amber); text-decoration:none; font-weight:900; }
    .formation-meta{ color: rgba(255,255,255,.70); font-size:.92rem; }
    

    /* ===== HERO (style Sessions) ===== */
.hero{
  border-radius:22px;
  background:
    radial-gradient(1200px 400px at 15% 0%, rgba(255,255,255,.12), transparent 60%),
    radial-gradient(900px 350px at 85% 10%, rgba(255,193,7,.18), transparent 55%),
    linear-gradient(135deg,
      color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
      color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%)
    );
  color:#fff;
  box-shadow:0 18px 50px rgba(0,0,0,.14);
  overflow:hidden;
  position:relative;
  border: 1px solid rgba(255,255,255,.10);
}

.hero .accent{
  width:12px;
  background: var(--theme-color-secondaire);
  border-radius:999px;
  box-shadow:0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
}

.meta-chip{
  display:inline-flex;
  align-items:center;
  gap:.45rem;
  padding:.35rem .65rem;
  border-radius:999px;
  background:rgba(255,255,255,.12);
  border:1px solid rgba(255,255,255,.14);
  font-size:.82rem;
  backdrop-filter: blur(6px);
}

/* KPI chips */
.kpis{ display:flex; gap:.5rem; flex-wrap:wrap; }
.kpi{
  display:inline-flex;
  align-items:center;
  gap:.5rem;
  padding:.45rem .7rem;
  border-radius:14px;
  background: rgba(255,255,255,.10);
  border:1px solid rgba(255,255,255,.14);
  color: rgba(255,255,255,.90);
  font-size:.92rem;
}
.kpi i{ color: var(--theme-color-secondaire); }

/* Boutons dans le hero */
.hero .btn-hero{
  border-radius:14px;
  font-weight:900;
  padding:.55rem .9rem;
}
.hero .btn-hero.btn-ghost{
  border:1px solid rgba(255,255,255,.18);
  background: rgba(255,255,255,.06);
  color:#fff;
}
.hero .btn-hero.btn-ghost:hover{ background: rgba(255,255,255,.10); }

.hero .btn-hero.btn-amber{
  border:0;
  background: var(--theme-color-secondaire);
  color:#0b1a24;
  box-shadow: 0 14px 34px color-mix(in srgb, var(--theme-color-secondaire) 28%, transparent);
}
.hero .btn-hero.btn-amber:hover{ filter: brightness(1.04); }

/* Option vignette image catégorie (si utilisée) */
.hero-thumb{
  width: 110px; height: 78px;
  border-radius: 16px;
  border: 1px solid rgba(255,255,255,.14);
  box-shadow: 0 14px 40px rgba(0,0,0,.25);
  object-fit: cover;
}

/* Mobile */
@media (max-width: 768px){
  .hero{ border-radius:16px; }
  .hero-thumb{ width: 92px; height: 66px; border-radius: 14px; }
}

  </style>

  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/style-table.css') }}">
{% endblock %}

{% block body %}


    {% set heroCover =
      (categorie.photo ? asset('uploads/photos/categorie/' ~ categorie.photo) : asset('dist/img/placeholder-cat.png'))
    %}

    <div class="hero p-3 mb-4 d-flex gap-3">
      <div class="accent"></div>

      <div class="flex-grow-1">
        <div class="d-flex flex-wrap gap-2 mb-2">
          <span class="meta-chip"><i class="bi bi-folder2-open"></i> Catégorie</span>
          <span class="meta-chip"><i class="bi bi-mortarboard"></i> Mes cours</span>
          <span class="meta-chip"><i class="bi bi-shield-check"></i> Accès sécurisé</span>
        </div>

        <div class="d-flex flex-wrap align-items-end gap-3">
          <div class="me-auto">
            <h2 class="fw-bold mb-1">{{ categorie.nom }}</h2>
            <div class="opacity-75">Formations suivies et accessibles dans cette catégorie.</div>

            <div class="kpis mt-3">
              <div class="kpi">
                <i class="bi bi-mortarboard"></i>
                {{ formations|length }} formation{% if formations|length > 1 %}s{% endif %}
              </div>
              <div class="kpi"><i class="bi bi-lightning-charge"></i> Navigation rapide</div>
              <div class="kpi"><i class="bi bi-lock"></i> Contenu réservé</div>
            </div>
          </div>

          {# Optionnel: petite vignette image catégorie à droite (propre) #}
          <img src="{{ heroCover }}" alt="" class="hero-thumb d-none d-sm-block">

          <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-hero btn-ghost" href="{{ path('app_stagiaire_cours_index', {entite: entite.id}) }}">
              <i class="bi bi-arrow-left me-2"></i>Retour
            </a>
            <a class="btn btn-hero btn-amber"
              href="{{ path('app_stagiaire_cours_index', {entite: entite.id}) }}#cat-{{ categorie.id }}">
              <i class="bi bi-grid me-2"></i>Voir catégories
            </a>
          </div>
        </div>
      </div>
    </div>


    <div class="vstack gap-3 pb-4">
      {% for f in formations %}
        <div class="formation-row">
          <div class="d-flex flex-wrap align-items-center gap-2">
            <div class="fw-bold text-white">{{ f.titre }}</div>
            {% if f.niveau %}<span class="text-white-50">•</span><div class="text-white-50 small">{{ f.niveau.value ?? f.niveau.name }}</div>{% endif %}
            <span class="ms-auto">
              <a href="{{ path('app_stagiaire_formation_contenu', {entite: entite.id, slug: f.slug}) }}">
                Accéder au cours <i class="bi bi-arrow-right ms-1"></i>
              </a>
            </span>
          </div>

          <div class="formation-meta mt-1">
            <i class="bi bi-shield-check me-1"></i> Accès réservé (formation payée)
            {% if f.duree %} • <i class="bi bi-clock me-1"></i>{{ f.duree }} jour{% if f.duree>1 %}s{% endif %}{% endif %}
          </div>
        </div>
      {% else %}
        <div class="text-white-50">Aucune formation payée dans cette catégorie.</div>
      {% endfor %}
    </div>

{% endblock %}
