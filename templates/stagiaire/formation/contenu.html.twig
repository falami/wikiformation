  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/style-table.css') }}">
{% endblock %}

{% block body %}
  {% set banner = formation.photoCouverture ? asset('uploads/photos/formation/' ~ formation.photoCouverture) : asset('uploads/photos/formation/programme.jpg') %}

  <div class="container py-4">

    {# HERO #}
    <div class="course-hero mb-3" style="--hero-cover:url('{{ banner|e('html_attr') }}');">
      <div class="course-hero__bg"></div>

      <div class="course-hero__inner">
        <div class="crumbs mb-2">
          <span class="pill"><i class="bi bi-journal-text"></i> Cours</span>
          <span class="text-white-50">/</span>
          <a href="{{ path('app_stagiaire_cours_index', {entite: entite.id}) }}"><i class="bi bi-collection me-1"></i>Mes formations</a>
          <span class="text-white-50">/</span>
          <span class="pill"><i class="bi bi-mortarboard"></i> {{ formation.titre }}</span>
        </div>

        <h1 class="course-title">{{ formation.titre }}</h1>
        <p class="course-sub">
          Accédez au contenu pédagogique, médias, ressources et quiz. Utilisez le sommaire à gauche pour naviguer rapidement.
        </p>

        <div class="chips">
          {% if formation.niveau %}
            <span class="chip"><i class="bi bi-award"></i> {{ formation.niveau.value ?? formation.niveau.name }}</span>
          {% endif %}
          {% if formation.duree %}
            <span class="chip"><i class="bi bi-clock"></i> {{ formation.duree }} jour{% if formation.duree > 1 %}s{% endif %}</span>
          {% endif %}
          <span class="chip"><i class="bi bi-shield-check"></i> Accès stagiaire</span>
        </div>

        <div class="hero-actions">
          <a class="btn btn-glass" href="{{ path('app_stagiaire_cours_index', {entite: entite.id}) }}">
            <i class="bi bi-arrow-left me-2"></i>Retour
          </a>
          <button class="btn btn-accent" type="button" id="btnScrollTop">
            <i class="bi bi-arrow-up-short me-1"></i>Haut
          </button>
        </div>
      </div>
    </div>

    {# SHELL #}
    <div class="shell">

      {# TOC #}
      <aside class="toc" id="toc">
        <div class="toc__top">
          <div class="toc__title">
            <span><i class="bi bi-list-nested me-2"></i>Sommaire</span>
            <span class="chapter-badge">{{ roots|length }} chapitre{% if roots|length > 1 %}s{% endif %}</span>
          </div>

          <div class="toc-search mb-2">
            <i class="bi bi-search"></i>
            <input type="text" id="tocSearch" placeholder="Rechercher un chapitre…">
          </div>

          <div class="toc__tools mb-2">
            <button class="toc-btn" type="button" id="tocExpand"><i class="bi bi-arrows-expand me-1"></i>Tout</button>
            <button class="toc-btn" type="button" id="tocCollapse"><i class="bi bi-arrows-collapse me-1"></i>Replier</button>
          </div>

          <div class="toc__progress" aria-hidden="true"><div id="tocProgress"></div></div>
        </div>

        <div class="toc__list">
          <ul id="tocList">
            {% for r in roots %}
              <li class="toc-item">
                <a href="#node-{{ r.id }}" data-toc-id="node-{{ r.id }}" class="toc-link">
                  <span class="toc-dot"></span>
                  <span class="toc-text">{{ r.titre }}</span>
                </a>

                {% if r.children|length %}
                  <ul class="lvl-2">
                    {% for c in r.children %}
                      <li class="toc-item">
                        <a href="#node-{{ c.id }}" data-toc-id="node-{{ c.id }}" class="toc-link">
                          <span class="toc-dot"></span>
                          <span class="toc-text">{{ c.titre }}</span>
                        </a>

                        {% if c.children|length %}
                          <ul class="lvl-3">
                            {% for g in c.children %}
                              <li class="toc-item">
                                <a href="#node-{{ g.id }}" data-toc-id="node-{{ g.id }}" class="toc-link">
                                  <span class="toc-dot"></span>
                                  <span class="toc-text">{{ g.titre }}</span>
                                </a>
                              </li>
                            {% endfor %}
                          </ul>
                        {% endif %}
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </li>
            {% else %}
              <li class="text-white-50 px-2 py-2">Aucun chapitre pour le moment.</li>
            {% endfor %}
          </ul>
        </div>
      </aside>

      {# CONTENT #}
      <main class="contenu">
        <div class="topbar" id="topbar">
          <div class="left">
            <div class="kicker">Lecture</div>
            <div class="now" id="nowReading">—</div>
          </div>
          <div class="right">
            
            <span class="icon-pill"><i class="bi bi-lightning-charge"></i> Navigation rapide</span>
            <span class="icon-pill"><i class="bi bi-mouse"></i> Scroll</span>
          </div>
        </div>

        {% import _self as macros %}
        {% for r in roots %}
          {{ macros.renderNode(r, formation)|raw }}
        {% endfor %}
      </main>
    </div>

  </div>

  {# MACRO #}
  {% macro renderNode(node, formation) %}
    <section id="node-{{ node.id }}" class="content-card chapter" data-title="{{ node.titre|e('html_attr') }}">
      <div class="chapter-head">
        <div>
          <h2 class="h5 chapter-title mb-1">
            <i class="bi bi-dot"></i>
            {{ node.titre }}
            <span class="chapter-badge ms-2">#{{ node.position }}</span>
            {% if not node.isPublished %}
              <span class="chapter-badge draft ms-2">Brouillon</span>
            {% endif %}
          </h2>

          <div class="chapter-meta">
            {% if node.dureeMinutes %}<i class="bi bi-clock me-1"></i>{{ node.dureeMinutes }} min · {% endif %}
            <i class="bi bi-folder2-open me-1"></i>Chapitre
          </div>
        </div>
      </div>

      {% for b in node.blocks %}
        <article class="block" id="block-{{ b.id }}">
          <div class="block-head">
            <div class="block-type"><i class="bi bi-grid-1x2 me-1"></i> {{ b.type.value }}</div>
            <button class="btn-copy" type="button" title="Copier le lien" data-anchor="#block-{{ b.id }}">
              <i class="bi bi-link-45deg"></i> Lien
            </button>
          </div>

          {% set uploadDir = 'uploads/photos/formation/' %}

          {% if b.type.value == 'texte' %}
            <div class="richtext">{{ b.content|raw }}</div>

          {% elseif b.type.value == 'image' %}
            {% if b.mediaFilename %}
              {% set p = asset(uploadDir ~ b.mediaFilename) %}
              <a data-fancybox="node-{{ node.id }}" href="{{ p }}" class="media d-block">
                <img src="{{ p }}" alt="">
              </a>
              {% if b.content %}<div class="text-white-50 small mt-2">{{ b.content|raw }}</div>{% endif %}
            {% endif %}

          {% elseif b.type.value == 'video' %}
            {% if b.mediaUrl %}
              {% set videoUrl = b.mediaUrl|default(b.content) %}
              {% if videoUrl %}
                {% set embedUrl = videoUrl %}
                {% if 'youtube.com' in videoUrl or 'youtu.be' in videoUrl %}
                  {% set videoId = '' %}
                  {% if 'v=' in videoUrl %}
                    {% set videoId = videoUrl|split('v=')[1]|split('&')[0] %}
                  {% elseif 'youtu.be/' in videoUrl %}
                    {% set videoId = videoUrl|split('youtu.be/')[1]|split('?')[0] %}
                  {% endif %}
                  {% set embedUrl = 'https://www.youtube-nocookie.com/embed/' ~ videoId %}
                {% elseif 'vimeo.com' in videoUrl %}
                  {% set videoId = videoUrl|split('/')|last %}
                  {% set embedUrl = 'https://player.vimeo.com/video/' ~ videoId %}
                {% endif %}

                <div class="video-embed">
                  <iframe
                    src="{{ embedUrl }}"
                    title="Video"
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen
                    loading="lazy"></iframe>
                </div>
              {% endif %}
            {% elseif b.content %}
              <div class="video-embed">
                <iframe src="{{ b.content }}" title="Video" frameborder="0" allowfullscreen loading="lazy"></iframe>
              </div>
            {% endif %}

          {% elseif b.type.value == 'file' %}
            {% if b.mediaFilename %}
              <div class="file-tile">
                <i class="bi bi-file-earmark-arrow-down fs-4"></i>
                <div class="flex-fill">
                  <div class="title">{{ b.content ? b.content|striptags|slice(0,120) : 'Fichier' }}</div>
                  <div class="small text-white-50">Ressource à télécharger</div>
                </div>
                <a href="{{ asset(uploadDir ~ b.mediaFilename) }}" download>Télécharger</a>
              </div>
            {% endif %}

          {% elseif b.type.value == 'code' %}
            {% if b.content %}
              <pre class="code"><code>{{ b.content }}</code></pre>
            {% endif %}

          {% elseif b.type.value == 'checklist' %}
            {% set m = b.meta ?? {} %}
            {% set items = attribute(m, 'items')|default([]) %}
            {% if items is iterable and items|length %}
              <ul class="mb-0">
                {% for it in items %}
                  <li class="mb-2">
                    <input type="checkbox" disabled {% if it.done %}checked{% endif %} class="form-check-input me-2">
                    <span>{{ it.label }}</span>
                  </li>
                {% endfor %}
              </ul>
            {% else %}
              {% if b.content %}<div class="richtext">{{ b.content|raw }}</div>{% endif %}
            {% endif %}

          {% elseif ((b.type.value ?? b.type.name ?? b.type)|lower) == 'quiz' or b.quiz is not null %}
            {# Tu gardes ton bloc quiz tel quel si tu veux.
               Ici je laisse juste un placeholder pour ne pas te recoller 200 lignes. #}
            {% include 'stagiaire/formation/_quiz_block.html.twig' with { b: b, node: node } only %}

          {% endif %}
        </article>
      {% endfor %}

      {% if node.children|length %}
        <div class="vstack gap-3 mt-3">
          {% for c in node.children %}
            {{ _self.renderNode(c, formation)|raw }}
          {% endfor %}
        </div>
      {% endif %}
    </section>
  {% endmacro %}
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://cdn.jsdelivr.net/npm/@fancyapps/ui/dist/fancybox.umd.js"></script>

  <script>
document.addEventListener('DOMContentLoaded', () => {

  /* ============================================================
     1. SMOOTH SCROLL (clic sommaire)
  ============================================================ */
  document.querySelectorAll('.toc a.toc-link').forEach(link => {
    link.addEventListener('click', e => {
      const id = link.getAttribute('href');
      const target = document.querySelector(id);
      if (!target) return;

      e.preventDefault();
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      history.replaceState(null, '', id);
    });
  });


  /* ============================================================
     2. BARRE DE PROGRESSION GLOBALE
  ============================================================ */
  const progressBar = document.getElementById('tocProgress');

  const getScrollTop = () =>
    window.scrollY ??
    window.pageYOffset ??
    document.documentElement.scrollTop ??
    0;

  const updateProgress = () => {
    if (!progressBar) return;

    const doc = document.documentElement;
    const top = getScrollTop();
    const max = doc.scrollHeight - window.innerHeight;
    const ratio = max > 0 ? Math.min(top / max, 1) : 0;

    progressBar.style.width = (ratio * 100).toFixed(1) + '%';
  };

  window.addEventListener('scroll', updateProgress, { passive: true });
  updateProgress();


  /* ============================================================
     3. INTERSECTION OBSERVER (chapitre actif + now reading)
  ============================================================ */
  const tocLinks = [...document.querySelectorAll('.toc a.toc-link')];
  const linkById = Object.fromEntries(tocLinks.map(a => [a.dataset.tocId, a]));
  const nowReading = document.getElementById('nowReading');

  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;

      const id = entry.target.id;
      const link = linkById[id];
      if (!link) return;

      tocLinks.forEach(l => l.classList.remove('active'));
      link.classList.add('active');

      const title = entry.target.dataset.title || link.textContent.trim();
      if (nowReading) nowReading.textContent = title;
    });
  }, {
    rootMargin: '-45% 0px -52% 0px',
    threshold: 0.01
  });

  document
    .querySelectorAll('.chapter[id^="node-"]')
    .forEach(sec => observer.observe(sec));


  /* ============================================================
     4. SOMMAIRE : COLLAPSE / EXPAND / SEARCH
  ============================================================ */
  const tocList = document.getElementById('tocList');
  const tocSearch = document.getElementById('tocSearch');
  const allItems = [...document.querySelectorAll('#tocList .toc-item')];

  const clearInlineDisplays = () => {
    document
      .querySelectorAll('#tocList .lvl-2, #tocList .lvl-3')
      .forEach(ul => ul.style.removeProperty('display'));
  };

  const setCollapsed = collapsed => {
    if (!tocList) return;
    clearInlineDisplays();
    tocList.classList.toggle('is-collapsed', collapsed);
  };

  const resetSearch = () => {
    if (!tocList) return;
    tocList.classList.remove('is-searching');
    allItems.forEach(li => li.classList.remove('is-hidden'));
  };

  const applySearch = value => {
    if (!tocList) return;

    const q = (value || '').trim().toLowerCase();

    if (!q) {
      resetSearch();
      return;
    }

    setCollapsed(false);
    tocList.classList.add('is-searching');

    allItems.forEach(li => li.classList.add('is-hidden'));

    const matches = allItems.filter(li => {
      const txt = li.querySelector(':scope > a .toc-text')?.textContent?.toLowerCase() || '';
      return txt.includes(q);
    });

    const showBranch = li => {
      li.classList.remove('is-hidden');

      // parents
      let p = li.parentElement;
      while (p && p !== tocList) {
        if (p.classList?.contains('toc-item')) {
          p.classList.remove('is-hidden');
        }
        p = p.parentElement;
      }

      // enfants
      li.querySelectorAll('.toc-item')
        .forEach(child => child.classList.remove('is-hidden'));
    };

    matches.forEach(showBranch);
  };

  document.getElementById('tocCollapse')?.addEventListener('click', () => {
    if (!tocList.classList.contains('is-searching')) {
      setCollapsed(true);
    }
  });

  document.getElementById('tocExpand')?.addEventListener('click', () => {
    setCollapsed(false);
  });

  tocSearch?.addEventListener('input', () => {
    applySearch(tocSearch.value);
  });

  tocSearch?.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
      tocSearch.value = '';
      resetSearch();
    }
  });

  setCollapsed(false);
  resetSearch();


  /* ============================================================
     5. COPIE DE LIEN (bloc)
  ============================================================ */
  document.addEventListener('click', e => {
    const btn = e.target.closest('.btn-copy[data-anchor]');
    if (!btn) return;

    const hash = btn.dataset.anchor;
    const url = location.origin + location.pathname + hash;

    navigator.clipboard.writeText(url).then(() => {
      btn.innerHTML = '<i class="bi bi-check2"></i> Copié';
      setTimeout(() => {
        btn.innerHTML = '<i class="bi bi-link-45deg"></i> Lien';
      }, 900);
    });
  });


  /* ============================================================
     6. BOUTON HAUT
  ============================================================ */
  document.getElementById('btnScrollTop')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });


  // ... TON CODE EXISTANT (sommaire, progress, etc.)

  /* ============================================================
     7. QUIZ — feedback + score (FRONT)
     - fonctionne avec ton _quiz_block.html.twig actuel
     - utilise data-correct="1" sur les inputs radio/checkbox
     - boolean : compare au hidden .expected-boolean
     - text : compare au hidden .expected-text (optionnel)
  ============================================================ */

  function setFeedback(qEl, ok, msg){
    const fb = qEl.querySelector('.quiz-feedback');
    if (!fb) return;
    fb.classList.remove('d-none');
    fb.classList.toggle('text-success', !!ok);
    fb.classList.toggle('text-danger', !ok);
    fb.textContent = msg || (ok ? '✅ Bonne réponse' : '❌ Mauvaise réponse');
  }

  function showExplanation(qEl){
    const exp = qEl.querySelector('.quiz-explanation');
    if (exp) exp.classList.remove('d-none');
  }

  function evaluateQuestion(qEl){
    const type = (qEl.dataset.qtype || '').toLowerCase();

    // SINGLE / MULTIPLE
    if (type === 'single' || type === 'multiple'){
      const inputs = [...qEl.querySelectorAll('input.form-check-input[type="radio"], input.form-check-input[type="checkbox"]')];
      const checked = inputs.filter(i => i.checked);

      // rien coché
      if (!checked.length){
        setFeedback(qEl, false, '⚠️ Sélectionne une réponse');
        return { answered: false, correct: false };
      }

      const correctInputs = inputs.filter(i => i.dataset.correct === '1');
      const checkedCorrect = checked.filter(i => i.dataset.correct === '1');

      let ok = false;
      if (type === 'single'){
        ok = checked.length === 1 && checkedCorrect.length === 1;
      } else {
        // multiple : exactement le même ensemble
        ok = checked.length === correctInputs.length && checkedCorrect.length === correctInputs.length;
      }

      setFeedback(qEl, ok, ok ? '✅ Bonne réponse' : '❌ Mauvaise réponse');
      if (!ok) showExplanation(qEl);
      return { answered: true, correct: ok };
    }

    // BOOLEAN
    if (type === 'boolean'){
      const expected = qEl.querySelector('.expected-boolean')?.value; // "true"/"false" ou vide
      const chosen = qEl.querySelector('input[type="radio"]:checked')?.value; // "true"/"false"

      if (!chosen){
        setFeedback(qEl, false, '⚠️ Choisis Vrai ou Faux');
        return { answered: false, correct: false };
      }
      if (!expected){
        // si pas de réponse attendue configurée → on ne peut pas corriger
        setFeedback(qEl, true, '✅ Réponse enregistrée');
        return { answered: true, correct: true };
      }

      const ok = chosen === expected;
      setFeedback(qEl, ok, ok ? '✅ Bonne réponse' : '❌ Mauvaise réponse');
      if (!ok) showExplanation(qEl);
      return { answered: true, correct: ok };
    }

    // TEXT
    if (type === 'text'){
      const input = qEl.querySelector('input.quiz-text');
      const expected = qEl.querySelector('.expected-text')?.value;

      const val = (input?.value || '').trim();
      if (!val){
        setFeedback(qEl, false, '⚠️ Écris une réponse');
        return { answered: false, correct: false };
      }

      if (!expected){
        setFeedback(qEl, true, '✅ Réponse enregistrée');
        return { answered: true, correct: true };
      }

      const ok = val.toLowerCase() === expected.trim().toLowerCase();
      setFeedback(qEl, ok, ok ? '✅ Bonne réponse' : '❌ Mauvaise réponse');
      if (!ok) showExplanation(qEl);
      return { answered: true, correct: ok };
    }

    // fallback
    setFeedback(qEl, true, '✅ OK');
    return { answered: true, correct: true };
  }

  document.querySelectorAll('form.quiz-form').forEach(form => {

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const questions = [...form.querySelectorAll('.quiz-q')];
      let score = 0;
      let answeredCount = 0;

      questions.forEach(qEl => {
        const res = evaluateQuestion(qEl);
        if (res.answered) answeredCount++;
        if (res.correct) score++;
      });

      // score
      const scoreEl = form.querySelector('.quiz-score');
      if (scoreEl) scoreEl.textContent = `Score : ${score}/${questions.length}`;

      // petit message global si tout n'est pas répondu
      if (answeredCount < questions.length){
        // tu peux aussi afficher une alerte si tu veux
      }
    });

    // reset
    form.querySelector('.quiz-reset')?.addEventListener('click', () => {
      form.reset();

      form.querySelectorAll('.quiz-feedback').forEach(fb=>{
        fb.classList.add('d-none');
        fb.classList.remove('text-success','text-danger');
        fb.textContent = '';
      });

      form.querySelectorAll('.quiz-explanation').forEach(exp=>{
        exp.classList.add('d-none');
      });

      const questions = [...form.querySelectorAll('.quiz-q')];
      const scoreEl = form.querySelector('.quiz-score');
      if (scoreEl) scoreEl.textContent = `Score : 0/${questions.length}`;
    });

  });

});
</script>


{% endblock %}
