{# templates/stagiaire/formation/contenu.html.twig #}
{% extends 'base_admin.html.twig' %}

{% block title %}{{ formation.titre }} — Cours{% endblock %}
{% block meta_description %}Cours en ligne — {{ formation.titre }} : chapitres, médias et ressources.{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fancyapps/ui/dist/fancybox.css" />

  <style>
    :root{
  --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
  --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
  --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
  --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};

  /* Premium dark base (harmonisé avec ton theme) */
  --bg: color-mix(in srgb, var(--theme-color-principal) 78%, #000 22%);
  --panel: rgba(8, 16, 24, .72);
  --panel-2: rgba(10, 20, 30, .82);
  --stroke: rgba(255,255,255,.10);
  --stroke-2: rgba(255,255,255,.14);
  --ink: rgba(255,255,255,.92);
  --muted: rgba(255,255,255,.70);

  --accent: var(--theme-color-secondaire);
  --accent-2: color-mix(in srgb, var(--theme-color-secondaire) 55%, #fff 45%);
  --danger: #e73d45;

  --radius-xl: 26px;
  --radius-lg: 18px;
  --radius-md: 14px;
  --shadow-lg: 0 18px 60px rgba(0,0,0,.42);
  --shadow-md: 0 12px 34px rgba(0,0,0,.32);

  --gap: 1.1rem;
}

/* page */
main{ margin-top: 0 !important; }
body{ overflow-x: hidden; }

/* (optionnel) si base_admin est claire : donne une base dark au contenu sans impacter ton layout */
.container{
  color: var(--ink);
}

/* ================= HERO premium ================= */
.course-hero{
  position: relative;
  border-radius: var(--radius-xl);
  overflow: hidden;
  border: 1px solid var(--stroke);
  box-shadow: var(--shadow-lg);
  background: linear-gradient(135deg, rgba(12,24,34,.92), rgba(6,14,20,.92));
}
.course-hero::before{
  content:"";
  position:absolute; inset:-2px;
  background:
    radial-gradient(1000px 380px at 12% 10%, rgba(255,255,255,.12), transparent 60%),
    radial-gradient(900px 360px at 84% 20%, color-mix(in srgb, var(--accent) 22%, transparent), transparent 55%),
    radial-gradient(700px 320px at 55% 100%, rgba(58,160,255,.10), transparent 55%);
  pointer-events:none;
}
.course-hero__bg{
  position:absolute; inset:0;
  background:
    linear-gradient(90deg, rgba(8,16,24,.96) 0%, rgba(8,16,24,.82) 45%, rgba(8,16,24,.25) 75%, rgba(8,16,24,0) 100%),
    var(--hero-cover) center/cover no-repeat;
  filter: saturate(1.05) brightness(.82);
  transform: scale(1.03);
  opacity: .92;
}
.course-hero__inner{
  position:relative; z-index:2;
  padding: 1.25rem 1.25rem 1.05rem;
}

.crumbs{
  display:flex; flex-wrap:wrap; gap:.5rem;
  align-items:center;
  font-size:.86rem;
  color: rgba(255,255,255,.78);
}
.crumbs a{
  color: rgba(255,255,255,.86);
  text-decoration:none;
  border-bottom:1px dashed rgba(255,255,255,.22);
}
.crumbs a:hover{ color:#fff; border-bottom-color: rgba(255,255,255,.45); }

.pill{
  display:inline-flex; align-items:center; gap:.45rem;
  padding:.32rem .65rem;
  border-radius:999px;
  background:rgba(255,255,255,.10);
  border:1px solid rgba(255,255,255,.12);
  backdrop-filter: blur(6px);
  font-size:.80rem;
}

.course-title{
  font-weight: 950;
  letter-spacing: -.02em;
  margin: .65rem 0 .25rem;
  line-height: 1.1;
  font-size: clamp(1.4rem, 2.0vw, 2.1rem);
  color: #fff !important;
}
.course-sub{
  margin:0;
  color: rgba(255,255,255,.74);
  max-width: 90ch;
}

.chips{ margin-top:.9rem; display:flex; flex-wrap:wrap; gap:.5rem; }
.chip{
  display:inline-flex; align-items:center; gap:.45rem;
  border-radius: 999px;
  padding:.42rem .7rem;
  background: rgba(10,18,26,.62);
  border:1px solid rgba(255,255,255,.12);
  color: rgba(255,255,255,.86);
  font-size:.88rem;
}
.chip i{ color: color-mix(in srgb, var(--accent) 92%, #fff 8%); }

.hero-actions{
  margin-top: 1rem;
  display:flex; flex-wrap:wrap; gap:.5rem;
  align-items:center;
}
.btn-glass{
  border-radius: 14px;
  border: 1px solid rgba(255,255,255,.18);
  background: rgba(255,255,255,.06);
  color: #fff;
  font-weight: 850;
  padding: .55rem .9rem;
}
.btn-glass:hover{ background: rgba(255,255,255,.10); }
.btn-accent{
  border-radius: 14px;
  border: 0;
  background: var(--accent);
  color: #0b1a24;
  font-weight: 950;
  padding: .55rem .9rem;
  box-shadow: 0 12px 28px color-mix(in srgb, var(--accent) 28%, transparent);
}
.btn-accent:hover{ filter: brightness(1.04); }

/* ================= APP SHELL ================= */
.shell{
  display:grid;
  grid-template-columns: 360px 1fr;
  gap: var(--gap);
  margin-top: var(--gap);
  align-items:start;
}
@media (max-width: 1200px){
  .shell{ grid-template-columns: 320px 1fr; }
}
@media (max-width: 992px){
  .shell{ grid-template-columns: 1fr; }
}

/* ================= Sidebar TOC ================= */
.toc{
  position: sticky;
  top: 20px;
  align-self: start;

  border-radius: var(--radius-lg);
  border: 1px solid var(--stroke);
  background: var(--panel);
  backdrop-filter: blur(12px);
  box-shadow: var(--shadow-md);
  overflow: hidden;

  max-height: calc(100vh - 110px);
  display:flex;
  flex-direction:column;
  min-height: 220px;
}

.toc__top{
  padding: .95rem .95rem .75rem;
  border-bottom: 1px solid rgba(255,255,255,.08);
  background: linear-gradient(180deg, rgba(255,255,255,.04), transparent);
}
.toc__title{
  display:flex; align-items:center; justify-content:space-between; gap:.75rem;
  margin:0 0 .6rem;
  font-weight: 950;
  letter-spacing: -.01em;
  font-size: 1.02rem;
}
.toc__tools{ display:flex; gap:.45rem; flex-wrap:wrap; }

.toc-btn{
  border: 1px solid rgba(255,255,255,.14);
  background: rgba(255,255,255,.06);
  color: rgba(255,255,255,.90);
  border-radius: 12px;
  padding: .35rem .55rem;
  font-weight: 850;
  font-size: .82rem;
}
.toc-btn:hover{ background: rgba(255,255,255,.10); }

.toc-search{ position: relative; }
.toc-search input{
  width: 100%;
  border-radius: 14px;
  border: 1px solid rgba(255,255,255,.14);
  background: rgba(5,10,14,.45);
  color: #fff;
  padding: .55rem .8rem .55rem 2.2rem;
  outline: none;
}
.toc-search i{
  position:absolute; left:.75rem; top:50%;
  transform: translateY(-50%);
  opacity:.8;
}

.toc__progress{
  height: 8px;
  border-radius: 999px;
  background: rgba(255,255,255,.10);
  overflow:hidden;
  margin-top: .65rem;
}
.toc__progress > div{
  height: 100%;
  width: 0%;
  background: linear-gradient(90deg, color-mix(in srgb, var(--accent) 65%, #ff6a6a), var(--accent));
  border-radius: 999px;
}

.toc__list{
  padding: .75rem .55rem .8rem;
  overflow: auto;
  scrollbar-gutter: stable;
}

/* scrollbar élégante */
.toc__list::-webkit-scrollbar{ width: 10px; }
.toc__list::-webkit-scrollbar-thumb{
  background: rgba(255,255,255,.12);
  border-radius: 999px;
  border: 2px solid rgba(0,0,0,0);
  background-clip: padding-box;
}
.toc__list::-webkit-scrollbar-thumb:hover{ background: rgba(255,255,255,.18); }

.toc ul{ list-style:none; padding-left:0; margin:0; }
.toc li{ margin: .25rem 0; }

.toc a.toc-link{
  display:flex;
  align-items:center;
  gap:.55rem;
  padding: .45rem .55rem;
  border-radius: 14px;
  text-decoration:none;
  color: rgba(255,255,255,.88);
  border: 1px solid transparent;
  opacity: .92;
  transition: background .15s ease, border-color .15s ease, transform .12s ease;
}
.toc a.toc-link .toc-dot{
  width: 8px; height: 8px; border-radius: 99px;
  background: rgba(255,255,255,.25);
  box-shadow: 0 0 0 4px rgba(255,255,255,.05);
  flex: 0 0 auto;
}
.toc a.toc-link:hover{
  background: rgba(255,255,255,.06);
  border-color: rgba(255,255,255,.10);
  transform: translateX(1px);
}
.toc a.toc-link.active{
  background: color-mix(in srgb, var(--accent) 14%, rgba(255,255,255,.05));
  border-color: color-mix(in srgb, var(--accent) 30%, transparent);
  opacity: 1;
}
.toc a.toc-link.active .toc-dot{
  background: var(--accent);
  box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 20%, transparent);
}

.lvl-2{ padding-left: 1.1rem; }
.lvl-3{ padding-left: 2.2rem; }
.toc .lvl-2 a{ font-size: .95rem; opacity:.92; }
.toc .lvl-3 a{ font-size: .90rem; opacity:.88; }

/* Sommaire : hiérarchie plus visible */
#tocList .lvl-2, #tocList .lvl-3{
  margin-left: .35rem;
  padding-left: .85rem;
  border-left: 1px solid rgba(255,255,255,.10);
}
#tocList .lvl-2 .toc-link{ opacity:.92; }
#tocList .lvl-3 .toc-link{ opacity:.82; font-size:.90rem; }
#tocList .toc-item.is-hidden{ display:none !important; }

/* Mode "replié" : on masque les sous-listes */
#tocList.is-collapsed .lvl-2,
#tocList.is-collapsed .lvl-3{
  display:none !important;
}
/* On garde visibles les branches pertinentes pendant une recherche */
#tocList.is-searching .lvl-2,
#tocList.is-searching .lvl-3{
  display:block !important;
}

/* ================= RIGHT SIDE (LECTURE) ================= */
.contenu{
  display:flex;
  flex-direction:column;
  gap: var(--gap);
  min-width: 0;

  position: relative;
  padding: .35rem;
  border-radius: var(--radius-xl);
  background:
    radial-gradient(900px 380px at 85% 0%, color-mix(in srgb, var(--accent) 16%, transparent), transparent 60%),
    radial-gradient(900px 380px at 5% 20%, rgba(255,255,255,.08), transparent 60%),
    linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.02));
  border: 1px solid rgba(255,255,255,.10);
  box-shadow: var(--shadow-md);
  color: var(--ink);
}
.contenu::before{
  content:"";
  position:absolute;
  inset: -1px;
  border-radius: inherit;
  background:
    radial-gradient(700px 240px at 12% 10%, rgba(255,255,255,.10), transparent 60%),
    radial-gradient(700px 260px at 80% 20%, color-mix(in srgb, var(--accent) 14%, transparent), transparent 60%);
  pointer-events:none;
  opacity:.55;
}

/* Topbar */
.topbar{
  position: sticky;
  top: 20px;
  z-index: 30;
  border-radius: 22px;
  border: 1px solid rgba(255,255,255,.12);
  background: rgba(10,18,26,.68);
  backdrop-filter: blur(14px);
  box-shadow: 0 18px 60px rgba(0,0,0,.35);
  padding: .9rem 1rem;
  display:flex;
  gap:.8rem;
  align-items:center;
  justify-content: space-between;
}
.topbar .left{ min-width: 0; }
.topbar .kicker{
  letter-spacing: .08em;
  text-transform: uppercase;
  font-weight: 900;
  font-size: .72rem;
  color: rgba(255,255,255,.62);
  margin-bottom: .15rem;
}
.topbar .now{
  font-weight: 950;
  letter-spacing: -.01em;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 74ch;
  color: rgba(255,255,255,.92);
}
.topbar .right{
  display:flex;
  gap:.45rem;
  align-items:center;
  flex-wrap:wrap;
}
.icon-pill{
  display:inline-flex;
  align-items:center;
  gap:.45rem;
  padding: .42rem .7rem;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,.14);
  background: rgba(255,255,255,.06);
  color: rgba(255,255,255,.86);
  font-weight: 850;
  font-size: .86rem;
}

/* Chapitres */
.content-card{
  position: relative;
  padding: 0;
  overflow: hidden;
  border-radius: 22px;
  border: 1px solid rgba(255,255,255,.12);
  background: rgba(10, 18, 26, .62);
  box-shadow: 0 18px 60px rgba(0,0,0,.28);
  scroll-margin-top: 160px;
  color: var(--ink);
}

/* header chapitre */
.content-card .chapter-head{
  margin: 0;
  padding: 1.05rem 1.15rem .9rem;
  background: linear-gradient(180deg, rgba(255,255,255,.06), rgba(0,0,0,.10));
  border-bottom: 1px solid rgba(255,255,255,.10);
  position: relative;
}
.content-card .chapter-head::before{
  content:"";
  position:absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6px;
  background: linear-gradient(180deg, var(--accent), color-mix(in srgb, var(--accent) 45%, transparent));
  opacity: .95;
}

.chapter-title{
  display:flex; align-items:center; gap:.65rem;
  margin:0;
  font-weight: 950;
  letter-spacing: -.01em;
  color: rgba(255,255,255,.95);
  font-size: 1.05rem;
}
.chapter-badge{
  font-size: .78rem;
  font-weight: 900;
  border-radius: 999px;
  padding: .25rem .55rem;
  border: 1px solid rgba(255,255,255,.14);
  background: rgba(255,255,255,.06);
  color: rgba(255,255,255,.88);
}
.chapter-meta{
  color: var(--muted);
  font-size: .92rem;
}
.draft{
  background: rgba(255,193,7,.18);
  border: 1px solid rgba(255,193,7,.22);
  color: #ffe7a1;
}

/* corps chapitre */
.content-card > .richtext,
.content-card > .block,
.content-card > .vstack{
  padding: 0.5rem 0.5rem;
}

.richtext p{ margin: .45rem 0; line-height: 1.7; color: rgba(255,255,255,.90); }
.richtext ul{ padding-left:1.25rem; }
.richtext :where(h1,h2,h3){ margin-top: .7rem; }
.richtext a{ color: var(--accent); text-decoration: none; }
.richtext a:hover{ text-decoration: underline; }

/* Blocks */
.block{
  margin-top: .85rem;
  border-radius: 18px;
  border: 1px solid rgba(255,255,255,.10);
  background: rgba(0,0,0,.18);
  box-shadow: 0 10px 32px rgba(0,0,0,.22);
  padding: .95rem 1rem;
  margin: 1rem 1rem;
  color: var(--ink);
}
.block-head{
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:.75rem;
  margin-bottom: .65rem;
}
.block-type{
  display:inline-flex;
  align-items:center;
  gap:.5rem;
  padding:.28rem .55rem;
  border-radius: 999px;
  background: rgba(255,255,255,.06);
  border: 1px solid rgba(255,255,255,.10);
  font-weight: 950;
  letter-spacing: .06em;
  font-size: .72rem;
  color: rgba(255,255,255,.85);
  text-transform: uppercase;
}
.btn-copy{
  border: 1px solid rgba(255,255,255,.14);
  background: rgba(255,255,255,.06);
  color: rgba(255,255,255,.92);
  border-radius: 999px;
  padding: .30rem .55rem;
  display:inline-flex;
  align-items:center;
  gap:.35rem;
  font-weight: 900;
  font-size: .80rem;
}
.btn-copy:hover{ background: rgba(255,255,255,.10); }

/* Medias */
.media img{
  width:100%;
  height:auto;
  border-radius: 18px;
  border: 1px solid rgba(255,255,255,.14);
  box-shadow: 0 18px 60px rgba(0,0,0,.30);
}
.video-embed{
  position:relative; width:100%;
  padding-top:56.25%;
  border-radius: 18px;
  overflow:hidden;
  border:1px solid rgba(255,255,255,.14);
  box-shadow: 0 18px 60px rgba(0,0,0,.30);
}
.video-embed iframe{ position:absolute; inset:0; width:100%; height:100%; }

pre.code{
  border-radius: 18px;
  border: 1px solid rgba(255,255,255,.14);
  background: rgba(0,0,0,.35);
  padding: .85rem;
  overflow:auto;
  color: #d7f7ff;
}

/* File tile */
.file-tile{
  display:flex; align-items:center; gap:.75rem;
  padding:.8rem .85rem;
  border:1px solid rgba(255,255,255,.12);
  border-radius: 14px;
  background: rgba(255,255,255,.06);
}
.file-tile .title{ font-weight: 950; }
.file-tile a{ color: var(--accent); font-weight: 950; text-decoration:none; }
.file-tile a:hover{ text-decoration: underline; }

/* ================= QUIZ ================= */
.quiz-form{ gap: .85rem !important; }

.quiz-q{
  border-radius: 18px;
  border: 1px solid rgba(255,255,255,.12);
  background: rgba(255,255,255,.04);
  padding: 1rem 1rem .95rem !important;
  color: var(--ink);
}

.quiz-q label{
  width: 100%;
  padding: .55rem .65rem;
  border-radius: 14px;
  border: 1px solid rgba(255,255,255,.10);
  background: rgba(0,0,0,.18);
  transition: transform .12s ease, background .15s ease, border-color .15s ease;
}
.quiz-q label:hover{
  background: rgba(255,255,255,.06);
  border-color: rgba(255,255,255,.16);
  transform: translateY(-1px);
}
.quiz-q .form-check-input{ transform: translateY(1px); }

.quiz-form > .d-flex{
  padding-top: .25rem;
  gap: .5rem !important;
}

.quiz-form button[type="submit"]{
  border-radius: 14px;
  border: 0;
  background: var(--accent);
  color: #0b1a24;
  font-weight: 950;
  padding: .55rem .85rem;
  box-shadow: 0 14px 34px color-mix(in srgb, var(--accent) 28%, transparent);
}
.quiz-form .quiz-reset{
  border-radius: 14px;
  border: 1px solid rgba(255,255,255,.18);
  background: rgba(255,255,255,.06);
  color: rgba(255,255,255,.92);
  font-weight: 900;
  padding: .55rem .85rem;
}
.quiz-score{
  display:inline-flex;
  padding:.38rem .65rem;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,.14);
  background: rgba(255,255,255,.06);
  font-weight: 900;
}

/* Feedback quiz */
.quiz-feedback{
  display:block;
  margin-top: .55rem;
  padding: .55rem .65rem;
  border-radius: 14px;
  border: 1px solid rgba(255,255,255,.12);
  background: rgba(0,0,0,.20);
}
.quiz-explanation{
  margin-top: .55rem;
  padding: .7rem .75rem;
  border-radius: 14px;
  border: 1px solid rgba(255,255,255,.10);
  background: rgba(255,255,255,.04);
  color: rgba(255,255,255,.85);
}

/* Bootstrap helpers en dark */
.text-muted{ color: rgba(255,255,255,.65) !important; }

/* responsive tweaks */
@media (max-width: 992px){
  .toc{ position: relative; top: 0; max-height: none; }
  .topbar{ position: relative; top: 0; }
  .contenu{ padding: .2rem; border-radius: 20px; }
  .content-card{ border-radius: 18px; }
  .content-card .chapter-head{ padding: .9rem .95rem .8rem; }
  .content-card > .richtext,
  .content-card > .block,
  .content-card > .vstack{
    padding: .85rem .95rem;
  }
}



    
