<script>
// SignaturePad init (robuste: canvas visible uniquement après "shown")
window.initSignaturePad = function(){
  const canvas = document.getElementById('signatureCanvas');
  if (!canvas) return;

  if (window.__signaturePad) { try{ window.__signaturePad.off(); }catch(_){ } window.__signaturePad=null; }

  const wrap = canvas.parentElement;
  const cssWidth  = wrap ? wrap.clientWidth : (canvas.clientWidth || 600);
  const cssHeight = 200;

  canvas.style.width  = cssWidth + 'px';
  canvas.style.height = cssHeight + 'px';

  const ratio = Math.max(window.devicePixelRatio || 1, 1);
  canvas.width  = Math.floor(cssWidth * ratio);
  canvas.height = Math.floor(cssHeight * ratio);

  const ctx = canvas.getContext('2d');
  ctx.setTransform(ratio, 0, 0, ratio, 0, 0);

  if (typeof window.SignaturePad !== 'function') { console.error('SignaturePad non chargé'); return; }
  window.__signaturePad = new SignaturePad(canvas, {
    throttle:16,
    minWidth:.5,
    maxWidth:2.5,
    backgroundColor:'rgb(255,255,255)'
  });
};






</script>
