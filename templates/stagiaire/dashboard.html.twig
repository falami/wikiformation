<script>
$(function(){

  function nowLabel(){
    const d = new Date();
    return d.toLocaleDateString('fr-FR') + ' ' +
          d.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
  }
  $('#hero-last-refresh').text('Maj : ' + nowLabel());

  /* ===== helpers ===== */
  function escapeHtml(s){return String(s||'').replace(/[&<>"']/g, m=>({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[m]));}
  function stripHtml(html){ return String(html||'').replace(/<[^>]+>/g,'').trim(); }
  function pad(n){ return n<10?('0'+n):n; }

  const toFr = (ymd)=>{
    if(!ymd) return '';
    if(ymd.includes('/')) return ymd;
    const [Y,M,D]=ymd.split('-').map(n=>parseInt(n,10));
    const p=n=>n<10?('0'+n):n;
    return p(D)+'/'+p(M)+'/'+Y;
  };


  document.addEventListener('shown.bs.dropdown', function(e){
    const wrapper = document.querySelector('#table-stagiaire_wrapper')?.closest('.section-card');
    wrapper?.classList.add('is-overlay');
  });

  document.addEventListener('hidden.bs.dropdown', function(e){
    const wrapper = document.querySelector('#table-stagiaire_wrapper')?.closest('.section-card');
    wrapper?.classList.remove('is-overlay');
  });


  


  /* ===== DataTables : mes sessions ===== */
  const dt = $('#table-stagiaire').DataTable({
    ajax:{ url:"{{ path('app_stagiaire_sessions_ajax', { entite: entite.id }) }}", type:'POST' },
    columns:[
      {data:'code'},
      {data:'formation'},
      {data:'dates'},
      {data:'formateur'},

      // ✅ Actions (dropdown) : inclut désormais "Mon dossier" + émargements + satisfaction + QCM etc.
      {
        data: 'actions',
        className: 'text-center',
        render: function(d, type, row){
          const raw = (d || '').trim();
          if(!raw) return '';

          const key = String(row.code || '').replace(/\W+/g,'_') || Math.random().toString(16).slice(2);
          const menuId = 'act_' + key;

          return `
            <div class="actions-wrap">
              <div class="dropdown action-dd">
                <button class="btn btn-action btn-sm dropdown-toggle" type="button"
                  id="${menuId}"
                  data-bs-toggle="dropdown"
                  data-bs-boundary="viewport"
                  data-bs-display="static"
                  aria-expanded="false">
                  <i class="bi bi-three-dots-vertical"></i> Actions
                </button>

                <div class="dropdown-menu dropdown-menu-end" aria-labelledby="${menuId}">
                  <div class="dd-head">
                    <div class="t"><i class="bi bi-lightning-charge me-1"></i> Actions</div>
                  </div>
                  ${raw}
                </div>

              </div>
            </div>
          `;
        }

      },

      {data:'firstStartIso', visible:false, searchable:false},
      {data:'lastEndIso', visible:false, searchable:false},
    ],
    order:[[5,'desc']], // ⚠️ avant c'était 6, car tu avais une colonne de plus


    pageLength:10,
    language: { url:'https://cdn.datatables.net/plug-ins/2.3.4/i18n/fr-FR.json' },
    drawCallback:function(){
      computeKpisFromTable(this.api());
      buildTimelineFromTable(this.api(), '#upcoming-timeline', 6);
    }
  });

  $('#searchAll').on('input', function(){ dt.search(this.value).draw(); });

  /* ===== KPIs ===== */
  function computeKpisFromTable(api){
    const data = api.rows({search:'applied'}).data().toArray();
    const now = new Date();

    let upcoming = 0, live = 0;

    data.forEach(row => {
      const start = row.firstStartIso ? new Date(row.firstStartIso) : null;
      const end   = row.lastEndIso ? new Date(row.lastEndIso) : null;
      if(!start || !end) return;

      if (now < start) upcoming++;
      else if (now >= start && now <= end) live++;
    });

    $('#kpi-upcoming').text(upcoming);
    $('#kpi-live').text(live);
  }


  /* ===== FullCalendar ===== */
  const calendar = new FullCalendar.Calendar(document.getElementById('calendar'), {
    locale:'fr', height:'auto', initialView:'dayGridMonth',
    headerToolbar:{ left:'prev,next today', center:'title', right:'dayGridMonth,timeGridWeek,listWeek' },
    events: "{{ path('app_stagiaire_calendar_feed', { entite: entite.id }) }}",
    eventDidMount: (info)=>{ info.el.style.borderRadius = '.6rem'; info.el.style.boxShadow = '0 8px 20px rgba(0,0,0,.08)'; },
    eventClick: (info) => {
      info.jsEvent?.preventDefault();
      const sid = info.event.extendedProps?.sessionId || info.event.id;
      const ymd = (info.event.startStr || '').slice(0,10);
      window.__openEma?.({ sessionId: sid, sessionLabel: info.event.title || 'Session', date: ymd });
    }
  });
  calendar.render();

  /* ===== Timeline ===== */
  function parseIsoToTs(iso){
    if(!iso) return null;

    // ISO “normal” (ATOM) => Date.parse OK
    let ts = Date.parse(iso);
    if(!Number.isNaN(ts)) return ts;

    // Fallback 1 : certaines chaînes arrivent sans ':' dans l’offset (+0100)
    // => on transforme en +01:00
    const fixed = String(iso).replace(/([+-]\d{2})(\d{2})$/, '$1:$2');
    ts = Date.parse(fixed);
    if(!Number.isNaN(ts)) return ts;

    return null;
  }

  function buildTimelineFromTable(api, selector, maxItems){
    const data = api.rows({ search: 'applied' }).data().toArray();
    const nowTs = Date.now();

    const items = [];

    data.forEach(row => {
      const startTs = parseIsoToTs(row.firstStartIso);
      const endTs   = parseIsoToTs(row.lastEndIso);

      if(startTs === null || endTs === null) return;

      // ✅ On garde la session si elle n'est pas terminée
      if(endTs <= nowTs) return;

      const isLive = (startTs <= nowTs && nowTs <= endTs);
      const d = new Date(startTs);

      items.push({
        sortTs: isLive ? nowTs - 1 : startTs, // live en haut
        when: d.toLocaleString('fr-FR', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }),
        what: `${stripHtml(row.formation)} (${row.code || ''})`.trim(),
        badge: isLive ? '<span class="soft-badge ms-2">EN COURS</span>' : ''
      });
    });

    items.sort((a,b)=> a.sortTs - b.sortTs);

    const ul = document.querySelector(selector);
    ul.innerHTML = '';

    if(items.length === 0){
      ul.innerHTML = `
        <li>
          <span class="dot"></span>
          <span class="when">—</span>
          <span class="what">Aucun évènement à venir.</span>
        </li>`;
      return;
    }

    items.slice(0, maxItems || 6).forEach(it => {
      const li = document.createElement('li');
      li.innerHTML = `
        <span class="dot"></span>
        <span class="when">${it.when}</span>
        <span class="what">${escapeHtml(it.what)} ${it.badge}</span>`;
      ul.appendChild(li);
    });
  }




  /* ===== Supports ===== */
    /* ===== Supports ===== */
  function loadAssets(){
    fetch("{{ path('app_stagiaire_supports_assets_feed', { entite: entite.id }) }}")
      .then(r=>r.json()).then(payload=>{
        const rows = (payload?.data||[]);
        $('#kpi-files').text(rows.length || 0);

        const wrap = document.getElementById('assets-list');
        wrap.innerHTML='';

        if(rows.length===0){
          wrap.innerHTML = '<div class="text-muted">Aucun support disponible pour le moment.</div>';
          return;
        }

        rows.slice(0,12).forEach(a=>{
          const col = document.createElement('div');
          col.className = 'col-12 col-md-6 col-xxl-3';
          col.innerHTML = `
            <div class="asset-item">
              <div class="asset-icon"><i class="bi bi-file-earmark-text-fill"></i></div>
              <div class="flex-grow-1 text-truncate">
                <div class="asset-name" title="${escapeHtml(a.titre || a.originalName || '')}">
                  ${escapeHtml(a.titre || a.originalName || 'Document')}
                </div>
                <div class="asset-meta">${escapeHtml(a.mimeType || '')} · ${escapeHtml(a.uploadedAt || '')}</div>
              </div>
              <a class="btn btn-sm btn-outline-secondary" href="${a.url}" target="_blank" title="Télécharger">
                <i class="bi bi-download"></i>
              </a>
            </div>`;
          wrap.appendChild(col);
        });
      });
  }

  loadAssets();
  $('#btnReloadAssets').on('click', loadAssets);


  /* ===== Émargements ===== */
  let STATE = {
    sessionId: null,
    sessionLabel: '—',
    date: (new Date()).toISOString().slice(0,10),
    trainer: null,
    me: null
  };

  function setHeader(){
    $('#ema-date').text(toFr(STATE.date));
    // l'input flatpickr garde la value ISO
    $('#ema-date-input').val(STATE.date);
    $('#ema-session').text(STATE.sessionLabel||'—');
  }

  function viewBtn(url, at){
    if(!url) return '';
    const safeAt = at ? escapeHtml(at) : '';
    return `
      <button type="button" class="btn btn-mini btn-outline-secondary js-view-sig"
              data-url="${escapeHtml(url)}" data-at="${safeAt}">
        <i class="bi bi-eye"></i>
      </button>`;
  }

  function cellHtmlForMe(info, periode){
    if(!info?.signed){
      return `<div class="ema-actioncell">
        <button class="btn btn-mini btn-outline-success js-open-sign" data-periode="${periode}">
          <i class="bi bi-pencil"></i> Signer
        </button>
      </div>`;
    }
    return `<div class="ema-actioncell">
      <span class="pill-success"><i class="bi bi-check2-circle"></i> Signé</span>
      ${viewBtn(info.url, info.at)}
      <button class="btn btn-mini btn-outline-danger js-unsign" data-periode="${periode}">
        <i class="bi bi-trash"></i>
      </button>
    </div>`;
  }

  function cellHtmlReadOnly(info){
    if(!info?.signed){
      return `<div class="ema-actioncell"><span class="badge bg-secondary-subtle text-secondary">Non signé</span></div>`;
    }
    return `<div class="ema-actioncell">
      <span class="pill-success"><i class="bi bi-check2-circle"></i> Signé</span>
      ${viewBtn(info.url, info.at)}
    </div>`;
  }

  function renderEma(){
    const trainerName = STATE.trainer?.name || '—';
    const meName = STATE.me?.name || 'Moi';

    const trainerAm = STATE.trainer?.am || {signed:false};
    const trainerPm = STATE.trainer?.pm || {signed:false};
    const meAm = STATE.me?.am || {signed:false};
    const mePm = STATE.me?.pm || {signed:false};

    const html = `
      <tr>
        <td data-label="Participant">
          <strong>Formateur</strong>
          <div class="small text-muted">${escapeHtml(trainerName)}</div>
        </td>
        <td class="text-center" data-label="Matin">${cellHtmlReadOnly(trainerAm)}</td>
        <td class="text-center" data-label="Après-midi">${cellHtmlReadOnly(trainerPm)}</td>
      </tr>
      <tr>
        <td data-label="Participant">
          <strong>Moi</strong>
          <div class="small text-muted">${escapeHtml(meName)}</div>
        </td>
        <td class="text-center" data-label="Matin">${cellHtmlForMe(meAm,'AM')}</td>
        <td class="text-center" data-label="Après-midi">${cellHtmlForMe(mePm,'PM')}</td>
      </tr>
    `;

    $('#ema-tbody').html(html);

    const todayIso = (new Date()).toISOString().slice(0,10);
    const todo = (STATE.date===todayIso ? ((meAm.signed?0:1) + (mePm.signed?0:1)) : 0);
    $('#kpi-sign').text(todo);
  }

  function loadEma(){
    $('#ema-tbody').html('<tr><td colspan="3" class="text-center text-muted py-4">⏳ Chargement…</td></tr>');

    const url = "{{ path('app_stagiaire_emargement_feed', { entite: entite.id }) }}"
              + "?session="+encodeURIComponent(STATE.sessionId)
              + "&date="+encodeURIComponent(STATE.date);

    return fetch(url, { headers:{'Accept':'application/json'} })
      .then(r => r.json())
      .then(j => {
        if(j?.error){
          $('#ema-tbody').html(`<tr><td colspan="3" class="text-center text-danger py-4">${escapeHtml(j.error)}</td></tr>`);
          return;
        }
        if (j?.sessionLabel) STATE.sessionLabel = j.sessionLabel;
        STATE.trainer = j?.trainer || null;
        STATE.me = j?.me || null;
        setHeader();
        renderEma();
      })
      .catch(e=>{
        console.error(e);
        $('#ema-tbody').html('<tr><td colspan="3" class="text-center text-danger py-4">Erreur de chargement</td></tr>');
      });
  }

  /* ===== Flatpickr (ema date) ===== */
  let __fpEma = null;
  function initEmaDatepicker(){
    const input = document.getElementById('ema-date-input');
    if(!input || typeof flatpickr !== 'function') return;

    if(__fpEma){ try{ __fpEma.destroy(); }catch(e){} __fpEma=null; }

    __fpEma = flatpickr(input, {
      locale: 'fr',
      dateFormat: 'Y-m-d',
      altInput: true,
      altFormat: 'd/m/Y',
      defaultDate: STATE?.date || new Date(),
      allowInput: true,
      onChange: function(selectedDates, dateStr){
        if(dateStr){
          STATE.date = dateStr;
          setHeader();
          loadEma();
        }
      }
    });
  }

  /* ===== Open ema modal ===== */
  window.__openEma = ({ sessionId, sessionLabel, date, periode })=>{
    if(!sessionId){ alert('ID session manquant'); return; }

    STATE.sessionId = String(sessionId);
    STATE.sessionLabel = sessionLabel || STATE.sessionLabel;
    if(date) STATE.date = String(date);

    // 👇 on stocke une "préférence" (AM/PM) pour auto-ouvrir la signature
    window.__AUTO_OPEN_PERIODE = periode || null;

    setHeader();

    return loadEma().then(()=>{
      const modalEl = document.getElementById('emargementModal');

      modalEl.addEventListener('shown.bs.modal', () => {
        initEmaDatepicker();

        // ✅ auto-open signature si demandé
        if(window.__AUTO_OPEN_PERIODE){
          const p = window.__AUTO_OPEN_PERIODE;
          window.__AUTO_OPEN_PERIODE = null; // important: éviter répétition

          // on cherche le bouton "Signer" du bon créneau (AM/PM)
          const btn = modalEl.querySelector(`.js-open-sign[data-periode="${p}"]`);
          if(btn) btn.click();
        }
      }, { once:true });

      bootstrap.Modal.getOrCreateInstance(modalEl).show();
    });
  };


  $('#ema-refresh').on('click', ()=>{
    // si flatpickr est actif, input.value est ISO Y-m-d
    const v = $('#ema-date-input').val();
    if(v) STATE.date = v;
    setHeader();
    loadEma();
  });

  /* ===== Signature: open modal + init canvas AFTER shown ===== */
  $(document).on('click', '.js-open-sign', function(e){
    e.preventDefault();

    if(typeof bootstrap === 'undefined' || !bootstrap.Modal){
      alert("Bootstrap JS n'est pas chargé (bootstrap.bundle.min.js).");
      return;
    }

    window.CURRENT_PERIODE = this.dataset.periode || null;

    const el = document.getElementById('signatureModal');
    el.addEventListener('shown.bs.modal', () => {
      window.initSignaturePad?.();
      window.__signaturePad?.clear();
    }, { once:true });

    bootstrap.Modal.getOrCreateInstance(el, { backdrop:'static', focus:false }).show();
  });



  $(document).on('click', '.js-next-ema', function(e){
    e.preventDefault();

    const sid = this.dataset.sessionId;
    const label = this.dataset.sessionLabel || 'Session';
    const date = this.dataset.date || (new Date()).toISOString().slice(0,10);
    const periode = this.dataset.periode || null; // AM / PM

    window.__openEma?.({ sessionId: sid, sessionLabel: label, date: date, periode: periode });
  });


  // Clear
  $('#btnClearSignature').on('click', ()=> window.__signaturePad?.clear());

  // Save
  $('#btnSaveSignature').on('click', async function(){
    if (!window.__signaturePad || window.__signaturePad.isEmpty()) { alert('Veuillez signer.'); return; }
    if (!window.CURRENT_PERIODE) { alert('Période inconnue.'); return; }

    const dataUrl = window.__signaturePad.toDataURL('image/png');
    const tpl = document.getElementById('sign-url-template')?.dataset?.url || '';
    const url = String(tpl).replace('__ID__', String(STATE.sessionId || ''));

    const form = new FormData();
    form.append('signatureData', dataUrl);
    form.append('periode', window.CURRENT_PERIODE);
    form.append('date', toFr(STATE.date)); // ton endpoint attend du d/m/Y

    const res = await fetch(url, {
      method:'POST',
      credentials:'same-origin',
      headers:{'X-Requested-With':'XMLHttpRequest'},
      body: form
    });

    const json = await res.json().catch(()=>null);
    if (!res.ok || !json || json.success !== true) {
      alert((json && (json.message||json.error)) || ('HTTP '+res.status));
      return;
    }

    bootstrap.Modal.getOrCreateInstance(document.getElementById('signatureModal')).hide();
    await loadEma();
  });

  // Preview signature (modal)
  $(document).on('click', '.js-view-sig', function(){
    const url = this.dataset.url;
    const at  = this.dataset.at || '';
    if(!url) return;

    $('#sigPreviewImg').attr('src', url);
    $('#sigPreviewMeta').text(at ? ('Signé le ' + at) : 'Signature');

    bootstrap.Modal.getOrCreateInstance(document.getElementById('sigPreviewModal')).show();
  });

  // Unsign
  $(document).on('click', '.js-unsign', async function(e){
    e.preventDefault();
    const periode = this.dataset.periode;
    if (!confirm('Supprimer votre signature '+periode+' ?')) return;

    const tpl = document.getElementById('unsign-url-template')?.dataset?.url || '';
    const url = String(tpl).replace('__ID__', String(STATE.sessionId || ''));

    const form = new FormData();
    form.append('periode', periode);
    form.append('date', toFr(STATE.date));

    const res = await fetch(url, {
      method:'POST',
      credentials:'same-origin',
      headers:{'X-Requested-With':'XMLHttpRequest'},
      body: form
    });

    const json = await res.json().catch(()=>null);
    if (!res.ok || !json || json.success !== true) {
      alert((json && (json.message||json.error)) || ('HTTP '+res.status));
      return;
    }

    await loadEma();
  });

  // Clic depuis la DataTable
  $(document).on('click', '.js-emargement', function(e){
    e.preventDefault();
    const sid = this.dataset.sessionId;
    const label = this.dataset.sessionLabel || 'Session';
    const today = (new Date()).toISOString().slice(0,10);
    window.__openEma?.({ sessionId: sid, sessionLabel: label, date: today });
  });


  function tagLastBackdrop(className){
  const bds = document.querySelectorAll('.modal-backdrop');
  const last = bds[bds.length - 1];
  if(last) last.classList.add(className);
}

// Emargement backdrop
document.getElementById('emargementModal')?.addEventListener('shown.bs.modal', () => {
  tagLastBackdrop('emargement-backdrop');
});

// Signature backdrop (au-dessus)
document.getElementById('signatureModal')?.addEventListener('shown.bs.modal', () => {
  tagLastBackdrop('signature-backdrop');
});

// Preview backdrop (au-dessus de tout)
document.getElementById('sigPreviewModal')?.addEventListener('shown.bs.modal', () => {
  tagLastBackdrop('preview-backdrop');
});








