
{# templates/stagiaire/supports.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}Mes supports — Stagiaire{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="https://cdn.datatables.net/2.2.2/css/dataTables.dataTables.css"/>
<style>
:root{
  --teal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#1e3a5f')) }};
  --amber: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffb703')) }};
  --ink:#0f2336; --muted:#6f8897; --card:#ffffff; --card-2:#f8fbfe; --line:#e6eef5; --radius:1rem;
}
.section-card{ background:var(--card); border:1px solid var(--line); border-radius:1rem; box-shadow:0 14px 48px rgba(15,35,54,.12); }
.asset{ border:1px solid var(--line); border-radius:.9rem; padding:.7rem .8rem; display:flex; gap:.75rem; align-items:center; background:linear-gradient(180deg,var(--card),var(--card-2)); }
.asset .icon{ width:36px;height:36px;display:grid;place-items:center;border-radius:.6rem;background:color-mix(in oklab, var(--teal) 12%, white 88%); color:color-mix(in oklab, var(--teal) 85%, black 15%); }
.asset .name{ font-weight:800; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }

:root{ --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
       --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
       --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
       --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};}
@media (max-width:768px){
  table.dataTable td.action-column{ position:sticky; right:0; background:#fff; z-index:5; box-shadow:-8px 0 12px -8px rgba(0,0,0,.08); }
}
</style>
<link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
<link rel="stylesheet" href="https://cdn.datatables.net/2.2.2/css/dataTables.dataTables.css"/>
<link rel="stylesheet" href="{{ asset('dist/css/style-table.css') }}">
{% endblock %}

{% block body %}
<div class="container-fluid py-3">
  <div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h5 mb-0">Mes supports</h1>
    <a class="btn btn-outline-secondary" href="{{ path('app_stagiaire_dashboard', { entite: entite.id }) }}"><i class="bi bi-arrow-left"></i> Retour</a>
  </div>

  <div class="section-card p-3">
    <div class="row g-3 align-items-center mb-3">
      <div class="col-12 col-md-6">
        <div class="input-group">
          <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-search"></i></span>
          <input id="q" type="text" class="form-control border-start-0" placeholder="Rechercher un titre, une session…">
        </div>
      </div>
      <div class="col-12 col-md-6 text-md-end small text-muted">
        <span id="count">—</span> document(s)
      </div>
    </div>

    <div id="assets" class="row g-3">
      <div class="col-12 text-muted">Chargement…</div>
    </div>
  </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
(function(){
  function initSupports(){
    const wrap  = document.getElementById('assets');
    const q     = document.getElementById('q');
    const count = document.getElementById('count');

    // ✅ si on n'est pas sur la bonne page, on sort sans crash
    if (!wrap || !q || !count) return;

    // évite double init (Turbo)
    if (wrap.dataset.init === '1') return;
    wrap.dataset.init = '1';

    let rows = [], filtered = [];

    function render(list){
      wrap.innerHTML = '';
      if(!list.length){
        wrap.innerHTML = '<div class="col-12 text-muted">Aucun support.</div>';
        return;
      }

      list.forEach(a=>{
        const col = document.createElement('div');
        col.className = 'col-12 col-md-6 col-xxl-3';

        const name = a.titre || a.originalName || 'Document';
        const meta = [a.mimeType||'', a.sessionCode?('Session '+a.sessionCode):'', a.sessionTitle||'']
          .filter(Boolean).join(' · ');

        col.innerHTML = `
          <div class="asset">
            <div class="icon"><i class="bi bi-file-earmark-text"></i></div>
            <div class="flex-grow-1 text-truncate">
              <div class="name" title="${name}">${name}</div>
              <div class="text-muted small">${meta}</div>
            </div>
            <a class="btn btn-sm btn-outline-secondary" href="${a.url}" target="_blank" rel="noopener">
              <i class="bi bi-download"></i>
            </a>
          </div>`;
        wrap.appendChild(col);
      });
    }

    function applyFilter(){
      const s = q.value.trim().toLowerCase();
      filtered = !s ? rows : rows.filter(a=>{
        const t  = (a.titre||a.originalName||'').toLowerCase();
        const sc = (a.sessionCode||'').toLowerCase();
        const st = (a.sessionTitle||'').toLowerCase();
        return t.includes(s) || sc.includes(s) || st.includes(s);
      });
      count.textContent = filtered.length;
      render(filtered);
    }

    // ✅ si tu es bien sur /session/{id}/supports, session existe
    const feedUrl = "{{ path('app_stagiaire_session_supports_feed', { entite: entite.id, id: session.id }) }}";

    fetch(feedUrl, { headers: { 'Accept': 'application/json' } })
      .then(r => r.ok ? r.json() : Promise.reject(r))
      .then(p => {
        rows = Array.isArray(p?.data) ? p.data : [];
        count.textContent = rows.length;
        filtered = rows.slice(0);
        render(filtered);
      })
      .catch(() => {
        wrap.innerHTML = '<div class="col-12 text-danger">Erreur de chargement.</div>';
      });

    q.addEventListener('input', applyFilter);
  }

  document.addEventListener('DOMContentLoaded', initSupports);
  document.addEventListener('turbo:load', initSupports); // ✅ si Symfony UX Turbo
})();
</script>
{% endblock %}

