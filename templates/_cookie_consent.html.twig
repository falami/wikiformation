<div id="cookie-banner" 
     class="cookie-banner position-fixed bottom-0 start-0 end-0 bg-light shadow-lg p-3" 
     style="z-index: 1050; display: none;">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-center">
    <div class="mb-2 mb-md-0 text-dark">
      🍪 {{ 'cookies.message'|trans }}
      <a href="{{ path('app_public_politique_confidentialite') }}">{{ 'cookies.more'|trans }}</a>.
    </div>
    <div>
      <button id="accept-cookies" class="btn btn-success btn-sm me-2">{{ 'cookies.accept'|trans }}</button>
      <button id="reject-cookies" class="btn btn-secondary btn-sm">{{ 'cookies.reject'|trans }}</button>
    </div>
  </div>
</div>
